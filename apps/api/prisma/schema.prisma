generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 서비스 사용자 (프로필 정보만 보관, 인증 정보는 Account에 분리)
model User {
  /// 고유 식별자
  id                  String                 @id @default(cuid())
  /// OAuth 제공자에서 받은 이메일
  email               String                 @unique
  /// 리뷰 등에 표시되는 닉네임
  nickname            String                 @unique
  /// 프로필 이미지 URL
  profileImageUrl     String?                @db.VarChar(500)
  /// 역할 ('user' | 'admin')
  role                String                 @default("user") @db.VarChar(10)
  /// 연결된 OAuth 계정 (카카오 등)
  accounts            Account[]
  /// 소유한 방 목록
  ownedRooms          Room[]                 @relation("RoomOwner")
  /// 참여 중인 방 멤버십
  roomMembers         RoomMember[]
  /// 방 내 등록한 식당
  roomRestaurants     RoomRestaurant[]
  /// 생성한 방문 기록
  createdVisits       RoomVisit[]            @relation("VisitCreator")
  /// 방문 참여 기록
  visitParticipations RoomVisitParticipant[]
  /// 방 내 작성한 리뷰
  roomReviews         RoomReview[]
  /// 강퇴 기록
  roomKicks           RoomKick[]
  /// 생성한 투표
  createdPolls        RoomPoll[]             @relation("PollCreator")
  /// 투표 참여 기록
  pollVotes           RoomPollVote[]
  /// 방 알림
  notifications       RoomNotification[]
  /// FCM 푸시 토큰
  fcmTokens           FcmToken[]
  /// 푸시 알림 수신 여부
  pushEnabled         Boolean                @default(true)
  /// 데모 계정 정보 (관리자 생성 계정)
  demoAccount         DemoAccount?
  /// 커뮤니티 게시글
  posts               Post[]
  /// 커뮤니티 댓글
  comments            Comment[]
  /// 게시글 추천
  postLikes           PostLike[]    @relation("PostLikes")
  /// 댓글 추천
  commentLikes        CommentLike[] @relation("CommentLikes")
  /// 게시글 북마크
  postBookmarks       PostBookmark[]
  /// 마지막 활동 시각 (DAU 추적용)
  lastActiveAt        DateTime?
  /// 온보딩 완료 시각 (null이면 최초 로그인, 온보딩 모달 노출)
  onboardingCompletedAt DateTime?
  /// 튜토리얼 진행 상태 (코치마크 튜토리얼별 완료 기록)
  tutorialProgress    UserTutorialProgress[]
  /// 가입일
  createdAt           DateTime               @default(now())
  /// 최종 수정일
  updatedAt           DateTime               @updatedAt

  @@index([lastActiveAt])
}

/// OAuth 계정 정보 (User와 1:N, 다중 소셜 로그인 확장 가능)
model Account {
  /// 고유 식별자
  id           String   @id @default(cuid())
  /// OAuth 제공자 ('kakao', 'google' 등)
  provider     String   @db.VarChar(20)
  /// 제공자 측 고유 사용자 ID
  providerId   String
  /// bcrypt 해싱된 JWT Refresh Token
  refreshToken String?  @db.Text
  /// 연결된 사용자
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 사용자 ID (FK)
  userId       String
  /// 생성일
  createdAt    DateTime @default(now())
  /// 최종 수정일
  updatedAt    DateTime @updatedAt

  /// 동일 제공자의 동일 계정 중복 방지
  @@unique([provider, providerId])
  @@index([userId])
}

/// 공유 방 (초대 코드로 입장, 방 전용 식당/리뷰 리스트)
model Room {
  /// 고유 식별자
  id                  String           @id @default(cuid())
  /// 방 이름
  name                String           @db.VarChar(100)
  /// 8자 초대 코드
  inviteCode          String           @unique @db.VarChar(8)
  /// 초대 코드 만료 시간 (null = 무제한)
  inviteCodeExpiresAt DateTime?
  /// 공개 방 여부 (맛집 탐색 페이지 노출)
  isPublic            Boolean          @default(false)
  /// 최대 멤버 수 (2~20, 기본 4)
  maxMembers          Int              @default(4)
  /// 방 공지사항 (방장만 설정 가능)
  announcement        String?          @db.VarChar(500)
  /// 위시리스트 탭 표시 여부 (방별 설정, 기본 true)
  tabWishlistEnabled  Boolean          @default(true)
  /// 지역 탭 표시 여부 (방별 설정, 기본 true)
  tabRegionEnabled    Boolean          @default(true)
  /// 투표 탭 표시 여부 (방별 설정, 기본 false)
  tabPollEnabled      Boolean          @default(false)
  /// 통계 탭 표시 여부 (방별 설정, 기본 false)
  tabStatsEnabled     Boolean          @default(false)
  /// 방장 (User FK)
  owner               User             @relation("RoomOwner", fields: [ownerId], references: [id])
  /// 방장 ID
  ownerId             String
  /// 멤버 목록
  members             RoomMember[]
  /// 방 내 식당 목록
  restaurants         RoomRestaurant[]
  /// 강퇴 기록
  kicks               RoomKick[]
  /// 투표 목록
  polls               RoomPoll[]
  /// 알림 목록
  notifications       RoomNotification[]
  /// 생성일
  createdAt           DateTime         @default(now())
  /// 최종 수정일
  updatedAt           DateTime         @updatedAt

  @@index([ownerId])
  @@index([isPublic, updatedAt])
}

/// 방 멤버 (owner/manager/member 역할)
model RoomMember {
  /// 고유 식별자
  id       String   @id @default(cuid())
  /// 역할 ('owner' | 'manager' | 'member')
  role     String   @default("member") @db.VarChar(10)
  /// 소속 방
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /// 방 ID (FK)
  roomId   String
  /// 참여 유저
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 유저 ID (FK)
  userId   String
  /// 가입일
  joinedAt DateTime @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

/// 방 내 식당
model RoomRestaurant {
  /// 고유 식별자
  id           String      @id @default(cuid())
  /// 식당 이름
  name         String      @db.VarChar(200)
  /// 도로명/지번 주소
  address      String      @db.VarChar(300)
  /// 시/도
  province     String      @db.VarChar(50)
  /// 시/군/구
  city         String      @db.VarChar(50)
  /// 읍/면/동
  neighborhood String      @db.VarChar(100)
  /// 표시용 카테고리 (매핑 완료 시 Category.name, 미매핑 시 원본 입력값)
  category     String      @db.VarChar(100)
  /// 매핑된 카테고리 (null = 관리자 매핑 대기)
  categoryRef  Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  /// 카테고리 ID (FK, nullable)
  categoryId   Int?
  /// 위도 (카카오맵 좌표)
  latitude     Float?
  /// 경도 (카카오맵 좌표)
  longitude    Float?
  /// 폐점 여부
  isClosed     Boolean     @default(false)
  /// 위시리스트 여부 (방별로 관리, true면 아직 안 가본 "가고 싶은" 식당)
  isWishlist   Boolean     @default(false)
  /// 소속 방
  room         Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /// 방 ID (FK)
  roomId       String
  /// 등록자
  addedBy      User?       @relation(fields: [addedById], references: [id], onDelete: SetNull)
  /// 등록자 ID (FK, 탈퇴 시 null)
  addedById    String?
  /// 방문 기록 목록
  visits       RoomVisit[]
  /// 투표 선택지 연결
  pollOptions  RoomPollOption[]
  /// 식당 이미지 (최대 3개)
  images       RoomRestaurantImage[]
  /// 등록일
  createdAt    DateTime    @default(now())

  /// 같은 방에 이름+주소 중복 방지 (식당/위시리스트 통합)
  @@unique([roomId, name, address])
  @@index([roomId])
  @@index([addedById])
  @@index([categoryId])
}

/// 식당 카테고리 (관리자 CMS에서 관리, 13개 기본값 시드 후 자유롭게 추가/비활성)
model Category {
  /// 고유 식별자
  id            Int                @id @default(autoincrement())
  /// 카테고리 이름 (예: "양식")
  name          String             @unique @db.VarChar(50)
  /// 이모지 (UI 표시용, 예: "🍝")
  emoji         String?            @db.VarChar(10)
  /// 정렬 순서 (작을수록 앞)
  displayOrder  Int                @default(0)
  /// 활성 여부 (비활성 시 공개 UI에서 숨김)
  isActive      Boolean            @default(true)
  /// 매핑 규칙 (동의어 → 이 카테고리)
  mappings      CategoryMapping[]
  /// 이 카테고리로 분류된 식당
  restaurants   RoomRestaurant[]
  /// 생성일
  createdAt     DateTime           @default(now())
  /// 최종 수정일
  updatedAt     DateTime           @updatedAt

  @@index([isActive, displayOrder])
}

/// 카테고리 매핑 규칙 (원본 문자열 → Category)
/// 예: "맥도날드" → 양식, "커피전문점" → 카페
model CategoryMapping {
  /// 고유 식별자
  id          Int      @id @default(autoincrement())
  /// 원본 문자열 (카카오맵/네이버/유저 입력값)
  rawInput    String   @unique @db.VarChar(200)
  /// 매핑 대상 카테고리
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  /// 카테고리 ID (FK)
  categoryId  Int
  /// 생성일
  createdAt   DateTime @default(now())
  /// 최종 수정일
  updatedAt   DateTime @updatedAt

  @@index([categoryId])
}

/// 식당 이미지 (1:N, 식당당 최대 3개)
model RoomRestaurantImage {
  /// 고유 식별자
  id           String         @id @default(cuid())
  /// 소속 식당
  restaurant   RoomRestaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  /// 식당 ID (FK)
  restaurantId String
  /// 이미지 URL
  url          String         @db.VarChar(500)
  /// 표시 순서
  sortOrder    Int            @default(0)
  /// 등록일
  createdAt    DateTime       @default(now())

  @@index([restaurantId])
}

/// 방문 기록 (식당에 언제, 누구와 갔는지)
model RoomVisit {
  /// 고유 식별자
  id           String                 @id @default(cuid())
  /// 방문 날짜
  visitedAt    DateTime               @db.Date
  /// 방문 메모 (선택)
  memo         String?                @db.VarChar(500)
  /// 웨이팅 (없음/~10분/~30분/~1시간/1시간+)
  waitTime     String?                @db.VarChar(20)
  /// 배달 여부
  isDelivery   Boolean                @default(false)
  /// 방문 대상 식당
  restaurant   RoomRestaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  /// 식당 ID (FK)
  restaurantId String
  /// 방문 기록 생성자 (탈퇴 시 null)
  createdBy    User?                  @relation("VisitCreator", fields: [createdById], references: [id], onDelete: SetNull)
  /// 생성자 ID (FK, 탈퇴 시 null)
  createdById  String?
  /// 함께 간 멤버 태그
  participants RoomVisitParticipant[]
  /// 개별 리뷰 목록
  reviews      RoomReview[]
  /// 생성일
  createdAt    DateTime               @default(now())

  @@index([restaurantId])
  @@index([createdById])
}

/// 방문 참여자 태그
model RoomVisitParticipant {
  /// 고유 식별자
  id      String    @id @default(cuid())
  /// 방문 기록
  visit   RoomVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  /// 방문 ID (FK)
  visitId String
  /// 참여 유저
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 유저 ID (FK)
  userId  String

  @@unique([visitId, userId])
  @@index([userId])
}

/// 방 내 리뷰 (방문 기록당 1인 1리뷰)
model RoomReview {
  /// 고유 식별자
  id                  String    @id @default(cuid())
  /// 0.5~5 종합 평점 (0.5 단위)
  rating              Float
  /// 리뷰 본문
  content             String    @db.Text
  /// 재방문 의사 (1: 안 갈 것 같아요, 2: 사주면 갈게요, 3: 가까우면 갈만해요, 4: 또 가고 싶어요, 5: 꼭 다시 갈 거예요)
  wouldRevisit        Int       @default(4)
  /// 맛 (0.5~5, 선택, 0.5 단위)
  tasteRating         Float?
  /// 가성비 (0.5~5, 선택, 0.5 단위)
  valueRating         Float?
  /// 서비스/친절함 (0.5~5, 선택, 0.5 단위)
  serviceRating       Float?
  /// 청결함 (0.5~5, 선택, 0.5 단위)
  cleanlinessRating   Float?
  /// 접근성 (0.5~5, 선택, 0.5 단위)
  accessibilityRating Float?
  /// 다시 먹어볼 메뉴
  favoriteMenu        String?   @db.VarChar(200)
  /// 다음에 먹어볼 메뉴
  tryNextMenu         String?   @db.VarChar(200)
  /// 리뷰 이미지 URL (JSON 배열, 최대 3장)
  images              String?   @db.Text
  /// 소속 방문 기록
  visit               RoomVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  /// 방문 ID (FK)
  visitId             String
  /// 작성자
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 작성자 ID (FK)
  userId              String
  /// 작성일
  createdAt           DateTime  @default(now())
  /// 최종 수정일
  updatedAt           DateTime  @updatedAt

  @@unique([visitId, userId])
  @@index([userId])
}

/// 방 강퇴 기록 (재입장 차단용)
model RoomKick {
  /// 고유 식별자
  id       String   @id @default(cuid())
  /// 소속 방
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /// 방 ID (FK)
  roomId   String
  /// 강퇴당한 유저
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 유저 ID (FK)
  userId   String
  /// 강퇴 일시
  kickedAt DateTime @default(now())

  /// 같은 방에서 같은 유저 중복 강퇴 방지
  @@unique([roomId, userId])
  @@index([userId])
}

/// 서비스 공지사항 (관리자가 작성, 전체 사용자에게 노출)
model Notice {
  /// 고유 식별자
  id        String   @id @default(cuid())
  /// 공지 제목
  title     String   @db.VarChar(200)
  /// 공지 본문
  content   String   @db.Text
  /// 활성 여부 (비활성 시 노출 안 됨)
  enabled   Boolean  @default(true)
  /// 정렬 순서 (작을수록 위)
  sortOrder Int      @default(0)
  /// 작성일
  createdAt DateTime @default(now())
  /// 최종 수정일
  updatedAt DateTime @updatedAt

  @@index([enabled, sortOrder])
}

/// 방 투표 ("오늘 뭐 먹지?" 등 그룹 의사결정)
model RoomPoll {
  /// 고유 식별자
  id          String           @id @default(cuid())
  /// 투표 제목
  title       String           @db.VarChar(200)
  /// 소속 방
  room        Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /// 방 ID (FK)
  roomId      String
  /// 생성자
  createdBy   User             @relation("PollCreator", fields: [createdById], references: [id], onDelete: Cascade)
  /// 생성자 ID (FK)
  createdById String
  /// 마감 시각 (null = 수동 마감)
  endsAt      DateTime?
  /// 상태 ('active' | 'closed')
  status      String           @default("active") @db.VarChar(10)
  /// 선택지 목록
  options     RoomPollOption[]
  /// 생성일
  createdAt   DateTime         @default(now())

  @@index([roomId, status])
  @@index([createdById])
}

/// 투표 선택지
model RoomPollOption {
  /// 고유 식별자
  id           String          @id @default(cuid())
  /// 선택지 라벨 (식당 이름 또는 자유 텍스트)
  label        String          @db.VarChar(200)
  /// 연결된 식당 (선택, 카카오맵 링크용)
  restaurant   RoomRestaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  /// 식당 ID (FK, nullable)
  restaurantId String?
  /// 소속 투표
  poll         RoomPoll        @relation(fields: [pollId], references: [id], onDelete: Cascade)
  /// 투표 ID (FK)
  pollId       String
  /// 투표 기록
  votes        RoomPollVote[]
  /// 생성일
  createdAt    DateTime        @default(now())

  @@index([pollId])
}

/// 투표 참여 기록
model RoomPollVote {
  /// 고유 식별자
  id        String         @id @default(cuid())
  /// 선택한 옵션
  option    RoomPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  /// 옵션 ID (FK)
  optionId  String
  /// 투표한 유저
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 유저 ID (FK)
  userId    String
  /// 투표일
  createdAt DateTime       @default(now())

  /// 한 옵션에 같은 유저 중복 투표 방지
  @@unique([optionId, userId])
  @@index([userId])
}

/// 방 내 알림 (활동 알림)
model RoomNotification {
  /// 고유 식별자
  id        String   @id @default(cuid())
  /// 소속 방
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /// 방 ID (FK)
  roomId    String
  /// 수신자
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 수신자 ID (FK)
  userId    String
  /// 알림 유형 ('restaurant_added' | 'review_added' | 'visit_added' | 'poll_created' | 'member_joined')
  type      String   @db.VarChar(30)
  /// 알림 메시지
  message   String   @db.VarChar(500)
  /// 읽음 여부
  isRead    Boolean  @default(false)
  /// 생성일
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@index([roomId])
}

/// FCM 푸시 토큰 (기기별 1개, 유저가 여러 기기 사용 가능)
model FcmToken {
  /// 고유 식별자
  id        String   @id @default(cuid())
  /// 소유자
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 소유자 ID (FK)
  userId    String
  /// FCM 등록 토큰
  token     String   @unique @db.VarChar(500)
  /// 기기 식별 (브라우저/OS 등)
  device    String?  @db.VarChar(200)
  /// 생성일
  createdAt DateTime @default(now())
  /// 갱신일
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// 데모 계정 (관리자가 생성한 테스트용 계정 인덱스)
model DemoAccount {
  /// 고유 식별자
  id        String   @id @default(cuid())
  /// 연결된 사용자
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 사용자 ID (FK, 1:1)
  userId    String   @unique
  /// 관리자 메모
  memo      String?  @db.VarChar(200)
  /// 생성일
  createdAt DateTime @default(now())
}

/// 커뮤니티 게시판
model Board {
  /// 고유 식별자
  id          String   @id @default(cuid())
  /// 게시판 이름
  name        String   @db.VarChar(50)
  /// URL 슬러그
  slug        String   @unique @db.VarChar(50)
  /// 게시판 설명
  description String?  @db.VarChar(200)
  /// 정렬 순서 (작을수록 위)
  sortOrder   Int      @default(0)
  /// 활성 여부
  enabled     Boolean  @default(true)
  /// 인기글 기준 좋아요 수
  popularThreshold Int @default(5)
  /// 게시글 목록
  posts       Post[]
  /// 생성일
  createdAt   DateTime @default(now())
  /// 최종 수정일
  updatedAt   DateTime @updatedAt
}

/// 커뮤니티 게시글
model Post {
  /// 고유 식별자
  id        String     @id @default(cuid())
  /// 게시글 제목
  title     String     @db.VarChar(200)
  /// 게시글 본문
  content   String     @db.Text
  /// 소속 게시판
  board     Board      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  /// 게시판 ID (FK)
  boardId   String
  /// 작성자
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  /// 작성자 ID (FK)
  authorId  String
  /// 익명 여부
  isAnonymous Boolean @default(false)
  /// 댓글 목록
  comments  Comment[]
  /// 추천 목록
  likes     PostLike[]
  /// 북마크 목록
  bookmarks PostBookmark[]
  /// 태그된 식당 목록
  restaurants PostRestaurant[]
  /// 작성일
  createdAt DateTime   @default(now())
  /// 최종 수정일
  updatedAt DateTime   @updatedAt

  @@index([boardId, createdAt])
  @@index([authorId])
}

/// 게시글 태그 식당 (커뮤니티 게시글에 태그된 식당 정보)
model PostRestaurant {
  /// 고유 식별자
  id           String  @id @default(cuid())
  /// 소속 게시글
  post         Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// 게시글 ID (FK)
  postId       String
  /// 식당 이름
  name         String  @db.VarChar(100)
  /// 주소
  address      String  @db.VarChar(300)
  /// 카테고리
  category     String? @db.VarChar(50)
  /// 위도
  latitude     Float?
  /// 경도
  longitude    Float?
  /// 카카오 장소 ID
  kakaoPlaceId String? @db.VarChar(50)

  @@index([postId])
}

/// 게시글 추천 (유저당 1회)
model PostLike {
  /// 고유 식별자
  id        String   @id @default(cuid())
  /// 대상 게시글
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// 게시글 ID (FK)
  postId    String
  /// 추천한 유저
  user      User     @relation("PostLikes", fields: [userId], references: [id], onDelete: Cascade)
  /// 유저 ID (FK)
  userId    String
  /// 추천일
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
}

/// 커뮤니티 댓글
model Comment {
  /// 고유 식별자
  id           String        @id @default(cuid())
  /// 댓글 내용
  content      String        @db.Text
  /// 소속 게시글
  post         Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// 게시글 ID (FK)
  postId       String
  /// 작성자
  author       User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  /// 작성자 ID (FK)
  authorId     String
  /// 익명 여부
  isAnonymous  Boolean       @default(false)
  /// 추천 목록
  likes        CommentLike[]
  /// 작성일
  createdAt    DateTime      @default(now())

  @@index([postId, createdAt])
}

/// 댓글 추천 (유저당 1회)
model CommentLike {
  /// 고유 식별자
  id        String   @id @default(cuid())
  /// 대상 댓글
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  /// 댓글 ID (FK)
  commentId String
  /// 추천한 유저
  user      User     @relation("CommentLikes", fields: [userId], references: [id], onDelete: Cascade)
  /// 유저 ID (FK)
  userId    String
  /// 추천일
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
  @@index([commentId])
}

/// 게시글 북마크 (유저당 1회)
model PostBookmark {
  /// 고유 식별자
  id        String   @id @default(cuid())
  /// 대상 게시글
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// 게시글 ID (FK)
  postId    String
  /// 북마크한 유저
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 유저 ID (FK)
  userId    String
  /// 북마크일
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
}

/// 유저별 튜토리얼 진행 상태 (코치마크 튜토리얼별 완료 기록)
model UserTutorialProgress {
  /// 고유 식별자
  id          String   @id @default(cuid())
  /// 연결된 유저
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 유저 ID (FK)
  userId      String
  /// 튜토리얼 키 (예: 'create_room', 'add_restaurant')
  tutorialKey String   @db.VarChar(50)
  /// 완료 시각
  completedAt DateTime @default(now())

  @@unique([userId, tutorialKey])
  @@index([userId])
}

/// 고객 문의 (지역 추가 요청, 버그 신고, 기타 피드백)
model Inquiry {
  /// 고유 식별자
  id        String   @id @default(cuid())
  /// 문의 유형 (region_request, bug_report, feedback, other)
  category  String   @db.VarChar(30)
  /// 보낸 사람 이메일 (답변 회신용)
  email     String   @db.VarChar(200)
  /// 문의 제목
  subject   String   @db.VarChar(300)
  /// 문의 내용
  content   String   @db.Text
  /// 작성일
  createdAt DateTime @default(now())
}
