generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 서비스 사용자 (프로필 정보만 보관, 인증 정보는 Account에 분리)
model User {
  /// 고유 식별자
  id              String    @id @default(cuid())
  /// OAuth 제공자에서 받은 이메일
  email           String    @unique
  /// 리뷰 등에 표시되는 닉네임
  nickname        String    @unique
  /// 프로필 이미지 URL
  profileImageUrl String?   @db.VarChar(500)
  /// 역할 ('user' | 'admin')
  role            String    @default("user") @db.VarChar(10)
  /// 연결된 OAuth 계정 (카카오 등)
  accounts        Account[]
  /// 소유한 방 목록
  ownedRooms      Room[]           @relation("RoomOwner")
  /// 참여 중인 방 멤버십
  roomMembers     RoomMember[]
  /// 방 내 등록한 식당
  roomRestaurants RoomRestaurant[]
  /// 방 내 작성한 리뷰
  roomReviews     RoomReview[]
  /// 강퇴 기록
  roomKicks       RoomKick[]
  /// 마지막 활동 시각 (DAU 추적용)
  lastActiveAt    DateTime?
  /// 가입일
  createdAt       DateTime  @default(now())
  /// 최종 수정일
  updatedAt       DateTime  @updatedAt

  @@index([lastActiveAt])
}

/// OAuth 계정 정보 (User와 1:N, 다중 소셜 로그인 확장 가능)
model Account {
  /// 고유 식별자
  id           String   @id @default(cuid())
  /// OAuth 제공자 ('kakao', 'google' 등)
  provider     String   @db.VarChar(20)
  /// 제공자 측 고유 사용자 ID
  providerId   String
  /// bcrypt 해싱된 JWT Refresh Token
  refreshToken String?  @db.Text
  /// 연결된 사용자
  user         User     @relation(fields: [userId], references: [id])
  /// 사용자 ID (FK)
  userId       String
  /// 생성일
  createdAt    DateTime @default(now())
  /// 최종 수정일
  updatedAt    DateTime @updatedAt

  /// 동일 제공자의 동일 계정 중복 방지
  @@unique([provider, providerId])
  @@index([userId])
}

/// 공유 방 (초대 코드로 입장, 방 전용 식당/리뷰 리스트)
model Room {
  /// 고유 식별자
  id          String           @id @default(cuid())
  /// 방 이름
  name        String           @db.VarChar(100)
  /// 8자 초대 코드
  inviteCode  String           @unique @db.VarChar(8)
  /// 초대 코드 만료 시간 (null = 무제한)
  inviteCodeExpiresAt DateTime?
  /// 8자 공유 코드 (null = 한 번도 생성 안 함)
  shareCode           String?  @unique @db.VarChar(8)
  /// 공유 코드 활성 여부
  shareCodeEnabled    Boolean  @default(false)
  /// 방장 (User FK)
  owner       User             @relation("RoomOwner", fields: [ownerId], references: [id])
  /// 방장 ID
  ownerId     String
  /// 멤버 목록
  members     RoomMember[]
  /// 방 내 식당 목록
  restaurants RoomRestaurant[]
  /// 강퇴 기록
  kicks       RoomKick[]
  /// 생성일
  createdAt   DateTime         @default(now())
  /// 최종 수정일
  updatedAt   DateTime         @updatedAt

  @@index([ownerId])
}

/// 방 멤버 (owner/manager/member 역할)
model RoomMember {
  /// 고유 식별자
  id       String   @id @default(cuid())
  /// 역할 ('owner' | 'manager' | 'member')
  role     String   @default("member") @db.VarChar(10)
  /// 소속 방
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /// 방 ID (FK)
  roomId   String
  /// 참여 유저
  user     User     @relation(fields: [userId], references: [id])
  /// 유저 ID (FK)
  userId   String
  /// 가입일
  joinedAt DateTime @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

/// 방 내 식당
model RoomRestaurant {
  /// 고유 식별자
  id           String       @id @default(cuid())
  /// 식당 이름
  name         String       @db.VarChar(200)
  /// 도로명/지번 주소
  address      String       @db.VarChar(500)
  /// 시/도
  province     String       @db.VarChar(50)
  /// 시/군/구
  city         String       @db.VarChar(50)
  /// 읍/면/동
  neighborhood String       @db.VarChar(100)
  /// 카테고리
  category     String       @db.VarChar(100)
  /// 대표 이미지 URL
  imageUrl     String?      @db.VarChar(500)
  /// 위도 (카카오맵 좌표)
  latitude     Float?
  /// 경도 (카카오맵 좌표)
  longitude    Float?
  /// 소속 방
  room         Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /// 방 ID (FK)
  roomId       String
  /// 등록자
  addedBy      User         @relation(fields: [addedById], references: [id])
  /// 등록자 ID (FK)
  addedById    String
  /// 리뷰 목록
  reviews      RoomReview[]
  /// 등록일
  createdAt    DateTime     @default(now())

  @@index([roomId])
  @@index([addedById])
}

/// 방 내 리뷰
model RoomReview {
  /// 고유 식별자
  id                 String         @id @default(cuid())
  /// 1~5 평점
  rating             Int
  /// 리뷰 본문
  content            String         @db.Text
  /// 재방문 의사
  wouldRevisit       Boolean        @default(true)
  /// 리뷰 대상 방 식당
  roomRestaurant     RoomRestaurant @relation(fields: [roomRestaurantId], references: [id], onDelete: Cascade)
  /// 방 식당 ID (FK)
  roomRestaurantId   String
  /// 작성자
  user               User           @relation(fields: [userId], references: [id])
  /// 작성자 ID (FK)
  userId             String
  /// 작성일
  createdAt          DateTime       @default(now())
  /// 최종 수정일
  updatedAt          DateTime       @updatedAt

  @@index([roomRestaurantId])
  @@index([userId])
}

/// 방 강퇴 기록 (재입장 차단용)
model RoomKick {
  /// 고유 식별자
  id       String   @id @default(cuid())
  /// 소속 방
  room     Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  /// 방 ID (FK)
  roomId   String
  /// 강퇴당한 유저
  user     User     @relation(fields: [userId], references: [id])
  /// 유저 ID (FK)
  userId   String
  /// 강퇴 일시
  kickedAt DateTime @default(now())

  /// 같은 방에서 같은 유저 중복 강퇴 방지
  @@unique([roomId, userId])
  @@index([userId])
}

/// 고객 문의 (지역 추가 요청, 버그 신고, 기타 피드백)
model Inquiry {
  /// 고유 식별자
  id        String   @id @default(cuid())
  /// 문의 유형 (region_request, bug_report, feedback, other)
  category  String   @db.VarChar(30)
  /// 보낸 사람 이메일 (답변 회신용)
  email     String   @db.VarChar(200)
  /// 문의 제목
  subject   String   @db.VarChar(300)
  /// 문의 내용
  content   String   @db.Text
  /// 작성일
  createdAt DateTime @default(now())
}
