# MySQL Writer (쓰기용)
DATABASE_URL="mysql://app:app1234@localhost:3306/fearless_tasting"

# MySQL Reader (읽기용) - 미설정 시 DATABASE_URL과 동일한 DB 사용
DATABASE_READER_URL="mysql://app:app1234@localhost:3307/fearless_tasting"

# 카카오 OAuth (https://developers.kakao.com 에서 발급)
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_CALLBACK_URL=http://localhost:4000/auth/kakao/callback

# 네이버 로그인 + 장소 검색 (https://developers.naver.com/apps/)
# 같은 앱에 "네이버 로그인"과 "검색" 서비스를 모두 활성화하면 한 쌍의 값으로 둘 다 커버됨
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_CALLBACK_URL=http://localhost:4000/auth/naver/callback

# (선택) 검색 전용 앱을 따로 쓰는 경우만 override. 미설정 시 NAVER_CLIENT_ID 사용.
# NAVER_SEARCH_CLIENT_ID=
# NAVER_SEARCH_CLIENT_SECRET=

# JWT 시크릿 (랜덤 문자열로 교체)
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod

# 프론트엔드 URL (OAuth 콜백 리다이렉트용)
FRONTEND_URL=http://localhost:4321
