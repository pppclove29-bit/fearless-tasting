# 이 파일을 keystore.properties 로 복사한 뒤 실제 값을 채워넣으세요.
# keystore.properties 는 .gitignore 처리되어 절대 커밋되지 않습니다.
#
# 키스토어 생성 명령:
#   keytool -genkey -v \
#     -keystore fearless-tasting-release.keystore \
#     -alias fearless \
#     -keyalg RSA -keysize 2048 -validity 10000

storeFile=fearless-tasting-release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=fearless
keyPassword=YOUR_KEY_PASSWORD
