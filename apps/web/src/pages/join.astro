---
import BaseLayout from '@/layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="방 입장" description="초대 링크로 방에 입장하세요" noindex>
  <div class="join-page">
    <div class="join-card">
      <h1>방 입장</h1>
      <p class="join-desc">초대 링크를 통해 방에 입장합니다.</p>
      <p id="join-status" class="join-status">입장 준비 중...</p>
      <form id="join-form" hidden>
        <input type="text" id="join-code" placeholder="초대 코드를 입력하세요" required />
        <button type="submit" class="btn-join">입장하기</button>
      </form>
      <p id="join-error" class="join-error" hidden></p>
      <a href="/" class="join-home">홈으로 돌아가기</a>
    </div>
  </div>
</BaseLayout>

<style>
  .join-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
  }

  .join-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 2.5rem 2rem;
    max-width: 400px;
    width: 100%;
    text-align: center;
  }

  .join-card h1 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.3rem;
  }

  .join-desc {
    font-size: 0.85rem;
    color: var(--text-sub);
    margin-bottom: 1.5rem;
  }

  .join-status {
    font-size: 0.9rem;
    color: var(--text-muted);
    padding: 1rem 0;
  }

  .join-error {
    font-size: 0.85rem;
    color: #dc2626;
    margin-top: 0.75rem;
  }

  #join-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  #join-code {
    padding: 0.6rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.9rem;
    background: var(--bg-input);
    color: var(--text);
    text-align: center;
    letter-spacing: 0.05em;
  }

  #join-code:focus {
    outline: none;
    border-color: var(--border-mid);
  }

  .btn-join {
    padding: 0.65rem 1rem;
    background: var(--text-heading);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .btn-join:hover {
    opacity: 0.85;
  }

  .btn-join:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .join-home {
    display: inline-block;
    margin-top: 1.2rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .join-home:hover {
    color: var(--text-sub);
  }
</style>

<script>
  import { fetchCurrentUser, joinRoom, showToast } from '@/lib/api';

  async function initJoinPage() {
    const statusEl = document.getElementById('join-status');
    const formEl = document.getElementById('join-form') as HTMLFormElement | null;
    const codeInput = document.getElementById('join-code') as HTMLInputElement | null;
    const errorEl = document.getElementById('join-error');
    if (!statusEl || !formEl || !codeInput || !errorEl) return;

    const params = new URLSearchParams(location.search);
    const code = params.get('code')?.trim() || '';

    async function attemptJoin(inviteCode: string) {
      statusEl.textContent = '입장 중...';
      statusEl.hidden = false;
      errorEl.hidden = true;

      try {
        const room = await joinRoom(inviteCode);
        showToast(`"${room.name}" 방에 입장했습니다!`, 'success');
        location.href = `/room?id=${room.id}`;
      } catch (err) {
        statusEl.hidden = true;
        errorEl.textContent = err instanceof Error ? err.message : '입장에 실패했습니다.';
        errorEl.hidden = false;
        formEl.hidden = false;
        codeInput.value = inviteCode;
      }
    }

    const user = await fetchCurrentUser();

    if (!user) {
      // 비로그인 → 로그인 페이지로 리다이렉트 (코드 보존)
      const returnUrl = `/join${code ? `?code=${code}` : ''}`;
      localStorage.setItem('login_redirect', returnUrl);
      location.href = `${import.meta.env.PUBLIC_API_URL || 'http://localhost:4000'}/auth/kakao`;
    } else if (code) {
      // 코드가 URL에 있으면 자동 입장 시도
      await attemptJoin(code);
    } else {
      // 코드 없이 접근 → 수동 입력 폼 표시
      statusEl.hidden = true;
      formEl.hidden = false;
    }

    formEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      const inputCode = codeInput.value.trim();
      if (!inputCode) return;
      await attemptJoin(inputCode);
    });
  }

  document.addEventListener('astro:page-load', initJoinPage);
</script>
