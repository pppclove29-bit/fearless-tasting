---
import BaseLayout from '@/layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="방 입장" description="초대 링크로 방에 입장하세요" noindex>
  <div class="join-page">
    <div class="join-card">
      <h1>방 입장</h1>
      <p id="join-status" class="join-status">입장 준비 중...</p>
      <p id="join-error" class="join-error" hidden></p>
      <a href="/" class="join-home">홈으로 돌아가기</a>
    </div>
  </div>
</BaseLayout>

<style>
  .join-page {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60vh;
  }

  .join-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 2.5rem 2rem;
    max-width: 400px;
    width: 100%;
    text-align: center;
  }

  .join-card h1 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.75rem;
  }

  .join-status {
    font-size: 0.9rem;
    color: var(--text-muted);
    padding: 1rem 0;
  }

  .join-error {
    font-size: 0.85rem;
    color: #dc2626;
    margin-top: 0.75rem;
  }

  .join-home {
    display: inline-block;
    margin-top: 1.2rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .join-home:hover {
    color: var(--text-sub);
  }
</style>

<script>
  import { fetchCurrentUser, joinRoom, showToast } from '@/lib/api';

  async function initJoinPage() {
    const statusEl = document.getElementById('join-status');
    const errorEl = document.getElementById('join-error');
    if (!statusEl || !errorEl) return;

    const params = new URLSearchParams(location.search);
    const code = params.get('code')?.trim() || '';

    // 코드 없이 접근 → 홈으로 리다이렉트
    if (!code) {
      location.href = '/';
      return;
    }

    const user = await fetchCurrentUser();

    if (!user) {
      // 비로그인 → 로그인 선택 페이지 경유 (카카오/네이버 선택 가능)
      localStorage.setItem('login_redirect', `/join?code=${code}`);
      location.href = '/login';
      return;
    }

    // 자동 입장 시도
    statusEl.textContent = '입장 중...';
    try {
      const room = await joinRoom(code);
      showToast(`"${room.name}" 방에 입장했습니다!`, 'success');
      location.href = `/room?id=${room.id}`;
    } catch (err) {
      statusEl.hidden = true;
      errorEl.textContent = err instanceof Error ? err.message : '입장에 실패했습니다.';
      errorEl.hidden = false;
    }
  }

  document.addEventListener('astro:page-load', initJoinPage);
</script>
