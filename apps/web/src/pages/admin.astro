---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="관리자">
  <h1>관리자 페이지</h1>
  <p class="page-desc">문의 및 식당/리뷰를 관리합니다.</p>

  <div id="admin-content">
    <p id="loading-msg">로딩 중...</p>
    <p id="access-denied" hidden class="access-denied">관리자 권한이 필요합니다.</p>

    <div id="admin-tabs" hidden>
      <div class="tab-bar">
        <button type="button" class="tab-btn active" data-tab="inquiries">문의 관리</button>
        <button type="button" class="tab-btn" data-tab="restaurants">식당/리뷰 관리</button>
      </div>

      <div id="tab-inquiries" class="tab-panel"></div>
      <div id="tab-restaurants" class="tab-panel" hidden></div>
    </div>
  </div>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.25rem;
    font-size: 1.4rem;
  }

  .page-desc {
    color: #888;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .access-denied {
    color: #dc2626;
    font-size: 0.9rem;
    padding: 1rem;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
  }
</style>

<style is:global>
  .tab-bar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid #e8e8e8;
    padding-bottom: 0;
  }

  .tab-btn {
    padding: 0.6rem 1rem;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    font-size: 0.875rem;
    font-weight: 500;
    color: #888;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }

  .tab-btn:hover {
    color: #333;
  }

  .tab-btn.active {
    color: #111;
    font-weight: 600;
    border-bottom-color: #111;
  }

  .inquiry-card,
  .admin-restaurant-card {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .inquiry-header,
  .admin-rest-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .inquiry-category {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    background: #f0f0f0;
    color: #555;
  }

  .inquiry-category.region_request { background: #dbeafe; color: #1d4ed8; }
  .inquiry-category.bug_report { background: #fee2e2; color: #dc2626; }
  .inquiry-category.feedback { background: #dcfce7; color: #16a34a; }

  .inquiry-date {
    font-size: 0.75rem;
    color: #999;
  }

  .inquiry-subject {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .inquiry-meta {
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 0.5rem;
  }

  .inquiry-content {
    font-size: 0.85rem;
    color: #444;
    line-height: 1.6;
    white-space: pre-wrap;
  }

  .admin-rest-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #111;
  }

  .admin-rest-name a {
    color: inherit;
    text-decoration: none;
  }

  .admin-rest-name a:hover {
    text-decoration: underline;
  }

  .admin-rest-meta {
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 0.35rem;
  }

  .admin-rest-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .btn-danger-sm {
    padding: 0.3rem 0.65rem;
    background: #dc2626;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-danger-sm:hover {
    background: #b91c1c;
  }

  .btn-toggle-sm {
    padding: 0.3rem 0.65rem;
    background: #fff;
    color: #555;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-toggle-sm:hover {
    background: #f0f0f0;
  }

  .admin-reviews-panel {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid #f0f0f0;
  }

  .admin-review-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid #f5f5f5;
    font-size: 0.825rem;
  }

  .admin-review-item:last-child {
    border-bottom: none;
  }

  .admin-review-info {
    flex: 1;
    min-width: 0;
  }

  .admin-review-text {
    color: #444;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .admin-review-meta {
    font-size: 0.75rem;
    color: #999;
  }

  .empty-msg {
    text-align: center;
    color: #999;
    font-size: 0.9rem;
    padding: 2rem;
  }
</style>

<script>
  import { fetchCurrentUser, fetchInquiries, fetchRestaurant, deleteRestaurant, deleteReview } from '@/lib/api';
  import type { RestaurantDetail } from '@/lib/api';
  import { formatDate } from '@repo/utils';

  const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';

  const loadingMsg = document.getElementById('loading-msg')!;
  const accessDenied = document.getElementById('access-denied')!;
  const adminTabs = document.getElementById('admin-tabs')!;
  const inquiriesPanel = document.getElementById('tab-inquiries')!;
  const restaurantsPanel = document.getElementById('tab-restaurants')!;

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  const categoryLabel: Record<string, string> = {
    region_request: '지역 추가 요청',
    bug_report: '버그 신고',
    feedback: '피드백',
    other: '기타',
  };

  // 탭 전환
  for (const btn of document.querySelectorAll<HTMLButtonElement>('.tab-btn')) {
    btn.addEventListener('click', () => {
      for (const b of document.querySelectorAll('.tab-btn')) b.classList.remove('active');
      btn.classList.add('active');
      const tab = btn.dataset.tab!;
      inquiriesPanel.hidden = tab !== 'inquiries';
      restaurantsPanel.hidden = tab !== 'restaurants';
      if (tab === 'restaurants' && restaurantsPanel.innerHTML === '') {
        loadRestaurants();
      }
    });
  }

  async function loadInquiries() {
    const inquiries = await fetchInquiries();

    if (inquiries.length === 0) {
      inquiriesPanel.innerHTML = '<p class="empty-msg">등록된 문의가 없습니다.</p>';
      return;
    }

    inquiriesPanel.innerHTML = inquiries
      .map(
        (inq) => `
        <div class="inquiry-card">
          <div class="inquiry-header">
            <span class="inquiry-category ${inq.category}">${categoryLabel[inq.category] || inq.category}</span>
            <span class="inquiry-date">${formatDate(inq.createdAt)}</span>
          </div>
          <div class="inquiry-subject">${escapeHtml(inq.subject)}</div>
          <div class="inquiry-meta">${escapeHtml(inq.email)}</div>
          <div class="inquiry-content">${escapeHtml(inq.content)}</div>
        </div>
      `,
      )
      .join('');
  }

  interface RestaurantListItem {
    id: string;
    name: string;
    address: string;
    category: string;
    province: string;
    city: string;
    neighborhood: string;
  }

  async function fetchAllRestaurants(): Promise<RestaurantListItem[]> {
    try {
      const res = await fetch(`${API_BASE}/restaurants`, { credentials: 'include' });
      if (!res.ok) return [];
      return res.json();
    } catch {
      return [];
    }
  }

  async function loadRestaurants() {
    restaurantsPanel.innerHTML = '<p class="empty-msg">로딩 중...</p>';
    const restaurants = await fetchAllRestaurants();

    if (restaurants.length === 0) {
      restaurantsPanel.innerHTML = '<p class="empty-msg">등록된 식당이 없습니다.</p>';
      return;
    }

    restaurantsPanel.innerHTML = restaurants
      .map(
        (r) => `
        <div class="admin-restaurant-card" data-id="${r.id}">
          <div class="admin-rest-header">
            <span class="admin-rest-name"><a href="/restaurant?id=${r.id}">${escapeHtml(r.name)}</a></span>
            <div class="admin-rest-actions">
              <button type="button" class="btn-toggle-sm toggle-reviews-btn" data-id="${r.id}">리뷰 보기</button>
              <button type="button" class="btn-danger-sm delete-rest-btn" data-id="${r.id}">삭제</button>
            </div>
          </div>
          <div class="admin-rest-meta">${escapeHtml(r.address)} · ${escapeHtml(r.category)}</div>
          <div class="admin-reviews-panel" data-rest-id="${r.id}" hidden></div>
        </div>
      `,
      )
      .join('');

    // 식당 삭제
    for (const btn of restaurantsPanel.querySelectorAll<HTMLButtonElement>('.delete-rest-btn')) {
      btn.addEventListener('click', async () => {
        if (!confirm('정말 이 식당을 삭제하시겠습니까? 모든 리뷰도 함께 삭제됩니다.')) return;
        const id = btn.dataset.id!;
        try {
          await deleteRestaurant(id);
          const card = restaurantsPanel.querySelector<HTMLElement>(`.admin-restaurant-card[data-id="${id}"]`);
          if (card) card.remove();
        } catch {
          alert('식당 삭제에 실패했습니다.');
        }
      });
    }

    // 리뷰 토글
    for (const btn of restaurantsPanel.querySelectorAll<HTMLButtonElement>('.toggle-reviews-btn')) {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id!;
        const panel = restaurantsPanel.querySelector<HTMLElement>(`.admin-reviews-panel[data-rest-id="${id}"]`)!;

        if (!panel.hidden) {
          panel.hidden = true;
          btn.textContent = '리뷰 보기';
          return;
        }

        panel.innerHTML = '<p class="admin-review-meta">로딩 중...</p>';
        panel.hidden = false;
        btn.textContent = '리뷰 접기';

        try {
          const restaurant: RestaurantDetail = await fetchRestaurant(id);
          if (restaurant.reviews.length === 0) {
            panel.innerHTML = '<p class="admin-review-meta">리뷰가 없습니다.</p>';
            return;
          }

          panel.innerHTML = restaurant.reviews
            .map(
              (rev) => `
              <div class="admin-review-item" data-review-id="${rev.id}">
                <div class="admin-review-info">
                  <div class="admin-review-text">${escapeHtml(rev.user.nickname)}: ${escapeHtml(rev.content)}</div>
                  <div class="admin-review-meta">${'\u2605'.repeat(rev.rating)} · ${formatDate(rev.createdAt)}</div>
                </div>
                <button type="button" class="btn-danger-sm delete-rev-btn" data-review-id="${rev.id}">삭제</button>
              </div>
            `,
            )
            .join('');

          // 리뷰 삭제
          for (const delBtn of panel.querySelectorAll<HTMLButtonElement>('.delete-rev-btn')) {
            delBtn.addEventListener('click', async () => {
              if (!confirm('이 리뷰를 삭제하시겠습니까?')) return;
              const reviewId = delBtn.dataset.reviewId!;
              try {
                await deleteReview(reviewId);
                const item = panel.querySelector<HTMLElement>(`.admin-review-item[data-review-id="${reviewId}"]`);
                if (item) item.remove();
                if (panel.querySelectorAll('.admin-review-item').length === 0) {
                  panel.innerHTML = '<p class="admin-review-meta">리뷰가 없습니다.</p>';
                }
              } catch {
                alert('리뷰 삭제에 실패했습니다.');
              }
            });
          }
        } catch {
          panel.innerHTML = '<p class="admin-review-meta">리뷰를 불러올 수 없습니다.</p>';
        }
      });
    }
  }

  async function init() {
    const user = await fetchCurrentUser();

    if (!user || user.role !== 'admin') {
      loadingMsg.hidden = true;
      accessDenied.hidden = false;
      return;
    }

    loadingMsg.hidden = true;
    adminTabs.hidden = false;
    await loadInquiries();
  }

  init();
</script>
