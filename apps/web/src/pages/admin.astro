---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="관리자" noindex>
  <h1>관리자 페이지</h1>
  <p class="page-desc">문의를 관리합니다.</p>

  <div id="admin-content">
    <p id="loading-msg">로딩 중...</p>
    <p id="access-denied" hidden class="access-denied">관리자 권한이 필요합니다.</p>

    <div id="admin-tabs" hidden>
      <div class="tab-bar">
        <button type="button" class="tab-btn active" data-tab="stats">통계</button>
        <button type="button" class="tab-btn" data-tab="notices">공지 관리</button>
        <button type="button" class="tab-btn" data-tab="inquiries">문의 관리</button>
        <button type="button" class="tab-btn" data-tab="demo">가계정</button>
        <button type="button" class="tab-btn" data-tab="users">유저</button>
        <button type="button" class="tab-btn" data-tab="boards">게시판</button>
        <button type="button" class="tab-btn" data-tab="requests">요구사항</button>
      </div>

      <div id="tab-stats" class="tab-panel"></div>
      <div id="tab-notices" class="tab-panel" hidden></div>
      <div id="tab-inquiries" class="tab-panel" hidden></div>
      <div id="tab-demo" class="tab-panel" hidden></div>
      <div id="tab-users" class="tab-panel" hidden></div>
      <div id="tab-boards" class="tab-panel" hidden></div>
      <div id="tab-requests" class="tab-panel" hidden></div>
    </div>
  </div>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.25rem;
    font-size: 1.4rem;
  }

  .page-desc {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .access-denied {
    color: #dc2626;
    font-size: 0.9rem;
    padding: 1rem;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 8px;
  }
</style>

<style is:global>
  .tab-bar {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 0;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    cursor: grab;
    user-select: none;
    scroll-behavior: smooth;
  }
  .tab-bar::-webkit-scrollbar { display: none; }
  .tab-bar.is-dragging { cursor: grabbing; scroll-behavior: auto; }

  .tab-btn {
    padding: 0.6rem 1rem;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .tab-btn:hover {
    color: var(--text-sub);
  }

  .tab-btn.active {
    color: var(--text-heading);
    font-weight: 600;
    border-bottom-color: var(--text-heading);
  }

  .inquiry-card,
  .admin-restaurant-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .inquiry-header,
  .admin-rest-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .inquiry-category {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    background: var(--bg-hover);
    color: var(--text-sub);
  }

  .inquiry-category.region_request { background: #dbeafe; color: #1d4ed8; }
  .inquiry-category.bug_report { background: #fee2e2; color: #dc2626; }
  .inquiry-category.feedback { background: var(--bg-hover); color: var(--text-heading); }

  .inquiry-date {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .inquiry-subject {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .inquiry-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }

  .inquiry-content {
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.6;
    white-space: pre-wrap;
  }

  .admin-rest-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-heading);
  }

  .admin-rest-name a {
    color: inherit;
    text-decoration: none;
  }

  .admin-rest-name a:hover {
    text-decoration: underline;
  }

  .admin-rest-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-bottom: 0.35rem;
  }

  .admin-rest-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .btn-danger-sm {
    padding: 0.3rem 0.65rem;
    background: #dc2626;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-danger-sm:hover {
    background: #b91c1c;
  }

  .btn-toggle-sm {
    padding: 0.3rem 0.65rem;
    background: var(--bg-card);
    color: var(--text-sub);
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-toggle-sm:hover {
    background: var(--bg-hover);
  }

  .admin-reviews-panel {
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border-light);
  }

  .admin-review-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border-light);
    font-size: 0.825rem;
  }

  .admin-review-item:last-child {
    border-bottom: none;
  }

  .admin-review-info {
    flex: 1;
    min-width: 0;
  }

  .admin-review-text {
    color: var(--text-sub);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .admin-review-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .empty-msg {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    padding: 2rem;
  }

  /* 공지 관리 */
  .notice-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .notice-card.disabled {
    opacity: 0.5;
  }

  .notice-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .notice-order-badge {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-muted);
    background: var(--bg-hover);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }

  .notice-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-heading);
    flex: 1;
  }

  .notice-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .notice-badge.active { background: var(--bg-hover); color: var(--text-heading); }
  .notice-badge.inactive { background: #fee2e2; color: #dc2626; }

  .notice-content {
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.6;
    white-space: pre-wrap;
    margin-bottom: 0.5rem;
  }

  .notice-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .notice-date {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .notice-actions {
    display: flex;
    gap: 0.4rem;
  }

  .notice-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }

  .notice-form input,
  .notice-form textarea {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.85rem;
    font-family: inherit;
    margin-bottom: 0.5rem;
    background: var(--bg-input, var(--bg));
    color: var(--text);
  }

  .notice-form textarea {
    min-height: 80px;
    resize: vertical;
  }

  .notice-form-actions {
    display: flex;
    gap: 0.5rem;
  }

  .btn-primary-sm {
    padding: 0.35rem 0.75rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
  }

  .btn-outline-sm {
    padding: 0.35rem 0.75rem;
    background: none;
    color: var(--text-sub);
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
  }

  /* 가계정 관리 */
  .demo-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }

  .demo-form input {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.85rem;
    font-family: inherit;
    margin-bottom: 0.5rem;
    background: var(--bg-input, var(--bg));
    color: var(--text);
  }

  .demo-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .demo-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--bg-hover);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-heading);
    overflow: hidden;
    flex-shrink: 0;
  }

  .demo-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .demo-info {
    flex: 1;
    min-width: 0;
  }

  .demo-nickname {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-heading);
  }

  .demo-memo {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  .demo-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  .demo-actions {
    display: flex;
    gap: 0.4rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  .demo-edit-fields {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    flex: 1;
    min-width: 0;
  }

  .demo-edit-fields input {
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.82rem;
    font-family: inherit;
    background: var(--bg-input, var(--bg));
    color: var(--text);
  }

  .btn-login-sm {
    padding: 0.3rem 0.65rem;
    background: #2563eb;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-login-sm:hover {
    background: #1d4ed8;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
  }

  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    text-align: center;
  }

  .stat-value {
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-heading);
    line-height: 1.2;
  }

  .stat-label {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  .stats-section { margin-bottom: 1.5rem; }
  .stats-section-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.6rem;
  }

  .stat-growth {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    color: #16a34a;
    background: #dcfce7;
    padding: 0.1rem 0.4rem;
    border-radius: 10px;
    vertical-align: middle;
    margin-left: 0.3rem;
  }

  .mini-chart {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 100px;
    padding: 0.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
  }
  .mini-bar-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    height: 100%;
    min-width: 0;
  }
  .mini-bar {
    width: 100%;
    min-height: 2px;
    background: #3b82f6;
    border-radius: 2px 2px 0 0;
    transition: height 0.2s;
  }
  .mini-bar-label {
    font-size: 0.55rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
    white-space: nowrap;
  }

  .dual-chart {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
  }

  .chart-legend {
    display: flex;
    gap: 1rem;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .legend-item { display: inline-flex; align-items: center; gap: 0.3rem; }
  .legend-dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
  }

  @media (max-width: 600px) {
    .dual-chart { grid-template-columns: 1fr; }
  }

  /* 유저 관리 */
  .user-search-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 1rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .user-search-form input {
    flex: 1;
    padding: 0.5rem;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.85rem;
    font-family: inherit;
    background: var(--bg-input, var(--bg));
    color: var(--text);
  }

  .user-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .user-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--bg-hover);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-heading);
    overflow: hidden;
    flex-shrink: 0;
  }

  .user-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .user-info {
    flex: 1;
    min-width: 0;
  }

  .user-nickname {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-heading);
  }

  .user-email {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-top: 0.1rem;
    word-break: break-all;
  }

  .user-role-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    margin-top: 0.25rem;
  }

  .user-role-badge.admin {
    background: #dbeafe;
    color: #1d4ed8;
  }

  .user-role-badge.user {
    background: var(--bg-hover);
    color: var(--text-sub);
  }

  .user-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  .user-actions {
    flex-shrink: 0;
  }

  .btn-admin-toggle {
    padding: 0.4rem 0.85rem;
    border: none;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-admin-toggle.grant {
    background: #2563eb;
    color: #fff;
  }

  .btn-admin-toggle.grant:hover {
    background: #1d4ed8;
  }

  .btn-admin-toggle.revoke {
    background: #dc2626;
    color: #fff;
  }

  .btn-admin-toggle.revoke:hover {
    background: #b91c1c;
  }

  /* 게시판 관리 */
  .board-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }

  .board-form input {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.85rem;
    font-family: inherit;
    margin-bottom: 0.5rem;
    background: var(--bg-input, var(--bg));
    color: var(--text);
  }

  .board-form-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.5rem;
    flex-wrap: wrap;
  }
  .board-form-row label { white-space: nowrap; }

  .board-card-admin {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .board-card-admin.disabled {
    opacity: 0.5;
  }

  .board-admin-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.35rem;
  }

  .board-admin-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-heading);
  }

  .board-admin-slug {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-family: monospace;
  }

  .board-admin-desc {
    font-size: 0.82rem;
    color: var(--text-sub);
    margin-bottom: 0.35rem;
  }

  .board-admin-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.5rem;
  }

  .board-admin-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .board-admin-actions {
    display: flex;
    gap: 0.4rem;
  }

  /* 요구사항 관리 */
  .request-guide {
    background: var(--bg-hover);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
    font-size: 0.82rem;
    color: var(--text-sub);
    line-height: 1.6;
  }
  .request-guide h3 {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.5rem;
  }
  .request-guide ul {
    padding-left: 1.2rem;
    margin: 0.4rem 0;
  }
  .request-guide li { margin-bottom: 0.25rem; }
  .badge-open {
    display: inline-block;
    padding: 0.1rem 0.4rem;
    background: #dcfce7;
    color: #166534;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 600;
  }
  .rc-toggle {
    background: none;
    border: none;
    font-size: 0.75rem;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0;
    font-family: inherit;
    text-decoration: underline;
  }
  .rc-detail { margin-top: 0.5rem; }
  .rc-item {
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--border-light, var(--border));
  }
  .rc-author { font-size: 0.75rem; font-weight: 600; color: var(--text-heading); margin-right: 0.4rem; }
  .rc-date { font-size: 0.68rem; color: var(--text-muted); }
  .rc-body { font-size: 0.8rem; color: var(--text-sub); margin-top: 0.15rem; line-height: 1.4; }
  .rc-empty { font-size: 0.78rem; color: var(--text-muted); margin: 0.3rem 0; }
  .rc-write {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }
  .rc-input {
    flex: 1;
    padding: 0.35rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.78rem;
    font-family: inherit;
    color: var(--text);
    background: var(--bg);
    outline: none;
  }
  .rc-input:focus { border-color: var(--text-heading); }

  .badge-closed {
    display: inline-block;
    padding: 0.1rem 0.4rem;
    background: var(--bg-hover);
    color: var(--text-muted);
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 600;
  }

  .request-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }

  .request-form input,
  .request-form textarea {
    width: 100%;
    padding: 0.5rem;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.85rem;
    font-family: inherit;
    margin-bottom: 0.5rem;
    background: var(--bg-input, var(--bg));
    color: var(--text);
  }

  .request-form textarea {
    min-height: 100px;
    resize: vertical;
  }

  .request-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .request-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.35rem;
  }

  .request-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-heading);
  }

  .request-title a {
    color: inherit;
    text-decoration: none;
  }

  .request-title a:hover {
    text-decoration: underline;
  }

  .request-state {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
  }

  .request-state.open {
    background: #dcfce7;
    color: #16a34a;
  }

  .request-state.closed {
    background: var(--bg-hover);
    color: var(--text-muted);
  }

  .request-date {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }
</style>

<script>
  import { fetchCurrentUser, fetchInquiries, fetchAllNotices, createNotice, updateNotice, deleteNotice, fetchDemoAccounts, createDemoAccount, updateDemoAccount, deleteDemoAccount, loginAsDemoAccount, saveTokens, searchUserByEmail, updateUserRole, fetchAllBoards, createBoard, updateBoard, deleteBoard, createFeatureRequest, fetchFeatureRequests, fetchRequestComments, addRequestComment, fetchAdminDashboard } from '@/lib/api';
  import type { Notice, DemoAccount, AdminUserInfo, Board, FeatureRequestItem, AdminDashboard } from '@/lib/api';
  import { formatDate } from '@repo/utils';

  function initAdminPage() {

    const loadingMsg = document.getElementById('loading-msg');
    const accessDenied = document.getElementById('access-denied');
    const adminTabs = document.getElementById('admin-tabs');
    const statsPanel = document.getElementById('tab-stats');
    const noticesPanel = document.getElementById('tab-notices');
    const inquiriesPanel = document.getElementById('tab-inquiries');
    const demoPanel = document.getElementById('tab-demo');
    const usersPanel = document.getElementById('tab-users');
    const boardsPanel = document.getElementById('tab-boards');
    const requestsPanel = document.getElementById('tab-requests');
    if (!loadingMsg || !accessDenied || !adminTabs || !statsPanel || !noticesPanel || !inquiriesPanel || !demoPanel || !usersPanel || !boardsPanel || !requestsPanel) return;

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    const categoryLabel: Record<string, string> = {
      region_request: '지역 추가 요청',
      bug_report: '버그 신고',
      feedback: '피드백',
      other: '기타',
    };

    // 탭 전환
    const panels: Record<string, HTMLElement> = { stats: statsPanel, notices: noticesPanel, inquiries: inquiriesPanel, demo: demoPanel, users: usersPanel, boards: boardsPanel, requests: requestsPanel };
    for (const btn of document.querySelectorAll<HTMLButtonElement>('.tab-btn')) {
      btn.addEventListener('click', () => {
        for (const b of document.querySelectorAll('.tab-btn')) b.classList.remove('active');
        btn.classList.add('active');
        const tab = btn.dataset.tab!;
        for (const [key, panel] of Object.entries(panels)) panel.hidden = key !== tab;
        if (tab === 'inquiries' && inquiriesPanel.innerHTML === '') loadInquiries();
        if (tab === 'notices' && noticesPanel.innerHTML === '') loadNotices();
        if (tab === 'demo' && demoPanel.innerHTML === '') loadDemoAccounts();
        if (tab === 'users' && usersPanel.innerHTML === '') initUsersTab();
        if (tab === 'boards' && boardsPanel.innerHTML === '') loadBoardsAdmin();
        if (tab === 'requests' && requestsPanel.innerHTML === '') loadFeatureRequestsTab();
      });
    }

    // 탭바 드래그 스크롤 (마우스)
    const tabBar = document.querySelector<HTMLElement>('.tab-bar');
    if (tabBar) {
      let isDown = false;
      let startX = 0;
      let scrollLeft = 0;
      let dragged = false;
      tabBar.addEventListener('mousedown', (e) => {
        isDown = true;
        dragged = false;
        startX = e.pageX - tabBar.offsetLeft;
        scrollLeft = tabBar.scrollLeft;
        tabBar.classList.add('is-dragging');
      });
      tabBar.addEventListener('mouseleave', () => { isDown = false; tabBar.classList.remove('is-dragging'); });
      tabBar.addEventListener('mouseup', () => { isDown = false; tabBar.classList.remove('is-dragging'); });
      tabBar.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - tabBar.offsetLeft;
        const walk = x - startX;
        if (Math.abs(walk) > 5) dragged = true;
        tabBar.scrollLeft = scrollLeft - walk;
      });
      // 드래그 후 발생하는 click 이벤트 차단 (탭 전환 방지)
      tabBar.addEventListener('click', (e) => {
        if (dragged) {
          e.preventDefault();
          e.stopPropagation();
          dragged = false;
        }
      }, true);
    }

    async function loadStats() {
      statsPanel.innerHTML = '<p class="empty-msg">로딩 중...</p>';
      try {
        const d: AdminDashboard = await fetchAdminDashboard();
        const growthBadge = (n: number) => n > 0 ? `<span class="stat-growth">+${n}</span>` : '';
        const barChart = (values: number[], labels: string[], colors?: string[]) => {
          const max = Math.max(1, ...values);
          return `<div class="mini-chart">${values.map((v, i) =>
            `<div class="mini-bar-col" title="${labels[i]}: ${v}">
              <div class="mini-bar" style="height:${(v / max) * 100}%;${colors ? `background:${colors[i]}` : ''}"></div>
              <div class="mini-bar-label">${labels[i].slice(5)}</div>
             </div>`
          ).join('')}</div>`;
        };
        const signupValues = d.daily.signups.map((x) => x.count);
        const signupLabels = d.daily.signups.map((x) => x.date);
        const visitValues = d.daily.activity.map((x) => x.visits);
        const reviewValues = d.daily.activity.map((x) => x.reviews);
        const activityLabels = d.daily.activity.map((x) => x.date);

        statsPanel.innerHTML = `
          <div class="stats-section">
            <h3 class="stats-section-title">유저</h3>
            <div class="stats-grid">
              <div class="stat-card"><div class="stat-value">${d.users.dau}</div><div class="stat-label">DAU (오늘)</div></div>
              <div class="stat-card"><div class="stat-value">${d.users.wau}</div><div class="stat-label">WAU (7일)</div></div>
              <div class="stat-card"><div class="stat-value">${d.users.mau}</div><div class="stat-label">MAU (30일)</div></div>
              <div class="stat-card"><div class="stat-value">${d.users.total} ${growthBadge(d.users.newThisWeek)}</div><div class="stat-label">전체 유저</div></div>
            </div>
          </div>

          <div class="stats-section">
            <h3 class="stats-section-title">활동 (이번 주)</h3>
            <div class="stats-grid">
              <div class="stat-card"><div class="stat-value">${d.rooms.total} ${growthBadge(d.rooms.newThisWeek)}</div><div class="stat-label">방</div></div>
              <div class="stat-card"><div class="stat-value">${d.restaurants.total} ${growthBadge(d.restaurants.newThisWeek)}</div><div class="stat-label">식당 (위시 ${d.restaurants.wishlist})</div></div>
              <div class="stat-card"><div class="stat-value">${d.visits.total} ${growthBadge(d.visits.newThisWeek)}</div><div class="stat-label">방문</div></div>
              <div class="stat-card"><div class="stat-value">${d.reviews.total} ${growthBadge(d.reviews.newThisWeek)}</div><div class="stat-label">리뷰</div></div>
              <div class="stat-card"><div class="stat-value">${d.posts.total} ${growthBadge(d.posts.newThisWeek)}</div><div class="stat-label">게시글</div></div>
            </div>
          </div>

          <div class="stats-section">
            <h3 class="stats-section-title">일별 가입자 (최근 14일)</h3>
            ${barChart(signupValues, signupLabels)}
          </div>

          <div class="stats-section">
            <h3 class="stats-section-title">일별 활동 (최근 14일)</h3>
            <div class="chart-legend">
              <span class="legend-item"><span class="legend-dot" style="background:#3b82f6;"></span>방문</span>
              <span class="legend-item"><span class="legend-dot" style="background:#10b981;"></span>리뷰</span>
            </div>
            <div class="dual-chart">
              ${barChart(visitValues, activityLabels, visitValues.map(() => '#3b82f6'))}
              ${barChart(reviewValues, activityLabels, reviewValues.map(() => '#10b981'))}
            </div>
          </div>
        `;
      } catch {
        statsPanel.innerHTML = '<p class="empty-msg">통계를 불러올 수 없습니다.</p>';
      }
    }

    async function loadInquiries() {
      const inquiries = await fetchInquiries();

      if (inquiries.length === 0) {
        inquiriesPanel.innerHTML = '<p class="empty-msg">등록된 문의가 없습니다.</p>';
        return;
      }

      inquiriesPanel.innerHTML = inquiries
        .map(
          (inq) => `
          <div class="inquiry-card">
            <div class="inquiry-header">
              <span class="inquiry-category ${inq.category}">${categoryLabel[inq.category] || inq.category}</span>
              <span class="inquiry-date">${formatDate(inq.createdAt)}</span>
            </div>
            <div class="inquiry-subject">${escapeHtml(inq.subject)}</div>
            <div class="inquiry-meta">${escapeHtml(inq.email)}</div>
            <div class="inquiry-content">${escapeHtml(inq.content)}</div>
          </div>
        `,
        )
        .join('');
    }

    // ─── 공지 관리 ───

    function renderNoticeForm(notice?: Notice) {
      const isEdit = !!notice;
      return `
        <div class="notice-form" id="notice-form">
          <input type="text" id="nf-title" placeholder="공지 제목" maxlength="200" value="${notice ? escapeHtml(notice.title) : ''}" />
          <textarea id="nf-content" placeholder="공지 내용">${notice ? escapeHtml(notice.content) : ''}</textarea>
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.5rem;">
            <label style="font-size:0.82rem;display:flex;align-items:center;gap:0.4rem;">
              <input type="checkbox" id="nf-enabled" ${!notice || notice.enabled ? 'checked' : ''} /> 활성화
            </label>
            <label style="font-size:0.82rem;display:flex;align-items:center;gap:0.4rem;">
              순서 <input type="number" id="nf-sort-order" value="${notice?.sortOrder ?? 0}" min="0" style="width:60px;padding:0.25rem 0.4rem;border:1px solid var(--border-mid);border-radius:4px;font-size:0.82rem;background:var(--bg-input,var(--bg));color:var(--text);" />
            </label>
          </div>
          <div class="notice-form-actions">
            <button type="button" class="btn-primary-sm" id="nf-submit">${isEdit ? '수정' : '등록'}</button>
            <button type="button" class="btn-outline-sm" id="nf-cancel">취소</button>
          </div>
        </div>
      `;
    }

    async function loadNotices() {
      noticesPanel.innerHTML = '<p class="empty-msg">로딩 중...</p>';
      const notices = await fetchAllNotices();

      const listHtml = notices.length > 0
        ? notices.map((n) => `
          <div class="notice-card ${n.enabled ? '' : 'disabled'}">
            <div class="notice-header">
              <span class="notice-order-badge">#${n.sortOrder}</span>
              <span class="notice-title">${escapeHtml(n.title)}</span>
              <span class="notice-badge ${n.enabled ? 'active' : 'inactive'}">${n.enabled ? '활성' : '비활성'}</span>
            </div>
            <div class="notice-content">${escapeHtml(n.content)}</div>
            <div class="notice-footer">
              <span class="notice-date">${formatDate(n.createdAt)}</span>
              <div class="notice-actions">
                <button type="button" class="btn-toggle-sm move-notice-btn" data-id="${n.id}" data-dir="up" title="위로">▲</button>
                <button type="button" class="btn-toggle-sm move-notice-btn" data-id="${n.id}" data-dir="down" title="아래로">▼</button>
                <button type="button" class="btn-toggle-sm toggle-notice-btn" data-id="${n.id}" data-enabled="${n.enabled}">${n.enabled ? '비활성화' : '활성화'}</button>
                <button type="button" class="btn-outline-sm edit-notice-btn" data-id="${n.id}">수정</button>
                <button type="button" class="btn-danger-sm delete-notice-btn" data-id="${n.id}">삭제</button>
              </div>
            </div>
          </div>
        `).join('')
        : '<p class="empty-msg">등록된 공지가 없습니다.</p>';

      noticesPanel.innerHTML = `
        <button type="button" class="btn-primary-sm" id="new-notice-btn" style="margin-bottom:1rem;">새 공지 작성</button>
        <div id="notice-form-area"></div>
        <div id="notice-list">${listHtml}</div>
      `;

      // 새 공지 작성
      document.getElementById('new-notice-btn')!.addEventListener('click', () => {
        const area = document.getElementById('notice-form-area')!;
        if (area.querySelector('#notice-form')) return;
        area.innerHTML = renderNoticeForm();
        attachNoticeFormHandlers();
      });

      // 활성/비활성 토글
      for (const btn of noticesPanel.querySelectorAll<HTMLButtonElement>('.toggle-notice-btn')) {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id!;
          const enabled = btn.dataset.enabled === 'true';
          try {
            await updateNotice(id, { enabled: !enabled });
            await loadNotices();
          } catch { alert('상태 변경에 실패했습니다.'); }
        });
      }

      // 수정
      for (const btn of noticesPanel.querySelectorAll<HTMLButtonElement>('.edit-notice-btn')) {
        btn.addEventListener('click', () => {
          const id = btn.dataset.id!;
          const notice = notices.find((n) => n.id === id);
          if (!notice) return;
          const area = document.getElementById('notice-form-area')!;
          area.innerHTML = renderNoticeForm(notice);
          attachNoticeFormHandlers(notice.id);
        });
      }

      // 삭제
      for (const btn of noticesPanel.querySelectorAll<HTMLButtonElement>('.delete-notice-btn')) {
        btn.addEventListener('click', async () => {
          if (!confirm('이 공지를 삭제하시겠습니까?')) return;
          try {
            await deleteNotice(btn.dataset.id!);
            await loadNotices();
          } catch { alert('삭제에 실패했습니다.'); }
        });
      }

      // 순서 이동
      for (const btn of noticesPanel.querySelectorAll<HTMLButtonElement>('.move-notice-btn')) {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id!;
          const dir = btn.dataset.dir as 'up' | 'down';
          const idx = notices.findIndex((n) => n.id === id);
          if (idx < 0) return;
          const swapIdx = dir === 'up' ? idx - 1 : idx + 1;
          if (swapIdx < 0 || swapIdx >= notices.length) return;
          try {
            const a = notices[idx];
            const b = notices[swapIdx];
            await Promise.all([
              updateNotice(a.id, { sortOrder: b.sortOrder }),
              updateNotice(b.id, { sortOrder: a.sortOrder }),
            ]);
            await loadNotices();
          } catch { alert('순서 변경에 실패했습니다.'); }
        });
      }
    }

    function attachNoticeFormHandlers(editId?: string) {
      document.getElementById('nf-cancel')!.addEventListener('click', () => {
        document.getElementById('notice-form-area')!.innerHTML = '';
      });

      document.getElementById('nf-submit')!.addEventListener('click', async () => {
        const title = (document.getElementById('nf-title') as HTMLInputElement).value.trim();
        const content = (document.getElementById('nf-content') as HTMLTextAreaElement).value.trim();
        const enabled = (document.getElementById('nf-enabled') as HTMLInputElement).checked;
        const sortOrder = parseInt((document.getElementById('nf-sort-order') as HTMLInputElement).value, 10) || 0;
        if (!title || !content) { alert('제목과 내용을 입력해주세요.'); return; }

        try {
          if (editId) {
            await updateNotice(editId, { title, content, enabled, sortOrder });
          } else {
            await createNotice({ title, content, enabled, sortOrder });
          }
          await loadNotices();
        } catch { alert('저장에 실패했습니다.'); }
      });
    }

    // ─── 가계정 관리 ───

    async function loadDemoAccounts() {
      demoPanel.innerHTML = '<p class="empty-msg">로딩 중...</p>';
      let accounts: DemoAccount[];
      try {
        accounts = await fetchDemoAccounts();
      } catch {
        demoPanel.innerHTML = '<p class="empty-msg">가계정 목록을 불러올 수 없습니다.</p>';
        return;
      }

      const listHtml = accounts.length > 0
        ? accounts.map((acc) => `
          <div class="demo-card" data-id="${acc.id}">
            <div class="demo-avatar">
              ${acc.profileImageUrl
                ? `<img src="${escapeHtml(acc.profileImageUrl)}" alt="" />`
                : escapeHtml(acc.nickname.charAt(0))}
            </div>
            <div class="demo-info">
              <div class="demo-nickname">${escapeHtml(acc.nickname)}</div>
              ${acc.memo ? `<div class="demo-memo">${escapeHtml(acc.memo)}</div>` : ''}
              <div class="demo-date">${formatDate(acc.createdAt)}</div>
            </div>
            <div class="demo-actions">
              <button type="button" class="btn-outline-sm demo-edit-btn" data-id="${acc.id}">수정</button>
              <button type="button" class="btn-danger-sm demo-delete-btn" data-id="${acc.id}">삭제</button>
              <button type="button" class="btn-login-sm demo-login-btn" data-id="${acc.id}">이 계정으로 로그인</button>
            </div>
          </div>
        `).join('')
        : '<p class="empty-msg">등록된 가계정이 없습니다.</p>';

      demoPanel.innerHTML = `
        <div class="demo-form">
          <input type="text" id="demo-nickname" placeholder="닉네임 (필수)" maxlength="20" />
          <input type="text" id="demo-memo" placeholder="관리용 메모" maxlength="200" />
          <button type="button" class="btn-primary-sm" id="demo-create-btn">생성</button>
        </div>
        <div id="demo-list">${listHtml}</div>
      `;

      // 생성
      document.getElementById('demo-create-btn')!.addEventListener('click', async () => {
        const nickname = (document.getElementById('demo-nickname') as HTMLInputElement).value.trim();
        const memo = (document.getElementById('demo-memo') as HTMLInputElement).value.trim();
        if (!nickname) { alert('닉네임을 입력해주세요.'); return; }
        try {
          await createDemoAccount(nickname, memo || undefined);
          await loadDemoAccounts();
        } catch (e) { alert(e instanceof Error ? e.message : '생성에 실패했습니다.'); }
      });

      // 삭제
      for (const btn of demoPanel.querySelectorAll<HTMLButtonElement>('.demo-delete-btn')) {
        btn.addEventListener('click', async () => {
          if (!confirm('이 가계정을 삭제하시겠습니까?')) return;
          try {
            await deleteDemoAccount(btn.dataset.id!);
            await loadDemoAccounts();
          } catch (e) { alert(e instanceof Error ? e.message : '삭제에 실패했습니다.'); }
        });
      }

      // 로그인
      for (const btn of demoPanel.querySelectorAll<HTMLButtonElement>('.demo-login-btn')) {
        btn.addEventListener('click', async () => {
          if (!confirm('이 가계정으로 로그인하시겠습니까? 현재 세션이 교체됩니다.')) return;
          try {
            const tokens = await loginAsDemoAccount(btn.dataset.id!);
            saveTokens(tokens.accessToken, tokens.refreshToken);
            location.href = '/';
          } catch (e) { alert(e instanceof Error ? e.message : '로그인에 실패했습니다.'); }
        });
      }

      // 수정 (인라인 편집)
      for (const btn of demoPanel.querySelectorAll<HTMLButtonElement>('.demo-edit-btn')) {
        btn.addEventListener('click', () => {
          const id = btn.dataset.id!;
          const acc = accounts.find((a) => a.id === id);
          if (!acc) return;
          const card = demoPanel.querySelector<HTMLElement>(`.demo-card[data-id="${id}"]`);
          if (!card) return;

          // Replace info + actions with edit fields
          const avatar = card.querySelector('.demo-avatar')!.outerHTML;
          card.innerHTML = `
            ${avatar}
            <div class="demo-edit-fields">
              <input type="text" class="demo-edit-nickname" value="${escapeHtml(acc.nickname)}" placeholder="닉네임" maxlength="20" />
              <input type="text" class="demo-edit-memo" value="${acc.memo ? escapeHtml(acc.memo) : ''}" placeholder="관리용 메모" maxlength="200" />
            </div>
            <div class="demo-actions">
              <button type="button" class="btn-primary-sm demo-save-btn">저장</button>
              <button type="button" class="btn-outline-sm demo-cancel-btn">취소</button>
            </div>
          `;

          card.querySelector('.demo-save-btn')!.addEventListener('click', async () => {
            const nickname = (card.querySelector('.demo-edit-nickname') as HTMLInputElement).value.trim();
            const memo = (card.querySelector('.demo-edit-memo') as HTMLInputElement).value.trim();
            if (!nickname) { alert('닉네임을 입력해주세요.'); return; }
            try {
              await updateDemoAccount(id, { nickname, memo: memo || undefined });
              await loadDemoAccounts();
            } catch (e) { alert(e instanceof Error ? e.message : '수정에 실패했습니다.'); }
          });

          card.querySelector('.demo-cancel-btn')!.addEventListener('click', () => {
            loadDemoAccounts();
          });
        });
      }
    }

    // ─── 유저 관리 ───

    function renderUserCard(user: AdminUserInfo) {
      const isAdmin = user.role === 'admin';
      const roleLabel = isAdmin ? '어드민' : '일반 유저';
      const roleClass = isAdmin ? 'admin' : 'user';
      const btnClass = isAdmin ? 'revoke' : 'grant';
      const btnLabel = isAdmin ? '어드민 해제' : '어드민 지정';

      return `
        <div class="user-card" id="user-result-card">
          <div class="user-avatar">
            ${user.profileImageUrl
              ? `<img src="${escapeHtml(user.profileImageUrl)}" alt="" />`
              : escapeHtml(user.nickname.charAt(0))}
          </div>
          <div class="user-info">
            <div class="user-nickname">${escapeHtml(user.nickname)}</div>
            <div class="user-email">${escapeHtml(user.email)}</div>
            <span class="user-role-badge ${roleClass}">${roleLabel}</span>
            <div class="user-date">가입일: ${formatDate(user.createdAt)}</div>
          </div>
          <div class="user-actions">
            <button type="button" class="btn-admin-toggle ${btnClass}" id="user-role-toggle-btn"
              data-user-id="${user.id}" data-current-role="${user.role}">
              ${btnLabel}
            </button>
          </div>
        </div>
      `;
    }

    function initUsersTab() {
      usersPanel.innerHTML = `
        <div class="user-search-form">
          <input type="email" id="user-search-email" placeholder="이메일 주소를 정확히 입력하세요" />
          <button type="button" class="btn-primary-sm" id="user-search-btn">검색</button>
        </div>
        <div id="user-search-result"></div>
      `;

      const searchInput = document.getElementById('user-search-email') as HTMLInputElement;
      const searchBtn = document.getElementById('user-search-btn') as HTMLButtonElement;
      const resultArea = document.getElementById('user-search-result')!;

      async function doSearch() {
        const email = searchInput.value.trim();
        if (!email) {
          resultArea.innerHTML = '<p class="empty-msg">이메일을 입력해주세요.</p>';
          return;
        }

        resultArea.innerHTML = '<p class="empty-msg">검색 중...</p>';
        try {
          const user = await searchUserByEmail(email);
          resultArea.innerHTML = renderUserCard(user);
          attachRoleToggle(user);
        } catch (e) {
          resultArea.innerHTML = `<p class="empty-msg">${e instanceof Error ? escapeHtml(e.message) : '유저를 찾을 수 없습니다.'}</p>`;
        }
      }

      searchBtn.addEventListener('click', doSearch);
      searchInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') doSearch();
      });

      function attachRoleToggle(user: AdminUserInfo) {
        const toggleBtn = document.getElementById('user-role-toggle-btn');
        if (!toggleBtn) return;

        toggleBtn.addEventListener('click', async () => {
          const currentRole = toggleBtn.dataset.currentRole!;
          const newRole = currentRole === 'admin' ? 'user' : 'admin';
          const actionLabel = newRole === 'admin' ? '어드민으로 지정' : '어드민에서 해제';

          if (!confirm(`${escapeHtml(user.nickname)} 님을 ${actionLabel}하시겠습니까?`)) return;

          try {
            const updated = await updateUserRole(user.id, newRole);
            resultArea.innerHTML = renderUserCard(updated);
            attachRoleToggle(updated);
          } catch (e) {
            alert(e instanceof Error ? e.message : '권한 변경에 실패했습니다.');
          }
        });
      }
    }

    // ─── 게시판 관리 ───

    function renderBoardForm(board?: Board) {
      const isEdit = !!board;
      return `
        <div class="board-form" id="board-form">
          <input type="text" id="bf-name" placeholder="게시판 이름" maxlength="100" value="${board ? escapeHtml(board.name) : ''}" />
          <input type="text" id="bf-slug" placeholder="슬러그 (영문, 예: free)" maxlength="50" value="${board ? escapeHtml(board.slug) : ''}" ${isEdit ? 'readonly style="opacity:0.6;"' : ''} />
          <input type="text" id="bf-desc" placeholder="설명 (선택)" maxlength="200" value="${board?.description ? escapeHtml(board.description) : ''}" />
          <div class="board-form-row">
            <label style="font-size:0.82rem;display:flex;align-items:center;gap:0.4rem;">
              <input type="checkbox" id="bf-enabled" ${!board || board.enabled ? 'checked' : ''} /> 활성화
            </label>
            <label style="font-size:0.82rem;display:flex;align-items:center;gap:0.4rem;">
              순서 <input type="number" id="bf-sort-order" value="${board?.sortOrder ?? 0}" min="0" style="width:60px;padding:0.25rem 0.4rem;border:1px solid var(--border-mid);border-radius:4px;font-size:0.82rem;background:var(--bg-input,var(--bg));color:var(--text);" />
            </label>
            <label style="font-size:0.82rem;display:flex;align-items:center;gap:0.4rem;">
              인기글 기준 <input type="number" id="bf-popular-threshold" value="${board?.popularThreshold ?? 5}" min="1" style="width:60px;padding:0.25rem 0.4rem;border:1px solid var(--border-mid);border-radius:4px;font-size:0.82rem;background:var(--bg-input,var(--bg));color:var(--text);" title="추천 N개 이상이면 인기글로 표시" />
            </label>
          </div>
          <p style="font-size:0.72rem;color:var(--text-muted);margin:0 0 0.5rem;">인기글 기준: 추천 N개 이상 시 인기글 뱃지 표시</p>
          <div class="notice-form-actions">
            <button type="button" class="btn-primary-sm" id="bf-submit">${isEdit ? '수정' : '등록'}</button>
            <button type="button" class="btn-outline-sm" id="bf-cancel">취소</button>
          </div>
        </div>
      `;
    }

    async function loadBoardsAdmin() {
      boardsPanel.innerHTML = '<p class="empty-msg">로딩 중...</p>';
      let boards: Board[];
      try {
        boards = await fetchAllBoards();
      } catch {
        boardsPanel.innerHTML = '<p class="empty-msg">게시판 목록을 불러올 수 없습니다.</p>';
        return;
      }

      const listHtml = boards.length > 0
        ? boards.map((b) => `
          <div class="board-card-admin ${b.enabled ? '' : 'disabled'}">
            <div class="board-admin-header">
              <span class="board-admin-name">${escapeHtml(b.name)}</span>
              <span class="notice-badge ${b.enabled ? 'active' : 'inactive'}">${b.enabled ? '활성' : '비활성'}</span>
            </div>
            <div class="board-admin-slug">/${escapeHtml(b.slug)}</div>
            ${b.description ? `<div class="board-admin-desc">${escapeHtml(b.description)}</div>` : ''}
            <div class="board-admin-footer">
              <span class="board-admin-meta">순서: ${b.sortOrder} | ${formatDate(b.createdAt)}</span>
              <div class="board-admin-actions">
                <button type="button" class="btn-toggle-sm board-toggle-btn" data-id="${b.id}" data-enabled="${b.enabled}">${b.enabled ? '비활성화' : '활성화'}</button>
                <button type="button" class="btn-outline-sm board-edit-btn" data-id="${b.id}">수정</button>
                <button type="button" class="btn-danger-sm board-delete-btn" data-id="${b.id}" data-name="${escapeHtml(b.name)}">삭제</button>
              </div>
            </div>
          </div>
        `).join('')
        : '<p class="empty-msg">등록된 게시판이 없습니다.</p>';

      boardsPanel.innerHTML = `
        <button type="button" class="btn-primary-sm" id="new-board-btn" style="margin-bottom:1rem;">새 게시판</button>
        <div id="board-form-area"></div>
        <div id="board-list">${listHtml}</div>
      `;

      // 새 게시판
      document.getElementById('new-board-btn')!.addEventListener('click', () => {
        const area = document.getElementById('board-form-area')!;
        if (area.querySelector('#board-form')) return;
        area.innerHTML = renderBoardForm();
        attachBoardFormHandlers();
      });

      // 활성/비활성 토글
      for (const btn of boardsPanel.querySelectorAll<HTMLButtonElement>('.board-toggle-btn')) {
        btn.addEventListener('click', async () => {
          const id = btn.dataset.id!;
          const enabled = btn.dataset.enabled === 'true';
          try {
            await updateBoard(id, { enabled: !enabled });
            await loadBoardsAdmin();
          } catch { alert('상태 변경에 실패했습니다.'); }
        });
      }

      // 수정
      for (const btn of boardsPanel.querySelectorAll<HTMLButtonElement>('.board-edit-btn')) {
        btn.addEventListener('click', () => {
          const id = btn.dataset.id!;
          const board = boards.find((b) => b.id === id);
          if (!board) return;
          const area = document.getElementById('board-form-area')!;
          area.innerHTML = renderBoardForm(board);
          attachBoardFormHandlers(board.id);
        });
      }

      // 삭제 (게시판 이름 입력 확인)
      for (const btn of boardsPanel.querySelectorAll<HTMLButtonElement>('.board-delete-btn')) {
        btn.addEventListener('click', async () => {
          const boardName = btn.dataset.name || '';
          const input = prompt(`게시판 "${boardName}"을(를) 삭제하면 모든 게시글도 함께 삭제됩니다.\n\n확인하려면 게시판 이름을 입력하세요:`);
          if (input === null) return;
          if (input.trim() !== boardName) {
            alert('게시판 이름이 일치하지 않습니다.');
            return;
          }
          try {
            await deleteBoard(btn.dataset.id!);
            await loadBoardsAdmin();
          } catch { alert('삭제에 실패했습니다.'); }
        });
      }
    }

    function attachBoardFormHandlers(editId?: string) {
      document.getElementById('bf-cancel')!.addEventListener('click', () => {
        document.getElementById('board-form-area')!.innerHTML = '';
      });

      document.getElementById('bf-submit')!.addEventListener('click', async () => {
        const name = (document.getElementById('bf-name') as HTMLInputElement).value.trim();
        const slug = (document.getElementById('bf-slug') as HTMLInputElement).value.trim();
        const description = (document.getElementById('bf-desc') as HTMLInputElement).value.trim();
        const enabled = (document.getElementById('bf-enabled') as HTMLInputElement).checked;
        const sortOrder = parseInt((document.getElementById('bf-sort-order') as HTMLInputElement).value, 10) || 0;
        const popularThreshold = parseInt((document.getElementById('bf-popular-threshold') as HTMLInputElement).value, 10) || 5;

        if (!name) { alert('게시판 이름을 입력해주세요.'); return; }
        if (!editId && !slug) { alert('슬러그를 입력해주세요.'); return; }

        try {
          if (editId) {
            await updateBoard(editId, { name, description: description || undefined, enabled, sortOrder, popularThreshold });
          } else {
            await createBoard({ name, slug, description: description || undefined, enabled, sortOrder, popularThreshold });
          }
          await loadBoardsAdmin();
        } catch (e) { alert(e instanceof Error ? e.message : '저장에 실패했습니다.'); }
      });
    }

    // ─── 요구사항 관리 ───

    function renderRequestForm(): string {
      return `
        <div class="request-guide">
          <h3>요구사항 등록 안내</h3>
          <p>서비스에 추가하고 싶은 기능이나 수정이 필요한 부분을 등록해주세요.</p>
          <ul>
            <li><strong>제목</strong>: 어떤 기능인지 한 줄로 요약 (예: "커뮤니티에 이미지 첨부 기능")</li>
            <li><strong>상세 설명</strong>: 왜 필요한지, 어떻게 동작하면 좋겠는지 자유롭게 작성</li>
          </ul>
          <p>등록하면 개발팀에 자동으로 전달됩니다. 처리 상태는 아래 목록에서 확인할 수 있어요.</p>
          <p><span class="badge-open">open</span> = 검토 중 &nbsp; <span class="badge-closed">closed</span> = 완료</p>
        </div>
        <div class="request-form" id="request-form">
          <input type="text" id="rf-title" placeholder="요구사항 제목" maxlength="200" />
          <textarea id="rf-desc" placeholder="상세 설명 (왜 필요한지, 어떻게 동작하면 좋겠는지)"></textarea>
          <div class="notice-form-actions">
            <button type="button" class="btn-primary-sm" id="rf-submit">등록</button>
          </div>
        </div>
      `;
    }

    function renderRequestList(items: FeatureRequestItem[]): string {
      if (items.length === 0) return '<p class="empty-msg">등록된 요구사항이 없습니다.</p>';
      return items.map((item) => `
        <div class="request-card" data-issue="${item.id}">
          <div class="request-header">
            <span class="request-title"><a href="${item.url}" target="_blank" rel="noopener noreferrer">#${item.id} ${escapeHtml(item.title)}</a></span>
            <span class="request-state ${item.state}">${item.state === 'open' ? 'Open' : 'Closed'}</span>
          </div>
          <div class="request-date">${formatDate(item.createdAt)}</div>
          <div class="request-comments" id="rc-${item.id}">
            <button type="button" class="rc-toggle" data-issue="${item.id}">댓글 보기</button>
          </div>
        </div>
      `).join('');
    }

    async function loadFeatureRequestsTab() {
      requestsPanel.innerHTML = '<p class="empty-msg">로딩 중...</p>';
      try {
        const items = await fetchFeatureRequests();
        requestsPanel.innerHTML = renderRequestForm() + renderRequestList(items);
        bindRequestForm(items);
      } catch {
        requestsPanel.innerHTML = renderRequestForm() + '<p class="empty-msg">요구사항 목록을 불러올 수 없습니다.</p>';
        bindRequestForm([]);
      }
    }

    function bindRequestForm(_items: FeatureRequestItem[]) {
      const submitBtn = document.getElementById('rf-submit');
      if (!submitBtn) return;
      submitBtn.addEventListener('click', async () => {
        const titleInput = document.getElementById('rf-title') as HTMLInputElement | null;
        const descInput = document.getElementById('rf-desc') as HTMLTextAreaElement | null;
        if (!titleInput || !descInput) return;
        const title = titleInput.value.trim();
        const description = descInput.value.trim();
        if (!title) { alert('제목을 입력해주세요.'); return; }
        if (!description) { alert('상세 설명을 입력해주세요.'); return; }
        try {
          await createFeatureRequest(title, description);
          await loadFeatureRequestsTab();
        } catch (e) {
          alert(e instanceof Error ? e.message : '등록에 실패했습니다.');
        }
      });

      // 댓글 토글
      for (const btn of requestsPanel.querySelectorAll<HTMLButtonElement>('.rc-toggle')) {
        btn.addEventListener('click', async () => {
          const issueNum = parseInt(btn.dataset.issue || '0', 10);
          const container = document.getElementById(`rc-${issueNum}`);
          if (!container) return;

          if (container.dataset.loaded) {
            const detail = container.querySelector('.rc-detail');
            if (detail) { detail.remove(); btn.textContent = '댓글 보기'; container.dataset.loaded = ''; }
            return;
          }

          btn.textContent = '로딩 중...';
          try {
            const comments = await fetchRequestComments(issueNum);
            let html = '<div class="rc-detail">';
            if (comments.length > 0) {
              html += comments.map((c) => `
                <div class="rc-item">
                  <span class="rc-author">${escapeHtml(c.author)}</span>
                  <span class="rc-date">${formatDate(c.createdAt)}</span>
                  <div class="rc-body">${escapeHtml(c.body)}</div>
                </div>
              `).join('');
            } else {
              html += '<p class="rc-empty">댓글이 없습니다.</p>';
            }
            html += `<div class="rc-write">
              <input type="text" class="rc-input" placeholder="댓글 입력" maxlength="500" />
              <button type="button" class="btn-primary-sm rc-submit">작성</button>
            </div></div>`;
            container.insertAdjacentHTML('beforeend', html);
            container.dataset.loaded = 'true';
            btn.textContent = '댓글 닫기';

            const writeBtn = container.querySelector<HTMLButtonElement>('.rc-submit');
            const writeInput = container.querySelector<HTMLInputElement>('.rc-input');
            writeBtn?.addEventListener('click', async () => {
              const text = writeInput?.value.trim();
              if (!text) return;
              try {
                await addRequestComment(issueNum, text);
                container.dataset.loaded = '';
                const detail = container.querySelector('.rc-detail');
                if (detail) detail.remove();
                btn.click(); // reload
              } catch (e) {
                alert(e instanceof Error ? e.message : '댓글 작성에 실패했습니다.');
              }
            });
          } catch {
            btn.textContent = '댓글 보기';
          }
        });
      }
    }

    async function init() {
      const user = await fetchCurrentUser();

      if (!user || user.role !== 'admin') {
        loadingMsg.hidden = true;
        accessDenied.hidden = false;
        return;
      }

      loadingMsg.hidden = true;
      adminTabs.hidden = false;
      await loadStats();
    }

    init();
  }

  document.addEventListener('astro:page-load', initAdminPage);
</script>
