---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import { formatRating } from '@repo/utils';
import type { SharedRoomDetail } from '@repo/types';

const { code } = Astro.params;
const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';

let room: SharedRoomDetail | null = null;
let error = '';

try {
  const res = await fetch(`${API_BASE}/rooms/shared/${code}`);
  if (res.ok) {
    room = await res.json();
  } else {
    error = '유효하지 않은 공유 링크이거나, 비활성화된 링크입니다.';
  }
} catch {
  error = '서버에 연결할 수 없습니다.';
}

const title = room ? `${room.name}` : '공유된 맛집 리스트';
const description = room
  ? `${room.name} - ${room.restaurants.length}곳의 맛집 리스트`
  : '공유된 맛집 리스트를 확인하세요';

function escapeHtml(text: string): string {
  return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
---

<BaseLayout title={title} description={description}>
  <slot name="head">
    {room && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ItemList",
        "name": room.name,
        "description": `${room.name} - ${room.restaurants.length}곳의 맛집 리스트`,
        "url": (Astro.site ?? Astro.url.origin) + `/share/${code}`,
        "numberOfItems": room.restaurants.length,
        "itemListElement": room.restaurants.map((r, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "item": {
            "@type": "FoodEstablishment",
            "name": r.name,
            "address": r.address,
            "servesCuisine": r.category,
          },
        })),
      })} />
    )}
  </slot>
  <div id="share-page">
    {error && <p class="status-msg error">{error}</p>}

    {room && (
      <div id="share-content">
        <div class="share-header">
          <h1>{room.name}</h1>
          <span class="share-badge">공유된 맛집 리스트 · {room.restaurants.length}곳</span>
        </div>

        <div id="restaurant-detail-area"></div>

        {room.restaurants.length === 0 ? (
          <p class="empty-text">등록된 식당이 없습니다.</p>
        ) : (
          room.restaurants.map((r) => (
            <div class="share-restaurant-card" data-rid={r.id}>
              <div class="share-rest-name">{r.name}</div>
              <div class="share-rest-meta">{r.address} · {r.category}</div>
              <div class="share-rest-footer">
                <span class="share-rest-reviews-count">리뷰 {r.reviewCount}개</span>
              </div>
            </div>
          ))
        )}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .status-msg {
    text-align: center;
    padding: 3rem 1rem;
    color: #999;
    font-size: 0.9rem;
  }

  .status-msg.error {
    color: #dc2626;
  }
</style>

<style is:global>
  .share-header {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .share-header h1 {
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .share-header .share-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    font-size: 0.75rem;
    background: #f0f0f0;
    color: #666;
  }

  .share-restaurant-card {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.6rem;
    cursor: pointer;
    transition: border-color 0.15s;
  }

  .share-restaurant-card:hover { border-color: #ccc; }

  .share-rest-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #111;
    margin-bottom: 0.15rem;
  }

  .share-rest-meta {
    font-size: 0.8rem;
    color: #888;
  }

  .share-rest-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.35rem;
  }

  .share-rest-reviews-count {
    font-size: 0.75rem;
    color: #666;
  }

  .share-rest-detail {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .share-rest-detail h2 {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .share-rest-detail .detail-address {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 0.5rem;
  }

  .share-rest-detail .detail-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.8rem;
    color: #888;
  }

  .share-rest-detail .category-badge {
    background: #f0f0f0;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    font-size: 0.75rem;
    color: #555;
  }

  .detail-close-btn {
    float: right;
    padding: 0.3rem 0.6rem;
    background: #fff;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .detail-close-btn:hover { background: #f0f0f0; }

  .share-review-card {
    border-bottom: 1px solid #f0f0f0;
    padding: 0.6rem 0;
    font-size: 0.85rem;
  }

  .share-review-card:last-child { border-bottom: none; }

  .share-review-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.2rem;
  }

  .share-review-rating {
    color: #e6a817;
    font-weight: 600;
    font-size: 0.8rem;
  }

  .share-review-content {
    color: #444;
    line-height: 1.4;
  }

  .share-review-footer {
    margin-top: 0.2rem;
    font-size: 0.75rem;
    color: #999;
  }

  .empty-text {
    text-align: center;
    padding: 1.5rem;
    color: #999;
    font-size: 0.85rem;
  }
</style>

<script>
  import { fetchSharedRestaurantDetail } from '@/lib/api';
  import { formatRating, formatDate } from '@repo/utils';

  const shareCode = window.location.pathname.split('/share/')[1];

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  const renderStars = formatRating;

  function attachCardHandlers() {
    for (const card of document.querySelectorAll<HTMLElement>('.share-restaurant-card')) {
      card.addEventListener('click', () => {
        loadRestaurantDetail(card.dataset.rid!);
      });
    }
  }

  async function loadRestaurantDetail(rid: string) {
    const area = document.getElementById('restaurant-detail-area')!;
    area.innerHTML = '<p class="empty-text">로딩 중...</p>';

    try {
      const detail = await fetchSharedRestaurantDetail(shareCode, rid);
      const allReviews = detail.visits.flatMap((v) => v.reviews);

      const avgRating = allReviews.length > 0
        ? Math.round(allReviews.reduce((a, r) => a + r.rating, 0) / allReviews.length * 10) / 10
        : null;

      const sortedVisits = [...detail.visits].sort((a, b) => new Date(b.visitedAt).getTime() - new Date(a.visitedAt).getTime());

      let visitsHtml = '';
      if (sortedVisits.length === 0) {
        visitsHtml = '<p class="empty-text">아직 방문 기록이 없습니다.</p>';
      } else {
        visitsHtml = sortedVisits.map((visit) => {
          const reviewsHtml = visit.reviews.length > 0
            ? visit.reviews.map((rev) => {
                const detailRatings = [
                  rev.tasteRating != null ? `맛 ${rev.tasteRating}` : null,
                  rev.valueRating != null ? `가성비 ${rev.valueRating}` : null,
                  rev.serviceRating != null ? `서비스 ${rev.serviceRating}` : null,
                  rev.cleanlinessRating != null ? `청결 ${rev.cleanlinessRating}` : null,
                  rev.accessibilityRating != null ? `접근성 ${rev.accessibilityRating}` : null,
                ].filter(Boolean);
                const detailLine = detailRatings.length > 0 ? `<div style="font-size:0.72rem;color:#999;">${detailRatings.join(' · ')}</div>` : '';
                const menuLine = [
                  rev.favoriteMenu ? `또 먹고 싶은 메뉴: ${escapeHtml(rev.favoriteMenu)}` : null,
                  rev.tryNextMenu ? `다음에 시켜볼 메뉴: ${escapeHtml(rev.tryNextMenu)}` : null,
                ].filter(Boolean);
                const menuHtml = menuLine.length > 0 ? `<div style="font-size:0.72rem;color:#888;margin-top:0.15rem;">${menuLine.join(' | ')}</div>` : '';
                const revisitBadge = rev.wouldRevisit === false
                  ? '<span style="font-size:0.65rem;padding:0.1rem 0.3rem;border-radius:4px;background:#fee2e2;color:#991b1b;">재방문 X</span>'
                  : '<span style="font-size:0.65rem;padding:0.1rem 0.3rem;border-radius:4px;background:#dcfce7;color:#166534;">재방문 O</span>';
                return `
                  <div class="share-review-card">
                    <div class="share-review-header">
                      <span>${revisitBadge}</span>
                      <span class="share-review-rating">${renderStars(rev.rating)} ${rev.rating}</span>
                    </div>
                    ${detailLine}
                    <div class="share-review-content">${escapeHtml(rev.content)}</div>
                    ${menuHtml}
                    <div class="share-review-footer">${formatDate(rev.createdAt)}</div>
                  </div>
                `;
              }).join('')
            : '<p class="empty-text" style="padding:0.5rem;">리뷰 없음</p>';

          return `
            <div style="border:1px solid #e8e8e8;border-radius:8px;padding:0.75rem;margin-bottom:0.6rem;background:#fafafa;">
              <div style="font-size:0.8rem;font-weight:600;color:#333;margin-bottom:0.4rem;">
                ${formatDate(visit.visitedAt)}
                ${visit.memo ? `<span style="font-weight:400;color:#777;margin-left:0.5rem;">${escapeHtml(visit.memo)}</span>` : ''}
              </div>
              ${reviewsHtml}
            </div>
          `;
        }).join('');
      }

      area.innerHTML = `
        <div class="share-rest-detail">
          <button type="button" class="detail-close-btn" id="close-detail-btn">닫기</button>
          <h2>${escapeHtml(detail.name)}</h2>
          <div class="detail-address">${escapeHtml(detail.address)}</div>
          <div class="detail-meta">
            <span class="category-badge">${escapeHtml(detail.category)}</span>
            ${avgRating !== null ? `<span>${renderStars(Math.round(avgRating))} ${avgRating}</span>` : ''}
          </div>
          <div id="visits-list">${visitsHtml}</div>
        </div>
      `;

      document.getElementById('close-detail-btn')!.addEventListener('click', () => {
        area.innerHTML = '';
      });
    } catch {
      area.innerHTML = '<p class="empty-text">식당 정보를 불러올 수 없습니다.</p>';
    }
  }

  attachCardHandlers();
</script>
