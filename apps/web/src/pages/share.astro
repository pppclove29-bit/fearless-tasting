---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="공유된 맛집 리스트">
  <div id="share-page">
    <p id="loading-msg" class="status-msg">로딩 중...</p>
    <p id="error-msg" class="status-msg error" hidden></p>
    <div id="share-content" hidden></div>
  </div>
</BaseLayout>

<style>
  .status-msg {
    text-align: center;
    padding: 3rem 1rem;
    color: #999;
    font-size: 0.9rem;
  }

  .status-msg.error {
    color: #dc2626;
  }
</style>

<style is:global>
  .share-header {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .share-header h1 {
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .share-header .share-badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    font-size: 0.75rem;
    background: #f0f0f0;
    color: #666;
  }

  .share-restaurant-card {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.6rem;
    cursor: pointer;
    transition: border-color 0.15s;
  }

  .share-restaurant-card:hover { border-color: #ccc; }

  .share-rest-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #111;
    margin-bottom: 0.15rem;
  }

  .share-rest-meta {
    font-size: 0.8rem;
    color: #888;
  }

  .share-rest-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.35rem;
  }

  .share-rest-reviews-count {
    font-size: 0.75rem;
    color: #666;
  }

  /* 식당 상세 */
  .share-rest-detail {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .share-rest-detail h2 {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }

  .share-rest-detail .detail-address {
    font-size: 0.85rem;
    color: #666;
    margin-bottom: 0.5rem;
  }

  .share-rest-detail .detail-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.8rem;
    color: #888;
  }

  .share-rest-detail .category-badge {
    background: #f0f0f0;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    font-size: 0.75rem;
    color: #555;
  }

  .detail-close-btn {
    float: right;
    padding: 0.3rem 0.6rem;
    background: #fff;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    font-size: 0.8rem;
    cursor: pointer;
  }

  .detail-close-btn:hover { background: #f0f0f0; }

  .share-review-card {
    border-bottom: 1px solid #f0f0f0;
    padding: 0.6rem 0;
    font-size: 0.85rem;
  }

  .share-review-card:last-child { border-bottom: none; }

  .share-review-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.2rem;
  }

  .share-review-rating {
    color: #e6a817;
    font-weight: 600;
    font-size: 0.8rem;
  }

  .share-review-content {
    color: #444;
    line-height: 1.4;
  }

  .share-review-footer {
    margin-top: 0.2rem;
    font-size: 0.75rem;
    color: #999;
  }

  .empty-text {
    text-align: center;
    padding: 1.5rem;
    color: #999;
    font-size: 0.85rem;
  }
</style>

<script>
  import { fetchSharedRoom, fetchSharedRestaurantDetail } from '@/lib/api';
  import type { SharedRoomDetail, SharedRoomRestaurant, SharedRoomRestaurantDetail } from '@repo/types';

  const loadingMsg = document.getElementById('loading-msg')!;
  const errorMsg = document.getElementById('error-msg')!;
  const content = document.getElementById('share-content')!;

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function renderStars(rating: number): string {
    return '\u2605'.repeat(rating) + '\u2606'.repeat(5 - rating);
  }

  function formatDate(dateStr: string): string {
    return new Date(dateStr).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
  }

  let currentShareCode: string;
  let currentRoom: SharedRoomDetail;

  function renderPage() {
    let listHtml = '';
    if (currentRoom.restaurants.length === 0) {
      listHtml = '<p class="empty-text">등록된 식당이 없습니다.</p>';
    } else {
      listHtml = currentRoom.restaurants
        .map(
          (r) => `
          <div class="share-restaurant-card" data-rid="${r.id}">
            <div class="share-rest-name">${escapeHtml(r.name)}</div>
            <div class="share-rest-meta">${escapeHtml(r.address)} · ${escapeHtml(r.category)}</div>
            <div class="share-rest-footer">
              <span class="share-rest-reviews-count">리뷰 ${r.reviewCount}개</span>
            </div>
          </div>
        `,
        )
        .join('');
    }

    content.innerHTML = `
      <div class="share-header">
        <h1>${escapeHtml(currentRoom.name)}</h1>
        <span class="share-badge">공유된 맛집 리스트</span>
      </div>
      <div id="restaurant-detail-area"></div>
      ${listHtml}
    `;

    content.hidden = false;
    attachCardHandlers();
  }

  function attachCardHandlers() {
    for (const card of document.querySelectorAll<HTMLElement>('.share-restaurant-card')) {
      card.addEventListener('click', () => {
        loadRestaurantDetail(card.dataset.rid!);
      });
    }
  }

  async function loadRestaurantDetail(rid: string) {
    const area = document.getElementById('restaurant-detail-area')!;
    area.innerHTML = '<p class="empty-text">로딩 중...</p>';

    try {
      const detail = await fetchSharedRestaurantDetail(currentShareCode, rid);

      const avgRating = detail.reviews.length > 0
        ? Math.round(detail.reviews.reduce((a, r) => a + r.rating, 0) / detail.reviews.length * 10) / 10
        : null;

      let reviewsHtml = '';
      if (detail.reviews.length === 0) {
        reviewsHtml = '<p class="empty-text">아직 리뷰가 없습니다.</p>';
      } else {
        reviewsHtml = detail.reviews
          .map(
            (rev) => `
            <div class="share-review-card">
              <div class="share-review-header">
                <span class="share-review-rating">${renderStars(rev.rating)} ${rev.rating}</span>
              </div>
              <div class="share-review-content">${escapeHtml(rev.content)}</div>
              <div class="share-review-footer">${formatDate(rev.createdAt)}</div>
            </div>
          `,
          )
          .join('');
      }

      area.innerHTML = `
        <div class="share-rest-detail">
          <button type="button" class="detail-close-btn" id="close-detail-btn">닫기</button>
          <h2>${escapeHtml(detail.name)}</h2>
          <div class="detail-address">${escapeHtml(detail.address)}</div>
          <div class="detail-meta">
            <span class="category-badge">${escapeHtml(detail.category)}</span>
            ${avgRating !== null ? `<span>${renderStars(Math.round(avgRating))} ${avgRating}</span>` : ''}
          </div>
          <div id="reviews-list">${reviewsHtml}</div>
        </div>
      `;

      document.getElementById('close-detail-btn')!.addEventListener('click', () => {
        area.innerHTML = '';
      });
    } catch {
      area.innerHTML = '<p class="empty-text">식당 정보를 불러올 수 없습니다.</p>';
    }
  }

  // ─── 초기화 ───

  (async () => {
    const params = new URLSearchParams(location.search);
    const code = params.get('code');

    if (!code) {
      loadingMsg.hidden = true;
      errorMsg.textContent = '공유 코드가 없습니다.';
      errorMsg.hidden = false;
      return;
    }

    currentShareCode = code;

    try {
      currentRoom = await fetchSharedRoom(code);
      loadingMsg.hidden = true;
      renderPage();
    } catch {
      loadingMsg.hidden = true;
      errorMsg.textContent = '유효하지 않은 공유 링크이거나, 비활성화된 링크입니다.';
      errorMsg.hidden = false;
    }
  })();
</script>
