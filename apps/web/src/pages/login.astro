---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="로그인" description="카카오 계정으로 간편하게 로그인하세요">
  <div class="login-page">
    <h1>로그인</h1>
    <p class="login-desc">카카오 계정으로 간편하게 시작하세요.</p>

    <div id="login-ui" hidden>
      <a href=`${import.meta.env.PUBLIC_API_URL || 'http://localhost:4000'}/auth/kakao` class="kakao-btn">
        카카오로 시작하기
      </a>
    </div>

    <div class="login-success" id="login-success" hidden>
      <p>로그인 성공! 이동 중...</p>
    </div>
  </div>
</BaseLayout>

<style>
  .login-page {
    max-width: 400px;
    margin: 3rem auto;
    text-align: center;
    padding: 0 1rem;
  }

  h1 {
    margin-bottom: 0.5rem;
  }

  .login-desc {
    color: var(--text-sub);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .kakao-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: #FEE500;
    color: #191919;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .kakao-btn:hover {
    background: #F5DC00;
  }

  .login-success {
    margin-top: 1.5rem;
    padding: 1rem;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    color: #16a34a;
  }
</style>

<script>
  import { saveTokens } from '@/lib/api';

  const params = new URLSearchParams(location.search);
  const accessToken = params.get('access_token');
  const refreshToken = params.get('refresh_token');

  if (accessToken && refreshToken) {
    // 콜백: 토큰 저장 후 즉시 리다이렉트
    saveTokens(accessToken, refreshToken);
    history.replaceState(null, '', '/login');
    document.getElementById('login-success')!.hidden = false;

    const redirect = localStorage.getItem('login_redirect');
    localStorage.removeItem('login_redirect');
    location.href = redirect || '/';
  } else {
    // 로그인 페이지: 카카오 버튼 표시
    document.getElementById('login-ui')!.hidden = false;
  }
</script>
