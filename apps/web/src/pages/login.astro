---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="로그인" description="카카오 계정으로 간편하게 로그인하세요">
  <div class="login-page">
    <h1>로그인</h1>
    <p class="login-desc">카카오 계정으로 간편하게 시작하세요.</p>

    <a href=`${import.meta.env.PUBLIC_API_URL || 'http://localhost:4000'}/auth/kakao` class="kakao-btn" id="kakao-btn">
      카카오로 시작하기
    </a>

    <div class="login-success" id="login-success" hidden>
      <p>로그인 성공! 잠시 후 이동합니다.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .login-page {
    max-width: 400px;
    margin: 3rem auto;
    text-align: center;
    padding: 0 1rem;
  }

  h1 {
    margin-bottom: 0.5rem;
  }

  .login-desc {
    color: var(--text-sub);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .kakao-btn {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: #FEE500;
    color: #191919;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .kakao-btn:hover {
    background: #F5DC00;
  }

  .login-success {
    margin-top: 1.5rem;
    padding: 1rem;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 8px;
    color: #16a34a;
  }
</style>

<script>
  import { saveTokens } from '@/lib/api';

  const params = new URLSearchParams(location.search);
  const accessToken = params.get('access_token');
  const refreshToken = params.get('refresh_token');

  // 토큰이 없으면 바로 카카오 로그인으로 리다이렉트
  if (!accessToken || !refreshToken) {
    location.href = `${import.meta.env.PUBLIC_API_URL || 'http://localhost:4000'}/auth/kakao`;
  }

  if (accessToken && refreshToken) {
    saveTokens(accessToken, refreshToken);

    // URL에서 토큰 파라미터 제거 (히스토리에 남지 않도록)
    history.replaceState(null, '', '/login');

    const kakaoBtn = document.getElementById('kakao-btn')!;
    const successMsg = document.getElementById('login-success')!;
    kakaoBtn.hidden = true;
    successMsg.hidden = false;

    setTimeout(() => {
      const redirect = localStorage.getItem('login_redirect');
      localStorage.removeItem('login_redirect');
      location.href = redirect || '/';
    }, 1500);
  }
</script>
