  // ─── 멤버 탭 ───

  function renderMembersTab() {
    const panel = document.getElementById('tab-members')!;

    panel.innerHTML = `<div class="member-list">${currentRoom.members
      .map((m) => {
        let actionsHtml = '';
        if (isOwner() && m.userId !== currentUser.id) {
          actionsHtml = `
            <div class="member-actions">
              <select class="role-select" data-user-id="${m.userId}">
                <option value="manager" ${m.role === 'manager' ? 'selected' : ''}>매니저</option>
                <option value="member" ${m.role === 'member' ? 'selected' : ''}>멤버</option>
              </select>
              <button type="button" class="btn-outline-sm transfer-btn" data-user-id="${m.userId}">방장 위임</button>
              <button type="button" class="btn-danger-sm kick-btn" data-user-id="${m.userId}">강퇴</button>
            </div>
          `;
        }

        return `
          <div class="member-item">
            <div class="member-info">
              <span class="member-nickname">${escapeHtml(m.user.nickname)}</span>
              <span class="member-role-badge ${m.role}">${roleLabel[m.role]}</span>
            </div>
            ${actionsHtml}
          </div>
        `;
      })
      .join('')}</div>`;

    // 역할 변경
    for (const select of panel.querySelectorAll<HTMLSelectElement>('.role-select')) {
      select.addEventListener('change', async () => {
        const userId = select.dataset.userId!;
        try {
          await updateRoomMemberRole(currentRoom.id, userId, select.value);
          currentRoom = await fetchRoom(currentRoom.id);
          renderMembersTab();
        } catch { showToast('역할 변경에 실패했습니다.'); }
      });
    }

    // 강퇴
    for (const btn of panel.querySelectorAll<HTMLButtonElement>('.kick-btn')) {
      btn.addEventListener('click', async () => {
        if (!await showDangerConfirm('이 멤버를 강퇴하시겠습니까?', '강퇴')) return;
        const userId = btn.dataset.userId!;
        try {
          await kickRoomMember(currentRoom.id, userId);
          currentRoom = await fetchRoom(currentRoom.id);
          renderMembersTab();
        } catch { showToast('강퇴에 실패했습니다.'); }
