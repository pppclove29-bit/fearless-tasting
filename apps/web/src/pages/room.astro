    const restaurantsPanel = document.getElementById('tab-restaurants');
    const wishlistPanel = document.getElementById('tab-wishlist');
    const regionPanel = document.getElementById('tab-region');
    const statsPanel = document.getElementById('tab-stats');
    const membersPanel = document.getElementById('tab-members');
    if (!restaurantsPanel || !wishlistPanel || !regionPanel || !statsPanel || !membersPanel) return;
    const panels: Record<string, HTMLElement> = {
      restaurants: restaurantsPanel,
      wishlist: wishlistPanel,
      region: regionPanel,
      stats: statsPanel,
      members: membersPanel,
    };
