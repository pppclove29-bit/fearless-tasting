  async function initMainMap() {
    const container = document.getElementById('main-kakao-map');
    if (!container || !hasKakaoMap) return;

    const restaurantsWithCoords = currentRoom.restaurants.filter((r) => r.latitude != null && r.longitude != null);
    if (restaurantsWithCoords.length === 0) {
      const mapContainer = document.getElementById('main-map-container');
      if (mapContainer) mapContainer.hidden = true;
      return;
    }

    await loadKakaoMaps();
    const kakao = (window as Record<string, unknown>).kakao as Record<string, unknown>;
    const maps = kakao.maps as Record<string, unknown>;
    const LatLng = maps.LatLng as new (lat: number, lng: number) => unknown;
    const MapCtor = maps.Map as new (el: HTMLElement, opts: Record<string, unknown>) => Record<string, unknown>;
    const MarkerCtor = maps.Marker as new (opts: Record<string, unknown>) => Record<string, unknown>;
    const CustomOverlayCtor = maps.CustomOverlay as new (opts: Record<string, unknown>) => Record<string, unknown>;
    const MarkerClustererCtor = maps.MarkerClusterer as new (opts: Record<string, unknown>) => Record<string, unknown>;
    const LatLngBounds = maps.LatLngBounds as new () => Record<string, (pos: unknown) => void>;

    const center = new LatLng(restaurantsWithCoords[0].latitude!, restaurantsWithCoords[0].longitude!);
    const mainMap = new MapCtor(container, { center, level: 5 });

    const markers: Record<string, unknown>[] = [];
    let activeOverlay: Record<string, unknown> | null = null;
    let overlayClicked = false;

    // 노란 마커 이미지 (위시리스트용)
    const MarkerImageCtor = maps.MarkerImage as new (src: string, size: unknown, opts?: unknown) => unknown;
    const SizeCtor = maps.Size as new (w: number, h: number) => unknown;
    const PointCtor = maps.Point as new (x: number, y: number) => unknown;
    const wishlistMarkerSvg = encodeURIComponent('<svg xmlns="http://www.w3.org/2000/svg" width="28" height="40" viewBox="0 0 28 40"><path d="M14 0C6.3 0 0 6.3 0 14c0 10.5 14 26 14 26s14-15.5 14-26c0-7.7-6.3-14-14-14z" fill="#fbbf24" stroke="#78350f" stroke-width="1.5"/><circle cx="14" cy="14" r="5" fill="#fff"/></svg>');
    const wishlistMarkerImage = new MarkerImageCtor(
      `data:image/svg+xml;charset=utf-8,${wishlistMarkerSvg}`,
      new SizeCtor(28, 40),
      { offset: new PointCtor(14, 40) },
    );

    const clusterableMarkers: Record<string, unknown>[] = [];

    for (const r of restaurantsWithCoords) {
      const position = new LatLng(r.latitude!, r.longitude!);

      if (r.isWishlist) {
        // 위시리스트: 노란 마커, 클릭 불가, 클러스터링 제외
        const wishMarker = new MarkerCtor({ position, image: wishlistMarkerImage, clickable: false });
        (wishMarker as Record<string, (m: unknown) => void>).setMap(mainMap);
        markers.push(wishMarker);
        continue;
      }

      const marker = new MarkerCtor({ position });

      const ratingLine = r.avgRating !== null
        ? `<div style="color:#f59e0b;font-size:12px;">${svgStar} ${r.avgRating}</div>`
        : '';
      const overlayEl = document.createElement('div');
      const restUrl = `/room/restaurant?roomId=${currentRoom.id}&id=${r.id}`;
      overlayEl.innerHTML = `
        <a href="${restUrl}" style="display:block;text-decoration:none;color:inherit;background:var(--bg-card,#fff);border-radius:8px;padding:8px 12px;box-shadow:0 2px 8px rgba(0,0,0,0.25);min-width:100px;cursor:pointer;border:1px solid var(--border,#e8e8e8);">
          <div style="font-size:13px;font-weight:600;color:var(--text-heading,#111);margin-bottom:2px;">${escapeHtml(r.name)}</div>
          <div style="font-size:11px;color:var(--text-secondary,#888);">${escapeHtml(r.category || '')}</div>
          ${ratingLine}
        </a>
        <div style="width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-top:6px solid var(--bg-card,#fff);margin:0 auto;"></div>`;
      const overlay = new CustomOverlayCtor({ content: overlayEl, position, yAnchor: 1.3, clickable: true });

      const events = maps.event as Record<string, (t: unknown, e: string, cb: () => void) => void>;
      events.addListener(marker, 'click', () => {
        if (activeOverlay) (activeOverlay as Record<string, (m: unknown) => void>).setMap(null as unknown as never);
        (overlay as Record<string, (m: unknown) => void>).setMap(mainMap);
        activeOverlay = overlay;
      });

      clusterableMarkers.push(marker);
      markers.push(marker);
    }

    new MarkerClustererCtor({
      map: mainMap,
      markers: clusterableMarkers,
      gridSize: 60,
      minLevel: 2,
      minClusterSize: 2,
      styles: [{
        width: '36px', height: '36px',
        background: '#3b82f6',
        color: '#fff',
        borderRadius: '50%',
        textAlign: 'center',
        lineHeight: '36px',
        fontSize: '13px',
        fontWeight: '700',
        border: '2px solid #fff',
        boxShadow: '0 2px 6px rgba(0,0,0,0.3)',
      }],
    });

    // 모든 마커 포함하도록 범위 설정
    const bounds = new LatLngBounds();
    for (const r of restaurantsWithCoords) {
      bounds.extend(new LatLng(r.latitude!, r.longitude!));
    }
    if (restaurantsWithCoords.length > 1) {
      (mainMap as Record<string, (b: unknown) => void>).setBounds(bounds);
    }

    // 지도 클릭 시 오버레이 닫기 (오버레이 클릭 시에는 무시)
    const mapEvents = maps.event as Record<string, (t: unknown, e: string, cb: () => void) => void>;
    mapEvents.addListener(mainMap, 'click', () => {
      if (overlayClicked) { overlayClicked = false; return; }
      if (activeOverlay) {
        (activeOverlay as Record<string, (m: unknown) => void>).setMap(null as unknown as never);
        activeOverlay = null;
      }
    });

    // 내 위치
    let myLocationOverlay: Record<string, unknown> | null = null;
    let myLatLng: unknown = null;

    function showMyLocation() {
      if (!('geolocation' in navigator)) {
        showToast('이 브라우저에서는 위치 기능을 사용할 수 없습니다.');
        return;
      }
      const btn = document.getElementById('main-map-my-location');
      if (btn) btn.classList.add('active');

      navigator.geolocation.getCurrentPosition(
        (pos) => {
          myLatLng = new LatLng(pos.coords.latitude, pos.coords.longitude);
          if (!myLocationOverlay) {
            const myEl = document.createElement('div');
            myEl.innerHTML = '<div style="width:14px;height:14px;background:#4285F4;border:3px solid #fff;border-radius:50%;box-shadow:0 0 6px rgba(66,133,244,0.5);"></div>';
            myLocationOverlay = new CustomOverlayCtor({ map: mainMap, content: myEl, position: myLatLng, zIndex: 1 }) as Record<string, unknown>;
          } else {
            (myLocationOverlay as Record<string, (p: unknown) => void>).setPosition(myLatLng);
          }
          (mainMap as Record<string, (c: unknown) => void>).setCenter(myLatLng);
          (mainMap as Record<string, (l: number) => void>).setLevel(4);
        },
        (err) => {
          if (btn) btn.classList.remove('active');
          if (err.code === err.PERMISSION_DENIED) {
            showToast('위치 권한이 거부되었습니다. 브라우저 설정에서 허용해 주세요.');
          } else if (err.code === err.POSITION_UNAVAILABLE) {
            showToast('현재 위치를 확인할 수 없습니다.');
          } else if (err.code === err.TIMEOUT) {
            showToast('위치 확인 시간이 초과되었습니다.');
          }
        },
        { enableHighAccuracy: true, timeout: 10000 },
      );
    }

    // 유저 클릭 시에만 위치 요청 (자동 호출 시 브라우저가 조용히 거부할 수 있음)
    const myLocBtn = document.getElementById('main-map-my-location');
    myLocBtn?.addEventListener('click', showMyLocation);
  }

  function attachHeaderHandlers() {
    // 방 설정 모달
    const settingsBtn = document.getElementById('room-settings-btn');
    const settingsModal = document.getElementById('settings-modal');
    const settingsClose = document.getElementById('settings-modal-close');
    const settingsSave = document.getElementById('settings-save-btn');

    settingsBtn?.addEventListener('click', () => {
      if (settingsModal) settingsModal.hidden = false;
    });
    settingsClose?.addEventListener('click', () => {
      if (settingsModal) settingsModal.hidden = true;
    });
    settingsModal?.addEventListener('click', (e) => {
      if (e.target === settingsModal) settingsModal.hidden = true;
    });
    settingsSave?.addEventListener('click', async () => {
      const nameInput = document.getElementById('settings-name') as HTMLInputElement | null;
      const maxInput = document.getElementById('settings-max-members') as HTMLInputElement | null;
      const publicCb = document.getElementById('settings-public') as HTMLInputElement | null;
      const announcementInput = document.getElementById('settings-announcement') as HTMLTextAreaElement | null;
      const newName = nameInput?.value.trim();
      const newMax = maxInput ? parseInt(maxInput.value, 10) : undefined;
      const newPublic = publicCb?.checked;
      const newAnnouncement = announcementInput?.value.trim() || null;

      const updates: Record<string, unknown> = {};
      if (newName && newName !== currentRoom.name) updates.name = newName;
      if (newMax && newMax !== currentRoom.maxMembers) updates.maxMembers = newMax;
      if (newPublic !== undefined && newPublic !== currentRoom.isPublic) updates.isPublic = newPublic;
      if (newAnnouncement !== (currentRoom.announcement || null)) updates.announcement = newAnnouncement;

      if (Object.keys(updates).length === 0) {
        if (settingsModal) settingsModal.hidden = true;
        return;
      }

      try {
        await updateRoom(currentRoom.id, updates as { name?: string; maxMembers?: number; isPublic?: boolean; announcement?: string | null });
        currentRoom = await fetchRoom(currentRoom.id);
        if (settingsModal) settingsModal.hidden = true;
        renderPage();
        showToast('방 설정이 변경되었습니다.', 'success');
      } catch {
        showToast('방 설정 변경에 실패했습니다.');
      }
    });

    // 공유 팝오버
    const sharePopoverBtn = document.getElementById('share-popover-btn');
    const sharePopover = document.getElementById('share-popover');
    if (sharePopoverBtn && sharePopover) {
      sharePopoverBtn.addEventListener('click', () => {
        sharePopover.hidden = !sharePopover.hidden;
      });
      document.getElementById('share-popover-close')?.addEventListener('click', () => {
        sharePopover.hidden = true;
      });

      // 초대 링크 복사
      document.getElementById('copy-invite-btn')?.addEventListener('click', () => {
        const shareText = `🍽️ "${currentRoom.name}" 맛집 리스트에 초대합니다!\n우리만의 맛집을 함께 기록해요\n\n${getInviteLink()}`;
        navigator.clipboard.writeText(shareText);
        const btn = document.getElementById('copy-invite-btn');
        if (btn) { btn.textContent = '복사됨!'; setTimeout(() => { btn.textContent = '복사'; }, 1500); }
        showToast('초대 메시지가 복사되었습니다!', 'success');
      });

      // 카카오톡 공유
      document.getElementById('kakao-share-btn')?.addEventListener('click', () => {
        const kakao = (window as Record<string, unknown>).Kakao as Record<string, unknown> | undefined;
        if (!kakao) { showToast('카카오 SDK를 불러올 수 없습니다.'); return; }
        if (kakao.isInitialized && !(kakao.isInitialized as () => boolean)()) {
          const appKey = document.querySelector('meta[name="kakao-app-key"]')?.getAttribute('content');
          if (appKey) (kakao.init as (key: string) => void)(appKey);
        }
        if (kakao.Share) {
          const Share = kakao.Share as Record<string, (...args: unknown[]) => void>;
          Share.sendDefault({
            objectType: 'feed',
            content: {
              title: `"${currentRoom.name}" 맛집 리스트에 초대합니다!`,
              description: '우리만의 맛집을 함께 기록해요',
              imageUrl: `${location.origin}/og-image.png`,
              link: {
                webUrl: getInviteLink(),
                mobileWebUrl: getInviteLink(),
              },
            },
            buttons: [{
              title: '방 입장하기',
              link: {
                webUrl: getInviteLink(),
                mobileWebUrl: getInviteLink(),
              },
            }],
          });
        } else {
          showToast('카카오톡 공유 기능을 사용할 수 없습니다.');
        }
      });

      // 초대 코드 재생성
      document.getElementById('invite-regen-action')?.addEventListener('click', async () => {
        if (!await showConfirm('초대 링크를 재생성하시겠습니까? 기존 링크는 사용할 수 없게 됩니다.')) return;
        try {
          const result = await regenerateInviteCode(currentRoom.id);
          currentRoom.inviteCode = result.inviteCode;
          currentRoom.inviteCodeExpiresAt = result.inviteCodeExpiresAt;
          const urlInput = document.getElementById('share-invite-url') as HTMLInputElement | null;
          if (urlInput) urlInput.value = getInviteLink();
          showToast('초대 링크가 재생성되었습니다.', 'success');
        } catch { showToast('초대 링크 재생성에 실패했습니다.'); }
      });

      // 공개 방 토글
      const togglePublicCb = document.getElementById('toggle-public-cb') as HTMLInputElement | null;
      if (togglePublicCb) {
        togglePublicCb.addEventListener('change', async () => {
          const newValue = togglePublicCb.checked;
          try {
            const result = await toggleRoomPublic(currentRoom.id, newValue);
            currentRoom.isPublic = result.isPublic;
            togglePublicCb.checked = result.isPublic;
            showToast(result.isPublic ? '공개 방으로 설정되었습니다!' : '비공개로 전환되었습니다.', 'success');
          } catch {
            togglePublicCb.checked = !newValue;
            showToast('공개 설정 변경에 실패했습니다.');
          }
        });
      }

      // 최대 인원 변경
      const maxMembersInput = document.getElementById('max-members-input') as HTMLInputElement | null;
      if (maxMembersInput) {
        maxMembersInput.addEventListener('change', async () => {
          let newMax = parseInt(maxMembersInput.value, 10);
          const prevMax = currentRoom.maxMembers;
          if (isNaN(newMax) || newMax < currentRoom.members.length) newMax = currentRoom.members.length;
          if (newMax > 20) newMax = 20;
          maxMembersInput.value = String(newMax);
          if (newMax === prevMax) return;
          try {
            await updateRoom(currentRoom.id, { maxMembers: newMax });
            currentRoom.maxMembers = newMax;
            showToast(`최대 인원이 ${newMax}명으로 변경되었습니다.`, 'success');
          } catch {
            maxMembersInput.value = String(prevMax);
            showToast('최대 인원 변경에 실패했습니다.');
          }
        });
      }

      // 팝오버 외부 클릭 시 닫기
      document.addEventListener('click', (e) => {
        if (!sharePopover.hidden && !sharePopover.contains(e.target as Node) && !sharePopoverBtn.contains(e.target as Node)) {
          sharePopover.hidden = true;
        }
      });
    }

    document.getElementById('help-btn')?.addEventListener('click', showHelpModal);

    document.getElementById('delete-room-btn')?.addEventListener('click', async () => {
      const roomName = currentRoom.name;
      const input = prompt(`방을 삭제하면 모든 식당과 리뷰가 삭제됩니다.\n\n확인을 위해 방 이름 "${roomName}"을(를) 입력하세요.`);
      if (input === null) return;
      if (input.trim() !== roomName) {
        showToast('방 이름이 일치하지 않습니다.', 'info');
        return;
      }
      try {
        await deleteRoom(currentRoom.id);
        showToast('방이 삭제되었습니다.', 'success');
        location.href = '/';
      } catch { showToast('방 삭제에 실패했습니다.'); }
    });

    document.getElementById('leave-room-btn')?.addEventListener('click', async () => {
      if (!await showConfirm('방을 나가시겠습니까?')) return;
      try {
        await leaveRoom(currentRoom.id);
        location.href = '/';
      } catch (err) { showToast(err instanceof Error ? err.message : '방 나가기에 실패했습니다.'); }
    });
  }

