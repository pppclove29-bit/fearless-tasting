  function attachWishlistDrawerHandlers() {
    const openBtn = document.getElementById('wishlist-register-btn');
    const closeBtn = document.getElementById('close-wishlist-drawer');
    const overlay = document.getElementById('wishlist-drawer-overlay');
    const drawer = document.getElementById('wishlist-drawer');
    if (!openBtn || !drawer) return;

    const open = () => { drawer.classList.add('open'); overlay?.classList.add('open'); document.body.style.overflow = 'hidden'; };
    const close = () => { drawer.classList.remove('open'); overlay?.classList.remove('open'); document.body.style.overflow = ''; };

    openBtn.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    overlay?.addEventListener('click', close);
  }

  function attachWishlistSearchHandler() {
    const searchInput = document.getElementById('wl-rest-search') as HTMLInputElement | null;
    const results = document.getElementById('wl-address-results');
    const info = document.getElementById('wl-auto-filled-info');
    const nameEl = document.getElementById('wl-auto-filled-name');
    const addressEl = document.getElementById('wl-auto-filled-address');
    const categoryEl = document.getElementById('wl-auto-filled-category');
    const submitBtn = document.getElementById('wl-submit-btn') as HTMLButtonElement | null;
    if (!searchInput || !results || !info || !nameEl || !addressEl || !categoryEl || !submitBtn) return;

    let timer: ReturnType<typeof setTimeout> | null = null;
    searchInput.addEventListener('input', () => {
      if (timer) clearTimeout(timer);
      const q = searchInput.value.trim();
      if (!q || q.length < 2) { results.hidden = true; return; }
      timer = setTimeout(() => {
        const kakao = (window as Record<string, unknown>).kakao as { maps?: { services?: { Places: new () => { keywordSearch: (q: string, cb: (data: { place_name: string; address_name: string; road_address_name?: string; category_name?: string; category_group_name?: string; y: string; x: string }[], status: string) => void) => void }; Status: { OK: string } } } };
        if (!kakao?.maps?.services) {
          results.innerHTML = '<div class="rest-search-empty">카카오 지도를 사용할 수 없습니다.</div>';
          results.hidden = false;
          return;
        }
        const ps = new kakao.maps.services.Places();
        ps.keywordSearch(q, (data, status) => {
          if (status !== kakao.maps!.services!.Status.OK || data.length === 0) {
            results.innerHTML = '<div class="rest-search-empty">검색 결과가 없습니다.</div>';
            results.hidden = false;
            return;
          }
          results.innerHTML = data.slice(0, 8).map((p) =>
            `<button type="button" class="address-result-item" data-name="${escapeHtml(p.place_name)}" data-address="${escapeHtml(p.road_address_name || p.address_name)}" data-category="${escapeHtml(p.category_group_name || '기타')}" data-lat="${p.y}" data-lng="${p.x}">
              <div class="addr-name">${escapeHtml(p.place_name)}</div>
              <div class="addr-road">${escapeHtml(p.road_address_name || p.address_name)}</div>
            </button>`
          ).join('');
          results.hidden = false;
          for (const item of results.querySelectorAll<HTMLButtonElement>('.address-result-item')) {
            item.addEventListener('click', () => {
              const name = item.dataset.name || '';
              const address = item.dataset.address || '';
              const category = item.dataset.category || '기타';
              const lat = item.dataset.lat || '';
              const lng = item.dataset.lng || '';
              const parts = address.split(' ').filter(Boolean);
              const pMap: Record<string, string> = {
