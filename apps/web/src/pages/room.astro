    // ── 리뷰 안 쓴 방문 ──
    const unreviewedHtml = unreviewedVisits.length > 0 ? `
      <div class="stat-section">
        <h3 class="stat-section-title"><span class="stat-badge stat-badge-red">${unreviewedVisits.length}</span> 아직 리뷰를 안 쓴 방문</h3>
        ${unreviewedVisits.map((v) => `
          <div class="unreviewed-item">
            <span>${escapeHtml(v.restaurantName)}</span>
