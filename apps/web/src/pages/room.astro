    try {
      const result = await fetchRoomRestaurants(currentRoom.id, {
        page: restPage,
        pageSize: REST_PAGE_SIZE,
        search: searchQuery || undefined,
        category: activeCategory || undefined,
        sort: sortOrder,
        wishlist: false,
      });
      restData = result.data;
      restTotal = result.total;

      // 카테고리 필터 업데이트 (전체 식당 기준 — 검색/카테고리 무관하게)
