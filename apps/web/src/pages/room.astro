            <a href="/room/add?roomId=${currentRoom.id}" class="empty-state-cta">+ 식당 등록하기</a>
          </div>`;
      }
      return;
    }

    const totalPages = Math.ceil(restTotal / REST_PAGE_SIZE);
    const hasMore = restPage < totalPages;

    listEl.innerHTML = restData.map((r) => renderRestaurantCard(r)).join('')
      + (hasMore
