        : (restTotal > REST_PAGE_SIZE ? `<p class="rest-list-end">전체 ${restTotal}개</p>` : ''));

    attachRestaurantCardHandlers();

    document.getElementById('rest-load-more')?.addEventListener('click', async () => {
      restPage++;
