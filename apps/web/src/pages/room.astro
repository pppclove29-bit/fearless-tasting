  const shortProvinceMap: Record<string, string> = {
    '서울': '서울특별시', '부산': '부산광역시', '대구': '대구광역시',
    '인천': '인천광역시', '광주': '광주광역시', '대전': '대전광역시',
    '울산': '울산광역시', '세종': '세종특별자치시', '경기': '경기도',
    '강원': '강원특별자치도', '충북': '충청북도', '충남': '충청남도',
    '전북': '전북특별자치도', '전남': '전라남도', '경북': '경상북도',
    '경남': '경상남도', '제주': '제주특별자치도',
  };

  /** 주소 문자열에서 시/도, 시군구, 읍면동 자동 파싱 */
  function parseAddress(address: string): { province: string; city: string; neighborhood: string } {
    const parts = address.split(' ').filter(Boolean);
    const rawProvince = parts[0] || '';
    const province = shortProvinceMap[rawProvince] || rawProvince;
    return { province, city: parts[1] || '', neighborhood: parts[2] || '' };
  }

  function attachRestaurantFormHandler() {
    const btn = document.getElementById('add-rest-submit') as HTMLButtonElement | null;
    btn?.addEventListener('click', () => withLoading(btn, async () => {
      // 카카오/직접 입력 모드 판별: manual-form-area가 hidden이 아니면 직접 입력 모드
      const manualArea = document.getElementById('manual-form-area');
      const isManual = manualArea ? !manualArea.hidden : true;
      const formArea = isManual ? manualArea : document.getElementById('kakao-form-area');

      const nameEl = formArea?.querySelector<HTMLInputElement>('[id="add-rest-name"]') ?? document.getElementById('add-rest-name') as HTMLInputElement;
      const addressEl = formArea?.querySelector<HTMLInputElement>('[id="add-rest-address"]') ?? document.getElementById('add-rest-address') as HTMLInputElement;
      const categoryEl = formArea?.querySelector<HTMLInputElement>('[id="add-rest-category"]') ?? document.getElementById('add-rest-category') as HTMLInputElement;

      const name = nameEl.value.trim();
      const address = addressEl.value.trim();
      const category = categoryEl.value.trim();

      const missing: string[] = [];
      if (!name) missing.push('식당 이름');
      if (!address) missing.push('주소');
      if (!category) missing.push('카테고리');
      if (missing.length > 0) {
        showToast(`${missing.join(', ')}을(를) 입력해 주세요.`, 'info');
        return;
      }

      // hidden 필드에 값이 있으면 사용 (카카오), 없으면 주소에서 파싱 (수동)
      const provinceEl = (formArea?.querySelector<HTMLInputElement>('[id="add-rest-province"]') ?? document.getElementById('add-rest-province')) as HTMLInputElement;
      const cityEl = (formArea?.querySelector<HTMLInputElement>('[id="add-rest-city"]') ?? document.getElementById('add-rest-city')) as HTMLInputElement;
      const neighborhoodEl = (formArea?.querySelector<HTMLInputElement>('[id="add-rest-neighborhood"]') ?? document.getElementById('add-rest-neighborhood')) as HTMLInputElement;

      let province = provinceEl.value.trim();
      let city = cityEl.value.trim();
      let neighborhood = neighborhoodEl.value.trim();

      if (!province || !city || !neighborhood) {
        const parsed = parseAddress(address);
        province = parsed.province;
        city = parsed.city;
        neighborhood = parsed.neighborhood;
      } else {
        province = shortProvinceMap[province] || province;
      }

      if (!province || !city) {
        showToast('주소를 "시/도 시/군/구 읍/면/동 ..." 형식으로 입력해 주세요.', 'info');
        return;
      }

      const latEl = (formArea?.querySelector<HTMLInputElement>('[id="add-rest-lat"]') ?? document.getElementById('add-rest-lat')) as HTMLInputElement | null;
      const lngEl = (formArea?.querySelector<HTMLInputElement>('[id="add-rest-lng"]') ?? document.getElementById('add-rest-lng')) as HTMLInputElement | null;
      let latitude = latEl?.value ? Number(latEl.value) : undefined;
      let longitude = lngEl?.value ? Number(lngEl.value) : undefined;

      // 직접 입력 모드에서 좌표가 없으면 카카오 Geocoder로 주소 → 좌표 변환
      if (!latitude && !longitude && isManual && hasKakaoMap) {
        try {
          await loadKakaoMaps();
          const coords = await new Promise<{ lat: number; lng: number } | null>((resolve) => {
            const maps = (window as Record<string, unknown>).kakao as Record<string, unknown>;
            const geocoder = new ((maps.maps as Record<string, unknown>).services as Record<string, new () => Record<string, unknown>>).Geocoder();
            (geocoder as Record<string, (...args: unknown[]) => unknown>).addressSearch(address, (result: Array<{ y: string; x: string }>, status: string) => {
              if (status === 'OK' && result.length > 0) {
                resolve({ lat: Number(result[0].y), lng: Number(result[0].x) });
              } else {
                resolve(null);
              }
            });
          });
          if (coords) {
            latitude = coords.lat;
            longitude = coords.lng;
          }
        } catch { /* 좌표 변환 실패해도 등록은 진행 */ }
      }

      const isClosed = (document.getElementById('add-rest-closed') as HTMLInputElement)?.checked || false;
      await createRoomRestaurant(currentRoom.id, { name, address, province, city, neighborhood, category, latitude, longitude, isClosed } as Parameters<typeof createRoomRestaurant>[1]);
      currentRoom = await fetchRoom(currentRoom.id);
      restPage = 1;
      await renderRestaurantsTab();
      renderRegionTab();
      // 드로어 닫기
      const drawerEl = document.getElementById('add-rest-drawer');
      const overlayEl = document.getElementById('add-rest-overlay');
      drawerEl?.classList.remove('open');
      overlayEl?.classList.remove('open');
      document.body.style.overflow = '';
      showToast('식당이 등록되었습니다.', 'success');
    }).catch((err) => showToast(err instanceof Error ? err.message : '등록에 실패했습니다.')));
  }

  // ─── 카카오 장소 검색 (식당 등록 폼) ───

  let kakaoMapsLoaded = false;

  function loadKakaoMaps(): Promise<void> {
    if (kakaoMapsLoaded) return Promise.resolve();
    return new Promise((resolve) => {
      function tryLoad() {
        const kakao = (window as Record<string, unknown>).kakao as Record<string, unknown> | undefined;
        if (!kakao || !kakao.maps) { setTimeout(tryLoad, 100); return; }
        const maps = kakao.maps as Record<string, unknown>;
        (maps.load as (cb: () => void) => void)(() => {
          kakaoMapsLoaded = true;
          resolve();
        });
      }
      tryLoad();
    });
  }

  function attachPlaceSearchHandler() {
    const searchInput = document.getElementById('add-rest-search') as HTMLInputElement | null;
    const resultsDiv = document.getElementById('address-results');
    if (!searchInput || !resultsDiv) return;

    let debounceTimer: ReturnType<typeof setTimeout>;

    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      const keyword = searchInput.value.trim();
      if (keyword.length < 2) {
        resultsDiv.hidden = true;
        return;
      }
      debounceTimer = setTimeout(async () => {
        await loadKakaoMaps();
        const kakao = (window as Record<string, unknown>).kakao as Record<string, unknown>;
        const maps = kakao.maps as Record<string, unknown>;
        const services = maps.services as Record<string, new () => Record<string, unknown>>;
        const places = new services.Places();

        (places.keywordSearch as (keyword: string, cb: (data: Array<Record<string, string>>, status: string) => void, options: Record<string, string>) => void)(
          keyword,
          (data: Array<Record<string, string>>, status: string) => {
            const OK = ((maps.services as Record<string, Record<string, string>>).Status as Record<string, string>).OK;
            if (status !== OK || data.length === 0) {
              resultsDiv.hidden = true;
              return;
            }
            resultsDiv.innerHTML = data.slice(0, 15).map((place, i) => `
              <div class="address-result-item" data-idx="${i}" data-x="${place.x}" data-y="${place.y}">
                <div class="address-result-info">
                  <div class="address-result-name">${escapeHtml(place.place_name)}</div>
                  <div class="address-result-addr">${escapeHtml(place.address_name)}</div>
                </div>
                <div class="address-result-map" data-map-id="map-${i}"></div>
              </div>`).join('');
            resultsDiv.hidden = false;

            // 호버 시 SDK StaticMap 생성
            for (const item of resultsDiv.querySelectorAll<HTMLElement>('.address-result-item')) {
              let mapCreated = false;
              item.addEventListener('mouseenter', () => {
                if (mapCreated) return;
                mapCreated = true;
                const mapDiv = item.querySelector<HTMLElement>('.address-result-map');
                if (!mapDiv) return;
                const x = parseFloat(item.dataset.x || '0');
                const y = parseFloat(item.dataset.y || '0');
                const LatLng = maps.LatLng as new (lat: number, lng: number) => unknown;
                const center = new LatLng(y, x);
                const StaticMap = maps.StaticMap as new (container: HTMLElement, options: Record<string, unknown>) => unknown;
                const _Marker = (maps as Record<string, Record<string, unknown>>).Marker as Record<string, unknown>;
                new StaticMap(mapDiv, {
                  center,
                  level: 3,
                  marker: { position: center, text: '' },
                });
              });
              item.addEventListener('click', () => {
                const idx = Number(item.dataset.idx);
                const place = data[idx];
                fillFormFromPlace(place);
                resultsDiv.hidden = true;
                searchInput.value = '';
              });
            }
          },
          { category_group_code: 'FD6' },
        );
      }, 300);
    });

    // 외부 클릭 시 결과 닫기
    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('.address-search-wrap')) {
        resultsDiv.hidden = true;
      }
    });
  }

  function fillFormFromPlace(place: Record<string, string>) {
    const nameInput = document.getElementById('add-rest-name') as HTMLInputElement;
    const addressInput = document.getElementById('add-rest-address') as HTMLInputElement;
    const provinceInput = document.getElementById('add-rest-province') as HTMLInputElement;
    const cityInput = document.getElementById('add-rest-city') as HTMLInputElement;
    const neighborhoodInput = document.getElementById('add-rest-neighborhood') as HTMLInputElement;
    const categoryInput = document.getElementById('add-rest-category') as HTMLInputElement;
    const latInput = document.getElementById('add-rest-lat') as HTMLInputElement;
    const lngInput = document.getElementById('add-rest-lng') as HTMLInputElement;

    nameInput.value = place.place_name;
    addressInput.value = place.address_name;
    latInput.value = place.y;
    lngInput.value = place.x;

    const parsed = parseAddress(place.address_name);
    provinceInput.value = parsed.province;
    cityInput.value = parsed.city;
    neighborhoodInput.value = parsed.neighborhood;

    // 카카오 카테고리에서 마지막 카테고리 추출 (예: "음식점 > 한식 > 국밥" → "국밥")
    const catParts = (place.category_name || '').split(' > ');
    const lastCat = catParts[catParts.length - 1] || '';
    categoryInput.value = (lastCat && lastCat !== '음식점') ? lastCat : '음식점';

    // 요약 표시
    const infoEl = document.getElementById('auto-filled-info');
    const infoName = document.getElementById('auto-filled-name');
    const infoAddr = document.getElementById('auto-filled-address');
    const infoCat = document.getElementById('auto-filled-category');
    if (infoEl) {
      if (infoName) infoName.textContent = place.place_name;
      if (infoAddr) infoAddr.textContent = place.address_name;
      if (infoCat) infoCat.textContent = categoryInput.value;
      infoEl.hidden = false;
    }
  }

  // ─── 지역 탭 ───

  function calcRegionAvg(rests: typeof currentRoom.restaurants): string {
    const withRating = rests.filter((r) => r.avgRating !== null);
    if (withRating.length === 0) return '';
    const totalWeighted = withRating.reduce((s, r) => s + r.avgRating! * r._count.reviews, 0);
    const totalReviews = withRating.reduce((s, r) => s + r._count.reviews, 0);
    if (totalReviews === 0) return '';
    return (Math.round(totalWeighted / totalReviews * 10) / 10).toFixed(1);
  }

  function renderRegionTab() {
    const panel = document.getElementById('tab-region');
    if (!panel) return;
    const restaurants = currentRoom.restaurants;

    if (restaurants.length === 0) {
      panel.innerHTML = '<p class="empty-text">등록된 식당이 없습니다.</p>';
      return;
    }

    // 짧은 시/도 이름을 정식 이름으로 보정
    const provinceNormalizeMap: Record<string, string> = {
      '서울': '서울특별시', '부산': '부산광역시', '대구': '대구광역시',
      '인천': '인천광역시', '광주': '광주광역시', '대전': '대전광역시',
      '울산': '울산광역시', '세종': '세종특별자치시', '경기': '경기도',
      '강원': '강원특별자치도', '충북': '충청북도', '충남': '충청남도',
      '전북': '전북특별자치도', '전남': '전라남도', '경북': '경상북도',
      '경남': '경상남도', '제주': '제주특별자치도',
    };
    function normalizeProvince(p: string): string {
      return provinceNormalizeMap[p] || p;
    }
    // 식당 데이터의 province를 정규화
    for (const r of restaurants) {
      r.province = normalizeProvince(r.province);
    }

    const provinces = [...new Set(restaurants.map((r) => r.province).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'ko'));

    let selectedProvince: string | null = null;
    let selectedCity: string | null = null;
    let selectedNeighborhood: string | null = null;
    let sortBy = 'rating-high';

    function filterBy(province: string | null, city: string | null, neighborhood: string | null) {
      return restaurants.filter((r) => {
        if (province && r.province !== province) return false;
        if (city && r.city !== city) return false;
        if (neighborhood && r.neighborhood !== neighborhood) return false;
        return true;
      });
    }

    function getCities() {
      return [...new Set(filterBy(selectedProvince, null, null).map((r) => r.city).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'ko'));
    }

    function getNeighborhoods() {
      return [...new Set(filterBy(selectedProvince, selectedCity, null).map((r) => r.neighborhood).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'ko'));
    }

    function sortRestaurants(list: typeof restaurants) {
      const sorted = [...list];
      switch (sortBy) {
        case 'rating-high': return sorted.sort((a, b) => (b.avgRating ?? 0) - (a.avgRating ?? 0));
        case 'rating-low': return sorted.sort((a, b) => (a.avgRating ?? 0) - (b.avgRating ?? 0));
        case 'name': return sorted.sort((a, b) => a.name.localeCompare(b.name, 'ko'));
        case 'reviews': return sorted.sort((a, b) => b._count.reviews - a._count.reviews);
        case 'latest': return sorted.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());
        default: return sorted;
      }
    }

    let mapInitialized = false;

    function render() {
      const cities = selectedProvince ? getCities() : [];
      const neighborhoods = selectedCity ? getNeighborhoods() : [];
      const filtered = selectedProvince ? filterBy(selectedProvince, selectedCity, selectedNeighborhood) : [];

      let html = '<div class="region-tab">';

      // 시/도
      html += '<div class="region-depth"><span class="region-depth-label">시/도</span><div class="region-btns">';
      for (const p of provinces) {
        const avg = calcRegionAvg(filterBy(p, null, null));
        html += `<button type="button" class="region-btn ${selectedProvince === p ? 'active' : ''}" data-depth="province" data-val="${escapeHtml(p)}">${escapeHtml(p)}${avg ? ` <span class="region-avg">${svgStar}${avg}</span>` : ''}</button>`;
      }
      html += '</div></div>';

      // 시/군/구
      if (selectedProvince && cities.length > 0) {
        html += '<div class="region-depth"><span class="region-depth-label">시/군/구</span><div class="region-btns">';
        for (const c of cities) {
          const avg = calcRegionAvg(filterBy(selectedProvince, c, null));
          html += `<button type="button" class="region-btn ${selectedCity === c ? 'active' : ''}" data-depth="city" data-val="${escapeHtml(c)}">${escapeHtml(c)}${avg ? ` <span class="region-avg">${svgStar}${avg}</span>` : ''}</button>`;
        }
        html += '</div></div>';
      }

      // 읍/면/동
      if (selectedCity && neighborhoods.length > 0) {
        html += '<div class="region-depth"><span class="region-depth-label">읍/면/동</span><div class="region-btns">';
        for (const n of neighborhoods) {
          const avg = calcRegionAvg(filterBy(selectedProvince, selectedCity, n));
          html += `<button type="button" class="region-btn ${selectedNeighborhood === n ? 'active' : ''}" data-depth="neighborhood" data-val="${escapeHtml(n)}">${escapeHtml(n)}${avg ? ` <span class="region-avg">${svgStar}${avg}</span>` : ''}</button>`;
        }
        html += '</div></div>';
      }

      // 식당 목록
      if (selectedProvince) {
        const sorted = sortRestaurants(filtered);
        html += `<div class="region-list-header">`;
        html += `<span class="region-result-header">${sorted.length}개의 식당</span>`;
        if (sorted.length > 1) {
          const regionSortLabels: Record<string, string> = { 'rating-high': '평점 높은순', 'rating-low': '평점 낮은순', reviews: '리뷰 많은순', name: '이름순', latest: '최신순' };
          html += `<button type="button" class="sort-trigger-btn" id="region-sort-trigger">
            ${regionSortLabels[sortBy] || '평점 높은순'}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
          </button>`;
        }
        html += `</div>`;

        if (sorted.length > 0) {
          html += '<div class="region-restaurant-list">';
          for (const r of sorted) {
            const ratingStr = r.avgRating !== null ? `${renderStars(r.avgRating)} ${r.avgRating}` : '';
            const reviewCount = r._count.reviews;
            html += `
              <div class="region-rest-card" data-rid="${r.id}">
                <div class="region-rest-name">${escapeHtml(r.name)}</div>
                <div class="region-rest-meta">
                  <span class="category-badge">${escapeHtml(r.category || '')}</span>
                  ${ratingStr ? `<span class="region-rest-rating">${ratingStr}</span>` : ''}
                  <span class="region-rest-reviews">리뷰 ${reviewCount}개</span>
                </div>
                <div class="region-rest-addr">${escapeHtml(r.address)}</div>
              </div>`;
          }
          html += '</div>';
        }

        html += '<div id="region-detail-area"></div>';
      } else {
        html += '<p class="region-hint">시/도를 선택하면 해당 지역의 식당을 볼 수 있습니다.</p>';
      }

      html += '</div>';
      panel.innerHTML = html;

      // 지역 버튼 이벤트
      for (const btn of panel.querySelectorAll<HTMLButtonElement>('.region-btn')) {
        btn.addEventListener('click', () => {
          const depth = btn.dataset.depth!;
          const val = btn.dataset.val!;
          if (depth === 'province') {
            selectedProvince = selectedProvince === val ? null : val;
            selectedCity = null;
            selectedNeighborhood = null;
          } else if (depth === 'city') {
            selectedCity = selectedCity === val ? null : val;
            selectedNeighborhood = null;
          } else if (depth === 'neighborhood') {
            selectedNeighborhood = selectedNeighborhood === val ? null : val;
          }
          render();
        });
      }

      // 정렬 이벤트
      const regionSortBtn = document.getElementById('region-sort-trigger');
      regionSortBtn?.addEventListener('click', () => {
        const options = [
          { value: 'rating-high', label: '평점 높은순' },
          { value: 'rating-low', label: '평점 낮은순' },
          { value: 'reviews', label: '리뷰 많은순' },
          { value: 'name', label: '이름순' },
          { value: 'latest', label: '최신순' },
        ];
        openRoomSortSheet(options, sortBy, (val) => {
          sortBy = val;
          const label = options.find((o) => o.value === val)?.label || '평점 높은순';
          if (regionSortBtn) regionSortBtn.innerHTML = `${label} <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>`;
          render();
        });
      });

      // 식당 카드 클릭 → 상세
      for (const card of panel.querySelectorAll<HTMLElement>('.region-rest-card')) {
        card.addEventListener('click', () => {
          const rid = card.dataset.rid!;
          loadRestaurantDetail(rid, 'region-detail-area');
        });
      }

    }

    render();
  }

  // ─── 카카오맵 지도 탭 ───

  async function _renderMapTab() {
    const panel = document.getElementById('tab-map');
    if (!panel) return;

    const restaurantsWithCoords = currentRoom.restaurants.filter(
      (r) => r.latitude != null && r.longitude != null,
    );

    if (restaurantsWithCoords.length === 0) {
      panel.innerHTML = '<p class="map-no-data">좌표가 등록된 식당이 없습니다. 카카오 검색으로 식당을 등록하면 지도에 표시됩니다.</p>';
      return;
    }

    // 지역별 그룹핑
    const regionGroups = new Map<string, typeof restaurantsWithCoords>();
    for (const r of restaurantsWithCoords) {
      const region = r.neighborhood || r.city || '기타';
      const group = regionGroups.get(region);
      if (group) group.push(r);
      else regionGroups.set(region, [r]);
    }

    const regionBtns = regionGroups.size > 1
      ? `<div class="map-region-filters">
          <button type="button" class="map-region-btn active" data-region="all">전체 (${restaurantsWithCoords.length})</button>
          ${Array.from(regionGroups.entries()).map(([region, rests]) =>
            `<button type="button" class="map-region-btn" data-region="${escapeHtml(region)}">${escapeHtml(region)} (${rests.length})</button>`
          ).join('')}
        </div>`
      : '';

    panel.innerHTML = `${regionBtns}<div class="map-container"><div id="kakao-map"></div></div>`;

    await loadKakaoMaps();

    const kakao = (window as Record<string, unknown>).kakao as Record<string, unknown>;
    const maps = kakao.maps as Record<string, unknown>;
    const LatLng = maps.LatLng as new (lat: number, lng: number) => unknown;
    const MapConstructor = maps.Map as new (el: HTMLElement, opts: Record<string, unknown>) => Record<string, unknown>;
    const MarkerConstructor = maps.Marker as new (opts: Record<string, unknown>) => Record<string, unknown>;
    const CustomOverlayConstructor = maps.CustomOverlay as new (opts: Record<string, unknown>) => Record<string, unknown>;
    const LatLngBounds = maps.LatLngBounds as new () => Record<string, (pos: unknown) => void>;

    const container = document.getElementById('kakao-map');
    if (!container) return;
    const center = new LatLng(
      restaurantsWithCoords[0].latitude!,
      restaurantsWithCoords[0].longitude!,
    );

    const map = new MapConstructor(container, { center, level: 5 });

    let activeOverlay: Record<string, unknown> | null = null;
    let overlayClicked2 = false;
    const markerOverlayPairs: { marker: Record<string, unknown>; overlay: Record<string, unknown>; region: string }[] = [];

    for (const r of restaurantsWithCoords) {
      const position = new LatLng(r.latitude!, r.longitude!);
      const region = r.neighborhood || r.city || '기타';

      const marker = new MarkerConstructor({ map, position });

      const ratingLine = r.avgRating !== null
        ? `<div style="color:#f59e0b;font-size:12px;">${svgStar} ${r.avgRating} <span style="color:#999;font-size:11px;">(${r._count.reviews})</span></div>`
        : `<div style="color:#999;font-size:11px;">리뷰 없음</div>`;

      const overlayContent = document.createElement('div');
      overlayContent.className = 'map-overlay-card';
      const restUrl2 = `/room/restaurant?roomId=${currentRoom.id}&id=${r.id}`;
      overlayContent.innerHTML = `
        <a href="${restUrl2}" style="display:block;text-decoration:none;color:inherit;background:var(--bg-card,#fff);border-radius:8px;padding:8px 12px;box-shadow:0 2px 8px rgba(0,0,0,0.25);min-width:120px;cursor:pointer;border:1px solid var(--border,#e8e8e8);">
          <div style="font-size:13px;font-weight:600;color:var(--text-heading,#111);margin-bottom:2px;">${escapeHtml(r.name)}</div>
          <div style="font-size:11px;color:var(--text-secondary,#888);margin-bottom:3px;">${escapeHtml(r.category || '')}</div>
          ${ratingLine}
        </a>
        <div style="width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-top:6px solid var(--bg-card,#fff);margin:0 auto;"></div>
      `;

      const overlay = new CustomOverlayConstructor({
        content: overlayContent,
        position,
        yAnchor: 1.3,
        clickable: true,
      });

      const markerEvents = maps.event as Record<string, (target: unknown, type: string, cb: () => void) => void>;
      markerEvents.addListener(marker, 'click', () => {
        if (activeOverlay) {
          (activeOverlay as Record<string, () => void>).setMap(null as unknown as never);
        }
        (overlay as Record<string, (m: unknown) => void>).setMap(map);
        activeOverlay = overlay;
      });

      markerOverlayPairs.push({ marker, overlay, region });
    }

    // 지도 클릭 시 오버레이 닫기 (오버레이 클릭 시에는 무시)
    const mapEvents = maps.event as Record<string, (target: unknown, type: string, cb: () => void) => void>;
    mapEvents.addListener(map, 'click', () => {
      if (overlayClicked2) { overlayClicked2 = false; return; }
      if (activeOverlay) {
        (activeOverlay as Record<string, () => void>).setMap(null as unknown as never);
        activeOverlay = null;
      }
    });

    // 전체 마커 범위로 이동
    function fitBoundsToRegion(targetRegion: string | null) {
      const bounds = new LatLngBounds();
      let count = 0;

      for (const pair of markerOverlayPairs) {
        const show = !targetRegion || pair.region === targetRegion;
        (pair.marker as Record<string, (m: unknown) => void>).setMap(show ? map : null as unknown as never);
        if (pair.overlay === activeOverlay && !show) {
          (pair.overlay as Record<string, () => void>).setMap(null as unknown as never);
          activeOverlay = null;
        }
        if (show) {
          bounds.extend((pair.marker as Record<string, () => unknown>).getPosition());
          count++;
        }
      }

      if (count > 1) {
        (map as Record<string, (b: unknown) => void>).setBounds(bounds);
      } else if (count === 1) {
        for (const pair of markerOverlayPairs) {
          const show = !targetRegion || pair.region === targetRegion;
          if (show) {
            (map as Record<string, (c: unknown) => void>).setCenter((pair.marker as Record<string, () => unknown>).getPosition());
            (map as Record<string, (l: number) => void>).setLevel(4);
            break;
          }
        }
      }
    }

    fitBoundsToRegion(null);

    // 지역 필터 버튼 이벤트
    for (const btn of panel.querySelectorAll<HTMLElement>('.map-region-btn')) {
      btn.addEventListener('click', () => {
        panel.querySelector('.map-region-btn.active')?.classList.remove('active');
        btn.classList.add('active');
        const region = btn.dataset.region!;
        fitBoundsToRegion(region === 'all' ? null : region);
      });
    }
  }

  function attachRestaurantCardHandlers() {
    for (const card of document.querySelectorAll<HTMLElement>('.room-restaurant-card')) {
      card.addEventListener('click', (_e) => {
        const rid = card.dataset.rid!;
        location.href = `/room/restaurant?roomId=${currentRoom.id}&id=${rid}`;
      });
    }
  }


  // ─── 초기화 ───

  (async () => {
    const params = new URLSearchParams(location.search);
    const id = params.get('id');

    if (!id) {
      loadingMsg.hidden = true;
      errorMsg.textContent = '방 ID가 없습니다.';
      errorMsg.hidden = false;
      return;
    }

    try {
      const [user, room] = await Promise.all([
        fetchCurrentUser(),
        fetchRoom(id),
      ]);

      if (!user) {
        loadingMsg.hidden = true;
        errorMsg.textContent = '로그인이 필요합니다.';
        errorMsg.hidden = false;
        return;
      }

      currentUser = user;
      currentRoom = room;
      loadingMsg.hidden = true;
      renderPage();
    } catch (err) {
      console.error('[room] load failed:', err);
      loadingMsg.hidden = true;
      errorMsg.textContent = '방 정보를 불러올 수 없습니다.';
      errorMsg.hidden = false;
    }
  })();

  } // end initRoomPage

  document.addEventListener('astro:page-load', initRoomPage);
</script>
