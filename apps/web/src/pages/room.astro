  function renderNearestWishlistBanner() {
    const banner = document.getElementById('nearest-wishlist-banner');
    if (!banner || !navigator.geolocation) return;

    const withCoords = wishlistData.filter((r) => r.latitude != null && r.longitude != null);
    if (withCoords.length === 0) return;

    navigator.geolocation.getCurrentPosition(
      (pos) => {
        const { latitude: myLat, longitude: myLng } = pos.coords;
        const sorted = withCoords
          .map((r) => ({ r, dist: haversineKm(myLat, myLng, r.latitude!, r.longitude!) }))
          .sort((a, b) => a.dist - b.dist);
        const nearest = sorted[0];
        if (!nearest) return;
        const distText = nearest.dist < 1
          ? `${Math.round(nearest.dist * 1000)}m`
          : `${nearest.dist.toFixed(1)}km`;
        banner.innerHTML = `
          <a href="/room/restaurant?roomId=${currentRoom.id}&id=${nearest.r.id}" class="nearest-wishlist-card">
            <div class="nw-icon">📍</div>
            <div class="nw-info">
              <div class="nw-label">지금 위치에서 가까운 위시리스트</div>
              <div class="nw-name">${escapeHtml(nearest.r.name)}</div>
              <div class="nw-meta">${escapeHtml(nearest.r.category)} · ${distText}</div>
            </div>
            <div class="nw-arrow">›</div>
          </a>`;
        banner.hidden = false;
      },
      () => { /* 위치 거부 시 배너 미표시 */ },
      { timeout: 5000, maximumAge: 60000 },
    );
  }

