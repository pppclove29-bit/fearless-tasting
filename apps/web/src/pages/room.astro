    const memberHtml = memberStats.length > 0 ? `
      <div class="stat-section">
        <h3 class="stat-section-title">멤버 활동</h3>
        ${bestReviewer ? `<div style="margin-bottom:0.5rem;font-size:0.82rem;">
          ${mostGenerous && mostGenerous.avgRating !== null ? `<span class="stat-badge stat-badge-gold">가장 후한 평가</span> ${escapeHtml(mostGenerous.nickname)} (평균 ${mostGenerous.avgRating})&nbsp;&nbsp;` : ''}
          ${strictest && strictest.avgRating !== null && strictest.userId !== mostGenerous?.userId ? `<span class="stat-badge stat-badge-silver">가장 엄격한 평가</span> ${escapeHtml(strictest.nickname)} (평균 ${strictest.avgRating})` : ''}
        </div>` : ''}
        <table class="stat-table">
          <thead><tr><th>멤버</th><th class="num">방문</th><th class="num">리뷰</th><th class="num">평균</th><th class="num">재방문</th></tr></thead>
          <tbody>${memberStats.map((m) => `
