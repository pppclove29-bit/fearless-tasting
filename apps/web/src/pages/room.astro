  // ─── 통계 탭 ───

  const barColors = ['#1a1a1a','#333333','#4d4d4d','#666666','#808080','#999999','#b3b3b3','#cccccc','#e0e0e0','#f0f0f0'];

  function renderBarChart(entries: [string, number][]): string {
    if (entries.length === 0) return '';
    // 개수 내림차순 정렬
    const sorted = [...entries].sort((a, b) => b[1] - a[1]);
    const max = Math.max(...sorted.map(([, c]) => c));
    return sorted.map(([label, count], i) => {
      const pct = Math.round((count / max) * 100);
      const color = barColors[i % barColors.length];
      return `<div class="stat-bar-row">
        <span class="stat-bar-label">${escapeHtml(label)}</span>
        <div class="stat-bar-track"><div class="stat-bar-fill" style="width:${pct}%;background:${color}"></div></div>
        <span class="stat-bar-count">${count}</span>
      </div>`;
    }).join('');
  }

  function renderRadarChart(values: Record<string, number | null>): string {
    const labels: Record<string, string> = {
      tasteRating: '맛', valueRating: '가성비', serviceRating: '서비스',
      cleanlinessRating: '청결', accessibilityRating: '접근성',
    };
    const keys = Object.keys(labels);
    const vals = keys.map((k) => values[k] ?? 0);
    if (vals.every((v) => v === 0)) return '<p style="text-align:center;color:#999;font-size:0.82rem;">세부 평점 데이터가 아직 없습니다.</p>';

    const cx = 120, cy = 120, r = 90;
    const n = keys.length;
    const angleStep = (2 * Math.PI) / n;
    const offset = -Math.PI / 2;

    const isDark = document.documentElement.classList.contains('dark');
    const gridColor = isDark ? 'rgba(255,255,255,0.15)' : '#e8e8e8';
    const labelColor = isDark ? 'rgba(255,255,255,0.6)' : '#666';
    const polyStroke = isDark ? '#cccccc' : '#333333';
    const polyFill = isDark ? 'rgba(204,204,204,0.2)' : 'rgba(51,51,51,0.12)';
    const dotColor = isDark ? '#e0e0e0' : '#333333';

    // 그리드 원
    const gridCircles = [1, 2, 3, 4, 5].map((lv) => {
      const gr = (lv / 5) * r;
      return `<circle cx="${cx}" cy="${cy}" r="${gr}" fill="none" stroke="${gridColor}" stroke-width="0.5"/>`;
    }).join('');

    // 축선 + 라벨
    const axes = keys.map((k, i) => {
      const angle = offset + i * angleStep;
      const x2 = cx + r * Math.cos(angle);
      const y2 = cy + r * Math.sin(angle);
      const lx = cx + (r + 16) * Math.cos(angle);
      const ly = cy + (r + 16) * Math.sin(angle);
      return `<line x1="${cx}" y1="${cy}" x2="${x2}" y2="${y2}" stroke="${gridColor}" stroke-width="0.5"/>
        <text x="${lx}" y="${ly}" text-anchor="middle" dominant-baseline="central" font-size="10" fill="${labelColor}">${labels[k]}</text>`;
    }).join('');

    // 데이터 폴리곤
    const points = vals.map((v, i) => {
      const angle = offset + i * angleStep;
      const dr = (v / 5) * r;
      return `${cx + dr * Math.cos(angle)},${cy + dr * Math.sin(angle)}`;
    }).join(' ');

    // 점
    const dots = vals.map((v, i) => {
      const angle = offset + i * angleStep;
      const dr = (v / 5) * r;
      return `<circle cx="${cx + dr * Math.cos(angle)}" cy="${cy + dr * Math.sin(angle)}" r="3" fill="${dotColor}"/>`;
    }).join('');

    return `<div class="radar-chart">
      <svg viewBox="0 0 240 240" width="240" height="240">
        ${gridCircles}${axes}
        <polygon points="${points}" fill="${polyFill}" stroke="${polyStroke}" stroke-width="1.5"/>
        ${dots}
      </svg>
    </div>`;
  }

  async function renderStatsTab() {
    const panel = document.getElementById('tab-stats');
    if (!panel) return;
    const restaurants = currentRoom.restaurants;

    if (restaurants.length === 0) {
      panel.innerHTML = `<div class="empty-state"><div class="empty-state-icon">&#x1F4CA;</div><div class="empty-state-title">아직 통계 데이터가 없어요</div><div class="empty-state-desc">식당을 추가하고 리뷰를 남기면<br/>방 통계를 확인할 수 있어요</div></div>`;
      return;
    }

    panel.innerHTML = '<p class="empty-text">통계를 불러오는 중...</p>';

    let stats: RoomStats;
    try {
      stats = await fetchRoomStats(currentRoom.id);
    } catch (err) {
      console.error('[stats] fetchRoomStats failed:', err);
      panel.innerHTML = '<p class="empty-text">통계를 불러올 수 없습니다. 새로고침 후 다시 시도해주세요.</p>';
      return;
    }

    const { summary, memberStats, categoryStats, regionStats, detailRatingAvg,
