      return;
    }

    const iconMap: Record<string, { emoji: string; cls: string }> = {
      restaurant_added: { emoji: '🍽', cls: 'restaurant' },
      visit_added: { emoji: '👣', cls: 'visit' },
      review_added: { emoji: '⭐', cls: 'review' },
      member_joined: { emoji: '👤', cls: 'member' },
    };
    const defaultIcon = { emoji: '📌', cls: 'restaurant' };

    const getUserName = (d: Record<string, unknown>): string => {
      const user = d.user as { nickname?: string } | null;
      return user?.nickname || '';
    };

    const descMap: Record<string, (data: Record<string, unknown>) => string> = {
      restaurant_added: (d) => `<strong>${escapeHtml(getUserName(d))}</strong>님이 새로운 식당을 등록했습니다.`,
      visit_added: (d) => `<strong>${escapeHtml(getUserName(d))}</strong>님이 식당을 방문했습니다.`,
      review_added: (d) => `<strong>${escapeHtml(getUserName(d))}</strong>님이 리뷰를 작성했습니다.`,
      member_joined: (d) => `<strong>${escapeHtml(getUserName(d))}</strong>님이 새로운 멤버를 초대했습니다.`,
    };

    const subMap: Record<string, (data: Record<string, unknown>) => string> = {
      restaurant_added: (d) => `${escapeHtml(String(d.restaurantName || ''))}`,
      visit_added: (d) => `${escapeHtml(String(d.restaurantName || ''))}`,
      review_added: (d) => `${escapeHtml(String(d.restaurantName || ''))}${d.content ? ` — "${escapeHtml(String(d.content))}"` : ''}`,
      member_joined: (d) => {
        const u = d.user as { nickname?: string } | null;
        return u?.nickname ? `${escapeHtml(u.nickname)}님이 방에 참여했습니다.` : '';
      },
    };

    const timelineHtml = items.map((item) => {
      const rid = item.data.restaurantId as string | undefined;
      const tag = rid ? 'a' : 'div';
      const href = rid ? ` href="/room/restaurant?roomId=${currentRoom.id}&id=${rid}"` : '';
      const ic = iconMap[item.type] || defaultIcon;
      const sub = (subMap[item.type] || (() => ''))(item.data);
      return `
      <${tag}${href} class="timeline-item${rid ? ' timeline-link' : ''}">
        <div class="timeline-icon timeline-icon--${ic.cls}">${ic.emoji}</div>
        <div class="timeline-body">
          <div class="timeline-desc">${(descMap[item.type] || (() => item.type))(item.data)}</div>
          ${sub ? `<div class="timeline-sub">${sub}</div>` : ''}
        </div>
        <span class="timeline-date">${formatDate(item.date)}</span>
      </${tag}>`;
    }).join('');

    panel.innerHTML = `<div class="timeline-list">${timelineHtml}</div>`;
  }

