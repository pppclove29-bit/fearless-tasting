    // 방장 위임
    for (const btn of panel.querySelectorAll<HTMLButtonElement>('.transfer-btn')) {
      btn.addEventListener('click', async () => {
        if (!await showConfirm('이 멤버에게 방장을 위임하시겠습니까? 본인은 일반 멤버가 됩니다.')) return;
        const userId = btn.dataset.userId!;
        try {
          await transferOwnership(currentRoom.id, userId);
          currentRoom = await fetchRoom(currentRoom.id);
          renderPage();
        } catch { showToast('방장 위임에 실패했습니다.'); }
      });
    }
  }

  // ─── 통계 탭 ───

  function renderBarChart(entries: [string, number][]): string {
    if (entries.length === 0) return '';
    const max = Math.max(...entries.map(([, c]) => c));
    return entries.map(([label, count]) => {
      const pct = Math.round((count / max) * 100);
      return `<div class="stat-bar-row">
        <span class="stat-bar-label">${escapeHtml(label)}</span>
        <div class="stat-bar-track"><div class="stat-bar-fill" style="width:${pct}%"></div></div>
        <span class="stat-bar-count">${count}</span>
      </div>`;
    }).join('');
  }

  function renderRadarChart(values: Record<string, number | null>): string {
    const labels: Record<string, string> = {
      tasteRating: '맛', valueRating: '가성비', serviceRating: '서비스',
      cleanlinessRating: '청결', accessibilityRating: '접근성',
    };
    const keys = Object.keys(labels);
    const vals = keys.map((k) => values[k] ?? 0);
    if (vals.every((v) => v === 0)) return '<p style="text-align:center;color:#999;font-size:0.82rem;">세부 평점 데이터가 아직 없습니다.</p>';

    const cx = 120, cy = 120, r = 90;
    const n = keys.length;
    const angleStep = (2 * Math.PI) / n;
    const offset = -Math.PI / 2;

    // 그리드 원
    const gridCircles = [1, 2, 3, 4, 5].map((lv) => {
      const gr = (lv / 5) * r;
      return `<circle cx="${cx}" cy="${cy}" r="${gr}" fill="none" stroke="#e8e8e8" stroke-width="0.5"/>`;
    }).join('');

    // 축선 + 라벨
    const axes = keys.map((k, i) => {
      const angle = offset + i * angleStep;
      const x2 = cx + r * Math.cos(angle);
      const y2 = cy + r * Math.sin(angle);
      const lx = cx + (r + 16) * Math.cos(angle);
      const ly = cy + (r + 16) * Math.sin(angle);
      return `<line x1="${cx}" y1="${cy}" x2="${x2}" y2="${y2}" stroke="#e8e8e8" stroke-width="0.5"/>
        <text x="${lx}" y="${ly}" text-anchor="middle" dominant-baseline="central" font-size="10" fill="#666">${labels[k]}</text>`;
    }).join('');

    // 데이터 폴리곤
    const points = vals.map((v, i) => {
      const angle = offset + i * angleStep;
      const dr = (v / 5) * r;
      return `${cx + dr * Math.cos(angle)},${cy + dr * Math.sin(angle)}`;
    }).join(' ');

    // 점
    const dots = vals.map((v, i) => {
      const angle = offset + i * angleStep;
      const dr = (v / 5) * r;
      return `<circle cx="${cx + dr * Math.cos(angle)}" cy="${cy + dr * Math.sin(angle)}" r="3" fill="#111"/>`;
    }).join('');

    return `<div class="radar-chart">
      <svg viewBox="0 0 240 240" width="240" height="240">
        ${gridCircles}${axes}
        <polygon points="${points}" fill="rgba(17,17,17,0.1)" stroke="#111" stroke-width="1.5"/>
        ${dots}
      </svg>
    </div>`;
  }

  async function renderStatsTab() {
    const panel = document.getElementById('tab-stats')!;
    const restaurants = currentRoom.restaurants;

    if (restaurants.length === 0) {
      panel.innerHTML = '<p class="empty-text">아직 등록된 식당이 없습니다. 식당을 추가하면 통계를 확인할 수 있습니다.</p>';
