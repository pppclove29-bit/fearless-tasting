    if (timelinePanel) panels.timeline = timelinePanel;

    let wishlistLoaded = false;
    for (const btn of document.querySelectorAll<HTMLButtonElement>('.room-tab-btn')) {
      btn.addEventListener('click', () => {
        for (const b of document.querySelectorAll('.room-tab-btn')) b.classList.remove('active');
