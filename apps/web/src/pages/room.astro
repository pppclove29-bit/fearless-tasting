  function attachHeaderHandlers() {
    // 방 이름 수정 (owner만)
    const editNameBtn = document.getElementById('edit-name-btn');
    const nameDisplay = document.getElementById('room-name-display');
    const nameInput = document.getElementById('room-name-input') as HTMLInputElement | null;

    if (editNameBtn && nameDisplay && nameInput) {
      editNameBtn.addEventListener('click', () => {
        nameInput.value = currentRoom.name;
        nameDisplay.hidden = true;
        editNameBtn.hidden = true;
        nameInput.hidden = false;
        nameInput.focus();
        nameInput.select();
      });

      async function saveName() {
        if (!nameInput || !nameDisplay || !editNameBtn) return;
        const newName = nameInput.value.trim();
        nameInput.hidden = true;
        nameDisplay.hidden = false;
        editNameBtn.hidden = false;

        if (!newName || newName === currentRoom.name) return;

        try {
          await updateRoom(currentRoom.id, newName);
          currentRoom.name = newName;
          nameDisplay.textContent = newName;
        } catch {
          showToast('방 이름 변경에 실패했습니다.');
        }
      }

      nameInput.addEventListener('blur', saveName);
      nameInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter') { e.preventDefault(); nameInput.blur(); }
        if (e.key === 'Escape') {
          nameInput.hidden = true;
          nameDisplay!.hidden = false;
          editNameBtn!.hidden = false;
        }
      });
    }

    function getInviteLink() {
      return `${location.origin}/join?code=${currentRoom.inviteCode}`;
    }

    document.getElementById('copy-link-btn')?.addEventListener('click', () => {
      navigator.clipboard.writeText(getInviteLink());
      const btn = document.getElementById('copy-link-btn')!;
      const original = btn.innerHTML;
      btn.textContent = '복사됨!';
      setTimeout(() => { btn.innerHTML = original; }, 1500);
    });

    document.getElementById('help-btn')?.addEventListener('click', showHelpModal);

    document.getElementById('share-invite-btn')?.addEventListener('click', () => {
      navigator.share({
        title: `${currentRoom.name} - 무모한 시식가`,
        text: `"${currentRoom.name}" 방에 초대합니다! 아래 링크로 입장하세요.`,
        url: getInviteLink(),
      }).catch(() => {});
    });

    document.getElementById('regen-code-btn')?.addEventListener('click', async () => {
      if (!await showConfirm('초대 링크를 재생성하시겠습니까? 기존 링크는 사용할 수 없게 됩니다.')) return;
      try {
        const result = await regenerateInviteCode(currentRoom.id);
        currentRoom.inviteCode = result.inviteCode;
        currentRoom.inviteCodeExpiresAt = result.inviteCodeExpiresAt;
        showToast('초대 링크가 재생성되었습니다.', 'success');
      } catch {
        showToast('초대 링크 재생성에 실패했습니다.');
      }
    });

    document.getElementById('delete-room-btn')?.addEventListener('click', async () => {
      if (!await showDangerConfirm('정말 이 방을 삭제하시겠습니까? 모든 식당과 리뷰가 삭제됩니다.')) return;
      try {
        await deleteRoom(currentRoom.id);
        location.href = '/';
      } catch { showToast('방 삭제에 실패했습니다.'); }
    });

    document.getElementById('leave-room-btn')?.addEventListener('click', async () => {
      if (!await showConfirm('방을 나가시겠습니까?')) return;
      try {
        await leaveRoom(currentRoom.id);
        location.href = '/';
      } catch (err) { showToast(err instanceof Error ? err.message : '방 나가기에 실패했습니다.'); }
    });

    // 공유 링크 관리
    document.getElementById('copy-share-btn')?.addEventListener('click', () => {
      const shareUrl = document.getElementById('share-link')!.textContent!;
      navigator.clipboard.writeText(shareUrl);
      const btn = document.getElementById('copy-share-btn')!;
      btn.textContent = '복사됨!';
      setTimeout(() => { btn.textContent = '복사'; }, 1500);
    });

    document.getElementById('enable-share-btn')?.addEventListener('click', async () => {
      try {
        const result = await toggleShareCode(currentRoom.id, 'enable');
        currentRoom.shareCode = result.shareCode;
        currentRoom.shareCodeEnabled = result.shareCodeEnabled;
        renderPage();
      } catch { showToast('공유 링크 생성에 실패했습니다.'); }
    });

    document.getElementById('disable-share-btn')?.addEventListener('click', async () => {
      if (!await showConfirm('공유 링크를 비활성화하시겠습니까? 기존 링크로 접근할 수 없게 됩니다.')) return;
      try {
        const result = await toggleShareCode(currentRoom.id, 'disable');
        currentRoom.shareCode = result.shareCode;
        currentRoom.shareCodeEnabled = result.shareCodeEnabled;
        renderPage();
      } catch { showToast('비활성화에 실패했습니다.'); }
    });

    document.getElementById('regen-share-btn')?.addEventListener('click', async () => {
      if (!await showConfirm('공유 링크를 재생성하시겠습니까? 기존 링크는 더 이상 사용할 수 없습니다.')) return;
      try {
        const result = await toggleShareCode(currentRoom.id, 'regenerate');
        currentRoom.shareCode = result.shareCode;
        currentRoom.shareCodeEnabled = result.shareCodeEnabled;
        renderPage();
      } catch { showToast('재생성에 실패했습니다.'); }
    });
  }

  function switchToTab(tabName: string) {
    const btn = document.querySelector<HTMLButtonElement>(`.room-tab-btn[data-tab="${tabName}"]`);
    if (btn) btn.click();
  }

  function attachTabHandlers() {
    const panels: Record<string, HTMLElement> = {
      restaurants: document.getElementById('tab-restaurants')!,
      region: document.getElementById('tab-region')!,
      stats: document.getElementById('tab-stats')!,
      members: document.getElementById('tab-members')!,
    };
    const mapPanel = document.getElementById('tab-map');
    if (mapPanel) panels.map = mapPanel;
    const pollPanel = document.getElementById('tab-poll');
    if (pollPanel) panels.poll = pollPanel;
    const timelinePanel = document.getElementById('tab-timeline');
    if (timelinePanel) panels.timeline = timelinePanel;

    let mapRendered = false;

    for (const btn of document.querySelectorAll<HTMLButtonElement>('.room-tab-btn')) {
      btn.addEventListener('click', () => {
        for (const b of document.querySelectorAll('.room-tab-btn')) b.classList.remove('active');
        btn.classList.add('active');
        const tab = btn.dataset.tab!;
        for (const [key, panel] of Object.entries(panels)) {
          panel.hidden = key !== tab;
        }
        if (tab === 'map' && !mapRendered) {
          mapRendered = true;
          renderMapTab();
        }
      });
    }
  }

