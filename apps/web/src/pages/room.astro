        ${hasKakaoMap ? '<button type="button" class="room-tab-btn" data-tab="map">🗺️ 지도</button>' : ''}
        <button type="button" class="room-tab-btn" data-tab="poll">🗳️ 투표</button>
        <button type="button" class="room-tab-btn" data-tab="timeline">📋 활동</button>
        <button type="button" class="room-tab-btn" data-tab="stats">📊 통계</button>
