<script>
  import {
    fetchCurrentUser, fetchRoom, deleteRoom, leaveRoom,
    updateRoomMemberRole, kickRoomMember, transferOwnership,
    createRoomRestaurant,
    toggleShareCode, updateRoom, regenerateInviteCode,
    fetchRoomStats, toggleWishlist,
    createPoll, fetchPolls, votePoll, closePoll,
    fetchTimeline,
    showToast, showConfirm, showDangerConfirm,
  } from '@/lib/api';
  import type { AuthUser, RoomDetailResponse, RoomRestaurantInfo, RoomStats, Poll, TimelineItem } from '@/lib/api';
  import { getCities, getNeighborhoods } from '@/data/areas';
  import { formatRating, formatDate } from '@repo/utils';

  const loadingMsg = document.getElementById('loading-msg')!;
  const errorMsg = document.getElementById('error-msg')!;
  const content = document.getElementById('room-content')!;

  // 카카오맵 SDK 로드 여부
  const hasKakaoMap = typeof window !== 'undefined' && 'kakao' in window;

  // 카카오 공유 SDK 초기화
  interface KakaoSDK {
    isInitialized: () => boolean;
    init: (key: string) => void;
    Share: {
      sendDefault: (params: {
        objectType: string;
        content: { title: string; description: string; imageUrl: string; link: { mobileWebUrl: string; webUrl: string } };
        buttons?: { title: string; link: { mobileWebUrl: string; webUrl: string } }[];
      }) => void;
    };
  }
  const Kakao = (window as { Kakao?: KakaoSDK }).Kakao;
  const hasKakaoShare = !!Kakao;
  if (Kakao && !Kakao.isInitialized()) {
    const kakaoKey = document.querySelector<HTMLMetaElement>('meta[name="kakao-app-key"]')?.content;
    if (kakaoKey) Kakao.init(kakaoKey);
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  /** 버튼 중복 클릭 방지 래퍼 */
  async function withLoading(btn: HTMLButtonElement, fn: () => Promise<void>) {
    if (btn.disabled) return;
    const original = btn.textContent!;
    btn.disabled = true;
    btn.textContent = '처리 중...';
    try { await fn(); }
    finally { btn.disabled = false; btn.textContent = original; }
  }

  const renderStars = formatRating;

  // ── 바텀시트 유틸 ──
  const roomSortBackdrop = document.getElementById('room-sort-backdrop')!;
  const roomSortSheet = document.getElementById('room-sort-sheet')!;
  const roomSortOptions = document.getElementById('room-sort-options')!;

  function openRoomSortSheet(
    options: { value: string; label: string }[],
    currentValue: string,
    onSelect: (value: string) => void,
  ) {
    roomSortOptions.innerHTML = options.map((opt) =>
      `<button type="button" class="sheet-option ${opt.value === currentValue ? 'active' : ''}" data-value="${opt.value}">${opt.label}</button>`
    ).join('');

    roomSortBackdrop.hidden = false;
    roomSortSheet.hidden = false;
    requestAnimationFrame(() => {
      roomSortBackdrop.classList.add('visible');
      roomSortSheet.classList.add('visible');
    });

    const handler = (e: Event) => {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.sheet-option');
      if (!btn) return;
      closeRoomSortSheet();
      onSelect(btn.dataset.value!);
      roomSortOptions.removeEventListener('click', handler);
    };
    roomSortOptions.addEventListener('click', handler);
  }

  function closeRoomSortSheet() {
    roomSortBackdrop.classList.remove('visible');
    roomSortSheet.classList.remove('visible');
    setTimeout(() => {
      roomSortBackdrop.hidden = true;
      roomSortSheet.hidden = true;
    }, 300);
  }

  roomSortBackdrop.addEventListener('click', closeRoomSortSheet);

  function renderRestaurantCard(r: RoomRestaurantInfo): string {
    return `
      <div class="room-restaurant-card" data-rid="${r.id}">
        <div class="room-rest-name-row">
          <div class="room-rest-name">${escapeHtml(r.name)}${r.avgRating ? ` <span class="room-rest-rating">${renderStars(Math.round(r.avgRating))} ${r.avgRating}</span>` : ''}</div>
          <button type="button" class="btn-wishlist ${r.wishlisted ? 'active' : ''}" data-rid="${r.id}" title="찜">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="${r.wishlisted ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
        </div>
        <div class="room-rest-meta">${escapeHtml(r.address)} · ${escapeHtml(r.category)}</div>
        <div class="room-rest-footer">
          <span class="room-rest-added-by">${escapeHtml(r.addedBy?.nickname ?? '(탈퇴한 사용자)')}</span>
          <span class="room-rest-reviews-count">리뷰 ${r._count.reviews}개</span>
        </div>
      </div>`;
  }

  const roleLabel: Record<string, string> = { owner: '방장', manager: '매니저', member: '멤버' };

  let currentRoom: RoomDetailResponse;
  let currentUser: AuthUser;
  let myRole: string;

  function getMyRole(): string {
    const me = currentRoom.members.find((m) => m.userId === currentUser.id);
    return me?.role || 'member';
  }

  function isOwner(): boolean { return myRole === 'owner'; }
  function isManagerOrAbove(): boolean { return myRole === 'owner' || myRole === 'manager'; }

  // ─── 렌더링 ───

  function renderPage() {
    myRole = getMyRole();

    const svgLink = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>';
    const svgShare = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>';
    const svgRefresh = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>';
    const svgHelp = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>';

    const svgExit = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>';
    const svgTrash = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>';
    const svgGlobe = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>';

    let shareHtml = '';
    if (isManagerOrAbove()) {
      if (currentRoom.shareCodeEnabled && currentRoom.shareCode) {
        const shareUrl = `${location.origin}/share?code=${currentRoom.shareCode}`;
        shareHtml = `
          <div class="share-row">
            <span class="share-label">${svgGlobe} 외부 공유</span>
            <span class="share-link" id="share-link">${shareUrl}</span>
            <div class="share-link-actions">
              <button type="button" class="btn-share-action" id="copy-share-btn">복사</button>
              <button type="button" class="btn-share-action" id="disable-share-btn">끄기</button>
              <button type="button" class="btn-share-action" id="regen-share-btn">재생성</button>
            </div>
          </div>
        `;
      } else {
        shareHtml = `
          <div class="share-row">
            <button type="button" class="room-action-chip" id="enable-share-btn">${svgGlobe} 외부 공유 링크 만들기</button>
            <span class="share-desc">비회원도 읽기 전용으로 열람 가능</span>
          </div>
        `;
      }
    }

    const expiryText = currentRoom.inviteCodeExpiresAt
      ? (new Date(currentRoom.inviteCodeExpiresAt) < new Date() ? ' (만료됨)' : '')
      : '';

    content.innerHTML = `
      <a href="/" class="back-link">&larr; 내 방 목록</a>
      <div class="room-header">
        <div class="room-name-row">
          <h1 id="room-name-display">${escapeHtml(currentRoom.name)}</h1>
          ${isOwner() ? '<button type="button" class="btn-edit-name" id="edit-name-btn" title="방 이름 변경">✎</button>' : ''}
          <input type="text" id="room-name-input" class="room-name-input" maxlength="100" hidden />
        </div>
        <div class="room-header-actions">
          <button type="button" class="room-action-chip" id="copy-link-btn">${svgLink} 멤버 초대${expiryText}</button>
          ${'share' in navigator ? `<button type="button" class="room-action-chip" id="share-invite-btn">${svgShare} 카톡/문자 초대</button>` : ''}
          ${isOwner() ? `<button type="button" class="room-action-chip" id="regen-code-btn">${svgRefresh} 초대 코드 재생성</button>` : ''}
          <button type="button" class="room-action-chip" id="help-btn">${svgHelp} 도움말</button>
          ${isOwner()
            ? `<button type="button" class="room-action-chip room-action-chip--danger room-action-chip--right" id="delete-room-btn">${svgTrash} 방 삭제</button>`
            : `<button type="button" class="room-action-chip room-action-chip--danger room-action-chip--right" id="leave-room-btn">${svgExit} 방 나가기</button>`}
