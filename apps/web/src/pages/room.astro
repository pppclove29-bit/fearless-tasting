    try {
    // ── 기본 요약 ──
    const summaryHtml = `
      <div class="stats-grid">
        <div class="stat-card"><span class="stat-card-icon">🍽</span><div class="stat-card-body"><div class="stat-card-label">총 식당</div><div class="stat-value">${summary.totalRestaurants}</div></div></div>
        <div class="stat-card"><span class="stat-card-icon">📍</span><div class="stat-card-body"><div class="stat-card-label">총 방문</div><div class="stat-value">${summary.totalVisits}</div></div></div>
        <div class="stat-card"><span class="stat-card-icon">👥</span><div class="stat-card-body"><div class="stat-card-label">멤버</div><div class="stat-value">${currentRoom.members.length}</div></div></div>
