  function updateCategoryFilter() {
    const row = document.getElementById('category-filter-row');
    if (!row) return;
    // 카테고리 목록은 currentRoom.restaurants (전체)에서 추출하면 현재 페이지만 반영
    // 서버에서 전체 카테고리를 주지 않으므로 로컬 캐시 사용
    const categories = [...new Set(restData.map((r) => r.category))].sort();
    if (categories.length <= 1 && !activeCategory) {
      row.innerHTML = '';
      return;
    }
    row.innerHTML = `
      <button type="button" class="category-filter-btn ${!activeCategory ? 'active' : ''}" data-category="">전체</button>
      ${categories.map((c) => `<button type="button" class="category-filter-btn ${activeCategory === c ? 'active' : ''}" data-category="${escapeHtml(c)}">${escapeHtml(c)}</button>`).join('')}
    `;
    attachCategoryFilterHandlers();
