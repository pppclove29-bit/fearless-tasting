---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="방 상세" description="방의 식당과 리뷰를 확인하세요">
  <div id="room-page">
    <p id="loading-msg" class="status-msg">로딩 중...</p>
    <p id="error-msg" class="status-msg error" hidden></p>
    <div id="room-content" hidden></div>
  </div>

  <!-- 정렬 바텀시트 -->
  <div class="sheet-backdrop" id="room-sort-backdrop" hidden></div>
  <div class="sheet" id="room-sort-sheet" hidden>
    <div class="sheet-handle"></div>
    <div class="sheet-title">정렬</div>
    <div class="sheet-options" id="room-sort-options"></div>
  </div>
</BaseLayout>

<style>
  .status-msg {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .status-msg.error {
    color: #dc2626;
  }
</style>

<style is:global>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s;
  }

  .back-link:hover { color: var(--text-heading); }

  .room-header {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .room-name-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .room-header h1 {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.3;
    word-break: break-word;
    color: var(--text-heading);
  }

  .btn-edit-name {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    color: var(--text-muted);
    padding: 0.2rem;
    transition: color 0.15s;
  }

  .btn-edit-name:hover { color: var(--text-sub); }

  .room-name-input {
    font-size: 1.3rem;
    font-weight: 700;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    padding: 0.25rem 0.5rem;
    font-family: inherit;
    flex: 1;
    background: var(--bg-input);
    color: var(--text-heading);
  }

  .room-name-input:focus {
    outline: none;
    border-color: var(--text-sub);
  }

  .room-header-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    flex-wrap: wrap;
  }

  .room-action-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.7rem;
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--text-sub);
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    font-family: inherit;
    white-space: nowrap;
  }

  .room-action-chip:hover {
    border-color: var(--text-muted);
    background: var(--bg-card);
  }

  .room-action-chip:active { transform: scale(0.97); }

  .room-action-chip svg {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
  }

  .room-action-chip--danger {
    color: #dc2626;
    border-color: rgba(220, 38, 38, 0.2);
    background: rgba(220, 38, 38, 0.04);
  }

  .room-action-chip--danger:hover {
    border-color: rgba(220, 38, 38, 0.4);
    background: rgba(220, 38, 38, 0.08);
  }

  .room-action-chip--right {
    margin-left: auto;
  }

  .invite-expiry {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-left: 0.25rem;
  }

  .share-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.5rem;
    padding: 0.5rem 0.65rem;
    background: var(--bg-hover);
    border-radius: 8px;
    flex-wrap: wrap;
  }

  .share-label {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    color: var(--text-muted);
    font-weight: 600;
    white-space: nowrap;
  }

  .share-label svg {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
  }

  .share-desc {
    font-size: 0.7rem;
    color: var(--text-muted);
    margin-left: 0.25rem;
  }

  .share-link {
    font-family: monospace;
    font-size: 0.72rem;
    color: var(--text-sub);
    word-break: break-all;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
    min-width: 0;
  }

  .share-link-actions {
    display: flex;
    gap: 0.3rem;
    margin-left: auto;
  }

  .btn-share-action {
    padding: 0.2rem 0.5rem;
    background: var(--bg-card);
    color: var(--text-sub);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.15s;
    font-family: inherit;
  }

  .btn-share-action:hover { border-color: var(--text-muted); }

  .btn-danger-sm {
    padding: 0.4rem 0.75rem;
    background: #dc2626;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.1s;
    font-family: inherit;
  }

  .btn-danger-sm:hover { opacity: 0.85; }
  .btn-danger-sm:active { transform: scale(0.97); }

  .btn-outline-sm {
    padding: 0.4rem 0.75rem;
    background: var(--bg-card);
    color: var(--text-sub);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.15s, transform 0.1s;
    font-family: inherit;
  }

  .btn-outline-sm:hover { border-color: var(--text-muted); }
  .btn-outline-sm:active { transform: scale(0.97); }

  /* 탭 바 */
  .room-tab-bar {
    display: flex;
    gap: 0.35rem;
    margin-bottom: 1.25rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.25rem;
    background: var(--bg-hover);
    border-radius: 12px;
  }

  .room-tab-bar::-webkit-scrollbar { display: none; }

  .room-tab-btn {
    padding: 0.55rem 0.85rem;
    background: none;
    border: none;
    border-radius: 8px;
    font-size: 0.825rem;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
    font-family: inherit;
  }

  .room-tab-btn:hover { color: var(--text-sub); }

  .room-tab-btn.active {
    color: var(--text-heading);
    font-weight: 700;
    background: var(--bg-card);
    box-shadow: 0 1px 3px var(--shadow);
  }

  /* 멤버 리스트 */
  .member-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .member-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.85rem 1rem;
  }

  .member-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .member-nickname {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text);
  }

  .member-role-badge {
    display: inline-block;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    background: var(--bg-hover);
    color: var(--text-sub);
  }

  .member-role-badge.owner { background: #fef3c7; color: #92400e; }
  .member-role-badge.manager { background: #dbeafe; color: #1d4ed8; }

  .member-actions {
    display: flex;
    gap: 0.35rem;
    align-items: center;
  }

  .member-actions select {
    padding: 0.25rem 0.4rem;
    border: 1px solid var(--border-mid);
    border-radius: 4px;
    font-size: 0.75rem;
    background: var(--bg-input);
    color: var(--text);
  }

  /* 식당 카드 */
  .room-restaurant-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 0.6rem;
    cursor: pointer;
    transition: border-color 0.15s, transform 0.1s;
  }

  .room-restaurant-card:hover { border-color: var(--border-mid); }
  .room-restaurant-card:active { transform: scale(0.99); }

  .room-rest-name-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .room-rest-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-heading);
    margin-bottom: 0.15rem;
    flex: 1;
    min-width: 0;
  }

  .btn-wishlist {
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.15rem;
    color: var(--border-mid);
    transition: color 0.15s, transform 0.2s;
    flex-shrink: 0;
  }

  .btn-wishlist:hover { color: #e74c6f; }
  .btn-wishlist.active { color: #e74c6f; }

  .room-rest-rating {
    font-size: 0.8rem;
    color: #e6a817;
    font-weight: 500;
  }

  .room-rest-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .room-rest-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 0.35rem;
  }

  .room-rest-added-by {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .room-rest-reviews-count {
    font-size: 0.75rem;
    color: var(--text-sub);
  }

  .section-subtitle {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-heading);
    margin: 1.25rem 0 0.5rem;
  }

  .section-count {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  /* 식당 등록 폼 */
  .add-restaurant-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem;
    margin-bottom: 1rem;
  }

  .auto-filled-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    font-size: 0.78rem;
    color: var(--text-sub);
    background: var(--bg-hover);
    padding: 0.55rem 0.75rem;
    border-radius: 8px;
    margin-bottom: 0.5rem;
    border: 1px solid var(--border);
    line-height: 1.4;
  }

  .auto-filled-info span:first-child {
    font-weight: 600;
    color: var(--text-heading);
  }

  .auto-filled-info span:last-child {
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .add-restaurant-form h3 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.85rem;
    color: var(--text-heading);
  }

  .add-rest-mode-tabs {
    display: flex;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 0.85rem;
  }

  .add-rest-mode-btn {
    flex: 1;
    padding: 0.55rem 0;
    background: none;
    border: none;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s, color 0.15s;
  }

  .add-rest-mode-btn:first-child {
    border-right: 1.5px solid var(--border);
  }

  .add-rest-mode-btn.active {
    background: var(--text-heading);
    color: var(--bg);
    font-weight: 600;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .form-row.full {
    grid-template-columns: 1fr;
  }

  .add-restaurant-form input,
  .add-restaurant-form select {
    padding: 0.6rem 0.75rem;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 0.85rem;
    width: 100%;
    background: var(--bg-card);
    color: var(--text);
    font-family: inherit;
    transition: border-color 0.15s;
  }

  .add-restaurant-form input:focus,
  .add-restaurant-form select:focus {
    outline: none;
    border-color: var(--text-heading);
  }

  .category-chips {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .category-chips-label {
    font-size: 0.78rem;
    color: var(--text-muted);
    font-weight: 500;
    margin-right: 0.1rem;
    width: 100%;
    margin-bottom: 0.1rem;
  }

  .cat-chip {
    padding: 0.28rem 0.6rem;
    border: 1.5px solid var(--border);
    border-radius: 20px;
    background: var(--bg-card);
    color: var(--text-sub);
    font-size: 0.76rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
  }

  .cat-chip:hover { border-color: var(--text-muted); }

  .cat-chip.active {
    background: var(--text-heading);
    color: var(--bg);
    border-color: var(--text-heading);
  }

  .cat-chip-custom {
    flex: 1;
    min-width: 80px;
    max-width: 140px;
    padding: 0.28rem 0.5rem;
    border: 1.5px solid var(--border-mid);
    border-radius: 20px;
    font-size: 0.76rem;
    font-family: inherit;
    background: var(--bg-card);
    color: var(--text);
  }

  .cat-chip-custom:focus {
    outline: none;
    border-color: var(--text-heading);
  }

  .add-rest-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .btn-primary-sm {
    padding: 0.5rem 0.95rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 10px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.1s;
    font-family: inherit;
  }

  .btn-primary-sm:hover { opacity: 0.85; }
  .btn-primary-sm:active { transform: scale(0.97); }


  .rest-search {
    width: 100%;
    padding: 0.7rem 0.85rem;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    font-size: 0.875rem;
    font-family: inherit;
    margin-bottom: 0.75rem;
    transition: border-color 0.15s;
    background: var(--bg-card);
    color: var(--text);
  }

  .rest-search::placeholder { color: var(--text-muted); }

  .rest-search:focus {
    outline: none;
    border-color: var(--text-heading);
  }

  .btn-load-more {
    display: block;
    width: 100%;
    padding: 0.7rem;
    margin-top: 0.5rem;
    background: var(--bg-hover);
    border: 1px dashed var(--border-mid);
    border-radius: 10px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-sub);
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s, border-color 0.15s;
  }

  .btn-load-more:hover {
    background: var(--bg-card);
    border-color: var(--text-muted);
  }

  .rest-list-end {
    text-align: center;
    font-size: 0.75rem;
    color: var(--text-muted);
    padding: 0.5rem 0;
    margin: 0;
  }

  .category-filter-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .category-filter-btn {
    padding: 0.3rem 0.7rem;
    border: 1px solid var(--border-mid);
    border-radius: 100px;
    background: var(--bg-card);
    color: var(--text-sub);
    font-size: 0.8rem;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }

  .category-filter-btn:hover { background: var(--bg-hover); }

  .category-filter-btn.active {
    background: var(--text-heading);
    color: var(--bg);
    border-color: var(--text-heading);
  }

  /* ─── 투표 ─── */
  .poll-create-form {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .poll-create-form h3 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.75rem 0;
    color: var(--text-heading);
  }

  .poll-title-input {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.875rem;
    font-family: inherit;
    margin-bottom: 0.5rem;
    background: var(--bg-input);
    color: var(--text);
    box-sizing: border-box;
  }

  .poll-title-input:focus { outline: none; border-color: var(--text-sub); }

  .poll-options-list {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 0.75rem;
  }

  .poll-option-input {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.825rem;
    font-family: inherit;
    background: var(--bg-input);
    color: var(--text);
    box-sizing: border-box;
  }

  .poll-option-input:focus { outline: none; border-color: var(--text-sub); }

  .poll-form-actions {
    display: flex;
    gap: 0.5rem;
    justify-content: flex-end;
  }

  .poll-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.75rem;
  }

  .poll-card.poll-closed { opacity: 0.7; }

  .poll-card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .poll-card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-heading);
  }

  .poll-status-badge {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 6px;
    white-space: nowrap;
  }

  .poll-status-badge.active { background: #dcfce7; color: #166534; }
  .poll-status-badge.closed { background: var(--bg-hover); color: var(--text-muted); }

  .poll-card-meta {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .poll-options { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 0.5rem; }

  .poll-option-row {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    font-size: 0.825rem;
    transition: border-color 0.15s;
  }

  .poll-option-row.votable { cursor: pointer; }
  .poll-option-row.votable:hover { border-color: var(--text-muted); }

  .poll-option-row.my-vote {
    border-color: var(--text-heading);
    font-weight: 600;
  }

  .poll-option-bar {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    background: var(--bg-hover);
    border-radius: 8px;
    transition: width 0.3s ease;
    z-index: 0;
  }

  .poll-option-label { position: relative; z-index: 1; color: var(--text); }
  .poll-option-pct { position: relative; z-index: 1; color: var(--text-muted); font-size: 0.75rem; white-space: nowrap; }

  .poll-close-btn { margin-top: 0.5rem; }
  .poll-revote-hint { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.4rem; }

  /* ─── 타임라인 ─── */
  .timeline-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border-light);
  }

  .timeline-item:last-child { border-bottom: none; }

  .timeline-emoji {
    font-size: 1.4rem;
    line-height: 1;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .timeline-body { flex: 1; min-width: 0; }

  .timeline-desc {
    font-size: 0.85rem;
    color: var(--text);
    line-height: 1.4;
  }

  .timeline-desc strong { font-weight: 600; color: var(--text-heading); }

  .timeline-date {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
  }

  /* ─── 도움말 ─── */
  .help-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 1px solid var(--border-mid);
    background: var(--bg-card);
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

