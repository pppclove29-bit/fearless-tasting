  function attachCategoryFilterHandlers() {
    for (const btn of document.querySelectorAll<HTMLButtonElement>('.category-filter-btn')) {
      btn.addEventListener('click', () => {
        activeCategory = btn.dataset.category || '';
        renderRestaurantsTab();
      });
    }
  }

  function attachSearchHandler() {
    const input = document.getElementById('rest-search') as HTMLInputElement | null;
    if (!input) return;
    input.addEventListener('input', () => {
      searchQuery = input.value.trim();
      const filtered = (() => {
        let list = currentRoom.restaurants;
        if (activeCategory) list = list.filter((r) => r.category === activeCategory);
        if (searchQuery) {
          const q = searchQuery.toLowerCase();
          list = list.filter((r) => r.name.toLowerCase().includes(q) || r.address.toLowerCase().includes(q));
        }
        return list;
      })();
      const listEl = document.getElementById('restaurant-list')!;
      if (filtered.length === 0) {
        listEl.innerHTML = '<p class="empty-text">검색 결과가 없습니다.</p>';
      } else {
        listEl.innerHTML = filtered.map((r) => `
          <div class="room-restaurant-card" data-rid="${r.id}">
            <div class="room-rest-name">${escapeHtml(r.name)}${r.avgRating ? ` <span class="room-rest-rating">${renderStars(Math.round(r.avgRating))} ${r.avgRating}</span>` : ''}</div>
            <div class="room-rest-meta">${escapeHtml(r.address)} · ${escapeHtml(r.category)}</div>
            <div class="room-rest-footer">
              <span class="room-rest-added-by">${escapeHtml(r.addedBy.nickname)}</span>
              <span class="room-rest-reviews-count">리뷰 ${r._count.reviews}개</span>
            </div>
          </div>
        `).join('');
      }
      attachRestaurantCardHandlers();
    });
  }

  function attachRestaurantFormHandler() {
    document.getElementById('add-rest-submit')?.addEventListener('click', async () => {
      const name = (document.getElementById('add-rest-name') as HTMLInputElement).value.trim();
      const address = (document.getElementById('add-rest-address') as HTMLInputElement).value.trim();
      const province = (document.getElementById('add-rest-province') as HTMLInputElement).value.trim();
      const city = (document.getElementById('add-rest-city') as HTMLInputElement).value.trim();
      const neighborhood = (document.getElementById('add-rest-neighborhood') as HTMLInputElement).value.trim();
      const category = (document.getElementById('add-rest-category') as HTMLInputElement).value.trim();

      if (!name || !address || !province || !city || !neighborhood || !category) {
        showToast('모든 항목을 입력해 주세요.', 'info');
        return;
      }

      const latEl = document.getElementById('add-rest-lat') as HTMLInputElement | null;
      const lngEl = document.getElementById('add-rest-lng') as HTMLInputElement | null;
      const latitude = latEl?.value ? Number(latEl.value) : undefined;
      const longitude = lngEl?.value ? Number(lngEl.value) : undefined;
      const waitTimeEl = document.getElementById('add-rest-waittime') as HTMLSelectElement | null;
      const waitTime = waitTimeEl?.value || undefined;

      try {
        await createRoomRestaurant(currentRoom.id, { name, address, province, city, neighborhood, category, latitude, longitude, waitTime } as Parameters<typeof createRoomRestaurant>[1]);
        currentRoom = await fetchRoom(currentRoom.id);
        renderRestaurantsTab();
        renderRegionTab();
        showToast('식당이 등록되었습니다.', 'success');
      } catch (err) { showToast(err instanceof Error ? err.message : '등록에 실패했습니다.'); }
    });
  }

  // ─── 카카오 장소 검색 (식당 등록 폼) ───

  let kakaoMapsLoaded = false;

  function loadKakaoMaps(): Promise<void> {
    if (kakaoMapsLoaded) return Promise.resolve();
    return new Promise((resolve) => {
      const kakao = (window as Record<string, unknown>).kakao as Record<string, unknown>;
      const maps = kakao.maps as Record<string, unknown>;
      (maps.load as (cb: () => void) => void)(() => {
        kakaoMapsLoaded = true;
        resolve();
      });
    });
  }

  function attachPlaceSearchHandler() {
    const searchInput = document.getElementById('add-rest-search') as HTMLInputElement | null;
    const resultsDiv = document.getElementById('address-results');
    if (!searchInput || !resultsDiv) return;

    let debounceTimer: ReturnType<typeof setTimeout>;

    searchInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      const keyword = searchInput.value.trim();
      if (keyword.length < 2) {
        resultsDiv.hidden = true;
        return;
      }
      debounceTimer = setTimeout(async () => {
        await loadKakaoMaps();
        const kakao = (window as Record<string, unknown>).kakao as Record<string, unknown>;
        const maps = kakao.maps as Record<string, unknown>;
        const services = maps.services as Record<string, new () => Record<string, unknown>>;
        const places = new services.Places();

        (places.keywordSearch as (keyword: string, cb: (data: Array<Record<string, string>>, status: string) => void, options: Record<string, string>) => void)(
          keyword,
          (data: Array<Record<string, string>>, status: string) => {
            const OK = ((maps.services as Record<string, Record<string, string>>).Status as Record<string, string>).OK;
            if (status !== OK || data.length === 0) {
              resultsDiv.hidden = true;
              return;
            }
            resultsDiv.innerHTML = data.slice(0, 8).map((place, i) => `
              <div class="address-result-item" data-idx="${i}">
                <div class="address-result-name">${escapeHtml(place.place_name)}</div>
                <div class="address-result-addr">${escapeHtml(place.address_name)}</div>
              </div>
            `).join('');
            resultsDiv.hidden = false;

            for (const item of resultsDiv.querySelectorAll<HTMLElement>('.address-result-item')) {
              item.addEventListener('click', () => {
                const idx = Number(item.dataset.idx);
                const place = data[idx];
                fillFormFromPlace(place);
                resultsDiv.hidden = true;
                searchInput.value = '';
              });
            }
          },
          { category_group_code: 'FD6' },
        );
      }, 300);
    });

    // 외부 클릭 시 결과 닫기
    document.addEventListener('click', (e) => {
      if (!(e.target as HTMLElement).closest('.address-search-wrap')) {
        resultsDiv.hidden = true;
      }
    });
  }

  function fillFormFromPlace(place: Record<string, string>) {
    const nameInput = document.getElementById('add-rest-name') as HTMLInputElement;
    const addressInput = document.getElementById('add-rest-address') as HTMLInputElement;
    const provinceInput = document.getElementById('add-rest-province') as HTMLInputElement;
    const cityInput = document.getElementById('add-rest-city') as HTMLInputElement;
    const neighborhoodInput = document.getElementById('add-rest-neighborhood') as HTMLInputElement;
    const categoryInput = document.getElementById('add-rest-category') as HTMLInputElement;
    const latInput = document.getElementById('add-rest-lat') as HTMLInputElement;
    const lngInput = document.getElementById('add-rest-lng') as HTMLInputElement;

    nameInput.value = place.place_name;
    addressInput.value = place.address_name;
    latInput.value = place.y;
    lngInput.value = place.x;

    // 주소에서 시/도, 시/군/구, 읍/면/동 파싱
    const parts = place.address_name.split(' ');
    provinceInput.value = parts[0] || '';
    cityInput.value = parts[1] || '';
    neighborhoodInput.value = parts[2] || '';

    // 카카오 카테고리에서 마지막 카테고리 추출 (예: "음식점 > 한식 > 국밥" → "국밥")
    const catParts = (place.category_name || '').split(' > ');
    const lastCat = catParts[catParts.length - 1] || '';
    if (lastCat && lastCat !== '음식점') {
      categoryInput.value = lastCat;
    }

    categoryInput.focus();
  }

  // ─── 지역 탭 ───

  function calcRegionAvg(rests: typeof currentRoom.restaurants): string {
    const withRating = rests.filter((r) => r.avgRating !== null);
    if (withRating.length === 0) return '';
    const totalWeighted = withRating.reduce((s, r) => s + r.avgRating! * r._count.reviews, 0);
    const totalReviews = withRating.reduce((s, r) => s + r._count.reviews, 0);
    if (totalReviews === 0) return '';
    return (Math.round(totalWeighted / totalReviews * 10) / 10).toFixed(1);
  }

  function renderRegionTab() {
    const panel = document.getElementById('tab-region')!;
    const restaurants = currentRoom.restaurants;

    if (restaurants.length === 0) {
      panel.innerHTML = '<p class="empty-text">등록된 식당이 없습니다.</p>';
      return;
    }

    const provinces = [...new Set(restaurants.map((r) => r.province).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'ko'));

    let selectedProvince: string | null = null;
    let selectedCity: string | null = null;
    let selectedNeighborhood: string | null = null;
    let sortBy = 'rating-high';

    function filterBy(province: string | null, city: string | null, neighborhood: string | null) {
      return restaurants.filter((r) => {
        if (province && r.province !== province) return false;
        if (city && r.city !== city) return false;
        if (neighborhood && r.neighborhood !== neighborhood) return false;
        return true;
      });
    }

    function getCities() {
      return [...new Set(filterBy(selectedProvince, null, null).map((r) => r.city).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'ko'));
    }

    function getNeighborhoods() {
      return [...new Set(filterBy(selectedProvince, selectedCity, null).map((r) => r.neighborhood).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'ko'));
    }

    function sortRestaurants(list: typeof restaurants) {
      const sorted = [...list];
      switch (sortBy) {
        case 'rating-high': return sorted.sort((a, b) => (b.avgRating ?? 0) - (a.avgRating ?? 0));
        case 'rating-low': return sorted.sort((a, b) => (a.avgRating ?? 0) - (b.avgRating ?? 0));
        case 'name': return sorted.sort((a, b) => a.name.localeCompare(b.name, 'ko'));
        case 'reviews': return sorted.sort((a, b) => b._count.reviews - a._count.reviews);
        case 'latest': return sorted.sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime());
        default: return sorted;
      }
    }

    function render() {
      const cities = selectedProvince ? getCities() : [];
      const neighborhoods = selectedCity ? getNeighborhoods() : [];
      const filtered = selectedProvince ? filterBy(selectedProvince, selectedCity, selectedNeighborhood) : [];

      let html = '<div class="region-tab">';

      // 시/도
      html += '<div class="region-depth"><span class="region-depth-label">시/도</span><div class="region-btns">';
      for (const p of provinces) {
        const avg = calcRegionAvg(filterBy(p, null, null));
        html += `<button type="button" class="region-btn ${selectedProvince === p ? 'active' : ''}" data-depth="province" data-val="${escapeHtml(p)}">${escapeHtml(p)}${avg ? ` <span class="region-avg">★${avg}</span>` : ''}</button>`;
      }
      html += '</div></div>';

      // 시/군/구
      if (selectedProvince && cities.length > 0) {
        html += '<div class="region-depth"><span class="region-depth-label">시/군/구</span><div class="region-btns">';
        for (const c of cities) {
          const avg = calcRegionAvg(filterBy(selectedProvince, c, null));
          html += `<button type="button" class="region-btn ${selectedCity === c ? 'active' : ''}" data-depth="city" data-val="${escapeHtml(c)}">${escapeHtml(c)}${avg ? ` <span class="region-avg">★${avg}</span>` : ''}</button>`;
        }
        html += '</div></div>';
      }

      // 읍/면/동
      if (selectedCity && neighborhoods.length > 0) {
        html += '<div class="region-depth"><span class="region-depth-label">읍/면/동</span><div class="region-btns">';
        for (const n of neighborhoods) {
          const avg = calcRegionAvg(filterBy(selectedProvince, selectedCity, n));
          html += `<button type="button" class="region-btn ${selectedNeighborhood === n ? 'active' : ''}" data-depth="neighborhood" data-val="${escapeHtml(n)}">${escapeHtml(n)}${avg ? ` <span class="region-avg">★${avg}</span>` : ''}</button>`;
        }
        html += '</div></div>';
      }

      // 식당 목록
      if (selectedProvince) {
        const sorted = sortRestaurants(filtered);
        html += `<div class="region-list-header">`;
        html += `<span class="region-result-header">${sorted.length}개의 식당</span>`;
        if (sorted.length > 1) {
          html += `<select class="region-sort" id="region-sort">
            <option value="rating-high" ${sortBy === 'rating-high' ? 'selected' : ''}>평점 높은순</option>
            <option value="rating-low" ${sortBy === 'rating-low' ? 'selected' : ''}>평점 낮은순</option>
            <option value="reviews" ${sortBy === 'reviews' ? 'selected' : ''}>리뷰 많은순</option>
            <option value="name" ${sortBy === 'name' ? 'selected' : ''}>이름순</option>
            <option value="latest" ${sortBy === 'latest' ? 'selected' : ''}>최신순</option>
          </select>`;
        }
        html += `</div>`;

        if (sorted.length > 0) {
          html += '<div class="region-restaurant-list">';
          for (const r of sorted) {
            const ratingStr = r.avgRating !== null ? `${renderStars(Math.round(r.avgRating))} ${r.avgRating}` : '';
            const reviewCount = r._count.reviews;
            html += `
              <div class="region-rest-card" data-rid="${r.id}">
                <div class="region-rest-name">${escapeHtml(r.name)}</div>
                <div class="region-rest-meta">
                  <span class="category-badge">${escapeHtml(r.category || '')}</span>
                  ${ratingStr ? `<span class="region-rest-rating">${ratingStr}</span>` : ''}
                  <span class="region-rest-reviews">리뷰 ${reviewCount}개</span>
                </div>
                <div class="region-rest-addr">${escapeHtml(r.address)}</div>
              </div>`;
          }
          html += '</div>';
        }

        html += '<div id="region-detail-area"></div>';
      } else {
        html += '<p class="region-hint">시/도를 선택하면 해당 지역의 식당을 볼 수 있습니다.</p>';
      }

      html += '</div>';
      panel.innerHTML = html;

      // 지역 버튼 이벤트
      for (const btn of panel.querySelectorAll<HTMLButtonElement>('.region-btn')) {
        btn.addEventListener('click', () => {
          const depth = btn.dataset.depth!;
          const val = btn.dataset.val!;
          if (depth === 'province') {
            selectedProvince = selectedProvince === val ? null : val;
            selectedCity = null;
            selectedNeighborhood = null;
          } else if (depth === 'city') {
            selectedCity = selectedCity === val ? null : val;
            selectedNeighborhood = null;
          } else if (depth === 'neighborhood') {
            selectedNeighborhood = selectedNeighborhood === val ? null : val;
          }
          render();
        });
      }

      // 정렬 이벤트
      document.getElementById('region-sort')?.addEventListener('change', (e) => {
        sortBy = (e.target as HTMLSelectElement).value;
        render();
      });

      // 식당 카드 클릭 → 상세
      for (const card of panel.querySelectorAll<HTMLElement>('.region-rest-card')) {
        card.addEventListener('click', () => {
          const rid = card.dataset.rid!;
          loadRestaurantDetail(rid, 'region-detail-area');
        });
      }
    }

    render();
  }

  // ─── 카카오맵 지도 탭 ───

  async function renderMapTab() {
    const panel = document.getElementById('tab-map');
    if (!panel) return;

    const restaurantsWithCoords = currentRoom.restaurants.filter(
      (r) => r.latitude != null && r.longitude != null,
    );

    if (restaurantsWithCoords.length === 0) {
      panel.innerHTML = '<p class="map-no-data">좌표가 등록된 식당이 없습니다. 카카오 검색으로 식당을 등록하면 지도에 표시됩니다.</p>';
      return;
    }

    panel.innerHTML = '<div class="map-container"><div id="kakao-map"></div></div><div id="map-detail-area"></div>';

    await loadKakaoMaps();

    const kakao = (window as Record<string, unknown>).kakao as Record<string, unknown>;
    const maps = kakao.maps as Record<string, unknown>;
    const LatLng = maps.LatLng as new (lat: number, lng: number) => unknown;
    const MapConstructor = maps.Map as new (el: HTMLElement, opts: Record<string, unknown>) => Record<string, unknown>;
    const MarkerConstructor = maps.Marker as new (opts: Record<string, unknown>) => Record<string, unknown>;
    const CustomOverlayConstructor = maps.CustomOverlay as new (opts: Record<string, unknown>) => Record<string, unknown>;
    const LatLngBounds = maps.LatLngBounds as new () => Record<string, (pos: unknown) => void>;

    const container = document.getElementById('kakao-map')!;
    const center = new LatLng(
      restaurantsWithCoords[0].latitude!,
      restaurantsWithCoords[0].longitude!,
    );

    const map = new MapConstructor(container, { center, level: 5 });
    const bounds = new LatLngBounds();

    let activeOverlay: Record<string, unknown> | null = null;

    for (const r of restaurantsWithCoords) {
      const position = new LatLng(r.latitude!, r.longitude!);
      bounds.extend(position);

      const marker = new MarkerConstructor({ map, position });

      const ratingLine = r.avgRating !== null
        ? `<div style="color:#f59e0b;font-size:12px;">★ ${r.avgRating} <span style="color:#999;font-size:11px;">(${r._count.reviews})</span></div>`
        : `<div style="color:#999;font-size:11px;">리뷰 없음</div>`;

      const overlayContent = document.createElement('div');
      overlayContent.className = 'map-overlay-card';
      overlayContent.innerHTML = `
        <div style="background:#fff;border-radius:8px;padding:8px 12px;box-shadow:0 2px 8px rgba(0,0,0,0.15);min-width:120px;cursor:pointer;border:1px solid #e8e8e8;">
          <div style="font-size:13px;font-weight:600;color:#111;margin-bottom:2px;">${escapeHtml(r.name)}</div>
          <div style="font-size:11px;color:#888;margin-bottom:3px;">${escapeHtml(r.category || '')}</div>
          ${ratingLine}
        </div>
        <div style="width:0;height:0;border-left:6px solid transparent;border-right:6px solid transparent;border-top:6px solid #fff;margin:0 auto;"></div>
      `;

      overlayContent.addEventListener('click', () => {
        loadRestaurantDetail(r.id, 'map-detail-area');
      });

      const overlay = new CustomOverlayConstructor({
        content: overlayContent,
        position,
        yAnchor: 1.3,
      });

      const markerEvents = maps.event as Record<string, (target: unknown, type: string, cb: () => void) => void>;
      markerEvents.addListener(marker, 'click', () => {
        if (activeOverlay) {
          (activeOverlay as Record<string, () => void>).setMap(null as unknown as never);
        }
        (overlay as Record<string, (m: unknown) => void>).setMap(map);
        activeOverlay = overlay;
      });
    }

    // 지도 클릭 시 오버레이 닫기
    const mapEvents = maps.event as Record<string, (target: unknown, type: string, cb: () => void) => void>;
    mapEvents.addListener(map, 'click', () => {
      if (activeOverlay) {
        (activeOverlay as Record<string, () => void>).setMap(null as unknown as never);
        activeOverlay = null;
      }
    });

    if (restaurantsWithCoords.length > 1) {
      (map as Record<string, (b: unknown) => void>).setBounds(bounds);
    }
  }

  function attachRestaurantCardHandlers() {
    for (const card of document.querySelectorAll<HTMLElement>('.room-restaurant-card')) {
      card.addEventListener('click', () => {
        const rid = card.dataset.rid!;
        loadRestaurantDetail(rid);
      });
    }
  }

  // ─── 식당 상세 (인라인) ───

  function renderReviewCard(rev: RoomReviewWithUser): string {
    const isReviewOwner = rev.userId === currentUser.id;
    const canDeleteReview = isReviewOwner || isManagerOrAbove();
    let actionsHtml = '';
    if (isReviewOwner || canDeleteReview) {
      actionsHtml = '<div class="room-review-actions">';
      if (isReviewOwner) {
        actionsHtml += `<button type="button" class="edit-rev-btn" data-rev-id="${rev.id}" data-rating="${rev.rating}" data-content="${escapeHtml(rev.content)}" data-revisit="${rev.wouldRevisit !== false}" data-taste="${rev.tasteRating ?? ''}" data-value="${rev.valueRating ?? ''}" data-service="${rev.serviceRating ?? ''}" data-cleanliness="${rev.cleanlinessRating ?? ''}" data-accessibility="${rev.accessibilityRating ?? ''}" data-fav-menu="${escapeHtml(rev.favoriteMenu ?? '')}" data-try-menu="${escapeHtml(rev.tryNextMenu ?? '')}">수정</button>`;
      }
      if (canDeleteReview) {
        actionsHtml += `<button type="button" class="danger delete-rev-btn" data-rev-id="${rev.id}">삭제</button>`;
      }
      actionsHtml += '</div>';
    }

    const isEdited = rev.updatedAt && rev.updatedAt !== rev.createdAt;
    const editedBadge = isEdited ? ' <span class="edited-badge">수정됨</span>' : '';
    const revisitBadge = rev.wouldRevisit === false
      ? '<span class="revisit-badge no">재방문 X</span>'
      : '<span class="revisit-badge yes">재방문 O</span>';

    const detailRatings = [
      rev.tasteRating != null ? `맛 ${rev.tasteRating}` : null,
      rev.valueRating != null ? `가성비 ${rev.valueRating}` : null,
      rev.serviceRating != null ? `서비스 ${rev.serviceRating}` : null,
      rev.cleanlinessRating != null ? `청결 ${rev.cleanlinessRating}` : null,
      rev.accessibilityRating != null ? `접근성 ${rev.accessibilityRating}` : null,
    ].filter(Boolean);
    const detailLine = detailRatings.length > 0 ? `<div class="review-detail-ratings">${detailRatings.join(' · ')}</div>` : '';

    const menuLine = [
      rev.favoriteMenu ? `다시 먹을 메뉴: ${escapeHtml(rev.favoriteMenu)}` : null,
      rev.tryNextMenu ? `다음에 먹을 메뉴: ${escapeHtml(rev.tryNextMenu)}` : null,
    ].filter(Boolean);
    const menuHtml = menuLine.length > 0 ? `<div class="review-menu-info">${menuLine.join(' | ')}</div>` : '';

    return `
      <div class="room-review-card" data-rev-id="${rev.id}">
        <div class="room-review-header">
          <span class="room-review-author">${escapeHtml(rev.user.nickname)} ${revisitBadge}</span>
          <span class="room-review-rating">${renderStars(rev.rating)} ${rev.rating}</span>
        </div>
        ${detailLine}
        <div class="room-review-content">${escapeHtml(rev.content)}</div>
        ${menuHtml}
        <div class="room-review-footer">
          <span>${formatDate(rev.createdAt)}${editedBadge}</span>
          ${actionsHtml}
        </div>
      </div>
    `;
  }

  function renderVisitCard(visit: RoomVisitWithDetails): string {
    const canDeleteVisit = visit.createdById === currentUser.id || isManagerOrAbove();
    const participantsHtml = visit.participants.length > 0
      ? visit.participants.map((p) => escapeHtml(p.user.nickname)).join(', ')
      : '';

    const myReviewExists = visit.reviews.some((r) => r.userId === currentUser.id);
    const reviewFormId = `review-form-${visit.id}`;

    const reviewFormHtml = myReviewExists
      ? ''
      : `<button type="button" class="btn-outline-sm toggle-review-form-btn" data-visit-id="${visit.id}">리뷰 작성</button>
         <div class="review-form" id="${reviewFormId}" style="display:none;">
           <select class="new-review-rating">
             <option value="5">5 - 최고</option><option value="4">4 - 좋음</option>
             <option value="3" selected>3 - 보통</option><option value="2">2 - 별로</option>
             <option value="1">1 - 나쁨</option>
           </select>
           <textarea class="new-review-content" placeholder="리뷰 내용을 작성해주세요"></textarea>
           <label class="revisit-toggle"><input type="checkbox" class="new-review-revisit" checked /> 재방문 의사 있음</label>
           <details class="review-detail-fields">
             <summary>세부 평점 (선택)</summary>
             <div class="detail-rating-grid">
               <label>맛 <select class="new-review-taste"><option value="">-</option><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option><option value="5">5</option></select></label>
               <label>가성비 <select class="new-review-value"><option value="">-</option><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option><option value="5">5</option></select></label>
               <label>서비스 <select class="new-review-service"><option value="">-</option><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option><option value="5">5</option></select></label>
               <label>청결 <select class="new-review-cleanliness"><option value="">-</option><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option><option value="5">5</option></select></label>
               <label>접근성 <select class="new-review-accessibility"><option value="">-</option><option value="1">1</option><option value="2">2</option><option value="3">3</option><option value="4">4</option><option value="5">5</option></select></label>
             </div>
             <input type="text" class="new-review-fav-menu" placeholder="다시 먹을 메뉴" maxlength="200" />
             <input type="text" class="new-review-try-menu" placeholder="다음에 먹을 메뉴" maxlength="200" />
           </details>
           <button type="button" class="btn-primary-sm submit-visit-review-btn" data-visit-id="${visit.id}">리뷰 작성</button>
         </div>`;

    const reviewsHtml = visit.reviews.map(renderReviewCard).join('');

    return `
      <div class="visit-card" data-visit-id="${visit.id}">
        <div class="visit-header">
          <span class="visit-date">${formatDate(visit.visitedAt)}</span>
          ${participantsHtml ? `<span class="visit-participants">함께: ${participantsHtml}</span>` : ''}
          <span class="visit-creator">기록: ${escapeHtml(visit.createdBy.nickname)}</span>
          ${canDeleteVisit ? `<button type="button" class="btn-danger-sm delete-visit-btn" data-visit-id="${visit.id}">삭제</button>` : ''}
        </div>
        ${visit.memo ? `<div class="visit-memo">${escapeHtml(visit.memo)}</div>` : ''}
        <div class="visit-reviews">
          ${reviewsHtml || '<p class="empty-text">아직 리뷰가 없습니다.</p>'}
        </div>
        ${reviewFormHtml}
      </div>
    `;
  }

  function collectDetailFields(container: HTMLElement, prefix: string): Partial<ReviewData> {
    const optInt = (sel: string) => { const v = container.querySelector<HTMLSelectElement>(sel)?.value; return v ? parseInt(v, 10) : undefined; };
    const optStr = (sel: string) => { const v = container.querySelector<HTMLInputElement>(sel)?.value.trim(); return v || undefined; };
    return {
      tasteRating: optInt(`.${prefix}-taste`),
      valueRating: optInt(`.${prefix}-value`),
      serviceRating: optInt(`.${prefix}-service`),
      cleanlinessRating: optInt(`.${prefix}-cleanliness`),
      accessibilityRating: optInt(`.${prefix}-accessibility`),
      favoriteMenu: optStr(`.${prefix}-fav-menu`),
      tryNextMenu: optStr(`.${prefix}-try-menu`),
    };
  }

  async function loadRestaurantDetail(rid: string, areaId = 'restaurant-detail-area') {
    const area = document.getElementById(areaId)!;
    area.innerHTML = '<p class="empty-text">로딩 중...</p>';

    try {
      const detail = await fetchRoomRestaurant(currentRoom.id, rid);
      const allReviews = detail.visits.flatMap((v) => v.reviews);

      const avgRating = allReviews.length > 0
        ? Math.round(allReviews.reduce((a, r) => a + r.rating, 0) / allReviews.length * 10) / 10
        : null;

      let deleteRestBtn = '';
      const canDeleteRest = detail.addedById === currentUser.id || isManagerOrAbove();
      if (canDeleteRest) {
        deleteRestBtn = `<button type="button" class="btn-danger-sm" id="delete-rest-btn">식당 삭제</button>`;
      }

      const waitTimeLabel = detail.waitTime ? `웨이팅: ${escapeHtml(detail.waitTime)}` : '';

      // 멤버 목록 (방문 기록 참여자 선택용)
      const memberOptions = currentRoom.members
        .filter((m) => m.userId !== currentUser.id)
        .map((m) => `<label class="participant-check"><input type="checkbox" value="${m.userId}" /> ${escapeHtml(m.user.nickname)}</label>`)
        .join('');

      const visitFormHtml = `
        <div class="visit-form">
          <h4>방문 기록 추가</h4>
          <input type="date" id="visit-date" value="${new Date().toISOString().slice(0, 10)}" />
          <input type="text" id="visit-memo" placeholder="메모 (선택)" maxlength="500" />
          ${memberOptions ? `<div class="participant-list"><span class="participant-label">함께 간 멤버:</span>${memberOptions}</div>` : ''}
          <button type="button" class="btn-primary-sm" id="submit-visit-btn">방문 기록 추가</button>
        </div>
      `;

      const sortedVisits = [...detail.visits].sort((a, b) => new Date(b.visitedAt).getTime() - new Date(a.visitedAt).getTime());

      const inlineHelpHtml = sortedVisits.length === 0
        ? '<div class="inline-help">리뷰를 남기려면 먼저 아래에서 <strong>방문 기록을 추가</strong>한 후, 해당 방문 카드의 "리뷰 작성" 버튼을 눌러주세요.</div>'
        : '';
      const visitsHtml = sortedVisits.length > 0
        ? sortedVisits.map(renderVisitCard).join('')
        : '<p class="empty-text">아직 방문 기록이 없습니다.</p>';

      area.innerHTML = `
        <div class="room-rest-detail">
          <button type="button" class="detail-close-btn" id="close-detail-btn">닫기</button>
          <h2>${escapeHtml(detail.name)}</h2>
          <div class="detail-address">${escapeHtml(detail.address)}</div>
          <div class="detail-meta">
            <span class="category-badge">${escapeHtml(detail.category)}</span>
            ${avgRating !== null ? `<span>${renderStars(Math.round(avgRating))} ${avgRating}</span>` : ''}
            ${waitTimeLabel ? `<span class="wait-badge">${waitTimeLabel}</span>` : ''}
            <span>등록: ${escapeHtml(detail.addedBy.nickname)}</span>
            ${deleteRestBtn}
          </div>
          ${inlineHelpHtml}
          ${visitFormHtml}
          <h3 class="visits-heading">방문 기록 (${detail.visits.length})</h3>
          <div id="visits-list">${visitsHtml}</div>
        </div>
      `;

      // 닫기
      document.getElementById('close-detail-btn')!.addEventListener('click', () => { area.innerHTML = ''; });

      // 식당 삭제
      document.getElementById('delete-rest-btn')?.addEventListener('click', async () => {
        if (!await showDangerConfirm('이 식당을 삭제하시겠습니까? 모든 방문 기록과 리뷰도 삭제됩니다.')) return;
        try {
          await deleteRoomRestaurant(currentRoom.id, rid);
          area.innerHTML = '';
          currentRoom = await fetchRoom(currentRoom.id);
          renderRestaurantsTab();
          renderRegionTab();
          showToast('식당이 삭제되었습니다.', 'success');
        } catch { showToast('삭제에 실패했습니다.'); }
      });

      // 방문 기록 추가
      document.getElementById('submit-visit-btn')!.addEventListener('click', async () => {
        const visitedAt = (document.getElementById('visit-date') as HTMLInputElement).value;
        const memo = (document.getElementById('visit-memo') as HTMLInputElement).value.trim();
        const participantIds = Array.from(area.querySelectorAll<HTMLInputElement>('.participant-check input:checked')).map((cb) => cb.value);
        if (!visitedAt) { showToast('방문 날짜를 선택해주세요.', 'info'); return; }

        try {
          await createRoomVisit(currentRoom.id, rid, { visitedAt, memo: memo || undefined, participantIds: participantIds.length > 0 ? participantIds : undefined });
          currentRoom = await fetchRoom(currentRoom.id);
          if (areaId === 'restaurant-detail-area') renderRegionTab();
          await loadRestaurantDetail(rid, areaId);
          showToast('방문 기록이 추가되었습니다.', 'success');
        } catch (err) { showToast(err instanceof Error ? err.message : '방문 기록 추가에 실패했습니다.'); }
      });

      attachVisitAndReviewHandlers(area, rid, areaId);
    } catch {
      area.innerHTML = '<p class="empty-text">식당 정보를 불러올 수 없습니다.</p>';
    }
  }

  function attachVisitAndReviewHandlers(area: HTMLElement, rid: string, areaId = 'restaurant-detail-area') {
    // 방문 기록 삭제
    for (const btn of area.querySelectorAll<HTMLButtonElement>('.delete-visit-btn')) {
      btn.addEventListener('click', async () => {
        if (!await showDangerConfirm('이 방문 기록을 삭제하시겠습니까? 포함된 리뷰도 삭제됩니다.')) return;
        try {
          await deleteRoomVisit(currentRoom.id, btn.dataset.visitId!);
          currentRoom = await fetchRoom(currentRoom.id);
          if (areaId === 'restaurant-detail-area') renderRegionTab();
          await loadRestaurantDetail(rid, areaId);
        } catch { showToast('방문 기록 삭제에 실패했습니다.'); }
      });
    }

    // 리뷰 작성 폼 토글
    for (const btn of area.querySelectorAll<HTMLButtonElement>('.toggle-review-form-btn')) {
      btn.addEventListener('click', () => {
        const form = document.getElementById(`review-form-${btn.dataset.visitId!}`);
        if (form) form.style.display = form.style.display === 'none' ? 'block' : 'none';
      });
    }

    // 리뷰 작성
    for (const btn of area.querySelectorAll<HTMLButtonElement>('.submit-visit-review-btn')) {
      btn.addEventListener('click', async () => {
        const visitCard = btn.closest('.visit-card')!;
        const visitId = btn.dataset.visitId!;
        const rating = parseInt(visitCard.querySelector<HTMLSelectElement>('.new-review-rating')!.value, 10);
        const content = visitCard.querySelector<HTMLTextAreaElement>('.new-review-content')!.value.trim();
        const wouldRevisit = visitCard.querySelector<HTMLInputElement>('.new-review-revisit')!.checked;
        if (!content) { showToast('내용을 입력해 주세요.', 'info'); return; }

        const detailFields = collectDetailFields(visitCard as HTMLElement, 'new-review');

        try {
          await createRoomReview(currentRoom.id, visitId, { rating, content, wouldRevisit, ...detailFields });
          currentRoom = await fetchRoom(currentRoom.id);
          if (areaId === 'restaurant-detail-area') renderRegionTab();
          await loadRestaurantDetail(rid, areaId);
          showToast('리뷰가 작성되었습니다.', 'success');
        } catch (err) { showToast(err instanceof Error ? err.message : '리뷰 작성에 실패했습니다.'); }
      });
    }

    // 리뷰 삭제
    for (const btn of area.querySelectorAll<HTMLButtonElement>('.delete-rev-btn')) {
      btn.addEventListener('click', async () => {
        if (!await showDangerConfirm('이 리뷰를 삭제하시겠습니까?')) return;
        try {
          await deleteRoomReview(currentRoom.id, btn.dataset.revId!);
          currentRoom = await fetchRoom(currentRoom.id);
          if (areaId === 'restaurant-detail-area') renderRegionTab();
          await loadRestaurantDetail(rid, areaId);
        } catch { showToast('리뷰 삭제에 실패했습니다.'); }
      });
    }

    // 리뷰 수정
    for (const btn of area.querySelectorAll<HTMLButtonElement>('.edit-rev-btn')) {
      btn.addEventListener('click', () => {
        const revId = btn.dataset.revId!;
        const origRating = btn.dataset.rating!;
        const origContent = btn.dataset.content!;
        const origRevisit = btn.dataset.revisit === 'true';
        const card = area.querySelector<HTMLElement>(`.room-review-card[data-rev-id="${revId}"]`)!;

        if (card.querySelector('.review-form')) return;

        const ratingOptions = [1, 2, 3, 4, 5]
          .map((v) => `<option value="${v}" ${v === Number(origRating) ? 'selected' : ''}>${v}점</option>`)
          .join('');

        const setSelected = (val: string) => [1, 2, 3, 4, 5].map((v) => `<option value="${v}" ${v === Number(val) ? 'selected' : ''}>${v}</option>`).join('');

        card.insertAdjacentHTML('beforeend', `
          <div class="review-form">
            <select class="edit-rating">${ratingOptions}</select>
            <textarea class="edit-content">${escapeHtml(origContent)}</textarea>
            <label class="revisit-toggle"><input type="checkbox" class="edit-revisit" ${origRevisit ? 'checked' : ''} /> 재방문 의사 있음</label>
            <details class="review-detail-fields">
              <summary>세부 평점 (선택)</summary>
              <div class="detail-rating-grid">
                <label>맛 <select class="edit-taste"><option value="">-</option>${setSelected(btn.dataset.taste || '')}</select></label>
                <label>가성비 <select class="edit-value"><option value="">-</option>${setSelected(btn.dataset.value || '')}</select></label>
                <label>서비스 <select class="edit-service"><option value="">-</option>${setSelected(btn.dataset.service || '')}</select></label>
                <label>청결 <select class="edit-cleanliness"><option value="">-</option>${setSelected(btn.dataset.cleanliness || '')}</select></label>
                <label>접근성 <select class="edit-accessibility"><option value="">-</option>${setSelected(btn.dataset.accessibility || '')}</select></label>
              </div>
              <input type="text" class="edit-fav-menu" placeholder="다시 먹을 메뉴" maxlength="200" value="${escapeHtml(btn.dataset.favMenu || '')}" />
              <input type="text" class="edit-try-menu" placeholder="다음에 먹을 메뉴" maxlength="200" value="${escapeHtml(btn.dataset.tryMenu || '')}" />
            </details>
            <div style="display:flex;gap:0.5rem;">
              <button type="button" class="btn-primary-sm save-edit-btn">저장</button>
              <button type="button" class="btn-outline-sm cancel-edit-btn">취소</button>
            </div>
          </div>
        `);

        card.querySelector('.save-edit-btn')!.addEventListener('click', async () => {
          const newRating = parseInt(card.querySelector<HTMLSelectElement>('.edit-rating')!.value, 10);
          const newContent = card.querySelector<HTMLTextAreaElement>('.edit-content')!.value.trim();
          const newRevisit = card.querySelector<HTMLInputElement>('.edit-revisit')!.checked;
          if (!newContent) { showToast('내용을 입력해 주세요.', 'info'); return; }

          const detailFields = collectDetailFields(card, 'edit');

          try {
            await updateRoomReview(currentRoom.id, revId, { rating: newRating, content: newContent, wouldRevisit: newRevisit, ...detailFields });
            currentRoom = await fetchRoom(currentRoom.id);
            if (areaId === 'restaurant-detail-area') renderRegionTab();
            await loadRestaurantDetail(rid, areaId);
            showToast('리뷰가 수정되었습니다.', 'success');
          } catch { showToast('수정에 실패했습니다.'); }
        });

        card.querySelector('.cancel-edit-btn')!.addEventListener('click', () => {
          card.querySelector('.review-form')!.remove();
        });
      });
    }
  }

  // ─── 초기화 ───

  (async () => {
    const params = new URLSearchParams(location.search);
    const id = params.get('id');

    if (!id) {
      loadingMsg.hidden = true;
      errorMsg.textContent = '방 ID가 없습니다.';
      errorMsg.hidden = false;
      return;
    }

    try {
      const [user, room] = await Promise.all([
        fetchCurrentUser(),
        fetchRoom(id),
      ]);

      if (!user) {
        loadingMsg.hidden = true;
        errorMsg.textContent = '로그인이 필요합니다.';
        errorMsg.hidden = false;
        return;
      }

      currentUser = user;
      currentRoom = room;
      loadingMsg.hidden = true;
      renderPage();
    } catch {
      loadingMsg.hidden = true;
      errorMsg.textContent = '방 정보를 불러올 수 없습니다.';
      errorMsg.hidden = false;
    }
  })();
</script>
