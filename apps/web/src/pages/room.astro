      </div>` : '';

    // ── 멤버 행동 분석 ──
    const behaviorHtml = memberBehaviors && memberBehaviors.length > 0 ? `
      <div class="stat-section">
        <h3 class="stat-section-title">멤버 행동 분석</h3>
        ${memberBehaviors.map((m) => {
          const tags: string[] = [];
          // 탐험가 vs 단골러
          if (m.explorerRate !== null) {
            if (m.explorerRate >= 80) tags.push('<span class="behavior-tag explorer" title="방문한 식당 중 ' + m.explorerRate + '%가 새로운 곳이에요">🧭 탐험가 ' + m.explorerRate + '%</span>');
            else if (m.explorerRate <= 30) tags.push('<span class="behavior-tag regular" title="같은 식당을 자주 재방문해요 (새 식당 ' + m.explorerRate + '%)">🏠 단골러 ' + (100 - m.explorerRate) + '%</span>');
            else tags.push('<span class="behavior-tag balanced" title="새로운 곳과 단골집을 골고루 다녀요">⚖️ 균형파 ' + m.explorerRate + '% 탐험</span>');
          }
          // 카테고리 편식
          if (m.categoryBias) {
            if (m.categoryBias.rate !== null && m.categoryBias.rate >= 60) {
              tags.push('<span class="behavior-tag picky" title="전체 방문의 ' + m.categoryBias.rate + '%가 ' + escapeHtml(m.categoryBias.category) + '이에요">🍽️ ' + escapeHtml(m.categoryBias.category) + ' 올인 ' + m.categoryBias.rate + '%</span>');
            } else if (m.categoryBias.uniqueCategories >= 5) {
              tags.push('<span class="behavior-tag diverse" title="' + m.categoryBias.uniqueCategories + '가지 다양한 카테고리를 경험했어요">🌈 잡식성 (' + m.categoryBias.uniqueCategories + '종)</span>');
            }
          }
          // 평가 성향
          if (m.ratingTendency) {
            tags.push('<span class="behavior-tag tendency" title="세부 평점 중 ' + m.ratingTendency.generousOn + ' 항목에 가장 높은 점수(평균 ' + m.ratingTendency.generousAvg + ')를 줘요">👍 ' + m.ratingTendency.generousOn + '에 후함 ' + m.ratingTendency.generousAvg + '</span>');
            tags.push('<span class="behavior-tag tendency-strict" title="세부 평점 중 ' + m.ratingTendency.strictOn + ' 항목에 가장 낮은 점수(평균 ' + m.ratingTendency.strictAvg + ')를 줘요">👎 ' + m.ratingTendency.strictOn + '에 엄격 ' + m.ratingTendency.strictAvg + '</span>');
          }
          // 리뷰 성실도
          if (m.reviewDiligence !== null) {
            if (m.reviewDiligence >= 90) tags.push('<span class="behavior-tag diligent" title="방문의 ' + m.reviewDiligence + '%에 리뷰를 남겼어요. 꾸준한 기록가!">✍️ 리뷰 개근 ' + m.reviewDiligence + '%</span>');
            else if (m.reviewDiligence <= 40) tags.push('<span class="behavior-tag lazy" title="방문의 ' + m.reviewDiligence + '%만 리뷰를 남겼어요">😴 귀차니즘 ' + m.reviewDiligence + '%</span>');
            else tags.push('<span class="behavior-tag" title="방문의 ' + m.reviewDiligence + '%에 리뷰를 남겼어요">✍️ 리뷰율 ' + m.reviewDiligence + '%</span>');
          }
          // 주말파 vs 평일파
          if (m.dayPreference) {
            if (m.dayPreference.type === 'weekend') tags.push('<span class="behavior-tag weekend" title="주로 주말에 맛집을 방문해요">🌅 주말파</span>');
            else if (m.dayPreference.type === 'weekday') tags.push('<span class="behavior-tag weekday" title="주로 평일에 맛집을 방문해요">💼 평일파</span>');
          }
          if (tags.length === 0) return '';
          return '<div class="behavior-member"><div class="behavior-member-name">' + escapeHtml(m.nickname) + '</div><div class="behavior-tags">' + tags.join('') + '</div></div>';
        }).filter(Boolean).join('')}
      </div>` : '';

    // ── 베스트 콤비 ──
    const comboHtml = bestCombos && bestCombos.length > 0 ? `
      <div class="stat-section">
        <h3 class="stat-section-title">베스트 맛집 메이트</h3>
        ${bestCombos.map((c, i) => `
          <div class="stat-bar-row">
            <span class="stat-bar-label" style="min-width:20px;font-weight:600;">${['🥇','🥈','🥉'][i] || (i+1)}</span>
            <span style="flex:1;font-size:0.82rem;">${escapeHtml(c.nickA)} & ${escapeHtml(c.nickB)}</span>
            <span style="font-size:0.82rem;font-weight:600;">${c.count}회 동행</span>
          </div>`).join('')}
      </div>` : '';

    // ── 방 행동 분석 ──
    const roomBehaviorItems: string[] = [];

    // 활성도 트렌드
    if (activityTrend) {
      const icon = activityTrend.changeRate !== null
        ? (activityTrend.changeRate > 0 ? '📈' : activityTrend.changeRate < 0 ? '📉' : '➡️')
        : '🆕';
      const label = activityTrend.changeRate !== null
        ? (activityTrend.changeRate > 0 ? '활성도 상승 +' + activityTrend.changeRate + '%' : activityTrend.changeRate < 0 ? '소강 상태 ' + activityTrend.changeRate + '%' : '유지 중')
        : '최근 3개월 ' + activityTrend.recent + '회 방문';
      roomBehaviorItems.push(`<div class="room-behavior-item">${icon} <strong>${label}</strong><span style="font-size:0.72rem;color:#999;margin-left:0.4rem;">최근 ${activityTrend.recent}회 vs 이전 ${activityTrend.previous}회</span></div>`);
    }

    // 평점 인플레이션
    if (ratingInflation) {
      const icon = ratingInflation.change > 0 ? '😊' : ratingInflation.change < 0 ? '🧐' : '😐';
      const label = ratingInflation.change > 0 ? '점점 후한 평가' : ratingInflation.change < 0 ? '점점 엄격한 평가' : '일관된 평가';
      roomBehaviorItems.push(`<div class="room-behavior-item">${icon} <strong>${label}</strong><span style="font-size:0.72rem;color:#999;margin-left:0.4rem;">초반 ${ratingInflation.earlyAvg} → 최근 ${ratingInflation.lateAvg} (${ratingInflation.change > 0 ? '+' : ''}${ratingInflation.change})</span></div>`);
    }

    // 카테고리 다양성
    if (diversityIndex !== null) {
      const icon = diversityIndex >= 70 ? '🌈' : diversityIndex >= 40 ? '🍽️' : '🎯';
      const label = diversityIndex >= 70 ? '미식 탐험대' : diversityIndex >= 40 ? '적당한 다양성' : '편식 방';
      roomBehaviorItems.push(`<div class="room-behavior-item">${icon} <strong>${label}</strong><span style="font-size:0.72rem;color:#999;margin-left:0.4rem;">다양성 지수 ${diversityIndex}%</span></div>`);
    }

    // 웨이팅 감수
    if (waitTolerance !== null && summary.totalVisits >= 3) {
      const icon = waitTolerance >= 50 ? '⏰' : '🏃';
      const label = waitTolerance >= 50 ? '줄서기 마니아 ' + waitTolerance + '%' : '노웨이팅주의 ' + (100 - waitTolerance) + '%';
      roomBehaviorItems.push(`<div class="room-behavior-item">${icon} <strong>${label}</strong></div>`);
    }

    // 피크 시즌
    if (peakMonth && monthlyVisits.length > 1) {
      roomBehaviorItems.push(`<div class="room-behavior-item">🔥 <strong>${peakMonth.month.slice(2)} 폭발적 활동</strong><span style="font-size:0.72rem;color:#999;margin-left:0.4rem;">${peakMonth.count}회 방문</span></div>`);
    }

    const roomBehaviorHtml = roomBehaviorItems.length > 0 ? `
      <div class="stat-section">
        <h3 class="stat-section-title">방 행동 분석</h3>
        ${roomBehaviorItems.join('')}
      </div>` : '';

    // ── 오래 안 간 식당 ──
    const staleHtml = staleRestaurants && staleRestaurants.length > 0 ? `
      <div class="stat-section">
        <h3 class="stat-section-title">오랫동안 안 간 식당</h3>
        ${staleRestaurants.map((r) => `
          <div class="stat-bar-row">
            <span style="flex:1;font-size:0.82rem;">${escapeHtml(r.name)}</span>
            <span style="font-size:0.78rem;color:#dc2626;font-weight:600;">${r.daysSince}일째 미방문</span>
          </div>`).join('')}
      </div>` : '';

    panel.innerHTML = `
      ${summaryHtml}
      ${unreviewedHtml}
      ${roomBehaviorHtml}
      ${behaviorHtml}
      ${comboHtml}
      ${memberHtml}
      ${topRatedHtml}
      ${bottomRatedHtml}
      ${revisitHtml}
      ${staleHtml}
      ${radarHtml}
      ${catHtml}
      ${regionHtml}
      ${dayHtml}
      ${monthHtml}
      ${waitHtml}
    `;

    // Chart.js 렌더링
    try {
      const { Chart, BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend } = await import('chart.js');
      Chart.register(BarController, BarElement, CategoryScale, LinearScale, Tooltip, Legend);

      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      const gridColor = isDark ? 'rgba(255,255,255,0.08)' : 'rgba(0,0,0,0.06)';
      const textColor = isDark ? '#a1a1aa' : '#71717a';

      // 월별 바 차트
      const monthCanvas = panel.querySelector('#chart-monthly') as HTMLCanvasElement | null;
      if (monthCanvas && monthlyVisits.length > 0) {
        const latestYear = [...new Set(monthlyVisits.map((m) => m.month.slice(0, 4)))].sort().reverse()[0];
        const labels = ['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
        const data = labels.map((_, i) => {
          const key = `${latestYear}-${String(i + 1).padStart(2, '0')}`;
          return monthlyVisits.find((m) => m.month === key)?.count || 0;
        });
        new Chart(monthCanvas, {
          type: 'bar',
          data: { labels, datasets: [{ data, backgroundColor: isDark ? '#f4f4f5' : '#1a1a1a', borderRadius: 4, barPercentage: 0.6 }] },
          options: { responsive: true, maintainAspectRatio: true, aspectRatio: 2, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { color: textColor, stepSize: 1 }, grid: { color: gridColor } }, x: { ticks: { color: textColor }, grid: { display: false } } } },
        });
      }
    } catch (chartErr) {
      console.warn('Chart.js 로드 실패:', chartErr);
    }

    } catch (renderErr) {
      console.error('[stats] render error:', renderErr);
      panel.innerHTML = `<p class="empty-text">통계 렌더링 중 오류가 발생했습니다: ${renderErr instanceof Error ? renderErr.message : String(renderErr)}</p>`;
    }
  }

  // ─── 식당 탭 ───

  // ─── 투표 탭 ───

  async function _renderPollTab() {
    const panel = document.getElementById('tab-poll');
    if (!panel) return;

    panel.innerHTML = '<p class="empty-text">투표를 불러오는 중...</p>';

    let polls: Poll[] = [];
    try {
      polls = await fetchPolls(currentRoom.id);
    } catch {
      panel.innerHTML = '<p class="empty-text">투표를 불러올 수 없습니다. 새로고침 후 다시 시도해주세요.</p>';
      return;
    }

    const totalVoters = (poll: Poll) => {
      const voters = new Set<string>();
      for (const opt of poll.options) for (const v of opt.votes) voters.add(v.userId);
      return voters.size;
    };

    const myVote = (poll: Poll) => {
      for (const opt of poll.options) {
        if (opt.votes.some((v) => v.userId === currentUser.id)) return opt.id;
      }
      return null;
    };

    const createFormHtml = `
      <div class="poll-create-form">
        <h3>🗳️ 새 투표 만들기</h3>
        <input type="text" id="poll-title" class="poll-title-input" placeholder="투표 제목 (예: 오늘 뭐 먹지?)" maxlength="200" />
        <div id="poll-options-list" class="poll-options-list">
          <input type="text" class="poll-option-input" placeholder="선택지 1" maxlength="200" />
          <input type="text" class="poll-option-input" placeholder="선택지 2" maxlength="200" />
        </div>
        <div class="poll-form-actions">
          <button type="button" class="btn-outline-sm" id="poll-add-option">+ 선택지 추가</button>
          <button type="button" class="btn-primary-sm" id="poll-submit">투표 만들기</button>
        </div>
      </div>`;

    const activePolls = polls.filter((p) => p.status === 'active');
    const closedPolls = polls.filter((p) => p.status === 'closed');

    const renderPollCard = (poll: Poll) => {
      const total = poll.options.reduce((s, o) => s + o.votes.length, 0);
      const myChoice = myVote(poll);
      const isCreator = poll.createdBy.id === currentUser.id;

      return `
        <div class="poll-card ${poll.status === 'closed' ? 'poll-closed' : ''}">
          <div class="poll-card-header">
            <span class="poll-card-title">${escapeHtml(poll.title)}</span>
            ${poll.status === 'closed' ? '<span class="poll-status-badge closed">마감</span>' : '<span class="poll-status-badge active">진행중</span>'}
          </div>
          <div class="poll-card-meta">${escapeHtml(poll.createdBy.nickname)} · ${formatDate(poll.createdAt)} · ${totalVoters(poll)}명 참여</div>
          <div class="poll-options">
            ${poll.options.map((opt) => {
              const pct = total > 0 ? Math.round((opt.votes.length / total) * 100) : 0;
              const isMyVote = myChoice === opt.id;
              const canVote = poll.status === 'active' && !isMyVote;
              return `
                <div class="poll-option-row ${isMyVote ? 'my-vote' : ''} ${canVote ? 'votable' : ''}"
                     ${canVote ? `data-poll-id="${poll.id}" data-option-id="${opt.id}"` : ''}>
                  <div class="poll-option-bar" style="width:${pct}%"></div>
                  <span class="poll-option-label">${escapeHtml(opt.label)}${isMyVote ? ' ✓' : ''}</span>
                  <span class="poll-option-pct">${opt.votes.length}표 (${pct}%)</span>
                </div>`;
            }).join('')}
          </div>
          ${myChoice && poll.status === 'active' ? '<p class="poll-revote-hint">다른 선택지를 눌러 투표를 변경할 수 있습니다</p>' : ''}
          ${isCreator && poll.status === 'active' ? `<button type="button" class="btn-outline-sm poll-close-btn" data-poll-id="${poll.id}">투표 마감</button>` : ''}
        </div>`;
    };

    const activePollsHtml = activePolls.length > 0
      ? `<h3 class="section-subtitle">진행중인 투표</h3>${activePolls.map(renderPollCard).join('')}`
      : '';

    const closedPollsHtml = closedPolls.length > 0
      ? `<h3 class="section-subtitle">마감된 투표</h3>${closedPolls.map(renderPollCard).join('')}`
      : '';

    const emptyHtml = polls.length === 0 ? '<div class="empty-state"><div class="empty-state-icon">&#x1F5F3;&#xFE0F;</div><div class="empty-state-title">아직 투표가 없어요</div><div class="empty-state-desc">멤버들과 함께 다음 맛집을 정해보세요!</div></div>' : '';

    panel.innerHTML = createFormHtml + emptyHtml + activePollsHtml + closedPollsHtml;

    // 선택지 추가
    document.getElementById('poll-add-option')?.addEventListener('click', () => {
      const list = document.getElementById('poll-options-list');
      if (!list) return;
      const count = list.querySelectorAll('.poll-option-input').length;
      if (count >= 10) { showToast('선택지는 최대 10개까지 가능합니다.'); return; }
      const input = document.createElement('input');
      input.type = 'text';
      input.className = 'poll-option-input';
      input.placeholder = `선택지 ${count + 1}`;
      input.maxLength = 200;
      list.appendChild(input);
    });

    // 투표 생성
    document.getElementById('poll-submit')?.addEventListener('click', async () => {
      const title = (document.getElementById('poll-title') as HTMLInputElement).value.trim();
      const optionInputs = document.querySelectorAll<HTMLInputElement>('.poll-option-input');
      const options = Array.from(optionInputs).map((i) => i.value.trim()).filter(Boolean);

      if (!title) { showToast('투표 제목을 입력해주세요.'); return; }
      if (options.length < 2) { showToast('선택지를 2개 이상 입력해주세요.'); return; }

      try {
        await createPoll(currentRoom.id, { title, options: options.map((label) => ({ label })) });
        showToast('투표가 생성되었습니다!', 'success');
        renderPollTab();
      } catch { showToast('투표 생성에 실패했습니다.'); }
    });

    // 투표 참여
    for (const row of document.querySelectorAll<HTMLElement>('.poll-option-row.votable')) {
      row.addEventListener('click', async () => {
        const pollId = row.dataset.pollId!;
        const optionId = row.dataset.optionId!;
        try {
          await votePoll(currentRoom.id, pollId, optionId);
          showToast('투표 완료!', 'success');
          renderPollTab();
        } catch (err) { showToast(err instanceof Error ? err.message : '투표에 실패했습니다.'); }
      });
    }

    // 투표 마감
    for (const btn of document.querySelectorAll<HTMLButtonElement>('.poll-close-btn')) {
      btn.addEventListener('click', async () => {
        if (!await showConfirm('이 투표를 마감하시겠습니까?')) return;
        try {
          await closePoll(currentRoom.id, btn.dataset.pollId!);
          showToast('투표가 마감되었습니다.', 'success');
          renderPollTab();
        } catch { showToast('투표 마감에 실패했습니다.'); }
      });
    }
  }

