      listHtml = '<p class="empty-text">해당 카테고리의 식당이 없습니다.</p>';
    } else {
      listHtml = filtered
        .map(
          (r) => `
          <div class="room-restaurant-card" data-rid="${r.id}">
            <div class="room-rest-name">${escapeHtml(r.name)}${r.avgRating ? ` <span class="room-rest-rating">${renderStars(Math.round(r.avgRating))} ${r.avgRating}</span>` : ''}</div>
            <div class="room-rest-meta">${escapeHtml(r.address)} · ${escapeHtml(r.category)}</div>
            <div class="room-rest-footer">
              <span class="room-rest-added-by">${escapeHtml(r.addedBy.nickname)}</span>
