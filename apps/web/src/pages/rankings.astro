---
export const prerender = false;
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSlot from '@/components/AdSlot.astro';

const now = new Date();
const year = now.getFullYear();
const month = now.getMonth() + 1;
---

<BaseLayout title="맛집 랭킹 — 진짜 리뷰 기반 최고의 맛집 순위" description="진짜 사용자 평가와 리뷰를 기반으로 선정된 맛집 랭킹. 솔직한 맛집 후기로 선정된 최고의 맛집들을 확인하세요.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "맛집 랭킹 - 무모한 시식가",
      "description": "사용자 평가와 리뷰를 기반으로 선정된 최고의 맛집들",
      "url": (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '') + "/rankings",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '') },
        { "@type": "ListItem", "position": 2, "name": "맛집 랭킹", "item": (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '') + "/rankings" },
      ]
    })} />
  </Fragment>

  <div class="rankings-page">
    <section class="rankings-hero">
      <span class="rankings-badge">{year}년 {month}월 기준</span>
      <h1>맛집 랭킹</h1>
      <p class="rankings-desc">사용자 평가와 리뷰를 기반으로 선정된 최고의 맛집들</p>
    </section>

    <div id="rankings-loading" class="loading-msg">불러오는 중...</div>
    <div id="rankings-error" class="error-msg" hidden></div>
    <div id="rankings-content" hidden></div>

    <AdSlot slot="rankings-bottom" position="bottom" format="horizontal" />

    <section class="rankings-seo">
      <h2>유저 활동 기반 맛집 랭킹</h2>
      <p>무모한 시식가에서 활동하는 유저들의 실제 방문 기록과 리뷰를 기반으로 선정된 맛집 랭킹입니다.
        평점과 리뷰 수를 종합적으로 고려하여 순위를 매깁니다.</p>
    </section>
  </div>
</BaseLayout>

<style is:global>
  .rankings-page {
    max-width: 800px;
    margin: 0 auto;
  }

  .rankings-hero {
    text-align: center;
    padding: 2.5rem 0 1.5rem;
    background: var(--bg-hover);
    border-radius: 16px;
    margin-bottom: 2rem;
  }

  .rankings-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: var(--bg-card);
    color: var(--text-sub);
    border: 1px solid var(--border);
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 100px;
    margin-bottom: 0.75rem;
  }

  .rankings-hero h1 {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--text-heading);
    margin-bottom: 0.4rem;
    letter-spacing: -0.03em;
  }

  .rankings-desc {
    font-size: 0.9rem;
    color: var(--text-sub);
  }

  .loading-msg, .error-msg {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .error-msg { color: #dc2626; }

  /* 랭킹 리스트 */
  .ranking-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .ranking-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    transition: box-shadow 0.15s;
  }

  .ranking-item:hover {
    box-shadow: 0 2px 10px var(--shadow);
  }

  .ranking-rank {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 700;
    flex-shrink: 0;
    background: var(--bg-hover);
    color: var(--text-muted);
  }

  .ranking-rank.rank-1 {
    background: #fef3c7;
    color: #92400e;
    font-size: 1.3rem;
  }

  .ranking-rank.rank-2 {
    background: #f1f5f9;
    color: #475569;
    font-size: 1.3rem;
  }

  .ranking-rank.rank-3 {
    background: #fef3c7;
    color: #a16207;
    font-size: 1.3rem;
  }

  [data-theme="dark"] .ranking-rank.rank-1 {
    background: #422006;
    color: #fde68a;
  }

  [data-theme="dark"] .ranking-rank.rank-2 {
    background: #1e293b;
    color: #cbd5e1;
  }

  [data-theme="dark"] .ranking-rank.rank-3 {
    background: #451a03;
    color: #fcd34d;
  }

  .ranking-info {
    flex: 1;
    min-width: 0;
  }

  .ranking-name-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.2rem;
  }

  .ranking-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-heading);
  }

  .ranking-category {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--text-sub);
    flex-shrink: 0;
    white-space: nowrap;
  }

  .ranking-address {
    font-size: 0.78rem;
    color: var(--text-muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ranking-stat {
    text-align: right;
    flex-shrink: 0;
  }

  .ranking-rating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-heading);
    justify-content: flex-end;
  }

  .ranking-rating-star {
    color: #f59e0b;
  }

  .ranking-review-count {
    font-size: 0.72rem;
    color: var(--text-muted);
    text-align: right;
    margin-top: 0.15rem;
  }

  /* 통계 섹션 */
  .rankings-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    padding: 2.5rem 1rem;
    margin-bottom: 1.5rem;
  }

  .stat-item {
    text-align: center;
    position: relative;
  }

  .stat-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: -0.75rem;
    top: 10%;
    height: 80%;
    width: 1px;
    background: var(--border);
  }

  .stat-value {
    font-size: 2rem;
    font-weight: 800;
    color: var(--text-heading);
    letter-spacing: -0.02em;
  }

  .stat-label {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
  }

  .rankings-seo {
    margin-top: 1rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.7;
  }

  .rankings-seo h2 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.5rem;
  }

  .rankings-seo p { margin-bottom: 0.4rem; }
  .rankings-seo p:last-child { margin-bottom: 0; }

  @media (max-width: 600px) {
    .ranking-item {
      padding: 0.85rem 1rem;
      gap: 0.75rem;
    }

    .ranking-rank {
      width: 36px;
      height: 36px;
      font-size: 0.95rem;
    }

    .ranking-rank.rank-1,
    .ranking-rank.rank-2,
    .ranking-rank.rank-3 {
      font-size: 1.1rem;
    }

    .stat-value {
      font-size: 1.5rem;
    }
  }
</style>

<script>
  import { fetchDiscover, fetchPlatformStats } from '@/lib/api';

  async function initRankingsPage() {
    const loadingEl = document.getElementById('rankings-loading');
    const errorEl = document.getElementById('rankings-error');
    const contentEl = document.getElementById('rankings-content');
    if (!loadingEl || !errorEl || !contentEl) return;

    try {
      const [discoverData, platformStats] = await Promise.all([
        fetchDiscover(),
        fetchPlatformStats(),
      ]);

      loadingEl.hidden = true;
      contentEl.hidden = false;

      // 공개 방 TOP 랭킹
      const topRooms = discoverData.topRooms || [];
      const topRated = discoverData.topRated || [];

      // 공개 방 랭킹
      const roomsHtml = topRooms.length === 0
        ? '<p style="text-align:center;padding:2rem;color:var(--text-muted);">아직 공개된 방이 없습니다.</p>'
        : `<h3 style="font-size:1rem;font-weight:700;margin-bottom:0.75rem;color:var(--text-heading);">인기 공개 방</h3>
           <div class="ranking-list">${topRooms.map((r, i) => {
            const rank = i + 1;
            const rankClass = rank <= 3 ? ` rank-${rank}` : '';
            const rankContent = rank === 1 ? '👑' : String(rank);
            return `
              <a href="/rooms/public/${r.id}" class="ranking-item" style="text-decoration:none;color:inherit;">
                <div class="ranking-rank${rankClass}">${rankContent}</div>
                <div class="ranking-info">
                  <div class="ranking-name">${r.name}</div>
                  <div class="ranking-address">식당 ${r.restaurantCount}개 · 멤버 ${r.memberCount}명</div>
                </div>
              </a>`;
          }).join('')}</div>`;

      // 고평점 식당 리스트
      const restaurantsHtml = topRated.length === 0 ? ''
        : `<h3 style="font-size:1rem;font-weight:700;margin:1.5rem 0 0.75rem;color:var(--text-heading);">고평점 맛집</h3>
           <div class="ranking-list">${topRated.slice(0, 10).map((r, i) => {
            const rank = i + 1;
            const rankClass = rank <= 3 ? ` rank-${rank}` : '';
            const rankContent = rank === 1 ? '👑' : String(rank);
            const shortAddr = r.address.replace(/^(\S+[시도])\s+(\S+[시군구]).*$/, '$1 $2').replace(/^(\S+)\s*$/, '$1');
            return `
              <a href="/rooms/public/${r.roomId}" class="ranking-item" style="text-decoration:none;color:inherit;">
                <div class="ranking-rank${rankClass}">${rankContent}</div>
                <div class="ranking-info">
                  <div class="ranking-name-row">
                    <div class="ranking-name">${r.name}</div>
                    <span class="ranking-category">${r.category}</span>
                  </div>
                  <div class="ranking-address">${shortAddr}</div>
                </div>
                <div class="ranking-stat">
                  <div class="ranking-rating">
                    <span class="ranking-rating-star">★</span>
                    ${r.avgRating}
                  </div>
                  <div class="ranking-review-count">${r.reviewCount}개 리뷰</div>
                </div>
              </a>`;
          }).join('')}</div>`;

      // 통계 섹션
      const statsHtml = `
        <div class="rankings-stats">
          <div class="stat-item">
            <div class="stat-value">${platformStats.restaurantCount}+</div>
            <div class="stat-label">등록된 맛집</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">${platformStats.reviewCount.toLocaleString()}+</div>
            <div class="stat-label">누적 리뷰</div>
          </div>
          <div class="stat-item">
            <div class="stat-value">${platformStats.roomCount}+</div>
            <div class="stat-label">개의 방</div>
          </div>
        </div>
      `;

      contentEl.innerHTML = roomsHtml + restaurantsHtml + statsHtml;
    } catch (err) {
      loadingEl.hidden = true;
      errorEl.hidden = false;
      errorEl.textContent = err instanceof Error ? err.message : '랭킹을 불러올 수 없습니다.';
    }
  }

  document.addEventListener('astro:page-load', initRankingsPage);
</script>
