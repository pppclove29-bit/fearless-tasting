---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSlot from '@/components/AdSlot.astro';
export const prerender = false;

const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';

interface DiscoverItem {
  name: string;
  address: string;
  category: string;
  avgRating: number;
  reviewCount: number;
  roomId: string;
}

let topRated: DiscoverItem[] = [];
try {
  const res = await fetch(`${API_BASE}/rooms/discover`);
  if (res.ok) {
    const data = await res.json() as { topRated?: DiscoverItem[] };
    topRated = data.topRated ?? [];
  }
} catch {
  /* fallback */
}
---

<BaseLayout title="맛집 추천 — 광고 없는 실제 방문 데이터 기반 맛집 리스트" description="실제 유저 방문 데이터로 선정한 맛집 추천. 고평점 맛집, 재방문율 높은 맛집 리스트를 확인하고 나만의 맛집 기록을 시작하세요." ogImageAlt="무모한 시식가 맛집 추천 — 실제 방문 데이터 기반 고평점 맛집과 재방문 맛집 리스트">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "맛집 추천 - 무모한 시식가",
      "description": "유저들이 선택한 인기 맛집, 고평점 맛집, 재방문 맛집 리스트",
      "url": (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '') + "/discover",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "맛집 추천", "item": siteUrl + "/discover" },
      ]
    })} />
    {topRated.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ItemList",
        "name": "고평점 맛집 추천",
        "itemListOrder": "https://schema.org/ItemListOrderDescending",
        "numberOfItems": topRated.slice(0, 12).length,
        "itemListElement": topRated.slice(0, 12).map((r, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "item": {
            "@type": "FoodEstablishment",
            "name": r.name,
            "address": r.address,
            "servesCuisine": r.category,
            "url": `${siteUrl}/rooms/public/${r.roomId}`,
            ...(r.reviewCount > 0 ? {
              "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": r.avgRating,
                "reviewCount": r.reviewCount,
                "bestRating": 5,
                "worstRating": 0.5,
              }
            } : {}),
          },
        })),
      })} />
    )}
  </Fragment>

  <div class="discover-page">
    <section class="discover-hero">
      <span class="discover-badge">광고 없는 실유저 추천</span>
      <h1>진짜 후기 기반 맛집</h1>
      <p class="discover-desc">
        친구·가족·팀이 실제로 다녀오고 남긴 솔직한 리뷰로 선정된 맛집.<br/>
        광고·협찬 없이 방문 데이터만으로 만든 리스트입니다.<br/>
        <small style="color: var(--text-muted); font-size: 0.78rem;">※ 공개로 설정된 방의 데이터만 표시되며, 작성자 정보는 노출되지 않습니다.</small>
      </p>
      <div class="discover-hero-cta" id="discover-hero-cta">
        <a href="/login" class="discover-cta-btn" id="discover-cta-guest" hidden>
          내 맛집 리스트 만들기
        </a>
        <a href="/rooms" class="discover-cta-btn" id="discover-cta-auth" hidden>
          내 방으로 이동 →
        </a>
      </div>
    </section>

    <div class="discover-filters" id="discover-filters">
      <button type="button" class="filter-chip active" data-category="전체">전체</button>
    </div>

    <div id="discover-content">
      <div class="discover-loading">불러오는 중...</div>
    </div>

    <AdSlot slot="discover-bottom" position="bottom" format="horizontal" />

    <section class="public-rooms-section">
      <div class="public-rooms-header">
        <h2>👀 다른 사람 방 구경하기</h2>
        <a href="/rooms/public" class="public-rooms-more">전체 보기 →</a>
      </div>
      <p class="public-rooms-desc">실제 유저가 정리한 맛집 리스트를 그대로 엿보세요.</p>
      <div id="public-rooms-content">
        <div class="discover-loading">불러오는 중...</div>
      </div>
    </section>

    <section class="discover-seo">
      <h2>실제 방문 기반 맛집 추천</h2>
      <p>무모한 시식가는 친구, 연인, 가족과 함께 만드는 프라이빗 맛집 리뷰 플랫폼입니다.
        이 페이지에서는 <strong>방장이 공개로 설정한 방</strong>의 방문 기록과 리뷰만 노출되며, 비공개 방의 데이터는 절대 공개되지 않습니다.</p>
      <p>리뷰 작성자와 방 멤버 정보도 표시되지 않습니다. 안심하고 비공개 방을 운영하세요.</p>
      <p><strong>고평점 맛집</strong>은 최근 90일간 리뷰 평균 평점이 높은 식당, <strong>재방문 맛집</strong>은 유저들이 여러 번 다시 찾는 식당입니다.</p>
    </section>
  </div>
</BaseLayout>

<style is:global>
  .discover-page {
    max-width: 960px;
    margin: 0 auto;
  }

  .discover-hero {
    text-align: center;
    padding: 2.5rem 0 1.5rem;
    background: var(--bg-hover);
    border-radius: 16px;
    margin-bottom: 1.5rem;
  }

  .discover-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: var(--accent-bg);
    color: var(--text-heading);
    border: 1px solid var(--text-heading);
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 100px;
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .discover-hero h1 {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--text-heading);
    margin-bottom: 0.4rem;
    letter-spacing: -0.03em;
  }

  .discover-desc {
    font-size: 0.9rem;
    color: var(--text-sub);
    line-height: 1.6;
    margin: 0 0 1.25rem;
  }

  .discover-hero-cta {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .discover-cta-btn {
    display: inline-block;
    padding: 0.7rem 1.6rem;
    background: var(--text-heading);
    color: var(--bg);
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 12px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .discover-cta-btn:hover { opacity: 0.88; }

  .discover-filters {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .filter-chip {
    padding: 0.5rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 100px;
    background: var(--bg-card);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-sub);
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
  }

  .filter-chip:hover {
    border-color: var(--border-mid);
    color: var(--text-heading);
  }

  .filter-chip.active {
    background: var(--text-heading);
    color: var(--bg);
    border-color: var(--text-heading);
  }

  .discover-loading {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
  }

  .discover-empty {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .discover-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 768px) {
    .discover-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .discover-grid {
      grid-template-columns: 1fr;
    }
  }

  .discover-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.15s;
  }

  .discover-card:hover {
    box-shadow: 0 4px 16px var(--shadow);
    transform: translateY(-2px);
  }

  .card-body {
    padding: 1rem;
  }

  .card-category {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-sub);
    margin-bottom: 0.4rem;
  }

  .card-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.35rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-rating {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
    margin-bottom: 0.6rem;
  }

  .card-rating-star {
    color: #f59e0b;
  }

  .card-rating-value {
    font-weight: 700;
    color: var(--text-heading);
  }

  .card-rating-count {
    color: var(--text-muted);
    font-size: 0.78rem;
  }

  .card-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-bottom: 0.85rem;
  }

  .card-info-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .card-info-row svg {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  .card-info-text {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-room {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.4rem;
    padding-top: 0.4rem;
    border-top: 1px solid var(--border-light);
  }

  .discover-card {
    text-decoration: none;
    color: inherit;
  }

  /* 공개 방 구경하기 섹션 */
  .public-rooms-section { margin-top: 2.5rem; }
  .public-rooms-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.25rem;
  }
  .public-rooms-header h2 {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text-heading);
    margin: 0;
    letter-spacing: -0.02em;
  }
  .public-rooms-more {
    font-size: 0.82rem;
    color: var(--text-sub);
    text-decoration: none;
    font-weight: 600;
    white-space: nowrap;
  }
  .public-rooms-more:hover { color: var(--text-heading); }
  .public-rooms-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }
  .public-rooms-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
  }
  @media (max-width: 768px) {
    .public-rooms-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .public-rooms-grid { grid-template-columns: 1fr; }
  }
  .public-room-mini {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 0.85rem 0.95rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.1s;
  }
  .public-room-mini:hover {
    border-color: var(--text-heading);
    transform: translateY(-2px);
  }
  .public-room-mini-name {
    font-size: 0.95rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.25rem;
    letter-spacing: -0.01em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .public-room-mini-stats {
    font-size: 0.74rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
  }
  .public-room-mini-stats .stat-rating { color: var(--text-heading); font-weight: 700; }
  .public-room-mini-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }
  .public-room-mini-tag {
    font-size: 0.68rem;
    color: var(--text-sub);
    background: var(--bg-hover);
    padding: 0.15rem 0.45rem;
    border-radius: 100px;
  }

  .discover-seo {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 2rem;
  }

  .discover-seo h2 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--text-heading);
  }

  .discover-seo p {
    font-size: 0.82rem;
    color: var(--text-sub);
    line-height: 1.7;
    margin: 0 0 0.4rem;
  }

  .discover-seo p:last-child {
    margin-bottom: 0;
  }
</style>

<script>
  import { fetchDiscover, fetchPublicRooms, fetchCurrentUser } from '@/lib/api';
  import type { DiscoverResponse } from '@/lib/api';

  async function initDiscoverPage() {
    const contentEl = document.getElementById('discover-content');
    const filtersEl = document.getElementById('discover-filters');
    if (!contentEl || !filtersEl) return;

    // 로그인 여부에 따라 히어로 CTA 분기
    fetchCurrentUser().then((user) => {
      const guestCta = document.getElementById('discover-cta-guest');
      const authCta = document.getElementById('discover-cta-auth');
      if (user && authCta) authCta.hidden = false;
      else if (!user && guestCta) guestCta.hidden = false;
    }).catch(() => {
      const guestCta = document.getElementById('discover-cta-guest');
      if (guestCta) guestCta.hidden = false;
    });

    let data: DiscoverResponse | null = null;
    let currentCategory = '전체';

    function getCategories() {
      if (!data) return [];
      const cats = new Set<string>();
      data.topRated.forEach((item) => cats.add(item.category));
      return Array.from(cats);
    }

    function renderFilters() {
      const cats = getCategories();
      filtersEl.innerHTML = `
        <button type="button" class="filter-chip ${currentCategory === '전체' ? 'active' : ''}" data-category="전체">전체</button>
        ${cats.map((c) => `<button type="button" class="filter-chip ${currentCategory === c ? 'active' : ''}" data-category="${c}">${c}</button>`).join('')}
      `;

      for (const btn of filtersEl.querySelectorAll<HTMLButtonElement>('.filter-chip')) {
        btn.addEventListener('click', () => {
          currentCategory = btn.dataset.category ?? '전체';
          renderFilters();
          renderCards();
        });
      }
    }

    function renderCards() {
      if (!data) return;
      let items = data.topRated;
      if (currentCategory !== '전체') {
        items = items.filter((item) => item.category === currentCategory);
      }

      if (items.length === 0) {
        contentEl.innerHTML = '<div class="discover-empty">아직 공개된 맛집 데이터가 없습니다.<br/>방을 공개로 설정하면 여기에 표시됩니다.</div>';
        return;
      }

      contentEl.innerHTML = `<div class="discover-grid">${items.map((item) => {
        const shortAddr = item.address.replace(/^(\S+[시도])\s+(\S+[시군구]).*$/, '$1 $2').replace(/^(\S+)\s*$/, '$1');
        return `
          <a href="/rooms/public/${item.roomId}" class="discover-card">
            <div class="card-body">
              <span class="card-category">${item.category}</span>
              <div class="card-name">${item.name}</div>
              <div class="card-rating">
                <span class="card-rating-star"><svg style="display:inline-block;vertical-align:middle" width="14" height="14" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="#f59e0b" stroke="none"/></svg></span>
                <span class="card-rating-value">${item.avgRating}</span>
                <span class="card-rating-count">(${item.reviewCount})</span>
              </div>
              <div class="card-info">
                <div class="card-info-row">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <span class="card-info-text">${shortAddr}</span>
                </div>
              </div>
              <div class="card-room">${item.roomName}</div>
            </div>
          </a>`;
      }).join('')}</div>`;
    }

    try {
      data = await fetchDiscover();
      renderFilters();
      renderCards();
    } catch {
      contentEl.innerHTML = '<div class="discover-empty">맛집 추천을 불러올 수 없습니다.</div>';
    }

    // 공개 방 구경하기 섹션
    const publicRoomsEl = document.getElementById('public-rooms-content');
    if (publicRoomsEl) {
      try {
        const publicRooms = await fetchPublicRooms(1, 6);
        if (!publicRooms.data.length) {
          publicRoomsEl.innerHTML = '<div class="discover-empty">아직 공개된 방이 없습니다.</div>';
        } else {
          publicRoomsEl.innerHTML = `<div class="public-rooms-grid">${publicRooms.data.map((room) => {
            const rating = room.avgRating != null
              ? `<span class="stat-rating">★ ${room.avgRating.toFixed(1)}</span> · `
              : '';
            const tags = (room.topCategories || []).slice(0, 3).map((c) => `<span class="public-room-mini-tag">#${c}</span>`).join('');
            return `
              <a href="/rooms/public/${room.id}" class="public-room-mini">
                <div class="public-room-mini-name">${room.name}</div>
                <div class="public-room-mini-stats">${rating}맛집 ${room.restaurantCount}곳 · 리뷰 ${room.reviewCount}개</div>
                <div class="public-room-mini-tags">${tags}</div>
              </a>`;
          }).join('')}</div>`;
        }
      } catch {
        publicRoomsEl.innerHTML = '<div class="discover-empty">공개 방을 불러올 수 없습니다.</div>';
      }
    }
  }

  document.addEventListener('astro:page-load', initDiscoverPage);
</script>
