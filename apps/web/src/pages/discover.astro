---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSlot from '@/components/AdSlot.astro';
export const prerender = false;
---

<BaseLayout title="맛집 추천 — 광고 없는 실제 방문 데이터 기반 맛집 리스트" description="실제 유저 방문 데이터로 선정한 맛집 추천. 고평점 맛집, 재방문율 높은 맛집 리스트를 확인하고 나만의 맛집 기록을 시작하세요." ogImageAlt="무모한 시식가 맛집 추천 — 실제 방문 데이터 기반 고평점 맛집과 재방문 맛집 리스트">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "맛집 추천 - 무모한 시식가",
      "description": "유저들이 선택한 인기 맛집, 고평점 맛집, 재방문 맛집 리스트",
      "url": (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '') + "/discover",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '') },
        { "@type": "ListItem", "position": 2, "name": "맛집 추천", "item": (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '') + "/discover" },
      ]
    })} />
  </Fragment>

  <div class="discover-page">
    <section class="discover-hero">
      <span class="discover-badge">엄선된 맛집 리스트</span>
      <h1>맛집 목록</h1>
      <p class="discover-desc">지역별, 카테고리별 최고의 맛집을 찾아보세요</p>
    </section>

    <div class="discover-filters" id="discover-filters">
      <button type="button" class="filter-chip active" data-category="전체">전체</button>
    </div>

    <div id="discover-content">
      <div class="discover-loading">불러오는 중...</div>
    </div>

    <AdSlot slot="discover-bottom" position="bottom" format="horizontal" />

    <section class="discover-seo">
      <h2>실제 방문 기반 맛집 추천</h2>
      <p>무모한 시식가는 친구, 연인, 가족과 함께 만드는 프라이빗 맛집 리뷰 플랫폼입니다.
        이 페이지에서는 유저들의 실제 방문 기록과 리뷰를 기반으로 선정된 맛집 리스트를 확인할 수 있습니다.</p>
      <p><strong>고평점 맛집</strong>은 최근 90일간 리뷰 평균 평점이 높은 식당, <strong>재방문 맛집</strong>은 유저들이 여러 번 다시 찾는 식당입니다.</p>
    </section>
  </div>
</BaseLayout>

<style is:global>
  .discover-page {
    max-width: 960px;
    margin: 0 auto;
  }

  .discover-hero {
    text-align: center;
    padding: 2.5rem 0 1.5rem;
    background: var(--bg-hover);
    border-radius: 16px;
    margin-bottom: 1.5rem;
  }

  .discover-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: var(--accent-bg);
    color: var(--text-heading);
    border: 1px solid var(--text-heading);
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 100px;
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .discover-hero h1 {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--text-heading);
    margin-bottom: 0.4rem;
    letter-spacing: -0.03em;
  }

  .discover-desc {
    font-size: 0.9rem;
    color: var(--text-sub);
  }

  .discover-filters {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .filter-chip {
    padding: 0.5rem 1.1rem;
    border: 1px solid var(--border);
    border-radius: 100px;
    background: var(--bg-card);
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-sub);
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
  }

  .filter-chip:hover {
    border-color: var(--border-mid);
    color: var(--text-heading);
  }

  .filter-chip.active {
    background: var(--text-heading);
    color: var(--bg);
    border-color: var(--text-heading);
  }

  .discover-loading {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
  }

  .discover-empty {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .discover-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 768px) {
    .discover-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .discover-grid {
      grid-template-columns: 1fr;
    }
  }

  .discover-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    transition: box-shadow 0.2s, transform 0.15s;
  }

  .discover-card:hover {
    box-shadow: 0 4px 16px var(--shadow);
    transform: translateY(-2px);
  }

  .card-body {
    padding: 1rem;
  }

  .card-category {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-sub);
    margin-bottom: 0.4rem;
  }

  .card-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.35rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-rating {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
    margin-bottom: 0.6rem;
  }

  .card-rating-star {
    color: #f59e0b;
  }

  .card-rating-value {
    font-weight: 700;
    color: var(--text-heading);
  }

  .card-rating-count {
    color: var(--text-muted);
    font-size: 0.78rem;
  }

  .card-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    margin-bottom: 0.85rem;
  }

  .card-info-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .card-info-row svg {
    flex-shrink: 0;
    color: var(--text-muted);
  }

  .card-info-text {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .card-room {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.4rem;
    padding-top: 0.4rem;
    border-top: 1px solid var(--border-light);
  }

  .discover-card {
    text-decoration: none;
    color: inherit;
  }

  .discover-seo {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    margin-top: 2rem;
  }

  .discover-seo h2 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--text-heading);
  }

  .discover-seo p {
    font-size: 0.82rem;
    color: var(--text-sub);
    line-height: 1.7;
    margin: 0 0 0.4rem;
  }

  .discover-seo p:last-child {
    margin-bottom: 0;
  }
</style>

<script>
  import { fetchDiscover } from '@/lib/api';
  import type { DiscoverResponse } from '@/lib/api';

  async function initDiscoverPage() {
    const contentEl = document.getElementById('discover-content');
    const filtersEl = document.getElementById('discover-filters');
    if (!contentEl || !filtersEl) return;

    let data: DiscoverResponse | null = null;
    let currentCategory = '전체';

    function getCategories() {
      if (!data) return [];
      const cats = new Set<string>();
      data.topRated.forEach((item) => cats.add(item.category));
      return Array.from(cats);
    }

    function renderFilters() {
      const cats = getCategories();
      filtersEl.innerHTML = `
        <button type="button" class="filter-chip ${currentCategory === '전체' ? 'active' : ''}" data-category="전체">전체</button>
        ${cats.map((c) => `<button type="button" class="filter-chip ${currentCategory === c ? 'active' : ''}" data-category="${c}">${c}</button>`).join('')}
      `;

      for (const btn of filtersEl.querySelectorAll<HTMLButtonElement>('.filter-chip')) {
        btn.addEventListener('click', () => {
          currentCategory = btn.dataset.category ?? '전체';
          renderFilters();
          renderCards();
        });
      }
    }

    function renderCards() {
      if (!data) return;
      let items = data.topRated;
      if (currentCategory !== '전체') {
        items = items.filter((item) => item.category === currentCategory);
      }

      if (items.length === 0) {
        contentEl.innerHTML = '<div class="discover-empty">아직 공개된 맛집 데이터가 없습니다.<br/>방을 공개로 설정하면 여기에 표시됩니다.</div>';
        return;
      }

      contentEl.innerHTML = `<div class="discover-grid">${items.map((item) => {
        const shortAddr = item.address.replace(/^(\S+[시도])\s+(\S+[시군구]).*$/, '$1 $2').replace(/^(\S+)\s*$/, '$1');
        return `
          <a href="/rooms/public/${item.roomId}" class="discover-card">
            <div class="card-body">
              <span class="card-category">${item.category}</span>
              <div class="card-name">${item.name}</div>
              <div class="card-rating">
                <span class="card-rating-star">★</span>
                <span class="card-rating-value">${item.avgRating}</span>
                <span class="card-rating-count">(${item.reviewCount})</span>
              </div>
              <div class="card-info">
                <div class="card-info-row">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  <span class="card-info-text">${shortAddr}</span>
                </div>
              </div>
              <div class="card-room">${item.roomName}</div>
            </div>
          </a>`;
      }).join('')}</div>`;
    }

    try {
      data = await fetchDiscover();
      renderFilters();
      renderCards();
    } catch {
      contentEl.innerHTML = '<div class="discover-empty">맛집 추천을 불러올 수 없습니다.</div>';
    }
  }

  document.addEventListener('astro:page-load', initDiscoverPage);
</script>
