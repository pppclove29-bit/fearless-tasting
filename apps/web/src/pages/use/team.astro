---
import BaseLayout from '@/layouts/BaseLayout.astro';
const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';
---

<BaseLayout
  title="회사 점심 맛집 관리 | 팀 맛집 리스트 공유 방법"
  description="회사 근처 점심 맛집, 팀원들이랑 같이 정리하고 싶다면? 무모한 시식가로 팀 맛집 리스트를 만들고, 동료들의 솔직한 리뷰를 확인하세요. 소모임 맛집 관리에도 딱이에요."
  ogImageAlt="팀 점심 맛집 리스트 관리 — 무모한 시식가"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "회사 점심 맛집 관리하는 방법",
      "description": "팀원들과 회사 근처 맛집 리스트를 공유하고 리뷰를 기록하는 플랫폼",
      "url": siteUrl + "/use/team",
      "audience": { "@type": "Audience", "audienceType": "Professionals" },
      "keywords": "회사 점심 맛집 관리, 팀 맛집 리스트 공유, 소모임 맛집 관리, 맛집 공유 앱 추천",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "팀 맛집 관리", "item": siteUrl + "/use/team" },
      ]
    })} />
  </Fragment>

  <div class="use-page">
    <section class="use-hero">
      <span class="use-badge">팀 맛집 관리</span>
      <h1>회사 점심 맛집,<br/>팀원들이랑 같이 정리하세요</h1>
      <p class="use-sub">매일 점심 뭐 먹지? 팀 맛집 리스트를 만들어두면 고민 끝!</p>
      <a href={`${apiUrl}/auth/kakao`} class="use-cta">카카오로 시작하기</a>
    </section>

    <section class="use-section">
      <h2>팀 맛집 리스트, 왜 필요할까?</h2>
      <p>
        "점심 뭐 먹지?" 매일 반복되는 이 질문. 회사 근처 맛집은 한정되어 있고,
        새로운 곳을 찾아도 기록이 없으면 잊어버립니다.
      </p>
      <p>
        <strong>팀원들의 리뷰가 쌓이면 점심 맛집 고민이 사라집니다.</strong>
        누가 어디 가서 뭘 먹었는지, 별점은 어땠는지 한눈에 확인하세요.
      </p>
    </section>

    <section class="use-section">
      <h2>회사 맛집 관리, 이런 게 불편했죠?</h2>
      <div class="problem-list">
        <div class="problem-item">
          <span class="problem-icon">&#x1F500;</span>
          <div>
            <strong>"거기 가봤는데 별로였어"</strong>
            <p>누군가 갔다 왔는데 공유가 안 돼서 또 가게 됨</p>
          </div>
        </div>
        <div class="problem-item">
          <span class="problem-icon">&#x1F4CB;</span>
          <div>
            <strong>엑셀/노션 맛집 리스트</strong>
            <p>만들어놓고 아무도 업데이트 안 함... 관리가 안 됨</p>
          </div>
        </div>
        <div class="problem-item">
          <span class="problem-icon">&#x1F937;</span>
          <div>
            <strong>신입의 점심 고민</strong>
            <p>새로 온 팀원은 어디가 맛있는지 몰라서 매번 물어봄</p>
          </div>
        </div>
      </div>
    </section>

    <section class="use-section">
      <h2>팀 맛집 리스트 만드는 가장 쉬운 방법</h2>
      <div class="steps">
        <div class="step-card">
          <div class="step-num">01</div>
          <h3>팀 방 만들기</h3>
          <p>"OO팀 점심 맛집" 방을 만들고 팀원들에게 초대 링크를 보냅니다.</p>
        </div>
        <div class="step-card">
          <div class="step-num">02</div>
          <h3>점심 후 30초 기록</h3>
          <p>카카오맵 검색으로 식당을 등록하고 별점만 남기면 끝. 한줄 리뷰는 선택.</p>
        </div>
        <div class="step-card">
          <div class="step-num">03</div>
          <h3>팀 맛집 지도 완성</h3>
          <p>팀원들의 리뷰가 쌓이면 자연스럽게 "우리 팀 맛집 리스트"가 완성됩니다.</p>
        </div>
      </div>
    </section>

    <section class="use-section">
      <h2>노션 맛집 리스트 vs 무모한 시식가</h2>
      <div class="compare-table">
        <div class="compare-row compare-header">
          <span></span>
          <span>노션/엑셀</span>
          <span>무모한 시식가</span>
        </div>
        <div class="compare-row">
          <span>등록 편의성</span>
          <span class="compare-no">직접 입력</span>
          <span class="compare-yes">카카오맵 검색 자동입력</span>
        </div>
        <div class="compare-row">
          <span>개인 리뷰</span>
          <span class="compare-no">공유 셀에 섞임</span>
          <span class="compare-yes">멤버별 별점/리뷰</span>
        </div>
        <div class="compare-row">
          <span>통계</span>
          <span class="compare-no">수동 집계</span>
          <span class="compare-yes">카테고리/평점/방문 자동 분석</span>
        </div>
        <div class="compare-row">
          <span>모바일</span>
          <span class="compare-no">불편</span>
          <span class="compare-yes">PWA 앱처럼 사용</span>
        </div>
      </div>
    </section>

    <section class="use-section">
      <h2>이런 팀/소모임에 딱이에요</h2>
      <div class="persona-list">
        <div class="persona-item">
          <span class="persona-emoji">&#x1F3E2;</span>
          <p><strong>회사 점심</strong> 맛집을 팀원들이랑 공유하고 싶을 때</p>
        </div>
        <div class="persona-item">
          <span class="persona-emoji">&#x1F37B;</span>
          <p><strong>동호회/소모임</strong> 정기 모임 맛집을 기록하고 싶을 때</p>
        </div>
        <div class="persona-item">
          <span class="persona-emoji">&#x1F3EB;</span>
          <p><strong>동기/학교 친구</strong> 모임 맛집을 한곳에 모으고 싶을 때</p>
        </div>
        <div class="persona-item">
          <span class="persona-emoji">&#x1F3E0;</span>
          <p><strong>자취방 근처</strong> 맛집을 룸메이트와 공유하고 싶을 때</p>
        </div>
      </div>
    </section>

    <section class="use-cta-section">
      <h2>팀 맛집 리스트,<br/>지금 시작하세요</h2>
      <p>카카오 로그인 한 번이면 바로 방을 만들 수 있어요</p>
      <a href={`${apiUrl}/auth/kakao`} class="use-cta">무료로 시작하기</a>
    </section>
  </div>
</BaseLayout>

<style>
  .use-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 1rem 3rem;
  }

  .use-hero {
    text-align: center;
    padding: 2.5rem 0 2rem;
  }

  .use-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: var(--accent-bg);
    color: var(--text-heading);
    border: 1px solid var(--text-heading);
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .use-hero h1 {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--text-heading);
    line-height: 1.3;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .use-sub {
    font-size: 0.92rem;
    color: var(--text-sub);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .use-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.8rem;
    background: #FEE500;
    color: #191919;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .use-cta:hover { background: #F5DC00; }

  .use-section {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .use-section h2 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.75rem;
  }

  .use-section p {
    font-size: 0.88rem;
    color: var(--text-sub);
    line-height: 1.7;
    margin: 0 0 0.5rem;
  }

  .use-section p:last-child { margin-bottom: 0; }

  .problem-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .problem-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .problem-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .problem-item strong {
    display: block;
    font-size: 0.88rem;
    color: var(--text-heading);
    margin-bottom: 0.15rem;
  }

  .problem-item p {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .step-card {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }

  .step-num {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.3rem;
  }

  .step-card h3 {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.25rem;
  }

  .step-card p {
    font-size: 0.82rem;
    color: var(--text-sub);
    line-height: 1.5;
    margin: 0;
  }

  .compare-table {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .compare-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
  }

  .compare-row span {
    padding: 0.6rem 0.75rem;
    font-size: 0.8rem;
    color: var(--text-sub);
    border-bottom: 1px solid var(--border-light);
  }

  .compare-header span {
    font-weight: 700;
    color: var(--text-heading);
    background: var(--bg-hover);
    font-size: 0.78rem;
  }

  .compare-yes { color: var(--text-heading) !important; font-weight: 600; }
  .compare-no { color: var(--text-muted) !important; }

  .persona-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .persona-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .persona-emoji {
    font-size: 1.3rem;
    flex-shrink: 0;
  }

  .persona-item p {
    font-size: 0.85rem;
    color: var(--text-sub);
    margin: 0;
  }

  .use-cta-section {
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
  }

  .use-cta-section h2 {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .use-cta-section p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  @media (max-width: 480px) {
    .use-hero h1 { font-size: 1.5rem; }
    .compare-row span { padding: 0.5rem; font-size: 0.72rem; }
  }
</style>
