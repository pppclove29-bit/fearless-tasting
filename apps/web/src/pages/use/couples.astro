---
import BaseLayout from '@/layouts/BaseLayout.astro';
const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';
---

<BaseLayout
  title="커플 맛집 리스트 정리 | 데이트 맛집 기록하는 방법"
  description="커플 맛집 리스트를 함께 기록하고 싶다면? 무모한 시식가로 둘만의 맛집 리스트를 만들고, 데이트 때마다 방문 기록과 리뷰를 남겨보세요. 우리만의 맛집 지도를 완성하세요."
  ogImageAlt="커플 맛집 리스트 기록 — 무모한 시식가"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "커플 맛집 리스트 정리하는 방법",
      "description": "커플이 함께 맛집 리스트를 기록하고 공유하는 플랫폼",
      "url": siteUrl + "/use/couples",
      "audience": { "@type": "Audience", "audienceType": "Couples" },
      "keywords": "커플 맛집 리스트, 데이트 맛집 기록, 커플 맛집 공유, 우리만의 맛집 리스트",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "커플 맛집 기록", "item": siteUrl + "/use/couples" },
      ]
    })} />
  </Fragment>

  <div class="use-page">
    <section class="use-hero">
      <span class="use-badge">커플 맛집 기록</span>
      <h1>데이트 맛집,<br/>둘만의 리스트로 기록하세요</h1>
      <p class="use-sub">다녀온 맛집, 가고 싶은 맛집을 함께 정리하고 솔직한 리뷰를 남겨보세요</p>
      <a href={`${apiUrl}/auth/kakao`} class="use-cta login-only-cta">카카오로 시작하기</a>
    </section>

    <section class="use-section">
      <h2>커플 맛집 리스트, 왜 필요할까?</h2>
      <p>
        "저번에 갔던 그 집 이름이 뭐였지?" 데이트할 때마다 맛집을 검색하고,
        다녀온 곳은 기억에서 사라집니다.
      </p>
      <p>
        <strong>함께 다녀온 맛집을 한곳에 기록</strong>하면, 다음 데이트 장소를 고를 때도,
        기념일에 다시 갈 곳을 찾을 때도 바로 꺼내볼 수 있습니다.
      </p>
    </section>

    <section class="use-section">
      <h2>커플 맛집 기록, 이런 게 불편했죠?</h2>
      <div class="problem-list">
        <div class="problem-item">
          <span class="problem-icon">&#x1F914;</span>
          <div>
            <strong>"거기 이름이 뭐였더라?"</strong>
            <p>분명 맛있었는데 이름을 기억 못하는 식당들</p>
          </div>
        </div>
        <div class="problem-item">
          <span class="problem-icon">&#x1F4F1;</span>
          <div>
            <strong>각자 다른 앱에 저장</strong>
            <p>하나는 카카오맵, 하나는 인스타 저장... 합칠 수가 없음</p>
          </div>
        </div>
        <div class="problem-item">
          <span class="problem-icon">&#x2764;&#xFE0F;</span>
          <div>
            <strong>둘의 평가가 다를 때</strong>
            <p>나는 맛있었는데 상대는 별로... 기록이 없으면 다시 가게 됨</p>
          </div>
        </div>
      </div>
    </section>

    <section class="use-section">
      <h2>데이트 맛집 기록하는 가장 쉬운 방법</h2>
      <div class="steps">
        <div class="step-card">
          <div class="step-num">01</div>
          <h3>커플 방 만들기</h3>
          <p>"우리 맛집 일기" 방을 만들고 상대에게 초대 링크를 보냅니다.</p>
        </div>
        <div class="step-card">
          <div class="step-num">02</div>
          <h3>데이트 후 기록</h3>
          <p>다녀온 식당을 등록하고 각자 별점과 리뷰를 남깁니다. 같은 식당에 대한 서로의 평가를 비교해보세요.</p>
        </div>
        <div class="step-card">
          <div class="step-num">03</div>
          <h3>추억 쌓기</h3>
          <p>방문 통계, 세부 평점, 카테고리 분석까지. 우리 커플의 맛집 취향을 한눈에 확인합니다.</p>
        </div>
      </div>
    </section>

    <section class="use-section">
      <h2>이런 커플에게 딱이에요</h2>
      <div class="persona-list">
        <div class="persona-item">
          <span class="persona-emoji">&#x1F37D;&#xFE0F;</span>
          <p><strong>주말마다 맛집 탐방</strong>하는 커플</p>
        </div>
        <div class="persona-item">
          <span class="persona-emoji">&#x1F4D6;</span>
          <p><strong>다녀온 곳을 기록</strong>으로 남기고 싶은 커플</p>
        </div>
        <div class="persona-item">
          <span class="persona-emoji">&#x1F3AF;</span>
          <p>데이트 장소를 <strong>매번 검색하기 귀찮은</strong> 커플</p>
        </div>
        <div class="persona-item">
          <span class="persona-emoji">&#x1F4CA;</span>
          <p>우리 <strong>맛집 취향을 분석</strong>해보고 싶은 커플</p>
        </div>
      </div>
    </section>

    <section class="use-cta-section login-only-cta">
      <h2>우리 커플 맛집 리스트,<br/>지금 시작하세요</h2>
      <p>카카오 로그인 한 번이면 바로 방을 만들 수 있어요</p>
      <a href={`${apiUrl}/auth/kakao`} class="use-cta">무료로 시작하기</a>
    </section>
  </div>
</BaseLayout>

<style>
  .use-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 1rem 3rem;
  }

  .use-hero {
    text-align: center;
    padding: 2.5rem 0 2rem;
  }

  .use-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: var(--accent-bg);
    color: var(--text-heading);
    border: 1px solid var(--text-heading);
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .use-hero h1 {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--text-heading);
    line-height: 1.3;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .use-sub {
    font-size: 0.92rem;
    color: var(--text-sub);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .use-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.8rem;
    background: #FEE500;
    color: #191919;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .use-cta:hover { background: #F5DC00; }

  .use-section {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .use-section h2 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.75rem;
  }

  .use-section p {
    font-size: 0.88rem;
    color: var(--text-sub);
    line-height: 1.7;
    margin: 0 0 0.5rem;
  }

  .use-section p:last-child { margin-bottom: 0; }

  .problem-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .problem-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .problem-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .problem-item strong {
    display: block;
    font-size: 0.88rem;
    color: var(--text-heading);
    margin-bottom: 0.15rem;
  }

  .problem-item p {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .step-card {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }

  .step-num {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.3rem;
  }

  .step-card h3 {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.25rem;
  }

  .step-card p {
    font-size: 0.82rem;
    color: var(--text-sub);
    line-height: 1.5;
    margin: 0;
  }

  .persona-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .persona-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  .persona-emoji {
    font-size: 1.3rem;
    flex-shrink: 0;
  }

  .persona-item p {
    font-size: 0.85rem;
    color: var(--text-sub);
    margin: 0;
  }

  .use-cta-section {
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
  }

  .use-cta-section h2 {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .use-cta-section p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  @media (max-width: 480px) {
    .use-hero h1 { font-size: 1.5rem; }
  }
</style>
