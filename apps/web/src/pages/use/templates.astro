---
import BaseLayout from '@/layouts/BaseLayout.astro';
const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';
---

<BaseLayout
  title="맛집리스트 템플릿 공유 | 회식·데이트·가족 방 템플릿 6종"
  description="맛집리스트 템플릿을 찾고 있나요? 무모한 시식가에서는 회식·데이트·신혼·가족·친구 등 상황별 방 템플릿 6종을 무료로 제공합니다. 방을 만들자마자 바로 기록 시작."
  ogImageAlt="무모한 시식가 맛집리스트 템플릿 공유 — 상황별 방 템플릿 6종"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "맛집리스트 템플릿 공유 — 상황별 방 템플릿 6종",
      "description": "회식·데이트·신혼·가족·친구 등 상황에 맞는 맛집리스트 템플릿을 무료로 제공",
      "url": siteUrl + "/use/templates",
      "keywords": "맛집리스트 템플릿, 맛집리스트 템플릿 공유, 맛집 템플릿, 회식 맛집 템플릿, 데이트 맛집 템플릿, 맛집리스트 정리",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "맛집리스트 템플릿", "item": siteUrl + "/use/templates" },
      ]
    })} />
  </Fragment>

  <div class="use-page">
    <section class="use-hero">
      <span class="use-badge">맛집리스트 템플릿</span>
      <h1>맛집리스트 템플릿,<br/>상황별로 6종 준비했어요</h1>
      <p class="use-sub">회식·데이트·신혼·가족·친구까지. 원하는 템플릿을 고르면 탭·알림까지 맞춤 세팅된 방이 바로 생성됩니다.</p>
      <a href={`${apiUrl}/auth/kakao`} class="use-cta login-only-cta">카카오로 시작하기</a>
    </section>

    <section class="use-section">
      <h2>템플릿이 왜 필요할까?</h2>
      <p>
        "방을 만들고 나서 어떻게 써야 할지 모르겠어요." 맛집리스트 정리, 막상 시작하려면 막막합니다.
      </p>
      <p>
        <strong>상황에 맞는 템플릿</strong>을 고르면 기본 이름·탭 구성·추천 기능이 자동으로 세팅됩니다. 회식 방이면 투표 기능이, 커플 방이면 위시리스트·지역 탭이 미리 켜져 있습니다.
      </p>
    </section>

    <section class="use-section">
      <h2>제공하는 템플릿 6종</h2>
      <div class="steps">
        <div class="step-card">
          <div class="step-num">🍻</div>
          <h3>회식 맛집</h3>
          <p>투표 탭 자동 활성화. "🍜 오늘 뭐 먹지?" 투표 시드까지 바로 추가됩니다.</p>
        </div>
        <div class="step-card">
          <div class="step-num">💑</div>
          <h3>우리 데이트 맛집</h3>
          <p>위시리스트·지역·통계 탭이 기본 ON. 다녀온 데이트 맛집과 취향 분석까지.</p>
        </div>
        <div class="step-card">
          <div class="step-num">🏠</div>
          <h3>신혼 맛집 지도</h3>
          <p>동네 맛집을 지도 기반으로 정리. 신혼집 주변 맛집 리스트 관리에 최적.</p>
        </div>
        <div class="step-card">
          <div class="step-num">👨‍👩‍👧</div>
          <h3>우리 가족 맛집</h3>
          <p>아이·부모님과 함께 가는 맛집. 가족 구성원별 평가 비교.</p>
        </div>
        <div class="step-card">
          <div class="step-num">🎉</div>
          <h3>친구들 맛집 모음</h3>
          <p>위시리스트·투표 ON. 친구 모임 장소 정할 때 바로 투표.</p>
        </div>
        <div class="step-card">
          <div class="step-num">📝</div>
          <h3>빈 방</h3>
          <p>직접 탭 구성부터 만들고 싶다면. 위시리스트·지역 탭만 기본 ON.</p>
        </div>
      </div>
    </section>

    <section class="use-section">
      <h2>템플릿으로 방 만드는 법</h2>
      <div class="steps">
        <div class="step-card">
          <div class="step-num">01</div>
          <h3>카카오 로그인</h3>
          <p>카카오 계정으로 3초 만에 로그인합니다.</p>
        </div>
        <div class="step-card">
          <div class="step-num">02</div>
          <h3>내 방 → 방 만들기</h3>
          <p>상황에 맞는 템플릿을 6종 중에서 고릅니다.</p>
        </div>
        <div class="step-card">
          <div class="step-num">03</div>
          <h3>기록 시작</h3>
          <p>기본 이름·탭·투표까지 자동 세팅. 초대 링크를 공유하고 바로 맛집 등록 시작.</p>
        </div>
      </div>
    </section>

    <section class="use-cta-section login-only-cta">
      <h2>템플릿 선택하고<br/>맛집리스트 바로 시작하기</h2>
      <p>카카오 로그인 한 번이면 템플릿 선택 후 바로 방 생성</p>
      <a href={`${apiUrl}/auth/kakao`} class="use-cta">무료로 시작하기</a>
    </section>
  </div>
</BaseLayout>

<style>
  .use-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 1rem 3rem;
  }

  .use-hero {
    text-align: center;
    padding: 2.5rem 0 2rem;
  }

  .use-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: var(--accent-bg);
    color: var(--text-heading);
    border: 1px solid var(--text-heading);
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .use-hero h1 {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--text-heading);
    line-height: 1.3;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .use-sub {
    font-size: 0.92rem;
    color: var(--text-sub);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .use-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.8rem;
    background: #FEE500;
    color: #191919;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .use-cta:hover { background: #F5DC00; }

  .use-section {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .use-section h2 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.75rem;
  }

  .use-section p {
    font-size: 0.88rem;
    color: var(--text-sub);
    line-height: 1.7;
    margin: 0 0 0.5rem;
  }

  .use-section p:last-child { margin-bottom: 0; }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .step-card {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }

  .step-num {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.3rem;
  }

  .step-card h3 {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.25rem;
  }

  .step-card p {
    font-size: 0.82rem;
    color: var(--text-sub);
    line-height: 1.5;
    margin: 0;
  }

  .use-cta-section {
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
  }

  .use-cta-section h2 {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .use-cta-section p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  @media (max-width: 480px) {
    .use-hero h1 { font-size: 1.5rem; }
  }
</style>
