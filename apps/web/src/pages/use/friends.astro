---
import BaseLayout from '@/layouts/BaseLayout.astro';
const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';
---

<BaseLayout
  title="친구랑 맛집 공유 방법 | 우리만의 맛집 리스트 만들기"
  description="친구끼리 맛집 리스트를 공유하고 싶다면? 무모한 시식가로 비공개 방을 만들어 맛집을 기록하고, 링크 하나로 친구에게 공유하세요. 카톡으로 보내면 묻히는 맛집, 이제 한곳에 정리하세요."
  ogImageAlt="친구랑 맛집 리스트 공유 중 — 무모한 시식가"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "name": "친구랑 맛집 공유하는 방법",
      "description": "친구끼리 맛집 리스트를 비공개로 공유하고 리뷰를 함께 기록하는 플랫폼",
      "url": siteUrl + "/use/friends",
      "audience": { "@type": "Audience", "audienceType": "Friends" },
      "keywords": "친구랑 맛집 공유, 맛집 리스트 공유 방법, 맛집 같이 정리하는 법, 맛집 공유 앱",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "친구와 맛집 공유", "item": siteUrl + "/use/friends" },
      ]
    })} />
  </Fragment>

  <div class="use-page">
    <section class="use-hero">
      <span class="use-badge">친구와 맛집 공유</span>
      <h1>친구랑 맛집 공유,<br/>이제 카톡에서 묻히지 마세요</h1>
      <p class="use-sub">링크 하나로 우리만의 맛집 리스트를 만들고, 솔직한 리뷰를 함께 기록하세요</p>
      <a href={`${apiUrl}/auth/kakao`} class="use-cta">카카오로 시작하기</a>
    </section>

    <section class="use-section">
      <h2>친구랑 맛집 공유, 왜 필요할까?</h2>
      <p>
        "여기 맛있었어!" 카톡으로 보내면 대화에 묻히고, 메모장에 적으면 나만 볼 수 있고,
        인스타에 저장하면 찾기 어렵습니다.
      </p>
      <p>
        <strong>맛집 리스트는 같이 쓸 때 의미가 있습니다.</strong>
        친구가 다녀온 곳, 내가 추천한 곳, 함께 가본 곳을 한곳에 모아보세요.
      </p>
    </section>

    <section class="use-section">
      <h2>카톡으로 맛집 공유하면 생기는 문제</h2>
      <div class="problem-list">
        <div class="problem-item">
          <span class="problem-icon">&#x1F4AC;</span>
          <div>
            <strong>대화에 묻힘</strong>
            <p>보낸 맛집 링크가 다른 대화에 밀려 찾을 수 없음</p>
          </div>
        </div>
        <div class="problem-item">
          <span class="problem-icon">&#x1F4DD;</span>
          <div>
            <strong>흩어진 기록</strong>
            <p>메모장, 인스타 저장, 카카오맵 즐겨찾기... 여기저기 분산</p>
          </div>
        </div>
        <div class="problem-item">
          <span class="problem-icon">&#x1F910;</span>
          <div>
            <strong>솔직한 후기 부재</strong>
            <p>공개 리뷰는 광고/협찬 섞여서 믿기 어려움</p>
          </div>
        </div>
      </div>
    </section>

    <section class="use-section">
      <h2>맛집 리스트 공유하는 가장 쉬운 방법</h2>
      <div class="steps">
        <div class="step-card">
          <div class="step-num">01</div>
          <h3>방 만들기</h3>
          <p>카카오 로그인 후 "우리 맛집 리스트" 방을 만듭니다. 10초면 완료.</p>
        </div>
        <div class="step-card">
          <div class="step-num">02</div>
          <h3>친구 초대</h3>
          <p>초대 링크를 카톡으로 보내면 친구가 클릭 한 번으로 입장합니다.</p>
        </div>
        <div class="step-card">
          <div class="step-num">03</div>
          <h3>함께 기록</h3>
          <p>다녀온 맛집을 등록하고, 별점과 한줄 리뷰를 남깁니다. 친구의 리뷰도 바로 확인!</p>
        </div>
      </div>
    </section>

    <section class="use-section">
      <h2>카카오맵 즐겨찾기 vs 무모한 시식가</h2>
      <div class="compare-table">
        <div class="compare-row compare-header">
          <span></span>
          <span>카카오맵 즐겨찾기</span>
          <span>무모한 시식가</span>
        </div>
        <div class="compare-row">
          <span>친구와 공유</span>
          <span class="compare-no">X</span>
          <span class="compare-yes">O (링크 초대)</span>
        </div>
        <div class="compare-row">
          <span>리뷰 작성</span>
          <span class="compare-no">공개만 가능</span>
          <span class="compare-yes">비공개 그룹 리뷰</span>
        </div>
        <div class="compare-row">
          <span>방문 기록</span>
          <span class="compare-no">X</span>
          <span class="compare-yes">날짜/메모/웨이팅</span>
        </div>
        <div class="compare-row">
          <span>통계/분석</span>
          <span class="compare-no">X</span>
          <span class="compare-yes">카테고리/지역/평점 분석</span>
        </div>
      </div>
    </section>

    <section class="use-cta-section">
      <h2>친구들과 맛집 리스트,<br/>지금 시작하세요</h2>
      <p>카카오 로그인 한 번이면 바로 방을 만들 수 있어요</p>
      <a href={`${apiUrl}/auth/kakao`} class="use-cta">무료로 시작하기</a>
    </section>
  </div>
</BaseLayout>

<style>
  .use-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 1rem 3rem;
  }

  .use-hero {
    text-align: center;
    padding: 2.5rem 0 2rem;
  }

  .use-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: var(--accent-bg);
    color: var(--text-heading);
    border: 1px solid var(--text-heading);
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .use-hero h1 {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--text-heading);
    line-height: 1.3;
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .use-sub {
    font-size: 0.92rem;
    color: var(--text-sub);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .use-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.75rem 1.8rem;
    background: #FEE500;
    color: #191919;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .use-cta:hover { background: #F5DC00; }

  .use-section {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .use-section h2 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.75rem;
  }

  .use-section p {
    font-size: 0.88rem;
    color: var(--text-sub);
    line-height: 1.7;
    margin: 0 0 0.5rem;
  }

  .use-section p:last-child { margin-bottom: 0; }

  .problem-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .problem-item {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
  }

  .problem-icon {
    font-size: 1.5rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .problem-item strong {
    display: block;
    font-size: 0.88rem;
    color: var(--text-heading);
    margin-bottom: 0.15rem;
  }

  .problem-item p {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 0;
  }

  .steps {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .step-card {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }

  .step-num {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.3rem;
  }

  .step-card h3 {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.25rem;
  }

  .step-card p {
    font-size: 0.82rem;
    color: var(--text-sub);
    line-height: 1.5;
    margin: 0;
  }

  .compare-table {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .compare-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
  }

  .compare-row span {
    padding: 0.6rem 0.75rem;
    font-size: 0.8rem;
    color: var(--text-sub);
    border-bottom: 1px solid var(--border-light);
  }

  .compare-header span {
    font-weight: 700;
    color: var(--text-heading);
    background: var(--bg-hover);
    font-size: 0.78rem;
  }

  .compare-yes { color: var(--text-heading) !important; font-weight: 600; }
  .compare-no { color: var(--text-muted) !important; }

  .use-cta-section {
    text-align: center;
    padding: 2.5rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
  }

  .use-cta-section h2 {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }

  .use-cta-section p {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  @media (max-width: 480px) {
    .use-hero h1 { font-size: 1.5rem; }
    .compare-row span { padding: 0.5rem; font-size: 0.72rem; }
  }
</style>
