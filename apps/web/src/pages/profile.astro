---
import BaseLayout from '@/layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="내 프로필" description="내 프로필 관리 - 닉네임 수정, 활동 요약, 계정 관리">
  <div class="profile-page" id="profile-page" hidden>
    <section class="profile-card">
      <div class="profile-header">
        <div class="profile-avatar" id="profile-avatar"></div>
        <div class="profile-name-area">
          <h1 class="profile-name" id="profile-name"></h1>
          <button type="button" class="edit-name-btn" id="edit-name-btn" title="닉네임 수정">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
        </div>
        <p class="profile-email" id="profile-email"></p>
      </div>
      <div class="nickname-edit-area" id="nickname-edit" hidden>
        <input type="text" id="nickname-input" class="nickname-input" maxlength="50" placeholder="새 닉네임" />
        <div class="nickname-edit-actions">
          <button type="button" class="btn-save" id="nickname-save">저장</button>
          <button type="button" class="btn-cancel" id="nickname-cancel">취소</button>
        </div>
      </div>
    </section>

    <section class="profile-section">
      <h2>활동 요약</h2>
      <div class="stats-grid" id="stats-grid">
        <div class="stat-item">
          <span class="stat-value" id="stat-rooms">-</span>
          <span class="stat-label">참여 중인 방</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="stat-restaurants">-</span>
          <span class="stat-label">등록한 식당</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="stat-reviews">-</span>
          <span class="stat-label">작성한 리뷰</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="stat-visits">-</span>
          <span class="stat-label">방문 기록</span>
        </div>
      </div>
    </section>

    <section class="profile-section">
      <h2>계정 관리</h2>
      <div class="account-actions">
        <button type="button" class="btn-logout" id="profile-logout">로그아웃</button>
        <div class="danger-zone">
          <p class="danger-desc">계정을 삭제하면 모든 리뷰, 방 멤버십 등 개인 데이터가 즉시 삭제되며 복구할 수 없습니다.</p>
          <button type="button" class="btn-delete-account" id="delete-account-btn">회원 탈퇴</button>
        </div>
      </div>
    </section>
  </div>

  <div class="profile-loading" id="profile-loading">
    <p>로딩 중...</p>
  </div>
</BaseLayout>

<style>
  .profile-page {
    max-width: 560px;
    margin: 0 auto;
  }

  .profile-loading {
    text-align: center;
    padding: 3rem;
    color: #999;
  }

  .profile-card {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .profile-header {
    text-align: center;
  }

  .profile-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #f0f0f0;
    margin: 0 auto 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: #999;
    overflow: hidden;
  }

  .profile-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-name-area {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .profile-name {
    font-size: 1.3rem;
    font-weight: 700;
    margin: 0;
  }

  .edit-name-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: #999;
    padding: 0.2rem;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s;
  }

  .edit-name-btn:hover {
    color: #333;
    background: #f0f0f0;
  }

  .profile-email {
    font-size: 0.85rem;
    color: #999;
    margin-top: 0.2rem;
  }

  .nickname-edit-area {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid #f0f0f0;
  }

  .nickname-input {
    width: 100%;
    padding: 0.6rem 0.8rem;
    border: 1px solid #d0d0d0;
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: inherit;
  }

  .nickname-input:focus {
    outline: none;
    border-color: #333;
  }

  .nickname-edit-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.5rem;
    justify-content: flex-end;
  }

  .btn-save {
    padding: 0.45rem 1rem;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.15s;
  }

  .btn-save:hover {
    background: #333;
  }

  .btn-cancel {
    padding: 0.45rem 1rem;
    background: none;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    color: #555;
    transition: background 0.15s;
  }

  .btn-cancel:hover {
    background: #f0f0f0;
  }

  .profile-section {
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 12px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .profile-section h2 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 1rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .stat-item {
    text-align: center;
    padding: 0.75rem;
    background: #f7f8fa;
    border-radius: 8px;
  }

  .stat-value {
    display: block;
    font-size: 1.4rem;
    font-weight: 700;
    color: #111;
  }

  .stat-label {
    display: block;
    font-size: 0.78rem;
    color: #888;
    margin-top: 0.15rem;
  }

  .account-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .btn-logout {
    width: 100%;
    padding: 0.65rem;
    background: none;
    border: 1px solid #d0d0d0;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    color: #555;
    transition: background 0.15s, border-color 0.15s;
  }

  .btn-logout:hover {
    background: #f0f0f0;
    border-color: #999;
  }

  .danger-zone {
    padding-top: 1rem;
    border-top: 1px solid #f0f0f0;
  }

  .danger-desc {
    font-size: 0.8rem;
    color: #999;
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .btn-delete-account {
    width: 100%;
    padding: 0.6rem;
    background: none;
    border: 1px solid #e8c4c4;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    color: #999;
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .btn-delete-account:hover {
    background: #fef2f2;
    border-color: #dc2626;
    color: #dc2626;
  }

  @media (max-width: 600px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<script>
  import { fetchCurrentUser, fetchMyRooms, fetchRankings, updateNickname, deleteAccount, logout, clearTokens, showToast, showDangerConfirm } from '@/lib/api';

  const profilePage = document.getElementById('profile-page')!;
  const profileLoading = document.getElementById('profile-loading')!;

  const user = await fetchCurrentUser();
  if (!user) {
    location.href = '/login';
  } else {
    profileLoading.hidden = true;
    profilePage.hidden = false;

    // 프로필 정보 표시
    const avatarEl = document.getElementById('profile-avatar')!;
    const nameEl = document.getElementById('profile-name')!;
    const emailEl = document.getElementById('profile-email')!;

    if (user.profileImageUrl) {
      avatarEl.innerHTML = `<img src="${user.profileImageUrl}" alt="프로필" />`;
    } else {
      avatarEl.textContent = user.nickname.charAt(0);
    }
    nameEl.textContent = user.nickname;
    emailEl.textContent = user.email;

    // 닉네임 수정
    const editBtn = document.getElementById('edit-name-btn')!;
    const editArea = document.getElementById('nickname-edit')!;
    const nicknameInput = document.getElementById('nickname-input') as HTMLInputElement;
    const saveBtn = document.getElementById('nickname-save')!;
    const cancelBtn = document.getElementById('nickname-cancel')!;

    editBtn.addEventListener('click', () => {
      nicknameInput.value = nameEl.textContent || '';
      editArea.hidden = false;
      nicknameInput.focus();
      nicknameInput.select();
    });

    cancelBtn.addEventListener('click', () => {
      editArea.hidden = true;
    });

    async function saveNickname() {
      const newName = nicknameInput.value.trim();
      if (!newName || newName === nameEl.textContent) {
        editArea.hidden = true;
        return;
      }
      try {
        const updated = await updateNickname(newName);
        nameEl.textContent = updated.nickname;
        if (!user.profileImageUrl) {
          avatarEl.textContent = updated.nickname.charAt(0);
        }
        editArea.hidden = true;
        showToast('닉네임이 변경되었습니다.');
      } catch (err) {
        showToast(err instanceof Error ? err.message : '닉네임 변경에 실패했습니다.');
      }
    }

    saveBtn.addEventListener('click', saveNickname);
    nicknameInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); saveNickname(); }
      if (e.key === 'Escape') { editArea.hidden = true; }
    });

    // 활동 요약 로드
    try {
      const [rooms, rankings] = await Promise.all([
        fetchMyRooms(),
        fetchRankings().catch(() => null),
      ]);

      document.getElementById('stat-rooms')!.textContent = String(rooms.length);

      const myRanking = rankings?.rankings.find((r) => r.userId === user.id);
      if (myRanking) {
        document.getElementById('stat-restaurants')!.textContent = String(myRanking.restaurantCount);
        document.getElementById('stat-reviews')!.textContent = String(myRanking.reviewCount);
        document.getElementById('stat-visits')!.textContent = String(myRanking.visitCount);
      }
    } catch {
      // 통계 로드 실패 시 무시
    }

    // 로그아웃
    document.getElementById('profile-logout')!.addEventListener('click', () => {
      logout();
      location.href = '/';
    });

    // 회원 탈퇴
    document.getElementById('delete-account-btn')!.addEventListener('click', async () => {
      const confirmed = await showDangerConfirm(
        '정말 탈퇴하시겠습니까?\n\n계정, 리뷰, 방 멤버십 등 모든 개인 데이터가 즉시 삭제되며 복구할 수 없습니다.',
        '탈퇴',
      );
      if (!confirmed) return;

      try {
        await deleteAccount();
        clearTokens();
        location.href = '/';
      } catch (err) {
        showToast(err instanceof Error ? err.message : '탈퇴에 실패했습니다.');
      }
    });
  }
</script>
