---
import BaseLayout from '@/layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="내 프로필" description="내 프로필 관리 - 닉네임 수정, 활동 요약, 계정 관리" noindex>
  <div class="profile-page" id="profile-page" hidden>
    <section class="profile-hero">
      <span class="profile-badge">내 계정</span>
      <h1 class="profile-hero-title">프로필</h1>
      <p class="profile-hero-desc">계정 정보와 설정을 관리하세요</p>
    </section>

    <section class="profile-card">
      <div class="profile-header">
        <div class="profile-avatar-wrap">
          <div class="profile-avatar" id="profile-avatar"></div>
          <label class="profile-avatar-edit" title="프로필 사진 변경">
            <input type="file" id="avatar-file-input" accept="image/*" hidden />
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </label>
        </div>
        <div class="profile-name-area">
          <h1 class="profile-name" id="profile-name"></h1>
          <button type="button" class="edit-name-btn" id="edit-name-btn" title="닉네임 수정">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
        </div>
        <p class="profile-email" id="profile-email"></p>
      </div>
      <div class="nickname-edit-area" id="nickname-edit" hidden>
        <input type="text" id="nickname-input" class="nickname-input" maxlength="50" placeholder="새 닉네임" />
        <div class="nickname-edit-actions">
          <button type="button" class="btn-save" id="nickname-save">저장</button>
          <button type="button" class="btn-cancel" id="nickname-cancel">취소</button>
        </div>
      </div>
    </section>

    <section class="profile-section">
      <h2>알림 설정</h2>
      <div class="theme-setting">
        <div class="theme-setting-info">
          <span class="theme-setting-label">푸시 알림</span>
          <span class="theme-setting-current" id="push-current">켜짐</span>
        </div>
        <div class="theme-switch-group" id="push-switch-group">
          <button type="button" class="theme-switch-btn active" data-push="on">켜기</button>
          <button type="button" class="theme-switch-btn" data-push="off">끄기</button>
        </div>
      </div>
    </section>

    <section class="profile-section">
      <h2>화면 설정</h2>
      <div class="theme-setting">
        <div class="theme-setting-info">
          <span class="theme-setting-label">테마</span>
          <span class="theme-setting-current" id="theme-current">라이트 모드</span>
        </div>
        <div class="theme-switch-group" id="theme-switch-group">
          <button type="button" class="theme-switch-btn active" data-theme="light">
            <span class="theme-switch-icon">&#9728;&#65039;</span> 라이트
          </button>
          <button type="button" class="theme-switch-btn" data-theme="dark">
            <span class="theme-switch-icon">&#127769;</span> 다크
          </button>
        </div>
      </div>
    </section>

    <section class="profile-section">
      <h2>계정</h2>
      <div class="account-actions">
        <button type="button" class="btn-logout" id="profile-logout">로그아웃</button>
        <a href="/profile/account" class="btn-account-manage">계정 관리</a>
      </div>
    </section>
  </div>

  <div class="profile-loading" id="profile-loading">
    <p>로딩 중...</p>
  </div>
</BaseLayout>

<style>
  .profile-page {
    max-width: 560px;
    margin: 0 auto;
  }

  .profile-hero {
    text-align: center;
    padding: 2.5rem 0 1.5rem;
    background: var(--bg-hover);
    border-radius: 16px;
    margin-bottom: 1rem;
  }

  .profile-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: var(--text-heading);
    color: var(--bg);
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 100px;
    margin-bottom: 0.75rem;
  }

  .profile-hero-title {
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--text-heading);
    margin: 0 0 0.4rem;
  }

  .profile-hero-desc {
    font-size: 0.9rem;
    color: var(--text-sub);
  }

  .profile-loading {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
  }

  .profile-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 2rem 1.5rem;
    margin-bottom: 1rem;
  }

  .profile-header {
    text-align: center;
  }

  .profile-avatar-wrap {
    position: relative;
    display: inline-block;
    margin: 0 auto 0.85rem;
  }

  .profile-avatar-edit {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 28px;
    height: 28px;
    background: var(--text-heading);
    color: var(--bg);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: 2px solid var(--bg-card);
    transition: opacity 0.15s;
  }

  .profile-avatar-edit:hover { opacity: 0.85; }

  .profile-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--bg-hover);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-muted);
    overflow: hidden;
  }

  .profile-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .profile-name-area {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .profile-name {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--text-heading);
  }

  .edit-name-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0.3rem;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .edit-name-btn:hover {
    color: var(--text-sub);
    background: var(--bg-hover);
  }

  .profile-email {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  .nickname-edit-area {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border-light);
  }

  .nickname-input {
    width: 100%;
    padding: 0.7rem 0.85rem;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 0.9rem;
    font-family: inherit;
    background: var(--bg-card);
    color: var(--text);
    transition: border-color 0.15s;
  }

  .nickname-input:focus {
    outline: none;
    border-color: var(--text-heading);
  }

  .nickname-edit-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.6rem;
    justify-content: flex-end;
  }

  .btn-save {
    padding: 0.5rem 1.1rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.1s;
    font-family: inherit;
  }

  .btn-save:hover { opacity: 0.85; }
  .btn-save:active { transform: scale(0.97); }

  .btn-cancel {
    padding: 0.5rem 1.1rem;
    background: none;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--text-sub);
    transition: border-color 0.15s;
    font-family: inherit;
  }

  .btn-cancel:hover {
    border-color: var(--text-muted);
  }

  .profile-section {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .profile-section h2 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 1rem;
    color: var(--text-heading);
  }

  .account-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .btn-logout {
    width: 100%;
    padding: 0.7rem;
    background: none;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--text-sub);
    transition: border-color 0.15s;
    font-family: inherit;
  }

  .btn-logout:hover {
    border-color: var(--text-heading);
  }

  .btn-account-manage {
    display: block;
    width: 100%;
    padding: 0.7rem;
    background: none;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--text-muted);
    text-align: center;
    text-decoration: none;
    transition: border-color 0.15s;
    font-family: inherit;
    box-sizing: border-box;
  }
  .btn-account-manage:hover {
    border-color: var(--text-heading);
    color: var(--text-sub);
  }

  .danger-zone {
    padding-top: 1rem;
    border-top: 1px solid var(--border-light);
  }

  .danger-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .btn-delete-account {
    width: 100%;
    padding: 0.65rem;
    background: none;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--text-muted);
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    font-family: inherit;
  }

  .btn-delete-account:hover {
    background: #fef2f2;
    border-color: #dc2626;
    color: #dc2626;
  }

  [data-theme="dark"] .btn-delete-account:hover {
    background: #451a1a;
    border-color: #dc2626;
    color: #fca5a5;
  }

  .theme-setting {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .theme-setting-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .theme-setting-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-heading);
  }

  .theme-setting-current {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .theme-switch-group {
    display: flex;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .theme-switch-btn {
    padding: 0.5rem 0.85rem;
    background: none;
    border: none;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s, color 0.15s;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .theme-switch-btn:first-child {
    border-right: 1.5px solid var(--border);
  }

  .theme-switch-btn.active {
    background: var(--text-heading);
    color: var(--bg);
    font-weight: 600;
  }

  .theme-switch-icon {
    font-size: 0.85rem;
  }

</style>

<script>
  import { fetchCurrentUser, updateNickname, updatePushEnabled, logout, clearTokens, showToast, apiFetch } from '@/lib/api';
  import { registerPushToken } from '@/lib/firebase';
  import { uploadImage } from '@/lib/image-upload';

  async function initProfilePage() {
    const profilePage = document.getElementById('profile-page');
    const profileLoading = document.getElementById('profile-loading');
    if (!profilePage || !profileLoading) return;

    const user = await fetchCurrentUser();
    if (!user) {
      location.href = `${import.meta.env.PUBLIC_API_URL || 'http://localhost:4000'}/auth/kakao`;
      return;
    }

    profileLoading.hidden = true;
    profilePage.hidden = false;

    // 프로필 정보 표시
    const avatarEl = document.getElementById('profile-avatar');
    const nameEl = document.getElementById('profile-name');
    const emailEl = document.getElementById('profile-email');
    if (!avatarEl || !nameEl || !emailEl) return;

    if (user.profileImageUrl) {
      avatarEl.innerHTML = `<img src="${user.profileImageUrl}" alt="프로필" />`;
    } else {
      avatarEl.textContent = user.nickname.charAt(0);
    }
    nameEl.textContent = user.nickname;
    emailEl.textContent = user.email;

    // 프로필 사진 변경
    const avatarFileInput = document.getElementById('avatar-file-input') as HTMLInputElement | null;
    if (avatarFileInput) {
      avatarFileInput.addEventListener('change', async () => {
        const file = avatarFileInput.files?.[0];
        if (!file) return;
        try {
          showToast('프로필 사진 업로드 중...', 'info');
          const { imageUrl } = await uploadImage(file, 'profiles');
          await updateNickname(user.nickname, imageUrl);
          avatarEl.innerHTML = `<img src="${imageUrl}" alt="프로필" />`;
          showToast('프로필 사진이 변경되었습니다.', 'success');
        } catch {
          showToast('프로필 사진 변경에 실패했습니다.');
        }
        avatarFileInput.value = '';
      });
    }

    // 닉네임 수정
    const editBtn = document.getElementById('edit-name-btn');
    const editArea = document.getElementById('nickname-edit');
    const nicknameInput = document.getElementById('nickname-input') as HTMLInputElement | null;
    const saveBtn = document.getElementById('nickname-save');
    const cancelBtn = document.getElementById('nickname-cancel');
    if (!editBtn || !editArea || !nicknameInput || !saveBtn || !cancelBtn) return;

    editBtn.addEventListener('click', () => {
      nicknameInput.value = nameEl.textContent || '';
      editArea.hidden = false;
      nicknameInput.focus();
      nicknameInput.select();
    });

    cancelBtn.addEventListener('click', () => {
      editArea.hidden = true;
    });

    async function saveNickname() {
      if (!nicknameInput || !nameEl || !editArea) return;
      const newName = nicknameInput.value.trim();
      if (!newName || newName === nameEl.textContent) {
        editArea.hidden = true;
        return;
      }
      try {
        const updated = await updateNickname(newName);
        nameEl.textContent = updated.nickname;
        if (!user.profileImageUrl && avatarEl) {
          avatarEl.textContent = updated.nickname.charAt(0);
        }
        editArea.hidden = true;
        showToast('닉네임이 변경되었습니다.');
      } catch (err) {
        showToast(err instanceof Error ? err.message : '닉네임 변경에 실패했습니다.');
      }
    }

    saveBtn.addEventListener('click', saveNickname);
    nicknameInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); saveNickname(); }
      if (e.key === 'Escape' && editArea) { editArea.hidden = true; }
    });

    // 테마 설정
    const themeCurrent = document.getElementById('theme-current');
    const themeGroup = document.getElementById('theme-switch-group');
    if (!themeCurrent || !themeGroup) return;

    function updateThemeUI() {
      if (!themeCurrent || !themeGroup) return;
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      themeCurrent.textContent = isDark ? '다크 모드 사용 중' : '라이트 모드 사용 중';
      for (const btn of themeGroup.querySelectorAll<HTMLButtonElement>('.theme-switch-btn')) {
        btn.classList.toggle('active', btn.dataset.theme === (isDark ? 'dark' : 'light'));
      }
    }
    updateThemeUI();

    for (const btn of themeGroup.querySelectorAll<HTMLButtonElement>('.theme-switch-btn')) {
      btn.addEventListener('click', () => {
        const theme = btn.dataset.theme;
        if (theme === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('theme', 'dark');
        } else {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'light');
        }
        updateThemeUI();
      });
    }

    // 푸시 알림 토글
    const pushCurrent = document.getElementById('push-current');
    const pushGroup = document.getElementById('push-switch-group');
    if (pushCurrent && pushGroup) {
      function updatePushUI() {
        if (!pushCurrent || !pushGroup) return;
        const isOn = user.pushEnabled;
        pushCurrent.textContent = isOn ? '켜짐' : '꺼짐';
        for (const btn of pushGroup.querySelectorAll<HTMLButtonElement>('.theme-switch-btn')) {
          btn.classList.toggle('active', btn.dataset.push === (isOn ? 'on' : 'off'));
        }
      }
      updatePushUI();

      for (const btn of pushGroup.querySelectorAll<HTMLButtonElement>('.theme-switch-btn')) {
        btn.addEventListener('click', async () => {
          const enabled = btn.dataset.push === 'on';
          if (enabled === user.pushEnabled) return;

          // "켜기": 브라우저 지원 + 알림 권한 확인 후 FCM 토큰 등록까지 수행
          if (enabled) {
            if (!('Notification' in window) || !('serviceWorker' in navigator)) {
              showToast('이 브라우저에서는 푸시 알림을 지원하지 않습니다.');
              return;
            }
            if (Notification.permission === 'denied') {
              showToast('알림 권한이 차단되어 있습니다. 브라우저 설정에서 허용해 주세요.');
              return;
            }
            if (Notification.permission === 'default') {
              const perm = await Notification.requestPermission();
              if (perm !== 'granted') {
                showToast('알림 권한이 허용되지 않아 푸시 알림을 켤 수 없습니다.');
                return;
              }
            }
            // 권한 granted 상태 → FCM 토큰 발급 + 서버 등록
            const token = await registerPushToken(apiFetch);
            if (!token) {
              showToast('푸시 토큰 발급에 실패했습니다. 잠시 후 다시 시도해 주세요.');
              return;
            }
          }

          try {
            await updatePushEnabled(enabled);
            user.pushEnabled = enabled;
            updatePushUI();
            showToast(enabled ? '푸시 알림이 켜졌습니다.' : '푸시 알림이 꺼졌습니다.');
          } catch (err) {
            showToast(err instanceof Error ? err.message : '설정 변경에 실패했습니다.');
          }
        });
      }
    }

    // 로그아웃
    const logoutBtn = document.getElementById('profile-logout');
    if (logoutBtn) {
      logoutBtn.addEventListener('click', () => {
        logout();
        location.href = '/';
      });
    }

  }

  document.addEventListener('astro:page-load', initProfilePage);
</script>
