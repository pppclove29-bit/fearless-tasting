---
import BaseLayout from '@/layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="내 프로필" description="내 프로필 관리 - 닉네임 수정, 활동 요약, 계정 관리">
  <div class="profile-page" id="profile-page" hidden>
    <section class="profile-card">
      <div class="profile-header">
        <div class="profile-avatar" id="profile-avatar"></div>
        <div class="profile-name-area">
          <h1 class="profile-name" id="profile-name"></h1>
          <button type="button" class="edit-name-btn" id="edit-name-btn" title="닉네임 수정">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </button>
        </div>
        <p class="profile-email" id="profile-email"></p>
      </div>
      <div class="nickname-edit-area" id="nickname-edit" hidden>
        <input type="text" id="nickname-input" class="nickname-input" maxlength="50" placeholder="새 닉네임" />
        <div class="nickname-edit-actions">
          <button type="button" class="btn-save" id="nickname-save">저장</button>
          <button type="button" class="btn-cancel" id="nickname-cancel">취소</button>
        </div>
      </div>
    </section>

    <section class="profile-section">
      <h2>활동 요약</h2>
      <div class="stats-grid" id="stats-grid">
        <div class="stat-item">
          <span class="stat-value" id="stat-rooms">-</span>
          <span class="stat-label">참여 중인 방</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="stat-restaurants">-</span>
          <span class="stat-label">등록한 식당</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="stat-reviews">-</span>
          <span class="stat-label">작성한 리뷰</span>
        </div>
        <div class="stat-item">
          <span class="stat-value" id="stat-visits">-</span>
          <span class="stat-label">방문 기록</span>
        </div>
      </div>
    </section>

    <section class="profile-section" id="wishlist-section" hidden>
      <h2>내가 찜한 식당</h2>
      <div id="wishlist-list"></div>
      <p id="wishlist-empty" class="wishlist-empty" hidden>아직 찜한 식당이 없습니다.</p>
    </section>

    <section class="profile-section">
      <h2>화면 설정</h2>
      <div class="theme-setting">
        <div class="theme-setting-info">
          <span class="theme-setting-label">테마</span>
          <span class="theme-setting-current" id="theme-current">라이트 모드</span>
        </div>
        <div class="theme-switch-group" id="theme-switch-group">
          <button type="button" class="theme-switch-btn active" data-theme="light">
            <span class="theme-switch-icon">&#9728;&#65039;</span> 라이트
          </button>
          <button type="button" class="theme-switch-btn" data-theme="dark">
            <span class="theme-switch-icon">&#127769;</span> 다크
          </button>
        </div>
      </div>
    </section>

    <section class="profile-section">
      <h2>계정 관리</h2>
      <div class="account-actions">
        <button type="button" class="btn-logout" id="profile-logout">로그아웃</button>
        <div class="danger-zone">
          <p class="danger-desc">계정을 삭제하면 모든 리뷰, 참여 중인 방 등 개인 데이터가 즉시 삭제되며 복구할 수 없습니다.</p>
          <button type="button" class="btn-delete-account" id="delete-account-btn">회원 탈퇴</button>
        </div>
      </div>
    </section>
  </div>

  <div class="profile-loading" id="profile-loading">
    <p>로딩 중...</p>
  </div>
</BaseLayout>

<style>
  .profile-page {
    max-width: 560px;
    margin: 0 auto;
  }

  .profile-loading {
    text-align: center;
    padding: 3rem;
    color: var(--text-muted);
  }

  .profile-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem 1.5rem;
    margin-bottom: 1rem;
  }

  .profile-header {
    text-align: center;
  }

  .profile-avatar {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--bg-hover);
    border: 2px solid var(--border);
    margin: 0 auto 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--text-muted);
    overflow: hidden;
  }

  .profile-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .profile-name-area {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }

  .profile-name {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0;
    color: var(--text-heading);
  }

  .edit-name-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0.3rem;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .edit-name-btn:hover {
    color: var(--text-sub);
    background: var(--bg-hover);
  }

  .profile-email {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  .nickname-edit-area {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border-light);
  }

  .nickname-input {
    width: 100%;
    padding: 0.7rem 0.85rem;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 0.9rem;
    font-family: inherit;
    background: var(--bg-card);
    color: var(--text);
    transition: border-color 0.15s;
  }

  .nickname-input:focus {
    outline: none;
    border-color: var(--text-heading);
  }

  .nickname-edit-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.6rem;
    justify-content: flex-end;
  }

  .btn-save {
    padding: 0.5rem 1.1rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.1s;
    font-family: inherit;
  }

  .btn-save:hover { opacity: 0.85; }
  .btn-save:active { transform: scale(0.97); }

  .btn-cancel {
    padding: 0.5rem 1.1rem;
    background: none;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--text-sub);
    transition: border-color 0.15s;
    font-family: inherit;
  }

  .btn-cancel:hover {
    border-color: var(--text-muted);
  }

  .profile-section {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .profile-section h2 {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 1rem;
    color: var(--text-heading);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
  }

  .stat-item {
    text-align: center;
    padding: 1rem 0.75rem;
    background: var(--bg-hover);
    border-radius: 12px;
  }

  .stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-heading);
  }

  .stat-label {
    display: block;
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-top: 0.2rem;
  }

  .account-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .btn-logout {
    width: 100%;
    padding: 0.7rem;
    background: none;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--text-sub);
    transition: border-color 0.15s;
    font-family: inherit;
  }

  .btn-logout:hover {
    border-color: var(--text-heading);
  }

  .danger-zone {
    padding-top: 1rem;
    border-top: 1px solid var(--border-light);
  }

  .danger-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0 0 0.75rem;
  }

  .btn-delete-account {
    width: 100%;
    padding: 0.65rem;
    background: none;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--text-muted);
    transition: background 0.15s, border-color 0.15s, color 0.15s;
    font-family: inherit;
  }

  .btn-delete-account:hover {
    background: #fef2f2;
    border-color: #dc2626;
    color: #dc2626;
  }

  [data-theme="dark"] .btn-delete-account:hover {
    background: #451a1a;
    border-color: #dc2626;
    color: #fca5a5;
  }

  .theme-setting {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .theme-setting-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .theme-setting-label {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-heading);
  }

  .theme-setting-current {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .theme-switch-group {
    display: flex;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .theme-switch-btn {
    padding: 0.5rem 0.85rem;
    background: none;
    border: none;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s, color 0.15s;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .theme-switch-btn:first-child {
    border-right: 1.5px solid var(--border);
  }

  .theme-switch-btn.active {
    background: var(--text-heading);
    color: var(--bg);
    font-weight: 600;
  }

  .theme-switch-icon {
    font-size: 0.85rem;
  }

  .wishlist-empty {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.875rem;
    padding: 1.5rem 0;
  }

  .wishlist-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border-light);
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
  }

  .wishlist-item:last-child { border-bottom: none; }

  .wishlist-item-info { min-width: 0; flex: 1; }
  .wishlist-item-name { font-size: 0.9rem; font-weight: 600; color: var(--text-heading); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .wishlist-item-meta { font-size: 0.78rem; color: var(--text-muted); margin-top: 0.15rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .wishlist-item-room { font-size: 0.72rem; color: var(--text-muted); background: var(--bg-hover); padding: 0.2rem 0.5rem; border-radius: 6px; white-space: nowrap; margin-left: 0.5rem; flex-shrink: 0; }
</style>

<script>
  import { fetchCurrentUser, fetchMyRooms, fetchRankings, fetchMyWishlists, updateNickname, deleteAccount, logout, clearTokens, showToast, showDangerConfirm } from '@/lib/api';

  const profilePage = document.getElementById('profile-page')!;
  const profileLoading = document.getElementById('profile-loading')!;

  const user = await fetchCurrentUser();
  if (!user) {
    location.href = `${import.meta.env.PUBLIC_API_URL || 'http://localhost:4000'}/auth/kakao`;
  } else {
    profileLoading.hidden = true;
    profilePage.hidden = false;

    // 프로필 정보 표시
    const avatarEl = document.getElementById('profile-avatar')!;
    const nameEl = document.getElementById('profile-name')!;
    const emailEl = document.getElementById('profile-email')!;

    if (user.profileImageUrl) {
      avatarEl.innerHTML = `<img src="${user.profileImageUrl}" alt="프로필" />`;
    } else {
      avatarEl.textContent = user.nickname.charAt(0);
    }
    nameEl.textContent = user.nickname;
    emailEl.textContent = user.email;

    // 닉네임 수정
    const editBtn = document.getElementById('edit-name-btn')!;
    const editArea = document.getElementById('nickname-edit')!;
    const nicknameInput = document.getElementById('nickname-input') as HTMLInputElement;
    const saveBtn = document.getElementById('nickname-save')!;
    const cancelBtn = document.getElementById('nickname-cancel')!;

    editBtn.addEventListener('click', () => {
      nicknameInput.value = nameEl.textContent || '';
      editArea.hidden = false;
      nicknameInput.focus();
      nicknameInput.select();
    });

    cancelBtn.addEventListener('click', () => {
      editArea.hidden = true;
    });

    async function saveNickname() {
      const newName = nicknameInput.value.trim();
      if (!newName || newName === nameEl.textContent) {
        editArea.hidden = true;
        return;
      }
      try {
        const updated = await updateNickname(newName);
        nameEl.textContent = updated.nickname;
        if (!user.profileImageUrl) {
          avatarEl.textContent = updated.nickname.charAt(0);
        }
        editArea.hidden = true;
        showToast('닉네임이 변경되었습니다.');
      } catch (err) {
        showToast(err instanceof Error ? err.message : '닉네임 변경에 실패했습니다.');
      }
    }

    saveBtn.addEventListener('click', saveNickname);
    nicknameInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); saveNickname(); }
      if (e.key === 'Escape') { editArea.hidden = true; }
    });

    // 활동 요약 로드
    try {
      const [rooms, rankings] = await Promise.all([
        fetchMyRooms(),
        fetchRankings().catch(() => null),
      ]);

      document.getElementById('stat-rooms')!.textContent = String(rooms.length);

      const myRanking = rankings?.rankings.find((r) => r.userId === user.id);
      if (myRanking) {
        document.getElementById('stat-restaurants')!.textContent = String(myRanking.restaurantCount);
        document.getElementById('stat-reviews')!.textContent = String(myRanking.reviewCount);
        document.getElementById('stat-visits')!.textContent = String(myRanking.visitCount);
      }
    } catch {
      // 통계 로드 실패 시 무시
    }

    // 찜한 식당 로드
    try {
      const wishlists = await fetchMyWishlists();
      const wishlistSection = document.getElementById('wishlist-section')!;
      const wishlistList = document.getElementById('wishlist-list')!;
      const wishlistEmpty = document.getElementById('wishlist-empty')!;

      wishlistSection.hidden = false;

      if (wishlists.length === 0) {
        wishlistEmpty.hidden = false;
      } else {
        function escapeHtml(text: string): string {
          const div = document.createElement('div');
          div.textContent = text;
          return div.innerHTML;
        }

        wishlistList.innerHTML = wishlists.map((w) => `
          <a href="/room/restaurant?roomId=${w.roomRestaurant.roomId}&id=${w.roomRestaurant.id}" class="wishlist-item">
            <div class="wishlist-item-info">
              <div class="wishlist-item-name">${escapeHtml(w.roomRestaurant.name)}</div>
              <div class="wishlist-item-meta">${escapeHtml(w.roomRestaurant.category)} · ${escapeHtml(w.roomRestaurant.address)}</div>
            </div>
            <span class="wishlist-item-room">${escapeHtml(w.roomRestaurant.room.name)}</span>
          </a>
        `).join('');
      }
    } catch {
      // 찜 목록 로드 실패 시 무시
    }

    // 테마 설정
    const themeCurrent = document.getElementById('theme-current')!;
    const themeGroup = document.getElementById('theme-switch-group')!;

    function updateThemeUI() {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      themeCurrent.textContent = isDark ? '다크 모드 사용 중' : '라이트 모드 사용 중';
      for (const btn of themeGroup.querySelectorAll<HTMLButtonElement>('.theme-switch-btn')) {
        btn.classList.toggle('active', btn.dataset.theme === (isDark ? 'dark' : 'light'));
      }
    }
    updateThemeUI();

    for (const btn of themeGroup.querySelectorAll<HTMLButtonElement>('.theme-switch-btn')) {
      btn.addEventListener('click', () => {
        const theme = btn.dataset.theme!;
        if (theme === 'dark') {
          document.documentElement.setAttribute('data-theme', 'dark');
          localStorage.setItem('theme', 'dark');
        } else {
          document.documentElement.removeAttribute('data-theme');
          localStorage.setItem('theme', 'light');
        }
        updateThemeUI();
      });
    }

    // 로그아웃
    document.getElementById('profile-logout')!.addEventListener('click', () => {
      logout();
      location.href = '/';
    });

    // 회원 탈퇴
    document.getElementById('delete-account-btn')!.addEventListener('click', async () => {
      const confirmed = await showDangerConfirm(
        '정말 탈퇴하시겠습니까?\n\n계정, 리뷰, 참여 중인 방 등 모든 개인 데이터가 즉시 삭제되며 복구할 수 없습니다.',
        '탈퇴',
      );
      if (!confirmed) return;

      try {
        await deleteAccount();
        clearTokens();
        location.href = '/';
      } catch (err) {
        showToast(err instanceof Error ? err.message : '탈퇴에 실패했습니다.');
      }
    });
  }
</script>
