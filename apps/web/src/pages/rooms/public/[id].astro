---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import type { SharedRoomDetail } from '@repo/types';

const { id } = Astro.params;
const API_BASE = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';
const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');

let room: SharedRoomDetail | null = null;
let error = '';

try {
  const res = await fetch(`${API_BASE}/rooms/public/${id}`);
  if (res.ok) {
    room = await res.json();
  } else {
    error = '공개 방을 찾을 수 없거나, 비공개 상태입니다.';
  }
} catch {
  error = '서버에 연결할 수 없습니다.';
}

const title = room ? `${room.name} 맛집 리스트` : '공개 맛집 방';
const summary = room?.summary;
const topCategoriesStr = summary?.topCategories?.length ? summary.topCategories.join(', ') : '';
const description = room && summary
  ? [
      `${room.name} · 맛집 ${summary.restaurantCount}곳 · 리뷰 ${summary.totalReviews}개`,
      summary.avgRating != null ? `평균 ★${summary.avgRating.toFixed(1)}` : null,
      topCategoriesStr ? `(${topCategoriesStr})` : null,
      '실제 방문자의 리얼 리뷰를 확인하세요.',
    ].filter(Boolean).join(' · ')
  : '공개 맛집 방을 확인하세요';
---

<BaseLayout
  title={title}
  description={description}
  ogImage={room ? `${API_BASE}/og/public-rooms/${id}.png` : undefined}
  ogImageAlt={room ? `${room.name} 맛집 리스트 — ${room.restaurants.length}곳` : '공개 맛집 방'}
  noindex={!room}
>
  <Fragment slot="head">
    {room && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ItemList",
        "name": room.name,
        "description": `${room.name} - ${room.restaurants.length}곳의 맛집 리스트`,
        "url": siteUrl + `/rooms/public/${id}`,
        "numberOfItems": room.restaurants.length,
        "itemListElement": room.restaurants.map((r, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "item": {
            "@type": "FoodEstablishment",
            "name": r.name,
            "address": r.address,
            "servesCuisine": r.category,
            ...(r.avgRating !== null && r.reviewCount > 0 ? {
              "aggregateRating": {
                "@type": "AggregateRating",
                "ratingValue": r.avgRating,
                "reviewCount": r.reviewCount,
                "bestRating": 5,
                "worstRating": 0.5,
              }
            } : {}),
          },
        })),
      })} />
    )}
    {room && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "홈", "item": siteUrl },
          { "@type": "ListItem", "position": 2, "name": "공개 맛집 방", "item": siteUrl + "/rooms/public" },
          { "@type": "ListItem", "position": 3, "name": room.name, "item": siteUrl + `/rooms/public/${id}` },
        ]
      })} />
    )}
  </Fragment>

  <div id="public-room-page">
    {error && <p class="status-msg error">{error}</p>}

    {room && (
      <div id="public-room-content">
        <a href="/rooms/public" class="back-link">&larr; 공개 맛집 방 목록</a>
        <div class="share-header">
          <h1>{room.name}</h1>
          <span class="share-badge">공개 맛집 리스트 &middot; {room.summary.restaurantCount}곳</span>
        </div>

        {room.summary.restaurantCount > 0 && (
          <div class="public-summary">
            <div class="public-summary-stats">
              <div class="public-stat">
                <div class="public-stat-value">{room.summary.restaurantCount}</div>
                <div class="public-stat-label">식당</div>
              </div>
              <div class="public-stat">
                <div class="public-stat-value">{room.summary.totalReviews}</div>
                <div class="public-stat-label">리뷰</div>
              </div>
              {room.summary.avgRating != null && (
                <div class="public-stat">
                  <div class="public-stat-value">★ {room.summary.avgRating.toFixed(1)}</div>
                  <div class="public-stat-label">평균 평점</div>
                </div>
              )}
            </div>
            {(room.summary.topCategories.length > 0 || room.summary.topRegions.length > 0) && (
              <div class="public-summary-tags">
                {room.summary.topCategories.map((c) => (
                  <span class="public-tag">#{c}</span>
                ))}
                {room.summary.topRegions.map((r) => (
                  <span class="public-tag public-tag-region">📍 {r}</span>
                ))}
              </div>
            )}
          </div>
        )}

        <div id="restaurant-detail-area"></div>

        {room.restaurants.length === 0 ? (
          <p class="empty-text">등록된 식당이 없습니다.</p>
        ) : (
          room.restaurants.map((r) => (
            <div class="share-restaurant-card" data-rid={r.id}>
              <div class="share-rest-name">{r.name}</div>
              <div class="share-rest-meta">{r.address} &middot; {r.category}</div>
              <div class="share-rest-footer">
                {r.avgRating != null && (
                  <span class="share-rest-rating">★ {r.avgRating.toFixed(1)}</span>
                )}
                <span class="share-rest-reviews-count">리뷰 {r.reviewCount}개</span>
              </div>
            </div>
          ))
        )}

        <section class="public-cta-section" id="public-cta-section">
          <div id="public-cta-guest" hidden>
            <h2 class="public-cta-title">이런 맛집 리스트, 나도 만들 수 있어요</h2>
            <p class="public-cta-desc">
              친구·연인·가족과 함께 우리만의 맛집 리스트를 만들어보세요.<br/>
              카카오·네이버 로그인으로 3초 만에 시작.
            </p>
            <a href="/login" class="public-cta-btn">무료로 시작하기</a>
          </div>
          <div id="public-cta-auth" hidden>
            <h2 class="public-cta-title">이 방에 참여해볼까요?</h2>
            <p class="public-cta-desc">
              방에 참여하면 식당을 함께 추가하고 리뷰를 남길 수 있어요.
            </p>
            <button type="button" class="public-cta-btn" id="public-join-btn">방 참여하기</button>
          </div>
          <div id="public-cta-member" hidden>
            <h2 class="public-cta-title">이미 참여 중인 방이에요</h2>
            <p class="public-cta-desc">내 방에서 바로 리뷰를 남기고 식당을 추가해보세요.</p>
            <a href="#" class="public-cta-btn" id="public-go-room-btn">방으로 이동</a>
          </div>
        </section>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .status-msg {
    text-align: center;
    padding: 3rem 1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .status-msg.error {
    color: #dc2626;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 1rem;
    font-size: 0.85rem;
    color: var(--text-sub);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--text-heading);
  }
</style>

<style is:global>
  .share-header {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .share-header h1 {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.35rem;
    color: var(--text-heading);
  }

  .share-header .share-badge {
    display: inline-block;
    padding: 0.25rem 0.65rem;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 500;
    background: var(--bg-hover);
    color: var(--text-sub);
  }

  .share-restaurant-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 0.6rem;
    cursor: pointer;
    transition: border-color 0.15s, transform 0.1s;
  }

  .share-restaurant-card:hover { border-color: var(--border-mid); }
  .share-restaurant-card:active { transform: scale(0.99); }

  .share-rest-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.2rem;
  }

  .share-rest-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .share-rest-footer {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
    align-items: center;
    margin-top: 0.35rem;
  }

  .share-rest-rating {
    font-size: 0.78rem;
    color: var(--text-heading);
    font-weight: 700;
  }

  .share-rest-reviews-count {
    font-size: 0.75rem;
    color: var(--text-sub);
    font-weight: 500;
  }

  /* 공개 방 요약 카드 */
  .public-summary {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 1rem;
  }
  .public-summary-stats {
    display: flex;
    gap: 1.5rem;
    justify-content: space-around;
    align-items: center;
  }
  .public-stat { text-align: center; }
  .public-stat-value {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text-heading);
    letter-spacing: -0.01em;
  }
  .public-stat-label {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }
  .public-summary-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.85rem;
    padding-top: 0.85rem;
    border-top: 1px dashed var(--border);
  }
  .public-tag {
    font-size: 0.72rem;
    color: var(--text-sub);
    background: var(--bg-hover);
    padding: 0.2rem 0.55rem;
    border-radius: 100px;
  }
  .public-tag-region { color: var(--text-heading); }

  /* 신규 유저 전환 CTA */
  .public-cta-section {
    margin-top: 2rem;
    padding: 2rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--text-heading);
    border-radius: 14px;
    text-align: center;
  }
  .public-cta-title {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text-heading);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .public-cta-desc {
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.6;
    margin: 0 0 1.1rem;
  }
  .public-cta-btn {
    display: inline-block;
    padding: 0.75rem 1.75rem;
    background: var(--text-heading);
    color: var(--bg);
    font-weight: 700;
    font-size: 0.9rem;
    border-radius: 12px;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .public-cta-btn:hover { opacity: 0.88; }

  .share-rest-detail {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .share-rest-detail h2 {
    font-size: 1.15rem;
    font-weight: 800;
    margin: 0 0 0.25rem;
    color: var(--text-heading);
  }

  .share-rest-detail .detail-address {
    font-size: 0.85rem;
    color: var(--text-sub);
    margin-bottom: 0.5rem;
  }

  .share-rest-detail .detail-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .share-rest-detail .category-badge {
    background: var(--bg-hover);
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-sub);
  }

  .detail-close-btn {
    float: right;
    padding: 0.35rem 0.7rem;
    background: var(--bg-card);
    color: var(--text-sub);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.15s;
    font-family: inherit;
  }

  .detail-close-btn:hover { border-color: var(--text-muted); }

  .share-review-card {
    border-bottom: 1px solid var(--border-light);
    padding: 0.7rem 0;
    font-size: 0.85rem;
  }

  .share-review-card:last-child { border-bottom: none; }

  .share-review-header {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
    margin-bottom: 0.25rem;
  }

  .share-review-rating {
    color: #e6a817;
    font-weight: 600;
    font-size: 0.8rem;
  }

  .share-review-content {
    color: var(--text);
    line-height: 1.5;
  }

  .share-review-footer {
    margin-top: 0.25rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .empty-text {
    text-align: center;
    padding: 1.5rem;
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .share-detail-ratings {
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .share-menu-info {
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  .revisit-badge {
    font-size: 0.65rem;
    padding: 0.1rem 0.3rem;
    border-radius: 4px;
  }

  .revisit-no {
    background: #fee2e2;
    color: #991b1b;
  }

  .revisit-yes {
    background: var(--bg-hover);
    color: var(--text-heading);
  }

  [data-theme="dark"] .revisit-no {
    background: #451a1a;
    color: #fca5a5;
  }

  [data-theme="dark"] .revisit-yes {
    background: var(--bg-hover);
    color: var(--text-heading);
  }

  .share-visit-card {
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 0.85rem;
    margin-bottom: 0.6rem;
    background: var(--bg-hover);
  }

  .share-visit-header {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-heading);
    margin-bottom: 0.4rem;
  }

  .share-visit-memo {
    font-weight: 400;
    color: var(--text-muted);
    margin-left: 0.5rem;
  }
</style>

<script>
  import { fetchPublicRoomRestaurantDetail, fetchCurrentUser, fetchMyRooms, joinPublicRoom } from '@/lib/api';
  import { formatRating, formatDate } from '@repo/utils';
  import { showToast } from '@/lib/toast';

  async function renderPublicRoomCta(roomId: string) {
    const section = document.getElementById('public-cta-section');
    if (!section) return;
    const guestBlock = document.getElementById('public-cta-guest');
    const authBlock = document.getElementById('public-cta-auth');
    const memberBlock = document.getElementById('public-cta-member');
    if (!guestBlock || !authBlock || !memberBlock) return;

    const user = await fetchCurrentUser().catch(() => null);
    if (!user) {
      guestBlock.hidden = false;
      return;
    }

    const myRooms = await fetchMyRooms().catch(() => []);
    const alreadyMember = myRooms.some((r) => r.id === roomId);

    if (alreadyMember) {
      memberBlock.hidden = false;
      const goBtn = document.getElementById('public-go-room-btn') as HTMLAnchorElement | null;
      if (goBtn) goBtn.href = `/room?id=${roomId}`;
      return;
    }

    authBlock.hidden = false;
    const joinBtn = document.getElementById('public-join-btn') as HTMLButtonElement | null;
    if (joinBtn) {
      joinBtn.addEventListener('click', async () => {
        joinBtn.disabled = true;
        try {
          await joinPublicRoom(roomId);
          showToast('방에 참여했습니다.', 'success');
          window.location.href = `/room?id=${roomId}`;
        } catch (err) {
          showToast(err instanceof Error ? err.message : '방 참여에 실패했습니다.', 'error');
          joinBtn.disabled = false;
        }
      });
    }
  }

  function initPublicRoomDetailPage() {
    const detailArea = document.getElementById('restaurant-detail-area');
    if (!detailArea) return;

    const pathMatch = window.location.pathname.match(/\/rooms\/public\/([^/]+)/);
    const roomId = pathMatch?.[1];
    if (!roomId) return;

    renderPublicRoomCta(roomId);

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    const renderStars = formatRating;

    function attachCardHandlers() {
      for (const card of document.querySelectorAll<HTMLElement>('.share-restaurant-card')) {
        card.addEventListener('click', () => {
          loadRestaurantDetail(card.dataset.rid!);
        });
      }
    }

    async function loadRestaurantDetail(rid: string) {
      detailArea.innerHTML = '<p class="empty-text">로딩 중...</p>';

      try {
        const detail = await fetchPublicRoomRestaurantDetail(roomId, rid);
        const allReviews = detail.visits.flatMap((v) => v.reviews);

        const avgRating = allReviews.length > 0
          ? Math.round(allReviews.reduce((a, r) => a + r.rating, 0) / allReviews.length * 10) / 10
          : null;

        const sortedVisits = [...detail.visits].sort((a, b) => new Date(b.visitedAt).getTime() - new Date(a.visitedAt).getTime());

        let visitsHtml = '';
        if (sortedVisits.length === 0) {
          visitsHtml = '<p class="empty-text">아직 방문 기록이 없습니다.</p>';
        } else {
          visitsHtml = sortedVisits.map((visit) => {
            const reviewsHtml = visit.reviews.length > 0
              ? visit.reviews.map((rev) => {
                  const detailRatings = [
                    rev.tasteRating != null ? `맛 ${rev.tasteRating}` : null,
                    rev.valueRating != null ? `가성비 ${rev.valueRating}` : null,
                    rev.serviceRating != null ? `서비스 ${rev.serviceRating}` : null,
                    rev.cleanlinessRating != null ? `청결 ${rev.cleanlinessRating}` : null,
                    rev.accessibilityRating != null ? `접근성 ${rev.accessibilityRating}` : null,
                  ].filter(Boolean);
                  const detailLine = detailRatings.length > 0 ? `<div class="share-detail-ratings">${detailRatings.join(' · ')}</div>` : '';
                  const menuLine = [
                    rev.favoriteMenu ? `또 먹고 싶은 메뉴: ${escapeHtml(rev.favoriteMenu)}` : null,
                    rev.tryNextMenu ? `다음에 시켜볼 메뉴: ${escapeHtml(rev.tryNextMenu)}` : null,
                  ].filter(Boolean);
                  const menuHtml = menuLine.length > 0 ? `<div class="share-menu-info">${menuLine.join(' | ')}</div>` : '';
                  const revisitLabels: Record<number, string> = { 5: '꼭 재방문', 4: '또 가고 싶어요', 3: '가까우면 갈만', 2: '사주면 갈게요', 1: '안 갈 것 같아요' };
                  const rvLv = rev.wouldRevisit ?? 4;
                  const revisitCls = rvLv >= 4 ? 'revisit-yes' : rvLv === 3 ? 'revisit-maybe' : 'revisit-no';
                  const revisitBadge = `<span class="revisit-badge ${revisitCls}">${revisitLabels[rvLv] ?? '또 가고 싶어요'}</span>`;
                  return `
                    <div class="share-review-card">
                      <div class="share-review-header">
                        <span>${revisitBadge}</span>
                        <span class="share-review-rating">${renderStars(rev.rating)} ${rev.rating}</span>
                      </div>
                      ${detailLine}
                      <div class="share-review-content">${escapeHtml(rev.content)}</div>
                      ${menuHtml}
                      <div class="share-review-footer">${formatDate(rev.createdAt)}</div>
                    </div>
                  `;
                }).join('')
              : '<p class="empty-text">리뷰 없음</p>';

            return `
              <div class="share-visit-card">
                <div class="share-visit-header">
                  ${formatDate(visit.visitedAt)}
                  ${visit.memo ? `<span class="share-visit-memo">${escapeHtml(visit.memo)}</span>` : ''}
                </div>
                ${reviewsHtml}
              </div>
            `;
          }).join('');
        }

        detailArea.innerHTML = `
          <div class="share-rest-detail">
            <button type="button" class="detail-close-btn" id="close-detail-btn">닫기</button>
            <h2>${escapeHtml(detail.name)}</h2>
            <div class="detail-address">${escapeHtml(detail.address)}</div>
            <div class="detail-meta">
              <span class="category-badge">${escapeHtml(detail.category)}</span>
              ${avgRating !== null ? `<span>${renderStars(avgRating)} ${avgRating}</span>` : ''}
            </div>
            <div id="visits-list">${visitsHtml}</div>
          </div>
        `;

        document.getElementById('close-detail-btn')!.addEventListener('click', () => {
          detailArea.innerHTML = '';
        });
      } catch {
        detailArea.innerHTML = '<p class="empty-text">식당 정보를 불러올 수 없습니다.</p>';
      }
    }

    attachCardHandlers();
  }

  document.addEventListener('astro:page-load', initPublicRoomDetailPage);
</script>
