  }
  [data-theme="dark"] .inline-help-hint strong { color: #fbbf24; }
  [data-theme="dark"] .inline-help-hint p { color: #fcd34d; }

  .form-textarea {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1.5px solid var(--border);
