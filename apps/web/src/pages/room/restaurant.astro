    border-radius: 8px;
    font-size: 0.8rem;
  }

  .review-form-extras input[type="text"] {
    width: 100%;
    padding: 0.4rem 0.5rem;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.8rem;
    font-family: inherit;
    background: var(--bg-card);
    color: var(--text);
  }

  .detail-rating-inline {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .detail-rating-item {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .detail-rating-item .detail-label {
    font-size: 0.82rem;
    color: var(--text-sub);
    white-space: nowrap;
  }

  /* 세부평점 별 */
  .detail-slider {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }
  .detail-slider-label { font-size: 0.8rem; font-weight: 600; color: var(--text-heading); min-width: 3.5em; }
  .detail-stars { display: inline-flex; gap: 0.1rem; }
  .detail-star {
    font-size: 1.3rem;
    color: var(--border);
    cursor: pointer;
    transition: color 0.1s;
    line-height: 1;
  }
  .detail-star.active { color: #f59e0b; }


  .review-detail-ratings {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.2rem;
  }

  .review-menu-info {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    margin-top: 0.2rem;
  }

  .wait-badge {
    font-size: 0.75rem;
    color: var(--text-sub);
    background: var(--bg-hover);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
  }

  .empty-text {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    padding: 1.5rem 0;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .form-row.full {
    grid-template-columns: 1fr;
  }

  /* === Review Bubble === */
  .review-bubble-wrap {
    display: flex;
    gap: 0.65rem;
    padding: 0.75rem 0;
  }
  .review-bubble-wrap + .review-bubble-wrap {
    border-top: 1px solid var(--border-light);
  }
  .review-avatar {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--bg-hover);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .review-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .avatar-initial {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-sub);
  }
  .review-bubble-body {
    flex: 1;
    min-width: 0;
  }
  .review-nickname {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .review-speech {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 2px 12px 12px 12px;
    padding: 0.65rem 0.9rem;
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.55;
    margin-bottom: 0.5rem;
    word-break: break-word;
    position: relative;
  }
  .review-speech::before {
    content: '';
    position: absolute;
    top: -1px;
    left: -7px;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 8px 8px 0;
    border-color: transparent var(--border) transparent transparent;
  }
  .review-speech::after {
    content: '';
    position: absolute;
    top: 0;
    left: -5px;
    width: 0;
    height: 0;
    border-style: solid;
    border-width: 0 7px 7px 0;
    border-color: transparent var(--bg-card) transparent transparent;
  }
  [data-theme="dark"] .review-speech {
    background: #333338;
    border-color: #444449;
  }
  [data-theme="dark"] .review-speech::before {
    border-color: transparent #444449 transparent transparent;
  }
  [data-theme="dark"] .review-speech::after {
    border-color: transparent #333338 transparent transparent;
  }
  .review-stars-big {
    display: flex;
    align-items: center;
    gap: 0.08rem;
    font-size: 1.4rem;
    color: #e6a817;
    margin-bottom: 0.3rem;
    letter-spacing: -0.02em;
  }
  .review-stars-big .star-muted { color: var(--border-mid); }
  .review-stars-big .rating-num {
    font-size: 1.05rem;
    font-weight: 700;
    margin-left: 0.3rem;
    color: var(--text-heading);
  }
  .review-detail-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: 0.35rem;
  }
  .review-detail-chip {
    font-size: 0.7rem;
    padding: 0.12rem 0.42rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--text-sub);
  }
  .review-speech-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    font-weight: 500;
    margin-bottom: 0.15rem;
    display: block;
  }
  .review-fav-menu {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.65rem;
    background: rgba(255, 152, 0, 0.1);
    border: 1px solid rgba(255, 152, 0, 0.25);
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #f59e0b;
    margin-bottom: 0.4rem;
  }
  .fav-menu-icon {
    font-size: 0.85rem;
    line-height: 1;
  }
  .fav-menu-label {
    font-weight: 500;
    opacity: 0.7;
    font-size: 0.72rem;
  }
  [data-theme="dark"] .review-fav-menu {
    background: rgba(245, 158, 11, 0.12);
    border-color: rgba(245, 158, 11, 0.3);
    color: #fbbf24;
  }
  .review-extras[hidden] { display: none; }
  .review-extras {
    animation: visitFadeIn 0.2s ease;
  }
  .review-toggle-extras {
    display: block;
    margin-top: 0.2rem;
    padding: 0;
    border: none;
    background: none;
    color: var(--text-muted);
    font-size: 0.75rem;
    font-family: inherit;
    cursor: pointer;
    font-weight: 500;
    transition: color 0.15s;
  }
  .review-toggle-extras:hover { color: var(--text-sub); }
  .review-meta-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    color: var(--text-sub);
    flex-wrap: wrap;
    font-weight: 500;
    margin-top: 0.3rem;
  }

  /* === Visit Carousel === */
  .visit-carousel-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    padding: 0.5rem 0;
  }
  .visit-nav-btn {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1.5px solid var(--border-mid);
    background: var(--bg-card);
    color: var(--text-heading);
    font-size: 1.2rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    font-family: inherit;
  }
  .visit-nav-btn:hover:not(:disabled) {
    background: var(--bg-hover);
    border-color: var(--text-muted);
  }
  .visit-nav-btn:disabled {
    opacity: 0.25;
    cursor: not-allowed;
  }
  .visit-nav-label {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-heading);
    min-width: 150px;
    text-align: center;
  }
  .visit-slide {
    animation: visitFadeIn 0.2s ease;
  }
  @keyframes visitFadeIn {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  import {
    fetchCurrentUser, fetchRoom, fetchRoomRestaurant,
    updateRoomRestaurant, deleteRoomRestaurant,
    deleteRoomVisit, updateRoomVisit,
    createRoomReview, updateRoomReview, deleteRoomReview,
    showToast, showDangerConfirm,
  } from '@/lib/api';
  import type { AuthUser, RoomDetailResponse, ReviewData } from '@/lib/api';
  import type { RoomReviewWithUser, RoomVisitWithDetails } from '@repo/types';
  import { formatRating, formatDate } from '@repo/utils';

  function initRestaurantPage() {
    const loadingMsg = document.getElementById('loading-msg');
    const errorMsg = document.getElementById('error-msg');
    const restaurantContent = document.getElementById('restaurant-content');
    const breadcrumb = document.getElementById('breadcrumb');
    const ratingSummary = document.getElementById('rating-summary');
    const area = document.getElementById('restaurant-detail-area');

    if (!loadingMsg || !errorMsg || !restaurantContent || !breadcrumb || !ratingSummary || !area) return;

    let currentRoom: RoomDetailResponse;
    let currentUser: AuthUser;
    let myRole: string;
    let restaurantId: string;
    let sortedVisits: RoomVisitWithDetails[] = [];
    let currentVisitIndex = 0;

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    async function withLoading(btn: HTMLButtonElement, fn: () => Promise<void>) {
      if (btn.disabled) return;
      const original = btn.textContent || '';
      btn.disabled = true;
      btn.textContent = '처리 중...';
      try { await fn(); }
      finally { btn.disabled = false; btn.textContent = original; }
    }

    const renderStars = formatRating;

    /** 클릭 가능한 별점 UI 생성 */
    function starRatingHtml(name: string, value: number, max = 5, size: 'default' | 'sm' = 'default'): string {
      const stars = Array.from({ length: max }, (_, i) =>
        `<span class="star ${i < value ? 'active' : ''}" data-value="${i + 1}">★</span>`
      ).join('');
      const sizeClass = size === 'sm' ? ' star-sm' : '';
      return `<span class="star-rating${sizeClass}" data-name="${name}" data-value="${value}">${stars}<span class="star-label">${value || ''}</span></span>`;
    }

    /** 세부 평점 한 항목 (별) */
    function detailSliderHtml(label: string, name: string, value: number | string): string {
      const v = typeof value === 'string' ? (value ? parseInt(value, 10) : 0) : (value || 0);
      const stars = Array.from({ length: 5 }, (_, i) =>
        `<span class="detail-star ${i < v ? 'active' : ''}" data-value="${i + 1}">★</span>`
      ).join('');
      return `
        <div class="detail-slider" data-name="${name}" data-value="${v}">
          <span class="detail-slider-label">${label}</span>
          <span class="detail-stars">${stars}</span>
        </div>`;
    }

    /** 컨테이너 내 별점 클릭 이벤트 바인딩 */
    function attachStarRatingHandlers(container: HTMLElement) {
      for (const ratingEl of container.querySelectorAll<HTMLElement>('.star-rating')) {
        for (const star of ratingEl.querySelectorAll<HTMLElement>('.star')) {
          star.addEventListener('click', () => {
            const val = parseInt(star.dataset.value || '0', 10);
            const current = parseInt(ratingEl.dataset.value || '0', 10);
            // 같은 별 다시 클릭하면 해제 (세부 평점만)
            const newVal = (current === val && ratingEl.classList.contains('star-sm')) ? 0 : val;
            ratingEl.dataset.value = String(newVal);
            const stars = ratingEl.querySelectorAll('.star');
            stars.forEach((s, i) => s.classList.toggle('active', i < newVal));
            const label = ratingEl.querySelector('.star-label');
            if (label) label.textContent = newVal ? String(newVal) : '';
          });
        }
      }
      // 세부평점 별 클릭 핸들러
      for (const slider of container.querySelectorAll<HTMLElement>('.detail-slider')) {
        for (const star of slider.querySelectorAll<HTMLElement>('.detail-star')) {
          star.addEventListener('click', () => {
            const val = parseInt(star.dataset.value || '0', 10);
            const current = parseInt(slider.dataset.value || '0', 10);
            const newVal = current === val ? 0 : val;
            slider.dataset.value = String(newVal);
            slider.querySelectorAll('.detail-star').forEach((s, i) => s.classList.toggle('active', i < newVal));
          });
        }
      }
    }

    /** star-rating 요소에서 값 읽기 */
    function getStarValue(container: HTMLElement, name: string): number {
      const el = container.querySelector<HTMLElement>(`.star-rating[data-name="${name}"]`);
      return el ? parseInt(el.dataset.value || '0', 10) : 0;
    }

    /** 세부평점 별에서 값 읽기 */
    function getSliderValue(container: HTMLElement, name: string): number {
      const el = container.querySelector<HTMLElement>(`.detail-slider[data-name="${name}"]`);
      return el ? parseInt(el.dataset.value || '0', 10) : 0;
    }

    function getOptionalSliderValue(container: HTMLElement, name: string, sendNull = false): number | null | undefined {
      const v = getSliderValue(container, name);
      return v > 0 ? v : (sendNull ? null : undefined);
    }

    function getMyRole(): string {
      const me = currentRoom.members.find((m) => m.userId === currentUser.id);
      return me?.role || 'member';
    }

    function isManagerOrAbove(): boolean { return myRole === 'owner' || myRole === 'manager'; }

    // ─── 렌더링 ───

    function getVisitNavLabel(idx: number): string {
      const v = sortedVisits[idx];
      if (!v) return '';
      const isUnknown = v.memo?.startsWith('(날짜 미상)') ?? false;
      return `${idx + 1}번째 방문 · ${isUnknown ? '날짜 미상' : formatDate(v.visitedAt)}`;
    }

    function renderReviewCard(rev: RoomReviewWithUser): string {
      const isReviewOwner = rev.userId === currentUser.id;
      const canDeleteReview = isReviewOwner || isManagerOrAbove();
      let actionsHtml = '';
      if (isReviewOwner || canDeleteReview) {
        const menuItems: string[] = [];
        if (isReviewOwner) {
          menuItems.push(`<button type="button" class="edit-rev-btn" data-rev-id="${rev.id}" data-rating="${rev.rating}" data-content="${escapeHtml(rev.content)}" data-revisit="${rev.wouldRevisit !== false}" data-taste="${rev.tasteRating ?? ''}" data-value="${rev.valueRating ?? ''}" data-service="${rev.serviceRating ?? ''}" data-cleanliness="${rev.cleanlinessRating ?? ''}" data-accessibility="${rev.accessibilityRating ?? ''}" data-fav-menu="${escapeHtml(rev.favoriteMenu ?? '')}" data-try-menu="${escapeHtml(rev.tryNextMenu ?? '')}">수정</button>`);
        }
        if (canDeleteReview) {
          menuItems.push(`<button type="button" class="danger delete-rev-btn" data-rev-id="${rev.id}">삭제</button>`);
        }
        actionsHtml = `<span class="more-menu-wrap"><button type="button" class="more-menu-btn" aria-label="리뷰 더보기">⋯</button><div class="more-menu-dropdown" hidden><div class="more-menu-title">리뷰</div>${menuItems.join('')}</div></span>`;
      }

      const revisitBadge = rev.wouldRevisit === false
        ? '<span class="revisit-badge no">재방문 X</span>'
        : '<span class="revisit-badge yes">재방문 O</span>';

      const detailRatings = [
        rev.tasteRating != null ? `맛 ${rev.tasteRating}` : null,
        rev.valueRating != null ? `가성비 ${rev.valueRating}` : null,
        rev.serviceRating != null ? `서비스 ${rev.serviceRating}` : null,
        rev.cleanlinessRating != null ? `청결 ${rev.cleanlinessRating}` : null,
        rev.accessibilityRating != null ? `접근성 ${rev.accessibilityRating}` : null,
      ].filter(Boolean);

      const favMenuHtml = rev.favoriteMenu
        ? `<div class="review-fav-menu"><span class="fav-menu-icon">&#x1F372;</span><span class="fav-menu-label">또 먹고 싶은</span> ${escapeHtml(rev.favoriteMenu)}</div>`
        : '';

      const hasExtras = detailRatings.length > 0 || rev.tryNextMenu;
      const extrasHtml = hasExtras ? `
        <div class="review-extras" hidden>
          ${detailRatings.length > 0 ? `<div class="review-detail-chips">${detailRatings.map(r => `<span class="review-detail-chip">${r}</span>`).join('')}</div>` : ''}
          ${rev.tryNextMenu ? `<div class="review-meta-row">다음에 시켜볼: ${escapeHtml(rev.tryNextMenu)}</div>` : ''}
        </div>
        <button type="button" class="review-toggle-extras">전체보기</button>
      ` : '';

      const avatarHtml = rev.user.profileImageUrl
        ? `<img src="${escapeHtml(rev.user.profileImageUrl)}" alt="${escapeHtml(rev.user.nickname)}" />`
        : `<span class="avatar-initial">${escapeHtml(rev.user.nickname.charAt(0))}</span>`;

      const speechContent = rev.content
        ? escapeHtml(rev.content)
        : '<span style="color:var(--text-muted);font-style:italic;">별점만 남긴 리뷰</span>';

      const bigStars = Array.from({ length: 5 }, (_, i) =>
        `<span class="${i < Math.round(rev.rating) ? '' : 'star-muted'}">★</span>`
      ).join('');

      return `
        <div class="review-bubble-wrap" data-rev-id="${rev.id}">
          <div class="review-avatar">${avatarHtml}</div>
          <div class="review-bubble-body">
            <div class="review-nickname">${escapeHtml(rev.user.nickname)} ${revisitBadge} ${actionsHtml}</div>
            <div class="review-speech">${speechContent}</div>
            <div class="review-stars-big">${bigStars} <span class="rating-num">${rev.rating}</span></div>
            ${favMenuHtml}
            ${extrasHtml}
          </div>
        </div>
      `;
    }

    function renderVisitCard(visit: RoomVisitWithDetails, index: number): string {
      const canDeleteVisit = visit.createdById === currentUser.id || isManagerOrAbove();
      const participantsHtml = visit.participants && visit.participants.length > 0
        ? visit.participants.map((p) => escapeHtml(p.user.nickname)).join(', ')
        : '';

      const myReviewExists = visit.reviews.some((r) => r.userId === currentUser.id);
      const reviewFormId = `review-form-${visit.id}`;

      const reviewFormHtml = myReviewExists
        ? ''
        : `<button type="button" class="btn-outline-sm toggle-review-form-btn" data-visit-id="${visit.id}">리뷰 작성</button>
           <div class="review-form" id="${reviewFormId}" style="display:none;">
             <div class="review-form-card">
               <div class="review-form-card-header">종합 평점</div>
               <div class="review-form-card-body" style="text-align:center;">
                 ${starRatingHtml('new-review-rating', 3)}
               </div>
             </div>
             <div class="review-form-card">
               <div class="review-form-card-header">세부 평점 <span class="optional-hint">(선택 · 같은 별 재클릭 시 취소)</span></div>
               <div class="review-form-card-body">
                 ${detailSliderHtml('맛', 'new-review-taste', 0)}
                 ${detailSliderHtml('가성비', 'new-review-value', 0)}
                 ${detailSliderHtml('서비스', 'new-review-service', 0)}
                 ${detailSliderHtml('청결', 'new-review-cleanliness', 0)}
                 ${detailSliderHtml('접근성', 'new-review-accessibility', 0)}
               </div>
             </div>
             <div class="review-form-card">
               <div class="review-form-card-header">한줄 리뷰 <span class="optional-hint">(선택)</span></div>
               <div class="review-form-card-body">
                 <textarea class="new-review-content" placeholder="이 식당에 대한 한줄 평을 남겨주세요"></textarea>
               </div>
             </div>
             <div class="review-form-card">
               <div class="review-form-card-body">
                 <div class="review-form-toggles">
                   <label class="review-form-toggle-item"><input type="checkbox" class="new-review-revisit" checked /><span class="review-form-toggle-text">또 가고 싶어요</span></label>
                 </div>
                 <input type="text" class="new-review-fav-menu" placeholder="또 먹고 싶은 메뉴 (선택)" maxlength="200" style="margin-top:0.5rem;" />
               </div>
             </div>
             <button type="button" class="btn-primary-sm submit-visit-review-btn" data-visit-id="${visit.id}" style="width:100%;padding:0.65rem;">리뷰 등록</button>
           </div>`;

      const reviewsHtml = visit.reviews.map(renderReviewCard).join('');

      const isDateUnknown = visit.memo?.startsWith('(날짜 미상)') ?? false;
      const displayMemo = isDateUnknown ? (visit.memo?.replace('(날짜 미상) ', '').replace('(날짜 미상)', '') || '') : (visit.memo || '');

      return `
        <div class="visit-slide" data-index="${index}" ${index > 0 ? 'style="display:none;"' : ''}>
        <div class="visit-card" data-visit-id="${visit.id}">
          <div class="visit-header">
            ${visit.waitTime ? `<span class="wait-badge">웨이팅: ${escapeHtml(visit.waitTime)}</span>` : ''}
            ${visit.isDelivery ? '<span class="delivery-badge">배달</span>' : ''}
            ${participantsHtml ? `<span class="visit-participants">함께: ${participantsHtml}</span>` : ''}
            ${canDeleteVisit ? `<span class="visit-actions"><span class="more-menu-wrap"><button type="button" class="more-menu-btn" aria-label="방문 더보기">⋯</button><div class="more-menu-dropdown" hidden><div class="more-menu-title">방문</div><button type="button" class="edit-visit-btn" data-visit-id="${visit.id}" data-visit-date="${visit.visitedAt.slice(0, 10)}" data-visit-memo="${escapeHtml(visit.memo || '')}" data-visit-wait="${escapeHtml(visit.waitTime || '')}" data-visit-delivery="${visit.isDelivery ? 'true' : 'false'}">수정</button><button type="button" class="danger delete-visit-btn" data-visit-id="${visit.id}">삭제</button></div></span></span>` : ''}
          </div>
          ${displayMemo ? `<div class="visit-memo">${escapeHtml(displayMemo)}</div>` : ''}
          <div class="visit-reviews">
            ${reviewsHtml || '<p class="empty-text" style="padding:0.75rem 0;">이 방문에 대한 리뷰를 남겨보세요</p>'}
          </div>
          ${reviewFormHtml}
        </div>
        </div>
      `;
    }

    function collectDetailFields(container: HTMLElement, prefix: string, isEdit = false): Partial<ReviewData> {
      const optStr = (sel: string) => { const v = container.querySelector<HTMLInputElement>(sel)?.value.trim(); return v || undefined; };
      const getVal = (name: string) => getOptionalSliderValue(container, `${prefix}-${name}`, isEdit);
      return {
        tasteRating: getVal('taste'),
        valueRating: getVal('value'),
        serviceRating: getVal('service'),
        cleanlinessRating: getVal('cleanliness'),
        accessibilityRating: getVal('accessibility'),
        favoriteMenu: optStr(`.${prefix}-fav-menu`),
      };
    }

    // ─── 식당 상세 로드 ───

    async function loadRestaurantDetail() {
      area.innerHTML = '<p class="empty-text">로딩 중...</p>';
      const detail = await fetchRoomRestaurant(currentRoom.id, restaurantId);
      renderRestaurantDetail(detail);
    }

    function renderRatingSummary(detail: Awaited<ReturnType<typeof fetchRoomRestaurant>>) {
      const allReviews = detail.visits.flatMap(v => v.reviews);
      if (allReviews.length === 0) {
        ratingSummary.innerHTML = `
          <div class="rating-hero">
            <div class="rating-hero-empty">아직 리뷰가 없습니다. 첫 번째 리뷰를 남겨보세요!</div>
          </div>`;
        ratingSummary.hidden = false;
        return;
      }

      const avg = (arr: number[]) => arr.length ? arr.reduce((a, b) => a + b, 0) / arr.length : 0;
      const avgRating = avg(allReviews.map(r => r.rating));
      const roundedAvg = Math.round(avgRating * 10) / 10;

      const subRatings = [
        { key: 'tasteRating', label: '맛' },
        { key: 'valueRating', label: '가성비' },
        { key: 'serviceRating', label: '서비스' },
        { key: 'cleanlinessRating', label: '청결' },
        { key: 'accessibilityRating', label: '접근성' },
      ] as const;

      const subBarsHtml = subRatings.map(({ key, label }) => {
        const vals = allReviews.map(r => r[key]).filter((v): v is number => v != null && v > 0);
        if (vals.length === 0) return '';
        const subAvg = avg(vals);
        const pct = (subAvg / 5) * 100;
        return `
          <div class="rating-bar-row">
            <span class="rating-bar-label">${label}</span>
            <div class="rating-bar-track"><div class="rating-bar-fill" style="width:${pct}%"></div></div>
            <span class="rating-bar-value">${(Math.round(subAvg * 10) / 10).toFixed(1)}</span>
          </div>`;
      }).filter(Boolean).join('');

      const starsHtml = Array.from({ length: 5 }, (_, i) =>
        `<span class="${i < Math.round(avgRating) ? '' : 'star-muted'}">★</span>`
      ).join('');

      const revisitYes = allReviews.filter(r => r.wouldRevisit !== false).length;
      const revisitRate = Math.round((revisitYes / allReviews.length) * 100);

      ratingSummary.innerHTML = `
        <div class="rating-hero">
          <div class="rating-hero-score">
            <div class="rating-circle">
              <span class="rating-circle-num">${roundedAvg.toFixed(1)}</span>
              <span class="rating-circle-label">평균</span>
            </div>
            <div class="rating-hero-info">
              <div class="rating-hero-stars">${starsHtml}</div>
              <div class="rating-hero-count">리뷰 ${allReviews.length}개 · 방문 ${detail.visits.length}회</div>
            </div>
          </div>
          ${subBarsHtml ? `<div class="rating-hero-bars">${subBarsHtml}
            <div class="rating-hero-meta">
              <div class="rating-meta-item">
                <span class="rating-meta-value ${revisitRate >= 50 ? 'positive' : 'negative'}">${revisitRate}%</span>
                <span class="rating-meta-label">재방문 의사</span>
              </div>
            </div>
          </div>` : ''}
        </div>`;
      ratingSummary.hidden = false;
    }

    function renderRestaurantDetail(detail: Awaited<ReturnType<typeof fetchRoomRestaurant>>) {
      try {
        // 브레드크럼
        breadcrumb.innerHTML = `
          <a href="/rooms">내 방</a>
          <span class="bc-sep">›</span>
          <a href="/room?id=${currentRoom.id}">${escapeHtml(currentRoom.name)}</a>
          <span class="bc-sep">›</span>
          <span class="bc-current">${escapeHtml(detail.name)}</span>
        `;

        // 평점 요약
        renderRatingSummary(detail);

        const canEditRest = detail.addedById === currentUser.id || isManagerOrAbove();
        let restMenuHtml = '';
        if (canEditRest) {
          restMenuHtml = `<span class="more-menu-wrap"><button type="button" class="more-menu-btn" aria-label="식당 더보기">⋯</button><div class="more-menu-dropdown" hidden><div class="more-menu-title">식당</div><button type="button" id="edit-rest-btn">수정</button><button type="button" class="danger" id="delete-rest-btn">삭제</button></div></span>`;
        }


        sortedVisits = [...detail.visits].sort((a, b) => new Date(b.visitedAt).getTime() - new Date(a.visitedAt).getTime());
        currentVisitIndex = 0;


        const helpHintHtml = sortedVisits.length === 0
          ? `<div class="empty-state">
              <div class="empty-state-icon">&#x1F37D;&#xFE0F;</div>
              <div class="empty-state-title">아직 방문 기록이 없어요</div>
              <div class="empty-state-desc">방문을 추가하면 리뷰를 작성할 수 있어요.<br/>첫 번째 방문을 기록해 보세요!</div>
              <a href="/room/add?roomId=${currentRoom.id}&restaurantId=${restaurantId}&name=${encodeURIComponent(detail.name)}" class="empty-state-cta">+ 첫 방문 추가하기</a>
            </div>`
          : '';

        const visitsHtml = sortedVisits.length > 0
          ? sortedVisits.map((v, i) => renderVisitCard(v, i)).join('')
          : '';

        area.innerHTML = `
          <div class="room-rest-detail">
            <h2>${detail.isClosed ? '<span class="closed-badge">폐점</span> ' : ''}${escapeHtml(detail.name)}</h2>
            <div class="detail-address">${escapeHtml(detail.address)}</div>
            <div class="detail-meta">
              <span class="category-badge">${escapeHtml(detail.category)}</span>
              <span class="detail-actions">${restMenuHtml}</span>
            </div>
            ${sortedVisits.length > 0 ? `
            <div class="visits-heading-row">
              <h3 class="visits-heading">방문 기록 (${detail.visits.length})</h3>
              <a href="/room/add?roomId=${currentRoom.id}&restaurantId=${restaurantId}&name=${encodeURIComponent(detail.name)}" class="btn-primary-sm" style="text-decoration:none;">+ 방문 추가</a>
            </div>` : ''}
            ${helpHintHtml}
            ${sortedVisits.length > 0 ? `
              <div class="visit-carousel-nav">
                <button type="button" class="visit-nav-btn visit-prev-btn" disabled>&#8249;</button>
                <span class="visit-nav-label">${getVisitNavLabel(0)}</span>
                <button type="button" class="visit-nav-btn visit-next-btn" ${sortedVisits.length <= 1 ? 'disabled' : ''}>&#8250;</button>
              </div>
            ` : ''}
            <div id="visits-list">${visitsHtml}</div>
          </div>
        `;

        // 식당 수정
        document.getElementById('edit-rest-btn')?.addEventListener('click', () => {
          const metaEl = area.querySelector('.detail-meta');
          if (!metaEl) return;
          if (area.querySelector('.edit-rest-form')) return;

          metaEl.insertAdjacentHTML('afterend', `
            <div class="edit-rest-form" style="background:var(--bg-hover);border-radius:8px;padding:0.75rem;margin-bottom:0.75rem;">
              <div class="form-row full" style="margin-bottom:0.5rem;">
                <label for="edit-rest-name" style="font-size:0.75rem;font-weight:600;color:var(--text-sub);margin-bottom:0.2rem;display:block;">식당 이름</label>
                <input type="text" id="edit-rest-name" value="${escapeHtml(detail.name)}" placeholder="식당 이름" style="width:100%;padding:0.5rem;border:1px solid var(--border-mid);border-radius:6px;font-size:0.85rem;background:var(--bg-card);color:var(--text);" />
              </div>
              <div class="form-row full" style="margin-bottom:0.5rem;">
                <label for="edit-rest-address" style="font-size:0.75rem;font-weight:600;color:var(--text-sub);margin-bottom:0.2rem;display:block;">주소</label>
                <input type="text" id="edit-rest-address" value="${escapeHtml(detail.address)}" placeholder="주소" style="width:100%;padding:0.5rem;border:1px solid var(--border-mid);border-radius:6px;font-size:0.85rem;background:var(--bg-card);color:var(--text);" />
              </div>
              <div class="form-row full" style="margin-bottom:0.5rem;">
                <label for="edit-rest-category" style="font-size:0.75rem;font-weight:600;color:var(--text-sub);margin-bottom:0.2rem;display:block;">카테고리</label>
                <input type="text" id="edit-rest-category" value="${escapeHtml(detail.category)}" placeholder="카테고리" style="width:100%;padding:0.5rem;border:1px solid var(--border-mid);border-radius:6px;font-size:0.85rem;background:var(--bg-card);color:var(--text);" />
              </div>
              <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
                <button type="button" class="btn-primary-sm" id="save-rest-edit">저장</button>
                <button type="button" class="btn-outline-sm" id="cancel-rest-edit">취소</button>
                <label class="closed-toggle-label"><input type="checkbox" id="edit-rest-closed" ${detail.isClosed ? 'checked' : ''} /><span class="closed-toggle-track"></span>폐점</label>
              </div>
            </div>
          `);

          document.getElementById('cancel-rest-edit')?.addEventListener('click', () => {
            area.querySelector('.edit-rest-form')?.remove();
          });

          document.getElementById('save-rest-edit')?.addEventListener('click', async () => {
            const newName = (document.getElementById('edit-rest-name') as HTMLInputElement | null)?.value.trim() || '';
            const newAddress = (document.getElementById('edit-rest-address') as HTMLInputElement | null)?.value.trim() || '';
            const newCategory = (document.getElementById('edit-rest-category') as HTMLInputElement | null)?.value.trim() || '';
            const newIsClosed = (document.getElementById('edit-rest-closed') as HTMLInputElement | null)?.checked ?? false;
            if (!newName || !newCategory) { showToast('이름과 카테고리를 입력해주세요.', 'info'); return; }

            try {
              const updateData: Parameters<typeof updateRoomRestaurant>[2] = { name: newName, category: newCategory, isClosed: newIsClosed, ...(newAddress && { address: newAddress }) };

              // 주소가 변경되면 카카오 지오코딩으로 좌표 갱신
              if (newAddress && newAddress !== detail.address && 'kakao' in window) {
                try {
                  const coords = await new Promise<{ lat: number; lng: number } | null>((resolve) => {
                    const maps = (window as Record<string, unknown>).kakao as { maps: { load: (cb: () => void) => void; services: { Geocoder: new () => { addressSearch: (addr: string, cb: (result: { y: string; x: string }[], status: string) => void) => void }; Status: { OK: string } } } };
                    maps.maps.load(() => {
                      const geocoder = new maps.maps.services.Geocoder();
                      geocoder.addressSearch(newAddress, (result, status) => {
                        if (status === maps.maps.services.Status.OK && result.length > 0) {
                          resolve({ lat: parseFloat(result[0].y), lng: parseFloat(result[0].x) });
                        } else {
                          resolve(null);
                        }
                      });
                    });
                  });
                  if (coords) {
                    updateData.latitude = coords.lat;
                    updateData.longitude = coords.lng;
                  }
                } catch { /* 지오코딩 실패 시 좌표 없이 주소만 업데이트 */ }
              }

              await updateRoomRestaurant(currentRoom.id, restaurantId, updateData);
              currentRoom = await fetchRoom(currentRoom.id);
              await loadRestaurantDetail();
              showToast('식당 정보가 수정되었습니다.', 'success');
            } catch { showToast('식당 수정에 실패했습니다.'); }
          });
        });

        // 식당 삭제
        document.getElementById('delete-rest-btn')?.addEventListener('click', async () => {
          if (!await showDangerConfirm('이 식당을 삭제하시겠습니까? 모든 방문 기록과 리뷰도 삭제됩니다.')) return;
          try {
            await deleteRoomRestaurant(currentRoom.id, restaurantId);
            showToast('식당이 삭제되었습니다.', 'success');
            location.href = `/room?id=${currentRoom.id}`;
          } catch { showToast('삭제에 실패했습니다.'); }
        });

        // 더보기(⋯) 메뉴 토글
        for (const menuBtn of area.querySelectorAll<HTMLButtonElement>('.more-menu-btn')) {
          menuBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            const dropdown = menuBtn.nextElementSibling as HTMLElement;
            // 다른 열린 메뉴 닫기
            for (const d of area.querySelectorAll('.more-menu-dropdown')) {
              if (d !== dropdown) (d as HTMLElement).hidden = true;
            }
            dropdown.hidden = !dropdown.hidden;
          });
        }
        document.addEventListener('click', () => {
          for (const d of area.querySelectorAll('.more-menu-dropdown')) {
            (d as HTMLElement).hidden = true;
          }
        });

        attachVisitAndReviewHandlers();
        attachStarRatingHandlers(area);
      } catch {
        area.innerHTML = '<p class="empty-text">식당 정보를 불러올 수 없습니다.</p>';
      }
    }

    function attachVisitAndReviewHandlers() {
      // 방문 기록 수정
      for (const btn of area.querySelectorAll<HTMLButtonElement>('.edit-visit-btn')) {
        btn.addEventListener('click', () => {
          const visitCard = btn.closest('.visit-card');
          if (!visitCard) return;
          if (visitCard.querySelector('.visit-edit-form')) return;

          const visitId = btn.dataset.visitId || '';
          const currentDate = btn.dataset.visitDate || '';
          const currentMemo = btn.dataset.visitMemo || '';
          const currentWait = btn.dataset.visitWait || '';
          const currentDelivery = btn.dataset.visitDelivery === 'true';

          const isDateUnknown = currentMemo.startsWith('(날짜 미상)');
          const waitOptions = ['없음', '~10분', '~30분', '~1시간', '1시간+'];
          const visitHeader = visitCard.querySelector('.visit-header');
          if (!visitHeader) return;
          // 기존 편집 폼이 있으면 제거
          visitCard.querySelector('.visit-edit-form')?.remove();
          visitHeader.insertAdjacentHTML('afterend', `
            <div class="visit-edit-form">
              <div class="visit-edit-row">
                <div class="visit-edit-field">
                  <label class="visit-edit-label">날짜</label>
                  <div class="visit-date-row">
                    <input type="date" class="visit-edit-date" value="${currentDate}" ${isDateUnknown ? 'disabled style="opacity:0.4;"' : ''} />
                    <label class="date-unknown-toggle"><input type="checkbox" class="visit-edit-date-unknown" ${isDateUnknown ? 'checked' : ''} /> 날짜 모름</label>
                  </div>
                </div>
                <div class="visit-edit-field">
                  <label class="visit-edit-label">메모</label>
                  <input type="text" class="visit-edit-memo" value="${escapeHtml(isDateUnknown ? currentMemo.replace('(날짜 미상) ', '').replace('(날짜 미상)', '') : currentMemo)}" placeholder="메모 (선택)" maxlength="500" />
                </div>
                <div class="visit-edit-field">
                  <label class="visit-edit-label">웨이팅</label>
                  <div class="wait-chips visit-edit-wait-chips">
                    ${waitOptions.map((w) => `<button type="button" class="wait-chip${currentWait === w ? ' active' : ''}" data-wait="${w}">${w}</button>`).join('')}
                  </div>
                </div>
                <div class="visit-edit-field">
                  <label class="visit-edit-label">배달</label>
                  <label class="revisit-toggle"><input type="checkbox" class="visit-edit-delivery" ${currentDelivery ? 'checked' : ''} /> 배달 주문</label>
                </div>
              </div>
              <div class="visit-edit-actions">
                <button type="button" class="btn-outline-sm cancel-visit-edit-btn">취소</button>
                <button type="button" class="btn-primary-sm save-visit-edit-btn">저장</button>
              </div>
            </div>
          `);

          // 웨이팅 칩 토글
          let editWaitTime = currentWait;
          for (const chip of visitCard.querySelectorAll<HTMLButtonElement>('.visit-edit-wait-chips .wait-chip')) {
            chip.addEventListener('click', () => {
              const val = chip.dataset.wait || '';
              if (editWaitTime === val) {
                editWaitTime = '';
                chip.classList.remove('active');
              } else {
                editWaitTime = val;
                for (const c of visitCard.querySelectorAll('.visit-edit-wait-chips .wait-chip')) c.classList.remove('active');
                chip.classList.add('active');
              }
            });
          }

          // 날짜 모름 토글
          const editDateCb = visitCard.querySelector<HTMLInputElement>('.visit-edit-date-unknown');
          const editDateInput = visitCard.querySelector<HTMLInputElement>('.visit-edit-date');
          if (editDateCb && editDateInput) {
            editDateCb.addEventListener('change', () => {
              editDateInput.disabled = editDateCb.checked;
              editDateInput.style.opacity = editDateCb.checked ? '0.4' : '1';
            });
          }

          visitCard.querySelector('.cancel-visit-edit-btn')?.addEventListener('click', () => {
            visitCard.querySelector('.visit-edit-form')?.remove();
          });

          visitCard.querySelector('.save-visit-edit-btn')?.addEventListener('click', async () => {
            const editIsUnknown = visitCard.querySelector<HTMLInputElement>('.visit-edit-date-unknown')?.checked ?? false;
            const rawDate = visitCard.querySelector<HTMLInputElement>('.visit-edit-date')?.value || '';
            const rawMemo = visitCard.querySelector<HTMLInputElement>('.visit-edit-memo')?.value.trim() || '';
            const newDate = editIsUnknown ? new Date().toISOString().slice(0, 10) : rawDate;
            const newMemo = editIsUnknown ? (rawMemo ? `(날짜 미상) ${rawMemo}` : '(날짜 미상)') : rawMemo;
            if (!newDate) { showToast('날짜를 입력해주세요.', 'info'); return; }

            try {
              const editDelivery = visitCard.querySelector<HTMLInputElement>('.visit-edit-delivery')?.checked ?? false;
              await updateRoomVisit(currentRoom.id, visitId, { visitedAt: newDate, memo: newMemo || undefined, waitTime: editWaitTime || undefined, isDelivery: editDelivery });
              currentRoom = await fetchRoom(currentRoom.id);
              await loadRestaurantDetail();
              showToast('방문 기록이 수정되었습니다.', 'success');
            } catch { showToast('방문 기록 수정에 실패했습니다.'); }
          });
        });
      }

      // 방문 기록 삭제
      for (const btn of area.querySelectorAll<HTMLButtonElement>('.delete-visit-btn')) {
        btn.addEventListener('click', async () => {
          if (!await showDangerConfirm('이 방문 기록을 삭제하시겠습니까? 포함된 리뷰도 삭제됩니다.')) return;
          try {
            await deleteRoomVisit(currentRoom.id, btn.dataset.visitId || '');
            currentRoom = await fetchRoom(currentRoom.id);
            await loadRestaurantDetail();
          } catch { showToast('방문 기록 삭제에 실패했습니다.'); }
        });
      }

      // 리뷰 작성 폼 토글
      for (const btn of area.querySelectorAll<HTMLButtonElement>('.toggle-review-form-btn')) {
        btn.addEventListener('click', () => {
          const form = document.getElementById(`review-form-${btn.dataset.visitId || ''}`);
          if (form) form.style.display = form.style.display === 'none' ? 'block' : 'none';
        });
      }

      // 리뷰 작성
      for (const btn of area.querySelectorAll<HTMLButtonElement>('.submit-visit-review-btn')) {
        btn.addEventListener('click', () => withLoading(btn, async () => {
          const visitCard = btn.closest('.visit-card');
          if (!visitCard) return;
          const visitId = btn.dataset.visitId || '';
          const rating = getStarValue(visitCard as HTMLElement, 'new-review-rating');
          const content = visitCard.querySelector<HTMLTextAreaElement>('.new-review-content')?.value.trim() || '';
          const wouldRevisit = visitCard.querySelector<HTMLInputElement>('.new-review-revisit')?.checked ?? true;
          if (!rating) { showToast('평점을 선택해주세요.', 'info'); return; }
          const detailFields = collectDetailFields(visitCard as HTMLElement, 'new-review');

          await createRoomReview(currentRoom.id, visitId, { rating, content, wouldRevisit, ...detailFields });
          currentRoom = await fetchRoom(currentRoom.id);
          await loadRestaurantDetail();
          showToast('리뷰가 작성되었습니다.', 'success');
        }).catch((err) => showToast(err instanceof Error ? err.message : '리뷰 작성에 실패했습니다.')));
      }

      // 리뷰 삭제
      for (const btn of area.querySelectorAll<HTMLButtonElement>('.delete-rev-btn')) {
        btn.addEventListener('click', async () => {
          if (!await showDangerConfirm('이 리뷰를 삭제하시겠습니까?')) return;
          try {
            await deleteRoomReview(currentRoom.id, btn.dataset.revId || '');
            currentRoom = await fetchRoom(currentRoom.id);
            await loadRestaurantDetail();
          } catch { showToast('리뷰 삭제에 실패했습니다.'); }
        });
      }

      // 리뷰 수정
      for (const btn of area.querySelectorAll<HTMLButtonElement>('.edit-rev-btn')) {
        btn.addEventListener('click', () => {
          const revId = btn.dataset.revId || '';
          const origRating = btn.dataset.rating || '0';
          const origContent = btn.dataset.content || '';
          const origRevisit = btn.dataset.revisit === 'true';
          const card = area.querySelector<HTMLElement>(`.review-bubble-wrap[data-rev-id="${revId}"]`);
          if (!card) return;

          if (card.querySelector('.review-form')) return;
          const bubbleBody = card.querySelector('.review-bubble-body');
          if (!bubbleBody) return;

          bubbleBody.insertAdjacentHTML('beforeend', `
            <div class="review-form">
              <div class="review-form-section">
                <span class="review-form-label">종합 평점</span>
                ${starRatingHtml('edit-rating', Number(origRating))}
              </div>
              <div class="review-form-section">
                <span class="review-form-label">세부 평점 <span class="optional-hint">(선택)</span></span>
                <div class="detail-rating-inline">
                  ${detailSliderHtml('맛', 'edit-taste', btn.dataset.taste || '')}
                  ${detailSliderHtml('가성비', 'edit-value', btn.dataset.value || '')}
                  ${detailSliderHtml('서비스', 'edit-service', btn.dataset.service || '')}
                  ${detailSliderHtml('청결', 'edit-cleanliness', btn.dataset.cleanliness || '')}
                  ${detailSliderHtml('접근성', 'edit-accessibility', btn.dataset.accessibility || '')}
                </div>
              </div>
              <textarea class="edit-content">${escapeHtml(origContent)}</textarea>
              <div class="review-form-extras">
                <label class="revisit-toggle"><input type="checkbox" class="edit-revisit" ${origRevisit ? 'checked' : ''} /> 재방문 의사</label>
                <input type="text" class="edit-fav-menu" placeholder="또 먹고 싶은 메뉴 (선택)" maxlength="200" value="${escapeHtml(btn.dataset.favMenu || '')}" />
              </div>
              <div style="display:flex;gap:0.5rem;">
                <button type="button" class="btn-primary-sm save-edit-btn">저장</button>
                <button type="button" class="btn-outline-sm cancel-edit-btn">취소</button>
              </div>
            </div>
          `);
          attachStarRatingHandlers(card);

          card.querySelector('.save-edit-btn')?.addEventListener('click', async () => {
            const newRating = getStarValue(card, 'edit-rating');
            const newContent = card.querySelector<HTMLTextAreaElement>('.edit-content')?.value.trim() || '';
            const newRevisit = card.querySelector<HTMLInputElement>('.edit-revisit')?.checked ?? true;
            const detailFields = collectDetailFields(card, 'edit', true);

            try {
              await updateRoomReview(currentRoom.id, revId, { rating: newRating, content: newContent, wouldRevisit: newRevisit, ...detailFields });
              currentRoom = await fetchRoom(currentRoom.id);
              await loadRestaurantDetail();
              showToast('리뷰가 수정되었습니다.', 'success');
            } catch { showToast('수정에 실패했습니다.'); }
          });

          card.querySelector('.cancel-edit-btn')?.addEventListener('click', () => {
            card.querySelector('.review-form')?.remove();
          });
        });
      }

      // 전체보기 토글
      for (const btn of area.querySelectorAll<HTMLButtonElement>('.review-toggle-extras')) {
        btn.addEventListener('click', () => {
          const extras = btn.previousElementSibling as HTMLElement | null;
          if (!extras) return;
          const isHidden = extras.hidden;
          extras.hidden = !isHidden;
          btn.textContent = isHidden ? '접기' : '전체보기';
        });
      }

      // ─── 방문 캐러셀 네비게이션 ───
      const prevBtn = area.querySelector<HTMLButtonElement>('.visit-prev-btn');
      const nextBtn = area.querySelector<HTMLButtonElement>('.visit-next-btn');

      function updateCarouselView() {
        const slides = area.querySelectorAll<HTMLElement>('.visit-slide');
        slides.forEach((s, i) => s.style.display = i === currentVisitIndex ? '' : 'none');
        const label = area.querySelector('.visit-nav-label');
        if (label) label.textContent = getVisitNavLabel(currentVisitIndex);
        if (prevBtn) prevBtn.disabled = currentVisitIndex === 0;
        if (nextBtn) nextBtn.disabled = currentVisitIndex >= sortedVisits.length - 1;
      }

      prevBtn?.addEventListener('click', () => {
        if (currentVisitIndex > 0) { currentVisitIndex--; updateCarouselView(); }
      });
      nextBtn?.addEventListener('click', () => {
        if (currentVisitIndex < sortedVisits.length - 1) { currentVisitIndex++; updateCarouselView(); }
      });

      // 스와이프
      const visitsList = area.querySelector<HTMLElement>('#visits-list');
      if (visitsList) {
        let startX = 0;
        visitsList.addEventListener('touchstart', (e) => { startX = e.changedTouches[0].screenX; }, { passive: true });
        visitsList.addEventListener('touchend', (e) => {
          const diff = startX - e.changedTouches[0].screenX;
          if (Math.abs(diff) > 60) {
            if (diff > 0 && currentVisitIndex < sortedVisits.length - 1) { currentVisitIndex++; updateCarouselView(); }
            else if (diff < 0 && currentVisitIndex > 0) { currentVisitIndex--; updateCarouselView(); }
          }
        }, { passive: true });
      }
    }

    // ─── 초기화 ───

    (async () => {
      const params = new URLSearchParams(location.search);
      const roomId = params.get('roomId');
      const rid = params.get('id');

      if (!roomId || !rid) {
        loadingMsg.hidden = true;
        errorMsg.textContent = '잘못된 접근입니다.';
        errorMsg.hidden = false;
        return;
      }

      restaurantId = rid;

      try {
        const [user, room, detail] = await Promise.all([
          fetchCurrentUser(),
          fetchRoom(roomId),
          fetchRoomRestaurant(roomId, rid),
        ]);

        if (!user) {
          loadingMsg.hidden = true;
          errorMsg.textContent = '로그인이 필요합니다.';
          errorMsg.hidden = false;
          return;
        }

        currentUser = user;
        currentRoom = room;
        myRole = getMyRole();
        loadingMsg.hidden = true;
        restaurantContent.hidden = false;

        renderRestaurantDetail(detail);
      } catch {
        loadingMsg.hidden = true;
        errorMsg.textContent = '식당 정보를 불러올 수 없습니다.';
        errorMsg.hidden = false;
      }
    })();
  }

  document.addEventListener('astro:page-load', initRestaurantPage);
</script>
