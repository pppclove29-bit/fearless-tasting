  .star-rating.star-sm .star {
    font-size: 1.25rem;
  }

  .star-rating .star-label {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-left: 0.3rem;
    min-width: 1.5em;
  }

  /* 세부 평점 */
  .review-form-extras {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
    padding: 0.6rem 0.75rem;
