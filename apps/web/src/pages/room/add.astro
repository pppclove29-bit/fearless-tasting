---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="식당 등록 · 리뷰" description="식당 등록부터 리뷰까지 한 번에" noindex>
  <div id="add-page">
    <p id="loading-msg" class="status-msg">로딩 중...</p>
    <p id="error-msg" class="status-msg error" hidden></p>
    <div id="add-content" hidden></div>
  </div>

<style is:global>
  #add-page {
    max-width: 480px;
    margin: 0 auto;
    padding: 1rem;
  }

  .status-msg { text-align: center; padding: 2rem 0; color: var(--text-muted); font-size: 0.9rem; }
  .status-msg.error { color: #dc2626; }

  .add-back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 1rem;
  }
  .add-back-link:hover { color: var(--text); }

  /* 스텝 인디케이터 */
  .step-indicator {
    display: flex;
    align-items: flex-start;
    gap: 0;
    margin-bottom: 1.5rem;
  }

  .step-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    flex-shrink: 0;
  }

  .step-dot {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    font-weight: 800;
    border: 1.5px solid var(--border);
    color: var(--text-muted);
    background: var(--bg-card);
    transition: all 0.3s;
  }
  .step-dot.active { border-color: var(--text-heading); color: var(--text-heading); background: rgba(0,0,0,0.04); }
  .step-dot.done { border-color: var(--text-heading); color: var(--text-heading); background: rgba(0,0,0,0.04); }

  .step-label {
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-muted);
  }
  .step-label.active { color: var(--text-heading); font-weight: 700; }
  .step-label.done { color: var(--text-heading); font-weight: 700; }

  .step-line {
    flex: 1;
    height: 2px;
    background: var(--border);
    transition: background 0.3s;
    margin-top: 17px;
  }
  .step-line.done { background: var(--text-heading); }

  /* 스텝 컨텐츠 */
  .step-panel { display: none; }
  .step-panel.active { display: block; }

  .step-panel-inner {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .step-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.4rem;
  }

  .step-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    margin-bottom: 1.2rem;
  }

  /* 공통 폼 */
  .form-group { margin-bottom: 1rem; }

  .form-label {
    display: block;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-sub);
    margin-bottom: 0.35rem;
  }

  .form-input {
    width: 100%;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--border-mid);
    border-radius: 8px;
    font-size: 0.85rem;
    font-family: inherit;
    background: var(--bg-card);
    color: var(--text);
    transition: border-color 0.15s;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.04);
  }
  .form-input:focus { border-color: var(--text-heading); outline: none; box-shadow: none; }
  .form-input::placeholder { color: var(--text-muted); }

  .form-textarea {
    width: 100%;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--border-mid);
    border-radius: 8px;
    font-size: 0.85rem;
    font-family: inherit;
    background: var(--bg-card);
    color: var(--text);
    min-height: 70px;
    resize: vertical;
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.04);
  }
  .form-textarea:focus { border-color: var(--text-heading); outline: none; box-shadow: none; }

  /* 구분선 */
  .form-divider {
    border: none;
    border-top: 1px solid var(--border-light);
    margin: 1.2rem 0;
  }

  .form-section-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-heading);
    margin-bottom: 0.8rem;
  }

  /* 카카오 검색 */
  .search-wrap { position: relative; }

  .search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    max-height: 300px;
    overflow-y: auto;
    background: var(--bg-card);
    border: 1px solid var(--border-mid);
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    z-index: 50;
  }

  .search-result-item {
    padding: 0.6rem 0.75rem;
    cursor: pointer;
    border-bottom: 1px solid var(--border-light);
    transition: background 0.1s;
  }
  .search-result-item:last-child { border-bottom: none; }
  .search-result-item:hover { background: var(--bg-hover); }

  .search-result-name { font-size: 0.85rem; font-weight: 600; color: var(--text-heading); }
  .search-result-addr { font-size: 0.72rem; color: var(--text-muted); margin-top: 0.1rem; }
  .search-result-cat { font-size: 0.65rem; color: var(--text-muted); margin-top: 0.1rem; }

  /* 선택된 식당 카드 */
  .selected-place {
    padding: 0.75rem;
    background: var(--bg-hover);
    border-radius: 10px;
    border: 1px solid var(--border);
    margin-top: 0.5rem;
  }
  .selected-place-name { font-size: 0.9rem; font-weight: 600; color: var(--text-heading); }
  .selected-place-meta { font-size: 0.75rem; color: var(--text-muted); margin-top: 0.15rem; }
  .selected-place-clear {
    font-size: 0.72rem;
    color: var(--text-heading);
    cursor: pointer;
    background: none;
    border: none;
    padding: 0;
    margin-top: 0.3rem;
    font-family: inherit;
  }

  /* 칩 공통 */
  .cat-chips, .wait-chips { display: flex; flex-wrap: wrap; gap: 0.3rem; }

  .cat-chip, .wait-chip {
    padding: 0.3rem 0.65rem;
    border-radius: 14px;
    font-size: 0.75rem;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-sub);
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
  }
  .cat-chip:hover, .wait-chip:hover { border-color: var(--border-mid); }
  .cat-chip.active, .wait-chip.active { background: var(--text-heading); color: var(--bg); border-color: var(--text-heading); }

  /* 별점 (0.5 단위) */
  .star-rating { display: inline-flex; gap: 0; align-items: center; }
  .star-rating-value { font-size: 0.95rem; font-weight: 600; color: var(--text-heading); margin-left: 0.5rem; min-width: 2ch; }

  .star-wrap {
    position: relative;
    width: 28px;
    height: 28px;
    cursor: pointer;
  }
  .star-wrap svg { width: 28px; height: 28px; display: block; }
  .star-wrap .star-bg { color: var(--border); }
  .star-wrap .star-half-fill,
  .star-wrap .star-full-fill { position: absolute; top: 0; left: 0; color: #f59e0b; opacity: 0; pointer-events: none; }
  .star-wrap.half .star-half-fill { opacity: 1; }
  .star-wrap.full .star-full-fill { opacity: 1; }
  .star-wrap.hover-half .star-half-fill { opacity: 0.6; }
  .star-wrap.hover-full .star-full-fill { opacity: 0.6; }
  .star-wrap.half .star-bg,
  .star-wrap.full .star-bg { opacity: 0; }

  /* 세부평점 칩 */
  .detail-rating-row {
    margin-bottom: 0.75rem;
  }
  .detail-rating-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-heading);
    margin-bottom: 0.35rem;
  }
  .detail-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .detail-chip {
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 100px;
    background: none;
    font-size: 0.75rem;
    color: var(--text-sub);
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
  }
  .detail-chip.active {
    background: var(--text-heading);
    color: var(--bg);
    border-color: var(--text-heading);
  }

  /* 체크박스 */
  .check-row { display: flex; align-items: center; gap: 0.4rem; font-size: 0.82rem; color: var(--text-sub); }
  .check-row input[type="checkbox"] { accent-color: var(--text-heading); }

  /* 재방문 의사 */
  .revisit-btns { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .revisit-btn {
    flex: 1;
    min-width: calc(33% - 0.4rem);
    padding: 0.5rem 0.3rem;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
    background: var(--bg);
    color: var(--text-sub);
    text-align: center;
    transition: all 0.15s;
  }
  .revisit-btn:hover { border-color: var(--border-mid); }
  .revisit-btn.active[data-val="5"] { background: var(--text-heading); color: var(--bg); border-color: var(--text-heading); }
  .revisit-btn.active[data-val="4"] { background: #2563eb; color: #fff; border-color: #2563eb; }
  .revisit-btn.active[data-val="3"] { background: #f59e0b; color: #fff; border-color: #f59e0b; }
  .revisit-btn.active[data-val="2"] { background: #f97316; color: #fff; border-color: #f97316; }
  .revisit-btn.active[data-val="1"] { background: var(--bg-hover); color: var(--text-muted); border-color: var(--border-mid); }

  /* 버튼 */
  .step-actions { display: flex; gap: 0.5rem; margin-top: 1.5rem; }

  .btn-next {
    flex: 1;
    padding: 0.65rem 1rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 10px;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.15s;
  }
  .btn-next:hover { opacity: 0.85; }
  .btn-next:disabled { opacity: 0.5; cursor: not-allowed; }

  .btn-back {
    padding: 0.65rem 1rem;
    background: none;
    color: var(--text-muted);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    font-family: inherit;
  }

  /* 완료 */
  .done-screen { text-align: center; padding: 2rem 0; }
  .done-icon { font-size: 3rem; margin-bottom: 0.5rem; }
  .done-title { font-size: 1.2rem; font-weight: 700; color: var(--text-heading); margin-bottom: 0.3rem; }
  .done-desc { font-size: 0.82rem; color: var(--text-muted); margin-bottom: 1.5rem; }
  .done-actions { display: flex; flex-direction: column; gap: 0.5rem; max-width: 240px; margin: 0 auto; }
  .done-actions a, .done-actions button {
    padding: 0.6rem 1rem;
    border-radius: 10px;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    font-family: inherit;
    cursor: pointer;
  }
  .done-btn-primary { background: var(--text-heading); color: var(--bg); border: none; }
  .done-btn-secondary { background: var(--bg-hover); color: var(--text-sub); border: 1px solid var(--border); }

  .manual-hint { font-size: 0.72rem; color: var(--text-muted); margin-bottom: 0.5rem; }

  .mode-toggle { display: flex; gap: 0; margin-bottom: 1.25rem; border: 1px solid var(--border); border-radius: 10px; overflow: hidden; }
  .mode-toggle-btn {
    flex: 1;
    padding: 0.65rem;
    border: none;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    background: var(--bg-card);
    color: var(--text-muted);
    text-align: center;
    transition: all 0.15s;
  }
  .mode-toggle-btn:first-child { border-right: 1px solid var(--border); }
  .mode-toggle-btn.active { background: var(--text-heading); color: var(--bg); }

  [hidden] { display: none !important; }

  /* 아코디언 카드 */
  .accordion-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    margin-bottom: 0.75rem;
    overflow: hidden;
  }

  .accordion-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.15rem;
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-heading);
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .accordion-header::-webkit-details-marker { display: none; }

  .accordion-chevron {
    color: var(--text-muted);
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .accordion-card[open] > .accordion-header .accordion-chevron {
    transform: rotate(180deg);
  }

  .accordion-body {
    padding: 0 1.15rem 1.15rem;
  }

  .optional-hint {
    font-size: 0.72rem;
    font-weight: 400;
    color: var(--text-muted);
  }

  .main-rating-area {
    text-align: center;
    padding: 0.5rem 0;
  }

  .main-rating-hint {
    display: block;
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.3rem;
  }
</style>

<script>
  import {
    fetchCurrentUser, fetchRoom,
    createRoomRestaurant, createRoomVisit, createRoomReview,
    toggleRestaurantWishlist,
    showToast,
  } from '@/lib/api';
  import type { AuthUser, RoomDetailResponse } from '@/lib/api';

  function initAddPage() {
    const loadingMsg = document.getElementById('loading-msg');
    const errorMsg = document.getElementById('error-msg');
    const content = document.getElementById('add-content');
    if (!loadingMsg || !errorMsg || !content) return;

    // 상태 초기화 (중복 실행 시 이전 에러 제거)
    loadingMsg.hidden = false;
    errorMsg.hidden = true;
    errorMsg.textContent = '';
    content.hidden = true;
    content.innerHTML = '';

    const params = new URLSearchParams(location.search);
    const roomId = params.get('roomId');
    const existingRestId = params.get('restaurantId');
    const existingRestName = params.get('name');
    const fromWishlist = params.get('fromWishlist') === '1';

    if (!roomId) {
      loadingMsg.hidden = true;
      errorMsg.textContent = '잘못된 접근입니다.';
      errorMsg.hidden = false;
      return;
    }

    init();

  async function init() {
    try {
      const [user, room] = await Promise.all([
        fetchCurrentUser(),
        fetchRoom(roomId!),
      ]);
      if (!user) { location.href = '/login'; return; }
      loadingMsg.hidden = true;
      content.hidden = false;
      renderWizard(user, room);
    } catch (err) {
      console.error('[add] init 실패:', err);
      loadingMsg.hidden = true;
      errorMsg.textContent = '페이지를 불러올 수 없습니다.';
      errorMsg.hidden = false;
    }
  }

  function escapeHtml(s: string) {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function renderWizard(_user: AuthUser, room: RoomDetailResponse) {
    // 카카오 SDK가 defer로 로드되므로 아직 없을 수 있음 — 설정만 있으면 true
    const kakaoMapKey = document.querySelector<HTMLMetaElement>('meta[name="kakao-app-key"]')?.content;
    const hasKakaoMap = !!kakaoMapKey;
    const categories = ['한식','중식','일식','양식','카페','분식','치킨','피자','고기','해산물','술집','베이커리','기타'];
    const waitOptions = ['없음','~10분','~30분','~1시간','1시간+'];
    const today = new Date().toISOString().split('T')[0];

    const isExisting = !!existingRestId;
    let currentStep = isExisting ? 2 : 1;
    let placeData: Record<string, string> = {};
    let selectedCategory = '';
    let selectedWait = '';
    let mainRating = 0;
    let wouldRevisit: number | null = null;
    const detailRatings: Record<string, number> = {};

    const backUrl = isExisting
      ? `/room/restaurant?roomId=${roomId}&id=${existingRestId}`
      : `/room?id=${roomId}`;
    const backLabel = isExisting && existingRestName
      ? escapeHtml(decodeURIComponent(existingRestName))
      : escapeHtml(room.name);

    content.innerHTML = `
      <a href="${backUrl}" class="add-back-link">&larr; ${backLabel}</a>

      <div class="step-indicator" ${isExisting ? 'hidden' : ''}>
        <div class="step-col">
          <div class="step-dot active" data-step="1">1</div>
          <span class="step-label active">식당</span>
        </div>
        <div class="step-line"></div>
        <div class="step-col">
          <div class="step-dot" data-step="2">2</div>
          <span class="step-label">리뷰</span>
        </div>
      </div>

      <!-- 스텝 1: 식당 -->
      <div class="step-panel ${isExisting ? '' : 'active'}" id="step-1">
        <div class="step-title">어디에 다녀왔나요?</div>
        <div class="step-desc">식당을 검색하거나 직접 입력하세요</div>

        ${hasKakaoMap ? `
          <div class="mode-toggle">
            <button type="button" class="mode-toggle-btn active" data-mode="kakao">카카오 검색</button>
            <button type="button" class="mode-toggle-btn" data-mode="manual">직접 입력</button>
          </div>
        ` : ''}

        <div id="kakao-area" ${!hasKakaoMap ? 'hidden' : ''}>
          <div class="form-group search-wrap">
            <input type="text" class="form-input" id="place-search" placeholder="식당 이름으로 검색" autocomplete="off" />
            <div class="search-results" id="search-results" hidden></div>
          </div>
          <div id="selected-place" hidden></div>
        </div>

        <div id="manual-area" ${hasKakaoMap ? 'hidden' : ''}>
          <p class="manual-hint">도로명/지번 주소를 정확히 입력하면 지도에 표시됩니다.</p>
          <div class="form-group">
            <input type="text" class="form-input" id="manual-name" placeholder="식당 이름" />
          </div>
          <div class="form-group">
            <input type="text" class="form-input" id="manual-address" placeholder="주소 (예: 서울특별시 강남구 역삼동 123)" />
          </div>
          <div class="form-group">
            <label class="form-label">카테고리</label>
            <div class="cat-chips" id="manual-cat-chips">
              ${categories.map((c) => `<button type="button" class="cat-chip" data-cat="${c}">${c}</button>`).join('')}
            </div>
            <input type="text" class="form-input" id="manual-cat-custom" placeholder="직접 입력" hidden style="margin-top:0.4rem" />
          </div>
        </div>

        <div class="step-actions">
          <button type="button" class="btn-next" id="btn-step1-next" disabled>다음: 리뷰 작성</button>
        </div>
      </div>

      <!-- 스텝 2: 리뷰 (방문 정보 포함) -->
      <div class="step-panel ${isExisting ? 'active' : ''}" id="step-2">
        <div class="step-title">어땠나요?</div>
        <div class="step-desc">방문 정보와 후기를 남겨주세요.</div>

        <details class="accordion-card" open>
          <summary class="accordion-header">
            <span>🗓️ 방문 정보</span>
            <svg class="accordion-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="accordion-body">
            <div class="form-group">
              <label class="form-label">방문일</label>
              <input type="date" class="form-input" id="visit-date" value="${today}" max="${today}" />
              <label class="check-row" style="margin-top:0.4rem">
                <input type="checkbox" id="visit-date-unknown" /> 날짜 모름
              </label>
            </div>
            <div class="form-group">
              <label class="form-label">웨이팅</label>
              <div class="wait-chips" id="wait-chips">
                ${waitOptions.map((w) => `<button type="button" class="wait-chip" data-wait="${w}">${w}</button>`).join('')}
              </div>
            </div>
          </div>
        </details>

        <details class="accordion-card" open>
          <summary class="accordion-header">
            <span>⭐ 총점</span>
            <svg class="accordion-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="accordion-body">
            <div class="main-rating-area">
              <div class="star-rating" id="main-stars">
                ${[1,2,3,4,5].map((n) => `<span class="star-wrap" data-star="${n}"><svg class="star-bg" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg><svg class="star-half-fill" viewBox="0 0 24 24" fill="currentColor"><defs><clipPath id="half-clip"><rect x="0" y="0" width="12" height="24"/></clipPath></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z" clip-path="url(#half-clip)"/></svg><svg class="star-full-fill" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87L18.18 22 12 18.27 5.82 22 7 14.14l-5-4.87 6.91-1.01L12 2z"/></svg></span>`).join('')}
                <span class="star-rating-value" id="main-stars-value"></span>
              </div>
              <span class="main-rating-hint">별을 눌러 평가하세요</span>
            </div>
          </div>
        </details>

        <details class="accordion-card">
          <summary class="accordion-header">
            <span>💬 리뷰 및 메모 <span class="optional-hint">(선택)</span></span>
            <svg class="accordion-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="accordion-body">
            <textarea class="form-textarea" id="review-content" placeholder="맛은 어땠나요? 함께 간 사람, 주문한 메뉴 등 자유롭게 적어주세요." maxlength="500"></textarea>
          </div>
        </details>

        <details class="accordion-card">
          <summary class="accordion-header">
            <span>🔍 세부 평점 <span class="optional-hint">(선택)</span></span>
            <svg class="accordion-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="accordion-body">
            <div id="detail-ratings">
              ${([
                ['taste','맛',['남겼다','억지로 먹었다','다 먹었다','한 그릇 더 먹고 싶었다','먹는 내내 감탄했다']],
                ['value','가성비',['돈 줘도 안 먹는다','좀 비싸다','적당하다','가격 대비 만족','사장님 남는 거 맞아요?']],
                ['service','서비스',['손님이 죄인인 줄','좀 불친절','보통','친절하다','사장님이 내 팬인가보다']],
                ['cleanliness','청결',['나오면 안 될 게 나왔다','좀 지저분','보통','깨끗하다','수술실인가?']],
                ['accessibility','접근성',['등산인가 식사인가','한참 헤맸다','무난하게 도착','찾기 쉬움','눈 감고도 감']],
              ] as [string, string, string[]][]).map(([key, label, guides]) => `
                <div class="detail-rating-row" data-key="${key}" data-value="0">
                  <span class="detail-rating-label">${label}</span>
                  <div class="detail-chips" data-key="${key}">
                    <button type="button" class="detail-chip active" data-val="0">잘 모르겠어요</button>
                    ${guides.map((g, i) => `<button type="button" class="detail-chip" data-val="${i + 1}">${i + 1}. ${g}</button>`).join('')}
                  </div>
                </div>
              `).join('')}
            </div>
          </div>
        </details>

        <details class="accordion-card">
          <summary class="accordion-header">
            <span>📍 재방문 의사</span>
            <svg class="accordion-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <div class="accordion-body">
            <div class="revisit-btns" id="revisit-btns">
              <button type="button" class="revisit-btn" data-val="5">꼭 다시 갈 거예요</button>
              <button type="button" class="revisit-btn" data-val="4">또 가고 싶어요</button>
              <button type="button" class="revisit-btn" data-val="3">가까우면 갈만해요</button>
              <button type="button" class="revisit-btn" data-val="2">사주면 갈게요</button>
              <button type="button" class="revisit-btn" data-val="1">안 갈 것 같아요</button>
            </div>
          </div>
        </details>

        <div class="step-actions">
          ${isExisting ? '' : '<button type="button" class="btn-back" id="btn-step2-back">이전</button>'}
          <button type="button" class="btn-next" id="btn-submit">등록 완료</button>
        </div>
      </div>

      <!-- 완료 -->
      <div class="step-panel" id="step-done">
        <div class="done-screen">
          <div class="done-icon">🎉</div>
          <div class="done-title">등록 완료!</div>
          <div class="done-desc">식당, 방문, 리뷰가 모두 저장되었습니다.</div>
          <div class="done-actions">
            <a href="${isExisting ? `/room/restaurant?roomId=${roomId}&id=${existingRestId}` : `/room?id=${roomId}`}" class="done-btn-primary">${isExisting ? '식당으로 돌아가기' : '방으로 돌아가기'}</a>
            <button type="button" class="done-btn-secondary" id="btn-add-more">하나 더 등록하기</button>
          </div>
        </div>
      </div>
    `;

    // ── 카카오 지오코딩 (주소 → 좌표) ──
    function geocodeAddress(address: string): Promise<{ lat: number; lng: number } | null> {
      return new Promise((resolve) => {
        const kakao = (window as Record<string, unknown>).kakao as Record<string, unknown> | undefined;
        if (!kakao || !kakao.maps) { resolve(null); return; }
        const maps = kakao.maps as Record<string, unknown>;
        const services = maps.services as Record<string, unknown> | undefined;
        if (!services) { resolve(null); return; }
        const Geocoder = services.Geocoder as new () => { addressSearch: (addr: string, cb: (res: Array<{ x: string; y: string }>, status: string) => void) => void };
        const StatusOK = (services.Status as Record<string, string>).OK;
        const geocoder = new Geocoder();
        geocoder.addressSearch(address, (result, status) => {
          if (status === StatusOK && result[0]) {
            resolve({ lat: Number(result[0].y), lng: Number(result[0].x) });
          } else {
            resolve(null);
          }
        });
      });
    }

    // ── 스텝 네비게이션 ──
    function goToStep(step: number) {
      currentStep = step;
      document.getElementById('step-1')!.classList.toggle('active', step === 1);
      document.getElementById('step-2')!.classList.toggle('active', step === 2);
      document.getElementById('step-done')!.classList.toggle('active', step === 3);

      const dots = content.querySelectorAll<HTMLElement>('.step-dot');
      const lines = content.querySelectorAll<HTMLElement>('.step-line');

      dots.forEach((dot, i) => {
        const s = i + 1;
        dot.classList.remove('active', 'done');
        if (s < step) dot.classList.add('done');
        else if (s === step && step <= 2) dot.classList.add('active');
        else if (step === 3) dot.classList.add('done');
        dot.textContent = s < step || step === 3 ? '✓' : String(s);
      });
      lines.forEach((line) => { line.classList.toggle('done', step >= 2); });

      const labels = content.querySelectorAll<HTMLElement>('.step-label');
      labels.forEach((label, i) => {
        const s = i + 1;
        label.classList.remove('active', 'done');
        if (s < step || step === 3) label.classList.add('done');
        else if (s === step) label.classList.add('active');
      });

      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ── 스텝 1: 식당 검색 ──
    const nextBtn1 = document.getElementById('btn-step1-next') as HTMLButtonElement;

    function updateStep1Btn() {
      const hasPlace = !!placeData.name;
      const hasManual = !!(document.getElementById('manual-name') as HTMLInputElement)?.value.trim()
        && !!(document.getElementById('manual-address') as HTMLInputElement)?.value.trim()
        && !!selectedCategory;
      const kakaoArea = document.getElementById('kakao-area');
      const isKakao = kakaoArea && !kakaoArea.hidden;
      nextBtn1.disabled = isKakao ? !hasPlace : !hasManual;
    }

    // 모드 토글
    for (const btn of content.querySelectorAll<HTMLButtonElement>('.mode-toggle-btn')) {
      btn.addEventListener('click', () => {
        const mode = btn.dataset.mode!;
        content.querySelectorAll('.mode-toggle-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('kakao-area')!.hidden = mode === 'manual';
        document.getElementById('manual-area')!.hidden = mode === 'kakao';
        updateStep1Btn();
      });
    }

    // 카카오 검색
    if (hasKakaoMap) {
      const searchInput = document.getElementById('place-search') as HTMLInputElement;
      const resultsDiv = document.getElementById('search-results')!;
      let timer: ReturnType<typeof setTimeout>;
      let kakaoLoaded = false;

      function loadMaps(): Promise<void> {
        if (kakaoLoaded) return Promise.resolve();
        return new Promise((resolve) => {
          // SDK defer 로드가 아직 안 끝났으면 대기
          function tryLoad() {
            const k = (window as Record<string, unknown>).kakao as Record<string, unknown> | undefined;
            if (!k || !k.maps) { setTimeout(tryLoad, 100); return; }
            const m = k.maps as Record<string, unknown>;
            (m.load as (cb: () => void) => void)(() => { kakaoLoaded = true; resolve(); });
          }
          tryLoad();
        });
      }

      searchInput.addEventListener('input', () => {
        clearTimeout(timer);
        const kw = searchInput.value.trim();
        if (kw.length < 2) { resultsDiv.hidden = true; return; }
        timer = setTimeout(async () => {
          try {
          await loadMaps();
          const k = (window as Record<string, unknown>).kakao as Record<string, unknown>;
          const m = k.maps as Record<string, unknown>;
          const svc = m.services as Record<string, new () => Record<string, unknown>>;
          const places = new svc.Places();
          (places.keywordSearch as (...args: unknown[]) => unknown)(kw, (data: Array<Record<string, string>>, status: string) => {
            const OK = ((m.services as Record<string, Record<string, string>>).Status as Record<string, string>).OK;
            if (status !== OK || !data.length) { resultsDiv.hidden = true; return; }
            resultsDiv.innerHTML = data.slice(0, 10).map((p, i) => {
              const catParts = (p.category_name || '').split(' > ');
              const cat = catParts[catParts.length - 1] || '';
              return `<div class="search-result-item" data-idx="${i}">
                <div class="search-result-name">${escapeHtml(p.place_name)}</div>
                <div class="search-result-addr">${escapeHtml(p.address_name)}</div>
                ${cat ? `<div class="search-result-cat">${escapeHtml(cat)}</div>` : ''}
              </div>`;
            }).join('');
            resultsDiv.hidden = false;

            for (const item of resultsDiv.querySelectorAll<HTMLElement>('.search-result-item')) {
              item.addEventListener('click', () => {
                const idx = Number(item.dataset.idx);
                const p = data[idx];
                const catParts = (p.category_name || '').split(' > ');
                const lastCat = catParts[catParts.length - 1] || '';
                placeData = {
                  name: p.place_name,
                  address: p.address_name,
                  lat: p.y,
                  lng: p.x,
                  category: (lastCat && lastCat !== '음식점') ? lastCat : '음식점',
                };
                const parts = p.address_name.split(' ').filter(Boolean);
                const pMap: Record<string, string> = {
                  '서울': '서울특별시', '부산': '부산광역시', '대구': '대구광역시',
                  '인천': '인천광역시', '광주': '광주광역시', '대전': '대전광역시',
                  '울산': '울산광역시', '세종': '세종특별자치시', '경기': '경기도',
                  '강원': '강원특별자치도', '충북': '충청북도', '충남': '충청남도',
                  '전북': '전북특별자치도', '전남': '전라남도', '경북': '경상북도',
                  '경남': '경상남도', '제주': '제주특별자치도',
                };
                placeData.province = pMap[parts[0]] || parts[0] || '';
                placeData.city = parts[1] || '';
                placeData.neighborhood = parts[2] || '';

                const selectedDiv = document.getElementById('selected-place')!;
                selectedDiv.innerHTML = `
                  <div class="selected-place">
                    <div class="selected-place-name">${escapeHtml(placeData.name)}</div>
                    <div class="selected-place-meta">${escapeHtml(placeData.address)} · ${escapeHtml(placeData.category)}</div>
                    <button type="button" class="selected-place-clear" id="clear-place">다시 검색</button>
                  </div>`;
                selectedDiv.hidden = false;
                resultsDiv.hidden = true;
                searchInput.value = '';
                searchInput.hidden = true;
                updateStep1Btn();

                document.getElementById('clear-place')!.addEventListener('click', () => {
                  placeData = {};
                  selectedDiv.hidden = true;
                  searchInput.hidden = false;
                  searchInput.focus();
                  updateStep1Btn();
                });
              });
            }
          }, { category_group_code: 'FD6' });
          } catch (err) { console.error('[kakao search]', err); }
        }, 300);
      });

      document.addEventListener('click', (e) => {
        if (!(e.target as HTMLElement).closest('.search-wrap')) resultsDiv.hidden = true;
      });
    }

    // 직접 입력 카테고리
    for (const chip of content.querySelectorAll<HTMLButtonElement>('#manual-cat-chips .cat-chip')) {
      chip.addEventListener('click', () => {
        content.querySelectorAll('#manual-cat-chips .cat-chip').forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        const val = chip.dataset.cat!;
        const customInput = document.getElementById('manual-cat-custom') as HTMLInputElement;
        if (val === '기타') {
          customInput.hidden = false;
          customInput.focus();
          selectedCategory = customInput.value.trim();
        } else {
          customInput.hidden = true;
          customInput.value = '';
          selectedCategory = val;
        }
        updateStep1Btn();
      });
    }
    (document.getElementById('manual-cat-custom') as HTMLInputElement)?.addEventListener('input', (e) => {
      selectedCategory = (e.target as HTMLInputElement).value.trim();
      updateStep1Btn();
    });
    document.getElementById('manual-name')?.addEventListener('input', updateStep1Btn);
    document.getElementById('manual-address')?.addEventListener('input', updateStep1Btn);

    nextBtn1.addEventListener('click', () => goToStep(2));

    // ── 스텝 2: 리뷰 + 방문 ──
    const dateUnknown = document.getElementById('visit-date-unknown') as HTMLInputElement;
    const dateInput = document.getElementById('visit-date') as HTMLInputElement;
    dateUnknown.addEventListener('change', () => { dateInput.disabled = dateUnknown.checked; });

    for (const chip of content.querySelectorAll<HTMLButtonElement>('#wait-chips .wait-chip')) {
      chip.addEventListener('click', () => {
        const wasActive = chip.classList.contains('active');
        content.querySelectorAll('#wait-chips .wait-chip').forEach((c) => c.classList.remove('active'));
        if (!wasActive) { chip.classList.add('active'); selectedWait = chip.dataset.wait!; }
        else selectedWait = '';
      });
    }

    // 별점 (0.5 단위 호버 + 클릭)
    const mainStarWraps = content.querySelectorAll<HTMLElement>('#main-stars .star-wrap');
    const mainStarsValue = content.querySelector<HTMLElement>('#main-stars-value');

    function updateStarDisplay(wraps: NodeListOf<HTMLElement>, rating: number) {
      wraps.forEach((w) => {
        const star = Number(w.dataset.star);
        w.classList.remove('half', 'full', 'hover-half', 'hover-full');
        if (rating >= star) w.classList.add('full');
        else if (rating >= star - 0.5) w.classList.add('half');
      });
    }

    for (const wrap of mainStarWraps) {
      wrap.addEventListener('click', (e) => {
        const star = Number(wrap.dataset.star);
        const rect = wrap.getBoundingClientRect();
        const isLeft = (e as MouseEvent).clientX < rect.left + rect.width / 2;
        const clickedVal = isLeft ? star - 0.5 : star;
        mainRating = (mainRating === clickedVal) ? 0 : clickedVal;
        updateStarDisplay(mainStarWraps, mainRating);
        if (mainStarsValue) mainStarsValue.textContent = mainRating ? String(mainRating) : '';
      });
      wrap.addEventListener('mousemove', (e) => {
        mainStarWraps.forEach((w) => w.classList.remove('hover-half', 'hover-full'));
        const star = Number(wrap.dataset.star);
        const rect = wrap.getBoundingClientRect();
        const isLeft = (e as MouseEvent).clientX < rect.left + rect.width / 2;
        const hoverVal = isLeft ? star - 0.5 : star;
        mainStarWraps.forEach((w) => {
          const s = Number(w.dataset.star);
          if (hoverVal >= s) w.classList.add('hover-full');
          else if (hoverVal >= s - 0.5) w.classList.add('hover-half');
        });
      });
      wrap.addEventListener('mouseleave', () => {
        mainStarWraps.forEach((w) => w.classList.remove('hover-half', 'hover-full'));
      });
    }

    for (const row of content.querySelectorAll<HTMLElement>('.detail-rating-row')) {
      const key = row.dataset.key || '';
      for (const chip of row.querySelectorAll<HTMLButtonElement>('.detail-chip')) {
        chip.addEventListener('click', () => {
          const val = Number(chip.dataset.val || 0);
          const current = Number(row.dataset.value || 0);
          // Clicking same chip again goes back to "잘 모르겠어요" (0)
          const newVal = (current === val && val !== 0) ? 0 : val;
          detailRatings[key] = newVal;
          row.dataset.value = String(newVal);
          row.querySelectorAll('.detail-chip').forEach((c) => c.classList.toggle('active', Number((c as HTMLElement).dataset.val) === newVal));
        });
      }
    }

    // 재방문 의사 버튼
    for (const btn of content.querySelectorAll<HTMLButtonElement>('.revisit-btn')) {
      btn.addEventListener('click', () => {
        content.querySelectorAll('.revisit-btn').forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');
        wouldRevisit = parseInt(btn.dataset.val!, 10);
      });
    }

    document.getElementById('btn-step2-back')?.addEventListener('click', () => goToStep(1));

    // ── 제출 ──
    const submitBtn = document.getElementById('btn-submit') as HTMLButtonElement;
    submitBtn.addEventListener('click', async () => {
      if (mainRating === 0) { showToast('총점을 선택해 주세요.', 'info'); return; }
      if (wouldRevisit === null) { showToast('재방문 의사를 선택해 주세요.', 'info'); return; }

      submitBtn.disabled = true;
      submitBtn.textContent = '처리 중...';

      try {
        // 1) 식당 등록 (기존 식당이면 건너뜀)
        let restaurantId: string;

        if (isExisting) {
          restaurantId = existingRestId!;
        } else {
          const kakaoArea = document.getElementById('kakao-area');
          const isKakao = kakaoArea && !kakaoArea.hidden;

          let restName: string, restAddress: string, restCategory: string;
          let province: string, city: string, neighborhood: string;
          let lat: number | undefined, lng: number | undefined;

          if (isKakao && placeData.name) {
            restName = placeData.name;
            restAddress = placeData.address;
            restCategory = placeData.category;
            province = placeData.province;
            city = placeData.city;
            neighborhood = placeData.neighborhood;
            lat = Number(placeData.lat) || undefined;
            lng = Number(placeData.lng) || undefined;
          } else {
            restName = (document.getElementById('manual-name') as HTMLInputElement).value.trim();
            restAddress = (document.getElementById('manual-address') as HTMLInputElement).value.trim();
            restCategory = selectedCategory;
            const parts = restAddress.split(' ').filter(Boolean);
            const pMap: Record<string, string> = {
              '서울': '서울특별시', '부산': '부산광역시', '대구': '대구광역시',
              '인천': '인천광역시', '광주': '광주광역시', '대전': '대전광역시',
              '울산': '울산광역시', '세종': '세종특별자치시', '경기': '경기도',
              '강원': '강원특별자치도', '충북': '충청북도', '충남': '충청남도',
              '전북': '전북특별자치도', '전남': '전라남도', '경북': '경상북도',
              '경남': '경상남도', '제주': '제주특별자치도',
            };
            province = pMap[parts[0]] || parts[0] || '';
            city = parts[1] || '';
            neighborhood = parts[2] || '';
          }

          if (!province || !city) {
            showToast('주소를 정확히 입력해 주세요.', 'info');
            submitBtn.disabled = false;
            submitBtn.textContent = '등록 완료';
            return;
          }

          // 직접 입력이면서 좌표가 없으면 카카오 지오코딩 시도
          if (!isKakao && (!lat || !lng) && hasKakaoMap) {
            try {
              const coords = await geocodeAddress(restAddress);
              if (coords) { lat = coords.lat; lng = coords.lng; }
            } catch { /* 지오코딩 실패해도 등록은 진행 */ }
          }

          const restaurant = await createRoomRestaurant(roomId!, {
            name: restName, address: restAddress, category: restCategory,
            province, city, neighborhood,
            latitude: lat, longitude: lng,
            isClosed: false,
          } as Parameters<typeof createRoomRestaurant>[1]);
          restaurantId = restaurant.id;
        }

        // 2) 방문 기록
        const visitDate = dateUnknown.checked ? today : dateInput.value;
        const memo = dateUnknown.checked ? '(날짜 미상)' : undefined;

        const visit = await createRoomVisit(roomId!, restaurantId, {
          visitedAt: visitDate,
          memo,
          waitTime: selectedWait || undefined,
        });

        // 3) 리뷰
        const reviewContent = (document.getElementById('review-content') as HTMLTextAreaElement).value.trim();

        await createRoomReview(roomId!, visit.id, {
          rating: mainRating,
          content: reviewContent,
          wouldRevisit: wouldRevisit!,
          tasteRating: detailRatings.taste || null,
          valueRating: detailRatings.value || null,
          serviceRating: detailRatings.service || null,
          cleanlinessRating: detailRatings.cleanliness || null,
          accessibilityRating: detailRatings.accessibility || null,
        });

        // 위시리스트에서 온 경우: 위시리스트 상태 해제
        if (fromWishlist && isExisting) {
          try { await toggleRestaurantWishlist(roomId!, restaurantId); } catch { /* ignore */ }
        }

        goToStep(3);
      } catch (err) {
        showToast(err instanceof Error ? err.message : '등록에 실패했습니다.');
        submitBtn.disabled = false;
        submitBtn.textContent = '등록 완료';
      }
    });

    document.getElementById('btn-add-more')?.addEventListener('click', () => { location.reload(); });
  }
  }

  document.addEventListener('astro:page-load', initAddPage);
</script>
</BaseLayout>
