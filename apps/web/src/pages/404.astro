---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="페이지를 찾을 수 없습니다" description="요청하신 페이지가 존재하지 않습니다">
  <div class="not-found">
    <span class="error-code">404</span>
    <h1>페이지를 찾을 수 없습니다</h1>
    <p>요청하신 페이지가 존재하지 않거나 이동되었을 수 있습니다.</p>
    <a href="/" class="home-btn">홈으로 돌아가기</a>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 4rem 1rem;
  }

  .error-code {
    font-size: 4rem;
    font-weight: 800;
    color: #e0e0e0;
    letter-spacing: -0.05em;
    line-height: 1;
  }

  h1 {
    font-size: 1.3rem;
    margin: 0.75rem 0 0.5rem;
  }

  p {
    font-size: 0.9rem;
    color: #888;
    margin-bottom: 2rem;
  }

  .home-btn {
    display: inline-block;
    padding: 0.65rem 1.75rem;
    background: #111;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .home-btn:hover {
    background: #333;
  }
</style>
