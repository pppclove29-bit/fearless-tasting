---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="페이지를 찾을 수 없습니다" description="요청하신 페이지가 존재하지 않습니다">
  <div class="not-found">
    <span class="error-code">404</span>
    <h1>페이지를 찾을 수 없습니다</h1>
    <p>요청하신 페이지가 존재하지 않거나 이동되었을 수 있습니다.</p>
    <div class="not-found-actions">
      <a href="/" class="home-btn">홈으로 돌아가기</a>
      <a href="/cs" class="cs-link">문의하기</a>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found {
    text-align: center;
    padding: 5rem 1rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .error-code {
    font-size: 6rem;
    font-weight: 800;
    color: #e0e0e0;
    letter-spacing: -0.05em;
    line-height: 1;
    display: block;
  }

  h1 {
    font-size: 1.4rem;
    margin: 1rem 0 0.5rem;
    color: #111;
  }

  p {
    font-size: 0.9rem;
    color: #888;
    margin-bottom: 2.5rem;
    line-height: 1.6;
  }

  .not-found-actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .home-btn {
    display: inline-block;
    padding: 0.7rem 2rem;
    background: #111;
    color: #fff;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .home-btn:hover {
    background: #333;
  }

  .cs-link {
    display: inline-block;
    padding: 0.7rem 2rem;
    background: #fff;
    color: #555;
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 8px;
    border: 1px solid #d0d0d0;
    text-decoration: none;
    transition: background 0.15s;
  }

  .cs-link:hover {
    background: #f5f5f5;
  }
</style>
