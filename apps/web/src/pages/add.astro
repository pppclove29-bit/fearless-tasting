---
import BaseLayout from '@/layouts/BaseLayout.astro';
import RestaurantForm from '@/components/RestaurantForm.astro';
---

<BaseLayout title="식당 등록" description="새로운 맛집을 등록해 주세요">
  <h1>식당 등록</h1>
  <p class="page-desc">새로운 맛집을 등록해 주세요.</p>
  <RestaurantForm />
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.25rem;
    font-size: 1.4rem;
  }

  .page-desc {
    color: #888;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }
</style>
