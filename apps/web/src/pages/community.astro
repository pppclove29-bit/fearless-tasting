---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSlot from '@/components/AdSlot.astro';
---

<BaseLayout title="커뮤니티" description="맛집 정보를 공유하고 소통하세요.">
  <div class="community-page">
    <div class="community-header">
      <div>
        <h1 class="community-title">커뮤니티</h1>
        <p class="community-desc">맛집 정보를 공유하고 소통하세요</p>
      </div>
    </div>

    <div class="community-toolbar">
      <div class="search-wrap">
        <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" class="search-input" id="post-search" placeholder="게시글 검색" />
      </div>
      <a class="btn-write" id="btn-write" href="#" hidden>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        글쓰기
      </a>
    </div>

    <div class="board-tabs" id="board-tabs">
      <div class="tabs-scroll" id="tabs-scroll"></div>
      <button type="button" class="popular-toggle" id="popular-toggle" title="인기글만 보기">인기글</button>
    </div>

    <div class="table-header">
      <span class="col-no">번호</span>
      <span class="col-cat">분류</span>
      <span class="col-title">제목</span>
      <span class="col-author">작성자</span>
      <span class="col-views">조회</span>
      <span class="col-date">작성시간</span>
    </div>

    <div id="feed-content">
      <p class="loading-msg">불러오는 중...</p>
    </div>

    <AdSlot slot="community-feed" position="middle" format="horizontal" />

    <div id="pagination-wrap" class="pagination" hidden></div>

    <!-- 글쓰기 모달 -->
    <div id="write-modal" class="modal-overlay" hidden>
      <div class="write-modal-content">
        <div class="write-modal-header">
          <h2 class="write-modal-title">새 게시글 작성</h2>
          <button type="button" class="write-modal-close" id="write-modal-close">&times;</button>
        </div>
        <form id="write-form">
          <div class="write-field">
            <label class="write-label">제목</label>
            <input type="text" id="write-title" class="write-input" maxlength="200" required />
          </div>
          <div class="write-field">
            <label class="write-label">분류</label>
            <select id="write-board" class="write-select"></select>
          </div>
          <div class="write-field">
            <label class="write-label">내용</label>
            <textarea id="write-content" class="write-textarea" placeholder="내용을 입력하세요" required></textarea>
          </div>
          <div class="write-field">
            <label class="write-checkbox-label">
              <input type="checkbox" id="write-anon" />
              <span>익명으로 작성</span>
            </label>
          </div>
          <div class="write-field">
            <label class="write-label">식당 태그 (선택, 최대 5개)</label>
            <div class="rest-tag-search-wrap">
              <input type="text" id="write-rest-search" class="write-input" placeholder="식당 이름으로 검색" />
              <div id="write-rest-results" class="rest-search-results" hidden></div>
            </div>
            <div id="write-rest-tags" class="rest-tags"></div>
          </div>
          <div class="write-actions">
            <button type="button" class="write-cancel" id="write-cancel">취소</button>
            <button type="submit" class="write-submit">작성</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .community-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
  }

  .community-header {
    margin-bottom: 1.5rem;
  }

  .community-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.3rem;
  }

  .community-desc {
    font-size: 0.88rem;
    color: var(--text-muted);
  }

  .community-toolbar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .search-wrap {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
  }

  .search-icon { color: var(--text-muted); flex-shrink: 0; }

  .search-input {
    flex: 1;
    border: none;
    background: none;
    font-size: 0.85rem;
    color: var(--text);
    font-family: inherit;
    outline: none;
  }
  .search-input::placeholder { color: var(--text-muted); }

  .btn-write {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.55rem 1rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 8px;
    font-size: 0.82rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.15s;
  }
  .btn-write:hover { opacity: 0.85; }
  .btn-write[hidden] { display: none; }

  .board-tabs {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
  }

  .tabs-scroll {
    flex: 1;
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding: 0.5rem 0;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .tabs-scroll::-webkit-scrollbar { display: none; }

  .popular-toggle {
    flex-shrink: 0;
    padding: 0.4rem 0.75rem;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-sub);
    font-size: 0.8rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .popular-toggle:hover { background: var(--bg-hover); }
  .popular-toggle.active {
    background: #f59e0b;
    color: #fff;
    border-color: #f59e0b;
    font-weight: 600;
  }

  .table-header {
    display: flex;
    align-items: center;
    padding: 0.6rem 0.5rem;
    border-bottom: 2px solid var(--text-heading);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-sub);
  }

  .col-no { width: 40px; text-align: center; flex: 0 0 40px; }
  .col-cat { width: 72px; text-align: center; flex: 0 0 72px; }
  .col-title { flex: 1 1 0; min-width: 0; overflow: hidden; padding-right: 0.5rem; }
  .col-author { width: 72px; text-align: center; flex: 0 0 72px; }
  .col-views { width: 50px; text-align: center; flex: 0 0 50px; }
  .col-date { width: 80px; text-align: right; flex: 0 0 80px; }

  .loading-msg {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    padding: 3rem 1rem;
  }

  .pagination {
    display: flex;
    justify-content: center;
    gap: 0.3rem;
    padding: 1.5rem 0;
  }


  /* 글쓰기 모달 */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .modal-overlay[hidden] { display: none; }

  .write-modal-content {
    background: var(--bg-card);
    border-radius: 16px;
    padding: 1.5rem;
    width: 100%;
    max-width: 520px;
    max-height: 90vh;
    overflow-y: auto;
  }

  .write-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .write-modal-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-heading);
  }

  .write-modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    color: var(--text-muted);
    cursor: pointer;
    line-height: 1;
  }

  .write-field { margin-bottom: 1rem; }

  .write-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-sub);
    margin-bottom: 0.35rem;
  }

  .write-input, .write-select {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-size: 0.88rem;
    color: var(--text);
    background: var(--bg);
    font-family: inherit;
    outline: none;
    box-sizing: border-box;
  }
  .write-input:focus, .write-select:focus, .write-textarea:focus {
    border-color: var(--text-heading);
  }

  .write-textarea {
    width: 100%;
    min-height: 180px;
    padding: 0.6rem 0.75rem;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    font-size: 0.88rem;
    color: var(--text);
    background: var(--bg);
    font-family: inherit;
    outline: none;
    box-sizing: border-box;
    resize: vertical;
  }
  .write-textarea::placeholder { color: var(--text-muted); }

  .write-checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--text-sub);
    cursor: pointer;
  }

  .write-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.5rem;
  }

  .write-cancel {
    padding: 0.55rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: none;
    color: var(--text-sub);
    font-size: 0.85rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
  }
  .write-cancel:hover { background: var(--bg-hover); }

  .write-submit {
    padding: 0.55rem 1.2rem;
    border: none;
    border-radius: 8px;
    background: var(--text-heading);
    color: var(--bg);
    font-size: 0.85rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
  }
  .write-submit:hover { opacity: 0.85; }

  .rest-tag-search-wrap { position: relative; }
  .rest-search-results {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    max-height: 200px;
    overflow-y: auto;
    z-index: 10;
  }
  .rest-search-results[hidden] { display: none; }
  .rest-search-item {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0.5rem 0.75rem;
    border: none;
    background: none;
    font-size: 0.82rem;
    color: var(--text);
    cursor: pointer;
    font-family: inherit;
  }
  .rest-search-item:hover { background: var(--bg-hover); }
  .rest-search-name { font-weight: 600; color: var(--text-heading); }
  .rest-search-addr { font-size: 0.75rem; color: var(--text-muted); }

  .rest-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.5rem; }
  .rest-tag-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg-hover);
    font-size: 0.78rem;
    color: var(--text-heading);
  }
  .rest-tag-remove {
    background: none;
    border: none;
    font-size: 0.9rem;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }
  .rest-tag-remove:hover { color: var(--text-heading); }
</style>

<style is:global>
  .tab-chip {
    flex-shrink: 0;
    padding: 0.4rem 0.85rem;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-sub);
    font-size: 0.8rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }
  .tab-chip:hover { background: var(--bg-hover); }
  .tab-chip.active {
    background: var(--text-heading);
    color: var(--bg);
    border-color: var(--text-heading);
    font-weight: 600;
  }

  .post-row {
    display: flex;
    align-items: center;
    padding: 0.75rem 0.5rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
    font-size: 0.82rem;
    gap: 0;
  }
  .post-row:hover { background: var(--bg-hover); }

  .post-row .col-no { color: var(--text-muted); font-size: 0.78rem; }
  .post-row .col-cat .cat-badge {
    display: inline-block;
    padding: 0.15rem 0.45rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.7rem;
    color: var(--text-sub);
  }
  .post-row .col-title {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
    overflow: hidden;
  }
  .post-row .col-title-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .post-row .post-preview {
    font-size: 0.75rem;
    color: var(--text-muted);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .post-row .popular-badge {
    flex-shrink: 0;
    font-size: 0.75rem;
    line-height: 1;
  }
  .post-row .post-title-text {
    font-weight: 600;
    color: var(--text-heading);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .post-row .new-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    background: #dc2626;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .post-row .comment-count {
    color: var(--text-muted);
    font-size: 0.75rem;
    flex-shrink: 0;
  }
  .post-row .col-author { color: var(--text-sub); font-size: 0.78rem; }
  .post-row .col-views { color: var(--text-muted); font-size: 0.78rem; }
  .post-row .col-date { color: var(--text-muted); font-size: 0.75rem; }

  /* 모바일 메타 (데스크탑에선 숨김) */
  .post-meta-mobile {
    display: none;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.72rem;
    color: var(--text-muted);
    flex-wrap: wrap;
    width: 100%;
  }
  .post-meta-mobile .meta-sep { color: var(--border-mid); }
  .post-meta-mobile .meta-comments {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.2rem;
    color: var(--text-sub);
  }

  /* 모바일: 카드형 레이아웃 — 반드시 .post-row 정의 뒤에 위치해야 함 */
  @media (max-width: 600px) {
    .table-header { display: none; }
    .post-row {
      flex-direction: column;
      align-items: flex-start;
      padding: 0.85rem 0.6rem;
      gap: 0.35rem;
    }
    .post-row .col-no { display: none; }
    .post-row .col-cat { width: auto; flex: none; text-align: left; }
    .post-row .col-title { padding-right: 0; width: 100%; }
    .post-row .col-title-row { flex-wrap: wrap; }
    .post-row .post-title-text { font-size: 0.92rem; white-space: normal; }
    .post-row .col-author,
    .post-row .col-views,
    .post-row .col-date { display: none; }
    .post-row .post-meta-mobile { display: flex; }
  }

  .page-btn {
    min-width: 32px;
    height: 32px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: none;
    cursor: pointer;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text-sub);
    font-family: inherit;
    transition: all 0.15s;
  }
  .page-btn:hover { background: var(--bg-hover); }
  .page-btn.active {
    background: var(--text-heading);
    color: var(--bg);
    border-color: var(--text-heading);
  }

  .feed-empty {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    padding: 3rem 1rem;
  }
</style>

<script>
  import { fetchBoards, fetchPosts, fetchMyPosts, fetchCurrentUser, createPost, showToast } from '@/lib/api';
  import type { BoardListItem, PaginatedPosts } from '@/lib/api';

  function initCommunityPage() {
    const tabsScroll = document.getElementById('tabs-scroll');
    const feedContent = document.getElementById('feed-content');
    const paginationWrap = document.getElementById('pagination-wrap');
    const btnWrite = document.getElementById('btn-write') as HTMLAnchorElement | null;
    const postSearch = document.getElementById('post-search') as HTMLInputElement | null;
    const popularToggle = document.getElementById('popular-toggle') as HTMLButtonElement | null;
    if (!tabsScroll || !feedContent || !paginationWrap || !btnWrite || !postSearch) return;

    let boards: BoardListItem[] = [];
    let activeSlug = '';
    let currentPage = 1;
    let totalPages = 1;
    let total = 0;
    let isLoggedIn = false;
    let searchQuery = '';
    let popularOnly = false;

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function relativeTime(dateStr: string): string {
      const now = Date.now();
      const then = new Date(dateStr).getTime();
      const diff = now - then;
      const mins = Math.floor(diff / 60000);
      if (mins < 1) return '방금 전';
      if (mins < 60) return `${mins}분 전`;
      const hours = Math.floor(mins / 60);
      if (hours < 24) return `${hours}시간 전`;
      const days = Math.floor(hours / 24);
      if (days === 1) return '어제';
      if (days < 30) return `${days}일 전`;
      return new Date(dateStr).toLocaleDateString('ko-KR', { year: '2-digit', month: 'numeric', day: 'numeric' });
    }

    function isNew(dateStr: string): boolean {
      return Date.now() - new Date(dateStr).getTime() < 24 * 60 * 60 * 1000;
    }

    function renderTabs() {
      tabsScroll.innerHTML = `<button type="button" class="tab-chip ${activeSlug === '' ? 'active' : ''}" data-slug="">전체</button>` +
        boards.map((b) => `<button type="button" class="tab-chip ${activeSlug === b.slug ? 'active' : ''}" data-slug="${escapeHtml(b.slug)}">${escapeHtml(b.name)}</button>`).join('');

      for (const btn of tabsScroll.querySelectorAll<HTMLButtonElement>('.tab-chip')) {
        btn.addEventListener('click', () => {
          activeSlug = btn.dataset.slug || '';
          currentPage = 1;
          renderTabs();
          loadPosts();
        });
      }
    }

    function renderPosts(result: PaginatedPosts) {
      total = result.total;
      totalPages = result.totalPages ?? Math.ceil(result.total / (result.pageSize ?? 20));

      if (result.data.length === 0) {
        feedContent.innerHTML = '<p class="feed-empty">게시글이 없습니다.</p>';
        paginationWrap.hidden = true;
        return;
      }

      const startNo = total - ((currentPage - 1) * (result.pageSize ?? 20));

      feedContent.innerHTML = result.data.map((post, idx) => {
        const commentCount = post._count?.comments ?? 0;
        const boardName = post.boardName || '';
        const authorName = post.isAnonymous ? '익명' : (post.author?.nickname || post.authorNickname || '');
        const no = startNo - idx;
        const slug = post.boardSlug || activeSlug;

        const contentPreview = post.content ? post.content.replace(/\n/g, ' ').slice(0, 60) : '';

        return `<a href="/community/${encodeURIComponent(slug)}/${post.id}" class="post-row">
          <span class="col-no">${no}</span>
          <span class="col-cat"><span class="cat-badge">${escapeHtml(boardName)}</span></span>
          <span class="col-title">
            <span class="col-title-row">
              ${post.isPopular ? '<span class="popular-badge" title="인기글">&#11088;</span>' : ''}
              <span class="post-title-text">${escapeHtml(post.title)}</span>
              ${isNew(post.createdAt) ? '<span class="new-badge">N</span>' : ''}
              ${commentCount > 0 ? `<span class="comment-count"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg> ${commentCount}</span>` : ''}
            </span>
            ${contentPreview ? `<span class="post-preview">${escapeHtml(contentPreview)}</span>` : ''}
          </span>
          <span class="col-author">${escapeHtml(authorName)}</span>
          <span class="col-views"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> ${post._count?.views ?? 0}</span>
          <span class="col-date">${relativeTime(post.createdAt)}</span>
          <span class="post-meta-mobile">
            <span>${escapeHtml(authorName)}</span>
            <span class="meta-sep">·</span>
            <span>${relativeTime(post.createdAt)}</span>
            <span class="meta-sep">·</span>
            <span>조회 ${post._count?.views ?? 0}</span>
            ${commentCount > 0 ? `<span class="meta-comments"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg> ${commentCount}</span>` : ''}
          </span>
        </a>`;
      }).join('');

      // Pagination
      if (totalPages > 1) {
        paginationWrap.hidden = false;
        let html = '';
        if (currentPage > 1) html += `<button type="button" class="page-btn" data-page="${currentPage - 1}">&lt;</button>`;
        const start = Math.max(1, currentPage - 2);
        const end = Math.min(totalPages, start + 4);
        for (let i = start; i <= end; i++) {
          html += `<button type="button" class="page-btn ${i === currentPage ? 'active' : ''}" data-page="${i}">${i}</button>`;
        }
        if (currentPage < totalPages) html += `<button type="button" class="page-btn" data-page="${currentPage + 1}">&gt;</button>`;
        paginationWrap.innerHTML = html;

        for (const btn of paginationWrap.querySelectorAll<HTMLButtonElement>('.page-btn')) {
          btn.addEventListener('click', () => {
            currentPage = parseInt(btn.dataset.page || '1', 10);
            loadPosts();
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
        }
      } else {
        paginationWrap.hidden = true;
      }
    }

    async function loadPosts() {
      try {
        let result: PaginatedPosts;
        if (activeSlug) {
          result = await fetchPosts(activeSlug, currentPage, 20, popularOnly);
        } else if (boards.length > 0) {
          result = await fetchPosts(boards[0].slug, currentPage, 20, popularOnly);
        } else {
          feedContent.innerHTML = '<p class="feed-empty">게시판이 없습니다.</p>';
          return;
        }
        renderPosts(result);
      } catch {
        feedContent.innerHTML = '<p class="feed-empty">게시글을 불러올 수 없습니다.</p>';
      }
    }

    // 검색 디바운스
    let searchTimer: ReturnType<typeof setTimeout> | null = null;
    postSearch.addEventListener('input', () => {
      if (searchTimer) clearTimeout(searchTimer);
      searchTimer = setTimeout(() => {
        searchQuery = postSearch.value.trim();
        currentPage = 1;
        loadPosts();
      }, 300);
    });

    // 인기글 필터 토글
    popularToggle?.addEventListener('click', () => {
      popularOnly = !popularOnly;
      popularToggle.classList.toggle('active', popularOnly);
      currentPage = 1;
      loadPosts();
    });

    async function init() {
      try {
        const [user, boardList] = await Promise.all([
          fetchCurrentUser().catch(() => null),
          fetchBoards(),
        ]);
        boards = boardList;
        isLoggedIn = !!user;

        if (isLoggedIn && btnWrite) {
          btnWrite.hidden = false;
          btnWrite.removeAttribute('href');
          btnWrite.addEventListener('click', (e) => {
            e.preventDefault();
            openWriteModal();
          });
        }

        // URL에서 board 선택
        const urlParams = new URLSearchParams(location.search);
        const boardParam = urlParams.get('board');
        if (boardParam && boards.some(b => b.slug === boardParam)) {
          activeSlug = boardParam;
        }

        renderTabs();
        await loadPosts();
      } catch {
        feedContent.innerHTML = '<p class="feed-empty">커뮤니티를 불러올 수 없습니다.</p>';
      }
    }

    // 글쓰기 모달
    const writeModal = document.getElementById('write-modal');
    const writeModalClose = document.getElementById('write-modal-close');
    const writeCancel = document.getElementById('write-cancel');
    const writeForm = document.getElementById('write-form') as HTMLFormElement | null;
    const writeTitle = document.getElementById('write-title') as HTMLInputElement | null;
    const writeBoard = document.getElementById('write-board') as HTMLSelectElement | null;
    const writeContent = document.getElementById('write-content') as HTMLTextAreaElement | null;
    const writeAnon = document.getElementById('write-anon') as HTMLInputElement | null;
    const writeRestSearch = document.getElementById('write-rest-search') as HTMLInputElement | null;
    const writeRestResults = document.getElementById('write-rest-results');
    const writeRestTags = document.getElementById('write-rest-tags');

    interface TaggedRestaurant {
      name: string;
      address: string;
      category?: string;
      latitude?: number;
      longitude?: number;
      kakaoPlaceId?: string;
    }
    let taggedRestaurants: TaggedRestaurant[] = [];

    function renderRestTags() {
      if (!writeRestTags) return;
      writeRestTags.innerHTML = taggedRestaurants.map((r, i) =>
        `<span class="rest-tag-chip">${escapeHtml(r.name)}<button type="button" class="rest-tag-remove" data-idx="${i}">&times;</button></span>`
      ).join('');
      for (const btn of writeRestTags.querySelectorAll<HTMLButtonElement>('.rest-tag-remove')) {
        btn.addEventListener('click', () => {
          const idx = parseInt(btn.dataset.idx || '0', 10);
          taggedRestaurants.splice(idx, 1);
          renderRestTags();
        });
      }
    }

    // 카카오 장소 검색
    let restSearchTimer: ReturnType<typeof setTimeout> | null = null;
    writeRestSearch?.addEventListener('input', () => {
      if (restSearchTimer) clearTimeout(restSearchTimer);
      restSearchTimer = setTimeout(() => {
        const query = writeRestSearch.value.trim();
        if (!query || query.length < 2) {
          if (writeRestResults) writeRestResults.hidden = true;
          return;
        }
        searchKakaoPlaces(query);
      }, 300);
    });

    function searchKakaoPlaces(query: string) {
      if (!writeRestResults) return;
      const kakaoMapKey = (document.querySelector('meta[name="kakao-map-key"]') as HTMLMetaElement | null)?.content;
      if (!kakaoMapKey) {
        // fallback: 수동 입력 모드
        writeRestResults.innerHTML = `<button type="button" class="rest-search-item" data-manual="true">
          <div class="rest-search-name">"${escapeHtml(query)}" 직접 추가</div>
          <div class="rest-search-addr">주소를 직접 입력해주세요</div>
        </button>`;
        writeRestResults.hidden = false;
        setupSearchResultHandlers(query);
        return;
      }

      const script = document.querySelector('script[src*="dapi.kakao.com"]');
      if (!script && typeof (window as Record<string, unknown>).kakao === 'undefined') {
        // 카카오 SDK 미로드 시 수동 입력
        writeRestResults.innerHTML = `<button type="button" class="rest-search-item" data-manual="true">
          <div class="rest-search-name">"${escapeHtml(query)}" 직접 추가</div>
          <div class="rest-search-addr">주소를 직접 입력해주세요</div>
        </button>`;
        writeRestResults.hidden = false;
        setupSearchResultHandlers(query);
        return;
      }

      const kakao = (window as Record<string, unknown>).kakao as { maps?: { services?: { Places: new () => { keywordSearch: (q: string, cb: (data: { place_name: string; address_name: string; category_group_name: string; y: string; x: string; id: string }[], status: string) => void) => void }; Status: { OK: string } } } };
      if (!kakao?.maps?.services) {
        writeRestResults.innerHTML = `<button type="button" class="rest-search-item" data-manual="true">
          <div class="rest-search-name">"${escapeHtml(query)}" 직접 추가</div>
          <div class="rest-search-addr">주소를 직접 입력해주세요</div>
        </button>`;
        writeRestResults.hidden = false;
        setupSearchResultHandlers(query);
        return;
      }

      const ps = new kakao.maps.services.Places();
      ps.keywordSearch(query, (data, status) => {
        if (status !== kakao.maps!.services!.Status.OK || data.length === 0) {
          writeRestResults.innerHTML = `<button type="button" class="rest-search-item" data-manual="true">
            <div class="rest-search-name">"${escapeHtml(query)}" 직접 추가</div>
            <div class="rest-search-addr">검색 결과가 없습니다. 직접 추가하세요.</div>
          </button>`;
          writeRestResults.hidden = false;
          setupSearchResultHandlers(query);
          return;
        }

        writeRestResults.innerHTML = data.slice(0, 5).map((place, i) =>
          `<button type="button" class="rest-search-item" data-place-idx="${i}" data-name="${escapeHtml(place.place_name)}" data-address="${escapeHtml(place.address_name)}" data-category="${escapeHtml(place.category_group_name || '')}" data-lat="${place.y}" data-lng="${place.x}" data-kakao-id="${place.id}">
            <div class="rest-search-name">${escapeHtml(place.place_name)}</div>
            <div class="rest-search-addr">${escapeHtml(place.address_name)}</div>
          </button>`
        ).join('');
        writeRestResults.hidden = false;
        setupSearchResultHandlers(query);
      });
    }

    function setupSearchResultHandlers(query: string) {
      if (!writeRestResults || !writeRestSearch) return;
      for (const item of writeRestResults.querySelectorAll<HTMLButtonElement>('.rest-search-item')) {
        item.addEventListener('click', () => {
          if (taggedRestaurants.length >= 5) {
            showToast('식당은 최대 5개까지 태그할 수 있습니다.');
            return;
          }

          if (item.dataset.manual === 'true') {
            const address = prompt('주소를 입력해주세요:') || '';
            taggedRestaurants.push({ name: query, address });
          } else {
            taggedRestaurants.push({
              name: item.dataset.name || '',
              address: item.dataset.address || '',
              category: item.dataset.category || undefined,
              latitude: item.dataset.lat ? parseFloat(item.dataset.lat) : undefined,
              longitude: item.dataset.lng ? parseFloat(item.dataset.lng) : undefined,
              kakaoPlaceId: item.dataset.kakaoId || undefined,
            });
          }

          renderRestTags();
          writeRestSearch.value = '';
          writeRestResults.hidden = true;
        });
      }
    }

    // 검색 결과 외부 클릭 시 닫기
    document.addEventListener('click', (e) => {
      if (writeRestResults && !writeRestResults.hidden) {
        const target = e.target as HTMLElement;
        if (!writeRestResults.contains(target) && target !== writeRestSearch) {
          writeRestResults.hidden = true;
        }
      }
    });

    function openWriteModal() {
      if (!writeModal || !writeBoard) return;
      writeBoard.innerHTML = boards.map((b) =>
        `<option value="${escapeHtml(b.slug)}" ${b.slug === activeSlug ? 'selected' : ''}>${escapeHtml(b.name)}</option>`
      ).join('');
      taggedRestaurants = [];
      renderRestTags();
      writeModal.hidden = false;
      writeTitle?.focus();
    }

    function closeWriteModal() {
      if (!writeModal) return;
      writeModal.hidden = true;
      if (writeTitle) writeTitle.value = '';
      if (writeContent) writeContent.value = '';
      if (writeAnon) writeAnon.checked = false;
      if (writeRestSearch) writeRestSearch.value = '';
      taggedRestaurants = [];
      renderRestTags();
    }

    writeModalClose?.addEventListener('click', closeWriteModal);
    writeCancel?.addEventListener('click', closeWriteModal);
    writeModal?.addEventListener('click', (e) => {
      if (e.target === writeModal) closeWriteModal();
    });

    writeForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const title = writeTitle?.value.trim();
      const content = writeContent?.value.trim();
      const slug = writeBoard?.value;
      const isAnonymous = writeAnon?.checked || false;
      if (!title || !content || !slug) return;

      const submitBtn = writeForm.querySelector<HTMLButtonElement>('.write-submit');
      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = '작성 중...'; }

      try {
        await createPost(slug, title, content, isAnonymous, taggedRestaurants.length > 0 ? taggedRestaurants : undefined);
        closeWriteModal();
        showToast('게시글이 작성되었습니다.', 'success');
        activeSlug = slug;
        currentPage = 1;
        renderTabs();
        await loadPosts();
      } catch (err) {
        showToast(err instanceof Error ? err.message : '게시글 작성에 실패했습니다.');
      } finally {
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '작성'; }
      }
    });

    init();
  }

  document.addEventListener('astro:page-load', initCommunityPage);
</script>
