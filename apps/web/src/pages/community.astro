---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="커뮤니티" description="무모한 시식가 커뮤니티 게시판. 맛집 정보와 리뷰를 자유롭게 나눠보세요.">
  <div class="community-page">
    <section class="community-hero">
      <h1>커뮤니티</h1>
      <p class="community-desc">맛집 이야기를 자유롭게 나눠보세요</p>
    </section>

    <div id="boards-content">
      <p class="loading-msg">불러오는 중...</p>
    </div>
  </div>
</BaseLayout>

<style>
  .community-page {
    max-width: 480px;
    margin: 0 auto;
  }

  .community-hero {
    text-align: center;
    padding: 2rem 0 1.5rem;
  }

  .community-hero h1 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.25rem;
  }

  .community-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .loading-msg {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    padding: 2rem;
  }
</style>

<style is:global>
  .board-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .board-card:hover {
    border-color: var(--border-mid);
  }

  .board-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.35rem;
  }

  .board-card-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-heading);
  }

  .board-card-count {
    font-size: 0.75rem;
    color: var(--text-muted);
    background: var(--bg-hover);
    padding: 0.15rem 0.5rem;
    border-radius: 10px;
  }

  .board-card-desc {
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.5;
  }

  .boards-empty {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    padding: 3rem 1rem;
  }
</style>

<script>
  import { fetchBoards } from '@/lib/api';
  import type { BoardListItem } from '@/lib/api';

  function initCommunityPage() {
    const content = document.getElementById('boards-content');
    if (!content) return;

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    async function loadBoards() {
      let boards: BoardListItem[];
      try {
        boards = await fetchBoards();
      } catch {
        content.innerHTML = '<p class="boards-empty">게시판을 불러올 수 없습니다.</p>';
        return;
      }

      if (boards.length === 0) {
        content.innerHTML = '<p class="boards-empty">아직 개설된 게시판이 없습니다.</p>';
        return;
      }

      content.innerHTML = boards.map((board) => {
        const postCount = board._count?.posts ?? 0;
        return `
          <a href="/community/${encodeURIComponent(board.slug)}" class="board-card">
            <div class="board-card-header">
              <span class="board-card-name">${escapeHtml(board.name)}</span>
              <span class="board-card-count">${postCount}개 글</span>
            </div>
            ${board.description ? `<p class="board-card-desc">${escapeHtml(board.description)}</p>` : ''}
          </a>
        `;
      }).join('');
    }

    loadBoards();
  }

  document.addEventListener('astro:page-load', initCommunityPage);
</script>
