---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="내 방" description="내가 참여한 맛집 공유 방 목록">
  <h1>내 방</h1>
  <p class="page-desc">방을 만들어 친구와 맛집 리스트를 공유하세요.</p>

  <div id="auth-gate">
    <p id="loading-msg" class="status-msg">로딩 중...</p>
    <p id="login-required" class="status-msg" hidden>
      <a href="/login">로그인</a>이 필요합니다.
    </p>
  </div>

  <div id="rooms-content" hidden>
    <div class="rooms-actions">
      <form id="create-form" class="action-form">
        <input type="text" id="create-name" placeholder="방 이름" required maxlength="100" />
        <button type="submit" class="btn-primary">방 만들기</button>
      </form>
      <form id="join-form" class="action-form">
        <input type="text" id="join-code" placeholder="초대 코드 (8자)" required maxlength="8" minlength="8" />
        <button type="submit" class="btn-secondary">입장</button>
      </form>
    </div>

    <div class="form-error" id="form-error" hidden></div>

    <div id="rooms-list"></div>
    <p id="empty-msg" class="status-msg" hidden>참여 중인 방이 없습니다. 방을 만들거나 초대 코드로 입장하세요.</p>
  </div>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.25rem;
    font-size: 1.4rem;
  }

  .page-desc {
    color: #888;
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .status-msg {
    text-align: center;
    padding: 2rem;
    color: #999;
    font-size: 0.9rem;
  }

  .status-msg a {
    color: #111;
    font-weight: 600;
  }

  .rooms-actions {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .action-form {
    display: flex;
    gap: 0.5rem;
    flex: 1;
    min-width: 240px;
  }

  .action-form input {
    flex: 1;
    padding: 0.6rem 0.75rem;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    font-size: 0.875rem;
  }

  .action-form input:focus {
    outline: none;
    border-color: #333;
    box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.05);
  }

  .btn-primary {
    padding: 0.6rem 1rem;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .btn-primary:hover { background: #333; }

  .btn-secondary {
    padding: 0.6rem 1rem;
    background: #fff;
    color: #333;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .btn-secondary:hover { background: #f0f0f0; }

  .form-error {
    padding: 0.75rem;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 6px;
    color: #dc2626;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
</style>

<style is:global>
  .room-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: #fff;
    border: 1px solid #e8e8e8;
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.6rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .room-card:hover {
    border-color: #ccc;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .room-info {
    min-width: 0;
  }

  .room-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #111;
    margin-bottom: 0.15rem;
  }

  .room-meta {
    font-size: 0.8rem;
    color: #888;
  }

  .room-role {
    display: inline-block;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    background: #f0f0f0;
    color: #555;
    margin-left: 0.5rem;
  }

  .room-role.owner { background: #fef3c7; color: #92400e; }
  .room-role.manager { background: #dbeafe; color: #1d4ed8; }
</style>

<script>
  import { fetchCurrentUser, fetchMyRooms, createRoom, joinRoom } from '@/lib/api';
  import type { RoomListItem } from '@/lib/api';

  const loadingMsg = document.getElementById('loading-msg')!;
  const loginRequired = document.getElementById('login-required')!;
  const roomsContent = document.getElementById('rooms-content')!;
  const roomsList = document.getElementById('rooms-list')!;
  const emptyMsg = document.getElementById('empty-msg')!;
  const formError = document.getElementById('form-error')!;
  const createForm = document.getElementById('create-form') as HTMLFormElement;
  const createNameInput = document.getElementById('create-name') as HTMLInputElement;
  const joinForm = document.getElementById('join-form') as HTMLFormElement;
  const joinCodeInput = document.getElementById('join-code') as HTMLInputElement;

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  const roleLabel: Record<string, string> = {
    owner: '방장',
    manager: '매니저',
    member: '멤버',
  };

  function renderRooms(rooms: RoomListItem[]) {
    if (rooms.length === 0) {
      roomsList.innerHTML = '';
      emptyMsg.hidden = false;
      return;
    }

    emptyMsg.hidden = true;
    roomsList.innerHTML = rooms
      .map(
        (r) => `
        <a href="/room?id=${r.id}" class="room-card">
          <div class="room-info">
            <div class="room-name">${escapeHtml(r.name)}</div>
            <div class="room-meta">멤버 ${r.memberCount}명 · 식당 ${r.restaurantCount}개</div>
          </div>
          <span class="room-role ${r.myRole}">${roleLabel[r.myRole] || r.myRole}</span>
        </a>
      `,
      )
      .join('');
  }

  function showError(msg: string) {
    formError.textContent = msg;
    formError.hidden = false;
  }

  // 방 만들기
  createForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.hidden = true;
    const name = createNameInput.value.trim();
    if (!name) return;

    try {
      await createRoom(name);
      createNameInput.value = '';
      const rooms = await fetchMyRooms();
      renderRooms(rooms);
    } catch (err) {
      showError(err instanceof Error ? err.message : '방 생성에 실패했습니다.');
    }
  });

  // 초대 코드 입장
  joinForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.hidden = true;
    const code = joinCodeInput.value.trim();
    if (!code) return;

    try {
      const room = await joinRoom(code);
      joinCodeInput.value = '';
      location.href = `/room?id=${room.id}`;
    } catch (err) {
      showError(err instanceof Error ? err.message : '입장에 실패했습니다.');
    }
  });

  // 초기화
  (async () => {
    const user = await fetchCurrentUser();
    loadingMsg.hidden = true;

    if (!user) {
      loginRequired.hidden = false;
      return;
    }

    roomsContent.hidden = false;
    const rooms = await fetchMyRooms();
    renderRooms(rooms);
  })();
</script>
