---
import BaseLayout from '@/layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="커뮤니티">
  <div class="board-page">
    <div class="board-tabs" id="board-tabs">
      <div class="tabs-scroll" id="tabs-scroll"></div>
    </div>

    <div id="feed-content">
      <p class="loading-msg">불러오는 중...</p>
    </div>

    <div id="load-more-wrap" class="load-more-wrap" hidden>
      <button type="button" class="load-more-btn" id="load-more-btn">더보기</button>
    </div>

    <button type="button" class="fab" id="fab-write" hidden aria-label="글쓰기">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>
    </button>
  </div>
</BaseLayout>

<style>
  .board-page {
    max-width: 480px;
    margin: 0 auto;
    padding-bottom: 80px;
  }

  .board-tabs {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .tabs-scroll {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding: 0.75rem 0.75rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .tabs-scroll::-webkit-scrollbar {
    display: none;
  }

  .loading-msg {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    padding: 3rem 1rem;
  }

  .load-more-wrap {
    text-align: center;
    padding: 1rem 0 2rem;
  }

  .load-more-btn {
    padding: 0.55rem 1.5rem;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--bg);
    color: var(--text-sub);
    font-size: 0.82rem;
    font-family: inherit;
    cursor: pointer;
    transition: background 0.15s;
  }

  .load-more-btn:hover {
    background: var(--bg-hover);
  }

  .fab {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    background: var(--text-heading);
    color: var(--bg);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    transition: transform 0.15s, box-shadow 0.15s;
    z-index: 100;
  }

  .fab:hover {
    transform: scale(1.08);
    box-shadow: 0 4px 16px rgba(0,0,0,0.2);
  }

  .fab:active {
    transform: scale(0.95);
  }
</style>

<style is:global>
  .tab-chip {
    flex-shrink: 0;
    padding: 0.4rem 0.85rem;
    border-radius: 16px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-sub);
    font-size: 0.8rem;
    font-weight: 500;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .tab-chip:hover {
    background: var(--bg-hover);
  }

  .tab-chip.active {
    background: var(--text-heading);
    color: var(--bg);
    border-color: var(--text-heading);
    font-weight: 600;
  }

  .feed-item {
    display: block;
    padding: 0.85rem 0.75rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
  }

  .feed-item:hover {
    background: var(--bg-hover);
  }

  .feed-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-hover);
    padding: 0.1rem 0.45rem;
    border-radius: 4px;
    margin-bottom: 0.3rem;
  }

  .feed-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.25rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .feed-preview {
    font-size: 0.82rem;
    color: var(--text-sub);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 0.4rem;
    word-break: break-word;
  }

  .feed-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .feed-meta-dot {
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: var(--text-muted);
    flex-shrink: 0;
  }

  .feed-empty {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    padding: 3rem 1rem;
  }
</style>

<script>
  import { fetchBoards, fetchPosts, fetchCurrentUser } from '@/lib/api';
  import type { BoardListItem, PostListItem, PaginatedPosts } from '@/lib/api';

  function initBoardPage() {
    const tabsScroll = document.getElementById('tabs-scroll');
    const feedContent = document.getElementById('feed-content');
    const loadMoreWrap = document.getElementById('load-more-wrap');
    const loadMoreBtn = document.getElementById('load-more-btn');
    const fabWrite = document.getElementById('fab-write');
    if (!tabsScroll || !feedContent || !loadMoreWrap || !loadMoreBtn || !fabWrite) return;

    const pathParts = location.pathname.split('/').filter(Boolean);
    const slugFromUrl = decodeURIComponent(pathParts[1] || '');
    if (!slugFromUrl) return;

    let boards: BoardListItem[] = [];
    let activeSlug = slugFromUrl;
    let currentPage = 1;
    let totalPages = 1;
    let posts: PostListItem[] = [];

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function relativeTime(dateStr: string): string {
      const now = Date.now();
      const then = new Date(dateStr).getTime();
      const diff = Math.floor((now - then) / 1000);
      if (diff < 60) return '방금 전';
      if (diff < 3600) return `${Math.floor(diff / 60)}분 전`;
      if (diff < 86400) return `${Math.floor(diff / 3600)}시간 전`;
      if (diff < 2592000) return `${Math.floor(diff / 86400)}일 전`;
      const d = new Date(dateStr);
      return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
    }

    function renderTabs() {
      tabsScroll.innerHTML = '';

      boards.forEach((board) => {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = `tab-chip${activeSlug === board.slug ? ' active' : ''}`;
        chip.textContent = board.name;
        chip.addEventListener('click', () => {
          // Navigate to the board's URL
          history.replaceState(null, '', `/community/${encodeURIComponent(board.slug)}`);
          selectBoard(board.slug);
        });
        tabsScroll.appendChild(chip);
      });
    }

    function updateActiveChip() {
      const chips = tabsScroll.querySelectorAll('.tab-chip');
      chips.forEach((chip, index) => {
        const board = boards[index];
        chip.classList.toggle('active', activeSlug === board?.slug);
      });
    }

    function selectBoard(slug: string) {
      if (slug === activeSlug) return;
      activeSlug = slug;
      currentPage = 1;
      posts = [];
      updateActiveChip();
      // Update page title
      const board = boards.find(b => b.slug === slug);
      if (board) document.title = `${board.name} — 커뮤니티 | 무모한 시식가`;
      loadPosts(true);
    }

    function renderFeed(reset: boolean) {
      if (reset) feedContent.innerHTML = '';

      if (posts.length === 0 && reset) {
        feedContent.innerHTML = '<p class="feed-empty">아직 작성된 글이 없습니다.</p>';
        loadMoreWrap.hidden = true;
        return;
      }

      const newPosts = reset ? posts : posts.slice((currentPage - 2) * 20);

      newPosts.forEach((post) => {
        const contentPreview = post.content ? post.content.replace(/\n/g, ' ').slice(0, 100) : '';
        const commentCount = post._count?.comments ?? 0;
        const a = document.createElement('a');
        a.href = `/community/${encodeURIComponent(post.boardSlug || activeSlug)}/${post.id}`;
        a.className = 'feed-item';
        a.innerHTML = `
          <div class="feed-title">${escapeHtml(post.title)}</div>
          ${contentPreview ? `<div class="feed-preview">${escapeHtml(contentPreview)}</div>` : ''}
          <div class="feed-meta">
            <span>${escapeHtml(post.author.nickname)}</span>
            <span class="feed-meta-dot"></span>
            <span>${relativeTime(post.createdAt)}</span>
            ${commentCount > 0 ? `<span class="feed-meta-dot"></span><span>댓글 ${commentCount}</span>` : ''}
          </div>
        `;
        feedContent.appendChild(a);
      });

      loadMoreWrap.hidden = currentPage >= totalPages;
    }

    async function loadPosts(reset: boolean) {
      if (reset) {
        feedContent.innerHTML = '<p class="loading-msg">불러오는 중...</p>';
      }

      let result: PaginatedPosts;
      try {
        result = await fetchPosts(activeSlug, currentPage, 20);
      } catch {
        feedContent.innerHTML = '<p class="feed-empty">게시글을 불러올 수 없습니다.</p>';
        loadMoreWrap.hidden = true;
        return;
      }

      totalPages = result.totalPages;
      if (reset) {
        posts = result.items;
      } else {
        posts = [...posts, ...result.items];
      }
      renderFeed(reset);
    }

    loadMoreBtn.addEventListener('click', () => {
      currentPage++;
      loadPosts(false);
    });

    async function init() {
      try {
        boards = await fetchBoards();
      } catch {
        feedContent.innerHTML = '<p class="feed-empty">게시판을 불러올 수 없습니다.</p>';
        return;
      }

      // Verify slug exists
      const board = boards.find(b => b.slug === slugFromUrl);
      if (board) {
        document.title = `${board.name} — 커뮤니티 | 무모한 시식가`;
      }

      renderTabs();

      const user = await fetchCurrentUser();
      if (user) {
        fabWrite.hidden = false;
        fabWrite.addEventListener('click', () => {
          location.href = `/community/${encodeURIComponent(activeSlug)}/write`;
        });
      }

      await loadPosts(true);
    }

    init();
  }

  document.addEventListener('astro:page-load', initBoardPage);
</script>
