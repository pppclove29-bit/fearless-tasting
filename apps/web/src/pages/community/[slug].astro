---
import BaseLayout from '@/layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="커뮤니티">
  <div class="board-page">
    <div class="board-header">
      <a href="/community" class="board-back">&larr; 게시판 목록</a>
      <h1 id="board-title">게시판</h1>
      <p id="board-desc" class="board-desc"></p>
    </div>

    <div class="board-actions" id="board-actions" hidden>
      <button type="button" class="btn-write" id="write-btn">글쓰기</button>
    </div>

    <div id="posts-content">
      <p class="loading-msg">불러오는 중...</p>
    </div>

    <div id="pagination" class="pagination" hidden></div>
  </div>
</BaseLayout>

<style>
  .board-page {
    max-width: 480px;
    margin: 0 auto;
  }

  .board-header {
    padding: 1.5rem 0 1rem;
  }

  .board-back {
    font-size: 0.82rem;
    color: var(--text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .board-back:hover {
    color: var(--text-sub);
  }

  .board-header h1 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.15rem;
  }

  .board-desc {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  .board-actions {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 1rem;
  }

  .btn-write {
    padding: 0.5rem 1rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .btn-write:hover {
    opacity: 0.85;
  }

  .loading-msg {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    padding: 2rem;
  }

  .pagination {
    display: flex;
    justify-content: center;
    gap: 0.35rem;
    padding: 1.5rem 0;
  }
</style>

<style is:global>
  .post-list {
    border-top: 2px solid var(--text-heading);
  }

  .post-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 0.5rem;
    border-bottom: 1px solid var(--border-light);
    text-decoration: none;
    color: inherit;
    transition: background 0.1s;
  }

  .post-item:hover {
    background: var(--bg-hover);
  }

  .post-item-likes {
    min-width: 28px;
    text-align: center;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--text-muted);
    flex-shrink: 0;
  }

  .post-item-likes.has-likes {
    color: #dc2626;
  }

  .post-item-body {
    flex: 1;
    min-width: 0;
  }

  .post-item-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-heading);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .post-item-title .comment-count {
    color: #dc2626;
    font-size: 0.78rem;
    font-weight: 600;
    margin-left: 0.3rem;
  }

  .post-item-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-top: 0.15rem;
  }

  .posts-empty {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    padding: 3rem 1rem;
  }

  .page-btn {
    padding: 0.35rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-card);
    color: var(--text-sub);
    font-size: 0.8rem;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }

  .page-btn:hover {
    background: var(--bg-hover);
  }

  .page-btn.active {
    background: var(--text-heading);
    color: var(--bg);
    border-color: var(--text-heading);
    font-weight: 600;
  }
</style>

<script>
  import { fetchBoards, fetchPosts, fetchCurrentUser } from '@/lib/api';
  import type { BoardListItem, PaginatedPosts } from '@/lib/api';
  import { formatDate } from '@repo/utils';

  function initBoardPage() {
    const content = document.getElementById('posts-content');
    const boardTitle = document.getElementById('board-title');
    const boardDesc = document.getElementById('board-desc');
    const boardActions = document.getElementById('board-actions');
    const writeBtn = document.getElementById('write-btn');
    const pagination = document.getElementById('pagination');
    if (!content || !boardTitle || !boardDesc || !boardActions || !writeBtn || !pagination) return;

    const pathParts = location.pathname.split('/').filter(Boolean);
    const slug = decodeURIComponent(pathParts[1] || '');
    if (!slug) return;

    let currentPage = 1;
    const pageSize = 20;

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    async function init() {
      // Load board info
      const boards = await fetchBoards();
      const board = boards.find((b: BoardListItem) => b.slug === slug);
      if (board) {
        boardTitle.textContent = board.name;
        document.title = `${board.name} — 커뮤니티 | 무모한 시식가`;
        if (board.description) boardDesc.textContent = board.description;
      }

      // Show write button for logged-in users
      const user = await fetchCurrentUser();
      if (user) {
        boardActions.hidden = false;
        writeBtn.addEventListener('click', () => {
          location.href = `/community/${encodeURIComponent(slug)}/write`;
        });
      }

      await loadPosts();
    }

    async function loadPosts() {
      content.innerHTML = '<p class="loading-msg">불러오는 중...</p>';
      let result: PaginatedPosts;
      try {
        result = await fetchPosts(slug, currentPage, pageSize);
      } catch {
        content.innerHTML = '<p class="posts-empty">게시글을 불러올 수 없습니다.</p>';
        pagination.hidden = true;
        return;
      }

      const posts = result.items;
      if (posts.length === 0) {
        content.innerHTML = '<p class="posts-empty">아직 작성된 글이 없습니다.</p>';
        pagination.hidden = true;
        return;
      }

      content.innerHTML = `<div class="post-list">${posts.map((post) => {
        const commentCount = post._count?.comments ?? 0;
        const likeCount = post._count?.likes ?? 0;
        return `
          <a href="/community/${encodeURIComponent(slug)}/${post.id}" class="post-item">
            <span class="post-item-likes${likeCount > 0 ? ' has-likes' : ''}">${likeCount || '0'}</span>
            <div class="post-item-body">
              <div class="post-item-title">${escapeHtml(post.title)}${commentCount > 0 ? `<span class="comment-count">${commentCount}</span>` : ''}</div>
              <div class="post-item-meta">
                <span>${escapeHtml(post.author.nickname)}</span>
                <span>${formatDate(post.createdAt)}</span>
              </div>
            </div>
          </a>
        `;
      }).join('')}</div>`;

      // Render pagination
      const totalPages = result.totalPages;
      if (totalPages > 1) {
        pagination.hidden = false;
        pagination.innerHTML = '';
        for (let i = 1; i <= totalPages; i++) {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = `page-btn${i === currentPage ? ' active' : ''}`;
          btn.textContent = String(i);
          btn.addEventListener('click', () => {
            currentPage = i;
            loadPosts();
            window.scrollTo({ top: 0, behavior: 'smooth' });
          });
          pagination.appendChild(btn);
        }
      } else {
        pagination.hidden = true;
      }
    }

    init();
  }

  document.addEventListener('astro:page-load', initBoardPage);
</script>
