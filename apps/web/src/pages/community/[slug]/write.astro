---
import BaseLayout from '@/layouts/BaseLayout.astro';
export const prerender = false;
---

<BaseLayout title="글쓰기 — 커뮤니티" noindex>
  <div class="write-page">
    <a href="#" class="write-back" id="write-back">&larr; 돌아가기</a>

    <h1 id="write-title">글쓰기</h1>

    <div id="write-content">
      <p class="loading-msg" id="write-loading">로딩 중...</p>

      <form id="write-form" class="write-form" hidden>
        <div class="form-group">
          <label for="post-title">제목</label>
          <input type="text" id="post-title" placeholder="제목을 입력하세요" maxlength="200" required />
        </div>
        <div class="form-group">
          <label for="post-content-input">내용</label>
          <textarea id="post-content-input" placeholder="내용을 입력하세요" maxlength="10000" required></textarea>
        </div>
        <button type="submit" class="submit-btn" id="submit-btn">등록</button>
      </form>

      <p id="write-login-msg" class="login-msg" hidden>로그인이 필요합니다.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .write-page {
    max-width: 480px;
    margin: 0 auto;
    padding-top: 1rem;
  }

  .write-back {
    font-size: 0.82rem;
    color: var(--text-muted);
    text-decoration: none;
    display: inline-block;
    margin-bottom: 1rem;
  }

  .write-back:hover {
    color: var(--text-sub);
  }

  h1 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 1.25rem;
  }

  .loading-msg {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    padding: 2rem;
  }

  .write-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-sub);
  }

  .form-group input,
  .form-group textarea {
    width: 100%;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border-mid);
    border-radius: 8px;
    font-size: 0.9rem;
    font-family: inherit;
    background: var(--bg-input, var(--bg));
    color: var(--text);
    box-sizing: border-box;
  }

  .form-group textarea {
    min-height: 200px;
    resize: vertical;
    line-height: 1.6;
  }

  .submit-btn {
    padding: 0.65rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .submit-btn:hover {
    opacity: 0.85;
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .login-msg {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
    padding: 3rem 1rem;
  }
</style>

<script>
  import { fetchCurrentUser, fetchPost, createPost, updatePost, showToast } from '@/lib/api';

  function initWritePage() {
    const writeBack = document.getElementById('write-back') as HTMLAnchorElement | null;
    const writeTitle = document.getElementById('write-title');
    const writeLoading = document.getElementById('write-loading');
    const writeForm = document.getElementById('write-form') as HTMLFormElement | null;
    const writeLoginMsg = document.getElementById('write-login-msg');
    const titleInput = document.getElementById('post-title') as HTMLInputElement | null;
    const contentInput = document.getElementById('post-content-input') as HTMLTextAreaElement | null;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    if (!writeBack || !writeTitle || !writeLoading || !writeForm || !writeLoginMsg || !titleInput || !contentInput || !submitBtn) return;

    const pathParts = location.pathname.split('/').filter(Boolean);
    // /community/slug/write
    const slug = decodeURIComponent(pathParts[1] || '');
    if (!slug) return;

    writeBack.href = `/community/${encodeURIComponent(slug)}`;

    const params = new URLSearchParams(location.search);
    const editPostId = params.get('edit');
    const isEdit = !!editPostId;

    if (isEdit) {
      writeTitle.textContent = '글 수정';
      submitBtn.textContent = '수정';
    }

    async function init() {
      const user = await fetchCurrentUser();
      if (!user) {
        writeLoading.hidden = true;
        writeLoginMsg.hidden = false;
        return;
      }

      if (isEdit && editPostId) {
        try {
          const post = await fetchPost(slug, editPostId);
          titleInput.value = post.title;
          contentInput.value = post.content;
        } catch {
          showToast('게시글을 불러올 수 없습니다.');
          location.href = `/community/${encodeURIComponent(slug)}`;
          return;
        }
      }

      writeLoading.hidden = true;
      writeForm.hidden = false;
    }

    writeForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const title = titleInput.value.trim();
      const content = contentInput.value.trim();
      if (!title || !content) {
        showToast('제목과 내용을 모두 입력해주세요.');
        return;
      }

      submitBtn.disabled = true;
      try {
        if (isEdit && editPostId) {
          const updated = await updatePost(slug, editPostId, { title, content });
          showToast('게시글이 수정되었습니다.');
          location.href = `/community/${encodeURIComponent(slug)}/${updated.id}`;
        } else {
          const created = await createPost(slug, title, content);
          showToast('게시글이 작성되었습니다.');
          location.href = `/community/${encodeURIComponent(slug)}/${created.id}`;
        }
      } catch (e) {
        showToast(e instanceof Error ? e.message : '저장에 실패했습니다.');
        submitBtn.disabled = false;
      }
    });

    init();
  }

  document.addEventListener('astro:page-load', initWritePage);
</script>
