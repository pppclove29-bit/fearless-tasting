---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSlot from '@/components/AdSlot.astro';
export const prerender = false;
---

<BaseLayout title="게시글 — 커뮤니티">
  <div class="post-page">
    <a href="#" class="back-link" id="post-back">&lt; 목록으로</a>

    <div class="post-more-dropdown" id="post-more-dropdown" hidden>
      <button type="button" class="dropdown-item" id="edit-post-btn">수정</button>
      <button type="button" class="dropdown-item dropdown-danger" id="delete-post-btn">삭제</button>
    </div>
    <button type="button" class="more-btn" id="post-more-btn" hidden aria-label="더보기">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
        <circle cx="12" cy="5" r="1.5"></circle>
        <circle cx="12" cy="12" r="1.5"></circle>
        <circle cx="12" cy="19" r="1.5"></circle>
      </svg>
    </button>

    <div id="post-content">
      <p class="loading-msg">불러오는 중...</p>
    </div>

    <AdSlot slot="community-post" position="bottom" format="horizontal" />
  </div>
</BaseLayout>

<style>
  .post-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
    position: relative;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 1.5rem;
  }
  .back-link:hover { color: var(--text); }

  .more-btn {
    position: absolute;
    top: 1.5rem;
    right: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    background: none;
    color: var(--text-muted);
    cursor: pointer;
    border-radius: 50%;
  }
  .more-btn:hover { background: var(--bg-hover); }

  .post-more-dropdown {
    position: absolute;
    top: 3.5rem;
    right: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    z-index: 20;
    overflow: hidden;
    min-width: 100px;
  }

  .dropdown-item {
    display: block;
    width: 100%;
    padding: 0.6rem 1rem;
    border: none;
    background: none;
    font-size: 0.85rem;
    font-family: inherit;
    color: var(--text-sub);
    cursor: pointer;
    text-align: left;
  }
  .dropdown-item:hover { background: var(--bg-hover); }
  .dropdown-danger { color: #dc2626; }

  .loading-msg {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    padding: 3rem 1rem;
  }
</style>

<style is:global>
  .post-detail-section {
    padding: 0;
  }

  .post-board-badge {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 500;
    color: var(--text-sub);
    border: 1px solid var(--border);
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    margin-right: 0.5rem;
    vertical-align: middle;
  }

  .post-detail-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.75rem;
    word-break: break-word;
    line-height: 1.4;
  }

  .post-meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--border);
  }

  .post-meta-left {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .post-meta-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .post-meta-right span {
    display: inline-flex;
    align-items: center;
    gap: 0.2rem;
  }

  .post-author-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .post-author-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--bg-hover);
    color: var(--text-sub);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 600;
    flex-shrink: 0;
  }

  .post-author-info {
    display: flex;
    flex-direction: column;
  }

  .post-author-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-heading);
  }

  .post-author-time {
    font-size: 0.72rem;
    color: var(--text-muted);
  }

  .post-detail-content {
    font-size: 0.9rem;
    color: var(--text-sub);
    line-height: 1.75;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .post-stats-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-bottom: 1rem;
  }

  .post-stat-item {
    display: flex;
    align-items: center;
  }

  .post-stat-icon {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .post-stats-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .post-stat {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .post-action-row {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  .post-action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg);
    color: var(--text-sub);
    font-size: 0.8rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
  }
  .post-action-btn:hover { background: var(--bg-hover); }
  .post-action-btn.active {
    background: var(--bg-hover);
    color: var(--text-heading);
    border-color: var(--text-muted);
  }

  .post-like-row {
    display: flex;
    justify-content: center;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--border);
  }

  .post-like-btn {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.35rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--bg);
    color: var(--text-sub);
    font-size: 0.8rem;
    font-family: inherit;
    cursor: pointer;
    transition: all 0.15s;
  }

  .post-like-btn:hover {
    background: var(--bg-hover);
  }

  .post-like-btn.liked {
    background: var(--bg-hover);
    color: var(--text-heading);
    border-color: var(--text-muted);
  }

  .post-like-static {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* Comments */
  .comments-section {
    padding: 0;
  }

  .comments-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .comments-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-heading);
  }

  .comment-write-area {
    background: var(--bg-hover);
    border-radius: 10px;
    padding: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .comment-textarea {
    width: 100%;
    min-height: 80px;
    border: none;
    background: none;
    font-size: 0.85rem;
    font-family: inherit;
    color: var(--text);
    outline: none;
    resize: none;
    box-sizing: border-box;
  }
  .comment-textarea::placeholder { color: var(--text-muted); }

  .comment-write-actions {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.5rem;
  }

  .comment-submit-btn {
    padding: 0.4rem 0.85rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
  }
  .comment-submit-btn:hover { opacity: 0.85; }

  .comment-item {
    display: flex;
    gap: 0.5rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid var(--border);
    align-items: flex-start;
  }

  .comment-like-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    margin-left: auto;
    flex-shrink: 0;
  }

  .comment-like-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0.2rem;
    transition: color 0.15s;
  }
  .comment-like-btn:hover { color: var(--text-heading); }

  .comment-like-count {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .comment-item:last-of-type {
    border-bottom: none;
  }

  .comment-avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--bg-hover);
    color: var(--text-sub);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    font-weight: 600;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .comment-body {
    flex: 1;
    min-width: 0;
  }

  .comment-top {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.15rem;
  }

  .comment-author {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-heading);
  }

  .comment-time {
    font-size: 0.7rem;
    color: var(--text-muted);
  }

  .comment-content {
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.5;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .comment-actions {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .comment-action-btn {
    padding: 0;
    background: none;
    border: none;
    font-size: 0.7rem;
    color: var(--text-muted);
    cursor: pointer;
    font-family: inherit;
    transition: color 0.15s;
  }

  .comment-action-btn:hover { color: var(--text-heading); }
  .comment-delete-btn:hover { color: #dc2626; }

  .comments-empty {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.82rem;
    padding: 1.5rem 0;
  }

  .post-error {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
    padding: 3rem 1rem;
  }

  .comment-login-msg {
    font-size: 0.82rem;
    color: var(--text-muted);
    text-align: center;
    padding: 1rem;
  }
</style>

<script>
  import { fetchBoards, fetchPost, deletePost, createComment, deleteComment, togglePostLike, toggleCommentLike, togglePostBookmark, fetchCurrentUser, showToast, showDangerConfirm } from '@/lib/api';
  import type { PostDetail, BoardListItem } from '@/lib/api';

  function initPostDetailPage() {
    const postContent = document.getElementById('post-content');
    const postBack = document.getElementById('post-back');
    const postMoreBtn = document.getElementById('post-more-btn');
    const postMoreDropdown = document.getElementById('post-more-dropdown');
    const editPostBtn = document.getElementById('edit-post-btn');
    const deletePostBtn = document.getElementById('delete-post-btn');
    if (!postContent || !postBack || !postMoreBtn || !postMoreDropdown || !editPostBtn || !deletePostBtn) return;

    const pathParts = location.pathname.split('/').filter(Boolean);
    const slug = decodeURIComponent(pathParts[1] || '');
    const postId = pathParts[2] || '';
    if (!slug || !postId) return;

    postBack.addEventListener('click', () => {
      if (history.length > 1) {
        history.back();
      } else {
        location.href = `/community/${encodeURIComponent(slug)}`;
      }
    });

    let dropdownOpen = false;
    postMoreBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdownOpen = !dropdownOpen;
      postMoreDropdown.hidden = !dropdownOpen;
    });

    document.addEventListener('click', () => {
      if (dropdownOpen) {
        dropdownOpen = false;
        postMoreDropdown.hidden = true;
      }
    });

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function relativeTime(dateStr: string): string {
      const now = Date.now();
      const then = new Date(dateStr).getTime();
      const diff = Math.floor((now - then) / 1000);
      if (diff < 60) return '방금 전';
      if (diff < 3600) return `${Math.floor(diff / 60)}분 전`;
      if (diff < 86400) return `${Math.floor(diff / 3600)}시간 전`;
      if (diff < 2592000) return `${Math.floor(diff / 86400)}일 전`;
      const d = new Date(dateStr);
      return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
    }

    function getInitial(nickname: string): string {
      return nickname.charAt(0).toUpperCase();
    }

    async function loadPost() {
      const user = await fetchCurrentUser();
      let post: PostDetail;
      try {
        post = await fetchPost(slug, postId);
      } catch {
        postContent.innerHTML = '<p class="post-error">게시글을 찾을 수 없습니다.</p>';
        return;
      }

      document.title = `${post.title} — 커뮤니티 | 무모한 시식가`;

      // Find board name
      let boardName = '';
      try {
        const boards: BoardListItem[] = await fetchBoards();
        const board = boards.find(b => b.slug === slug);
        if (board) boardName = board.name;
      } catch { /* ignore */ }

      const isAuthor = post.isAuthor || false;
      const isAdmin = user && user.role === 'admin';
      const canEdit = isAuthor;
      const canDelete = isAuthor || isAdmin;
      const likeCount = post._count?.likes ?? 0;

      if (canEdit || canDelete) {
        postMoreBtn.hidden = false;
      }
      if (!canEdit) editPostBtn.style.display = 'none';
      if (!canDelete) deletePostBtn.style.display = 'none';

      const commentCount = post.comments.length;
      const viewCount = post._count?.views ?? 0;

      let html = `<div class="post-detail-section">`;
      html += `
        <div class="post-title-row">
          ${boardName ? `<span class="post-board-badge">${escapeHtml(boardName)}</span>` : ''}
          <span class="post-detail-title">${escapeHtml(post.title)}</span>
        </div>
        <div class="post-meta-row">
          <div class="post-meta-left">
            <div class="post-author-avatar">${escapeHtml(getInitial(post.author.nickname))}</div>
            <span class="post-author-name">${escapeHtml(post.author.nickname)}</span>
            <span class="post-author-time">${relativeTime(post.createdAt)}${post.updatedAt !== post.createdAt ? ' (수정됨)' : ''}</span>
          </div>
          <div class="post-meta-right">
            <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> ${viewCount}</span>
            <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg> ${commentCount}</span>
            <span><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg> ${likeCount}</span>
          </div>
        </div>
        <div class="post-detail-content">${escapeHtml(post.content)}</div>
      </div>`;

      const bookmarkCount = post._count?.bookmarks ?? 0;
      const svgHeart = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>';
      const svgStar = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>';

      // 카운트 행 (조회/댓글/좋아요/북마크)
      html += `<div class="post-stats-row">
        <span class="post-stat"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> ${viewCount}</span>
        <span class="post-stat"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg> ${commentCount}</span>
        <span class="post-stat">${svgHeart} <span id="post-like-count">${likeCount}</span></span>
        <span class="post-stat">${svgStar} <span id="post-bookmark-count">${bookmarkCount}</span></span>
      </div>`;

      // 좋아요 + 북마크 액션 버튼
      if (user) {
        html += `<div class="post-action-row">
          <button type="button" class="post-action-btn" id="post-like-btn">${svgHeart} 좋아요</button>
          <button type="button" class="post-action-btn" id="post-bookmark-btn">${svgStar} 북마크</button>
        </div>`;
      }

      // 댓글 섹션
      html += `<div class="comments-section">`;
      html += `<div class="comments-header"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg> <span class="comments-title">댓글 ${commentCount}</span></div>`;

      // 댓글 입력 (로그인 시)
      if (user) {
        html += `<div class="comment-write-area">
          <textarea class="comment-textarea" id="comment-textarea" placeholder="댓글을 입력하세요" maxlength="1000"></textarea>
          <div class="comment-write-actions">
            <button type="button" class="comment-submit-btn" id="comment-submit-btn">댓글 작성</button>
          </div>
        </div>`;
      }

      if (post.comments.length > 0) {
        html += post.comments.map((comment) => {
          const canDeleteComment = user && (user.id === comment.author.id || user.role === 'admin');
          const commentLikeCount = comment._count?.likes ?? 0;
          return `
            <div class="comment-item">
              <div class="comment-avatar">${escapeHtml(getInitial(comment.author.nickname))}</div>
              <div class="comment-body">
                <div class="comment-top">
                  <span class="comment-author">${escapeHtml(comment.author.nickname)}</span>
                  <span class="comment-time">${relativeTime(comment.createdAt)}</span>
                </div>
                <div class="comment-content">${escapeHtml(comment.content)}</div>
                <div class="comment-actions">
                  ${canDeleteComment ? `<button type="button" class="comment-action-btn comment-delete-btn" data-comment-id="${comment.id}">삭제</button>` : ''}
                </div>
              </div>
              <div class="comment-like-wrap">
                ${user ? `<button type="button" class="comment-like-btn" data-comment-id="${comment.id}">${svgHeart}</button>` : ''}
                ${commentLikeCount > 0 ? `<span class="comment-like-count">${commentLikeCount}</span>` : ''}
              </div>
            </div>
          `;
        }).join('');
      }

      if (!user) {
        html += '<p class="comment-login-msg">댓글을 작성하려면 로그인이 필요합니다.</p>';
      }

      html += '</div>';
      postContent.innerHTML = html;

      // Edit/Delete handlers
      if (canEdit || canDelete) {
        editPostBtn.addEventListener('click', () => {
          postMoreDropdown.hidden = true;
          location.href = `/community/${encodeURIComponent(slug)}/write?edit=${postId}`;
        });
        deletePostBtn.addEventListener('click', async () => {
          postMoreDropdown.hidden = true;
          const confirmed = await showDangerConfirm('이 게시글을 삭제하시겠습니까?');
          if (!confirmed) return;
          try {
            await deletePost(slug, postId);
            showToast('게시글이 삭제되었습니다.');
            location.href = `/community/${encodeURIComponent(slug)}`;
          } catch (e) {
            showToast(e instanceof Error ? e.message : '삭제에 실패했습니다.');
          }
        });
      }

      // Post like (하트)
      document.getElementById('post-like-btn')?.addEventListener('click', async () => {
        try {
          const result = await togglePostLike(slug, postId);
          const countEl = document.getElementById('post-like-count');
          if (countEl) countEl.textContent = String(result.likeCount);
          const likeBtn = document.getElementById('post-like-btn');
          if (likeBtn) likeBtn.classList.toggle('active', result.liked);
        } catch (e) {
          showToast(e instanceof Error ? e.message : '좋아요에 실패했습니다.');
        }
      });

      // Post bookmark (별)
      document.getElementById('post-bookmark-btn')?.addEventListener('click', async () => {
        try {
          const result = await togglePostBookmark(slug, postId);
          const countEl = document.getElementById('post-bookmark-count');
          if (countEl) {
            const current = parseInt(countEl.textContent || '0', 10);
            countEl.textContent = String(result.bookmarked ? current + 1 : Math.max(0, current - 1));
          }
          const bookmarkBtn = document.getElementById('post-bookmark-btn');
          if (bookmarkBtn) bookmarkBtn.classList.toggle('active', result.bookmarked);
          showToast(result.bookmarked ? '북마크에 추가했습니다.' : '북마크를 해제했습니다.', 'success');
        } catch (e) {
          showToast(e instanceof Error ? e.message : '북마크에 실패했습니다.');
        }
      });

      // Comment likes (하트)
      for (const btn of postContent.querySelectorAll<HTMLButtonElement>('.comment-like-btn')) {
        btn.addEventListener('click', async () => {
          const commentId = btn.dataset.commentId;
          if (!commentId) return;
          try {
            await toggleCommentLike(slug, postId, commentId);
            await loadPost();
          } catch (e) {
            showToast(e instanceof Error ? e.message : '좋아요에 실패했습니다.');
          }
        });
      }

      // Comment delete
      for (const btn of postContent.querySelectorAll<HTMLButtonElement>('.comment-delete-btn')) {
        btn.addEventListener('click', async () => {
          const commentId = btn.dataset.commentId;
          if (!commentId) return;
          const confirmed = await showDangerConfirm('이 댓글을 삭제하시겠습니까?');
          if (!confirmed) return;
          try {
            await deleteComment(slug, postId, commentId);
            showToast('댓글이 삭제되었습니다.');
            await loadPost();
          } catch (e) {
            showToast(e instanceof Error ? e.message : '삭제에 실패했습니다.');
          }
        });
      }

      // 인라인 댓글 작성
      const commentSubmitBtn = document.getElementById('comment-submit-btn');
      const commentTextarea = document.getElementById('comment-textarea') as HTMLTextAreaElement | null;
      if (commentSubmitBtn && commentTextarea) {
        commentSubmitBtn.addEventListener('click', async () => {
          const text = commentTextarea.value.trim();
          if (!text) { showToast('댓글 내용을 입력해주세요.'); return; }
          commentSubmitBtn.setAttribute('disabled', 'true');
          try {
            await createComment(slug, postId, text);
            commentTextarea.value = '';
            showToast('댓글이 작성되었습니다.');
            await loadPost();
          } catch (e) {
            showToast(e instanceof Error ? e.message : '댓글 작성에 실패했습니다.');
          } finally {
            commentSubmitBtn.removeAttribute('disabled');
          }
        });
      }
    }

    loadPost();
  }

  document.addEventListener('astro:page-load', initPostDetailPage);
</script>
