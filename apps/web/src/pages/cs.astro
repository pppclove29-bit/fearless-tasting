---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="문의하기" description="지역 추가 요청, 버그 신고, 피드백 등 자유롭게 문의해 주세요">
  <slot name="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "name": "문의하기 - 무모한 시식가",
      "description": "지역 추가 요청, 버그 신고, 피드백 등 문의",
      "url": (Astro.site ?? Astro.url.origin) + "/cs",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "email": "pppclove29@naver.com",
        "availableLanguage": "Korean",
      },
    })} />
  </slot>
  <h1>문의하기</h1>
  <p class="page-desc">지역 추가 요청, 버그 신고, 피드백 등 자유롭게 문의해 주세요.</p>
  <p class="email-info">이메일로도 문의 가능합니다: <a href="mailto:pppclove29@naver.com">pppclove29@naver.com</a></p>

  <form id="inquiry-form" class="inquiry-form">
    <label for="category">문의 유형</label>
    <select id="category" name="category" required>
      <option value="">선택해 주세요</option>
      <option value="region_request">지역 추가 요청</option>
      <option value="bug_report">버그 신고</option>
      <option value="feedback">피드백</option>
      <option value="other">기타</option>
    </select>

    <label for="email">이메일</label>
    <input type="email" id="email" name="email" required placeholder="답변 받을 이메일 주소" />

    <label for="subject">제목</label>
    <input type="text" id="subject" name="subject" required placeholder="문의 제목" />

    <label for="content">내용</label>
    <textarea id="content" name="content" rows="6" required placeholder="문의 내용을 작성해 주세요."></textarea>

    <button type="submit" id="submit-btn">문의 보내기</button>
    <p id="result-msg" class="result-msg" hidden></p>
  </form>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 0.25rem;
    font-size: 1.4rem;
    color: var(--text-heading);
  }

  .page-desc {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  .email-info {
    font-size: 0.825rem;
    color: var(--text-sub);
    margin-bottom: 1.5rem;
  }

  .email-info a {
    color: var(--text-heading);
    font-weight: 500;
  }

  .inquiry-form {
    background: var(--bg-card);
    padding: 1.75rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 600px;
    margin: 0 auto;
  }

  label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-sub);
    margin-top: 0.5rem;
  }

  select,
  input,
  textarea {
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border-mid);
    border-radius: 8px;
    font-size: 0.875rem;
    font-family: inherit;
    transition: border-color 0.15s;
    background: var(--bg-input);
    color: var(--text);
  }

  select:focus,
  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--text-heading);
  }

  textarea {
    resize: vertical;
  }

  button[type="submit"] {
    margin-top: 1rem;
    padding: 0.7rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  button[type="submit"]:hover {
    background: var(--text-sub);
  }

  button[type="submit"]:disabled {
    background: var(--text-muted);
    cursor: not-allowed;
  }

  .result-msg {
    text-align: center;
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }

  .result-msg.success {
    color: #16a34a;
  }

  .result-msg.error {
    color: #dc2626;
  }
</style>

<script>
  import { createInquiry } from '@/lib/api';

  const form = document.getElementById('inquiry-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const resultMsg = document.getElementById('result-msg') as HTMLParagraphElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    resultMsg.hidden = true;

    const formData = new FormData(form);
    const category = formData.get('category') as string;
    const email = formData.get('email') as string;
    const subject = formData.get('subject') as string;
    const content = formData.get('content') as string;

    try {
      await createInquiry({ category, email, subject, content });
      resultMsg.textContent = '문의가 등록되었습니다. 감사합니다!';
      resultMsg.className = 'result-msg success';
      resultMsg.hidden = false;
      form.reset();
    } catch {
      resultMsg.textContent = '문의 등록에 실패했습니다. 잠시 후 다시 시도해 주세요.';
      resultMsg.className = 'result-msg error';
      resultMsg.hidden = false;
    } finally {
      submitBtn.disabled = false;
    }
  });
</script>
