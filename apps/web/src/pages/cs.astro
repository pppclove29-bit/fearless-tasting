---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="문의하기 — 무모한 시식가 고객센터" description="무모한 시식가 이용 중 궁금한 점이 있으시면 언제든 문의해 주세요. 기능 요청, 버그 신고, 피드백 등 빠르게 답변드립니다.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ContactPage",
      "name": "문의하기 - 무모한 시식가",
      "description": "기능 요청, 버그 신고, 피드백 등 문의",
      "url": (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '') + "/cs",
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "customer support",
        "email": "pppclove29@naver.com",
        "availableLanguage": "Korean",
      },
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '') },
        { "@type": "ListItem", "position": 2, "name": "문의하기", "item": (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '') + "/cs" },
      ]
    })} />
  </Fragment>

  <div class="cs-page">
    <section class="cs-hero">
      <span class="cs-badge">24시간 문의 가능</span>
      <h1>문의하기</h1>
      <p class="cs-desc">궁금하신 사항이 있으시면 언제든지 연락주세요</p>
    </section>

    <div class="cs-form-wrapper">
      <h2 class="form-title">문의 작성</h2>
      <form id="inquiry-form" class="inquiry-form">
        <div class="form-group">
          <label for="name">이름 *</label>
          <input type="text" id="name" name="name" required placeholder="홍길동" />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="email">이메일 *</label>
            <input type="email" id="email" name="email" required placeholder="example@email.com" />
          </div>
          <div class="form-group">
            <label for="phone">연락처</label>
            <input type="tel" id="phone" name="phone" placeholder="010-1234-5678" />
          </div>
        </div>

        <div class="form-group">
          <label for="subject">제목 *</label>
          <input type="text" id="subject" name="subject" required placeholder="문의 제목을 입력하세요" />
        </div>

        <div class="form-group">
          <label for="content">문의 내용 *</label>
          <textarea id="content" name="content" rows="6" required placeholder="문의하실 내용을 자세히 입력해주세요."></textarea>
        </div>

        <button type="submit" id="submit-btn" class="submit-btn">문의하기</button>
        <p id="result-msg" class="result-msg" hidden></p>
      </form>
    </div>

    <section class="cs-faq">
      <h2 class="faq-title">자주 묻는 질문</h2>
      <div class="faq-list">
        <div class="faq-item">
          <h3>무료인가요?</h3>
          <p>네, 모든 기능을 무료로 이용할 수 있습니다.</p>
        </div>
        <div class="faq-item">
          <h3>방에 몇 명까지 참여할 수 있나요?</h3>
          <p>한 방에 최대 4명까지 참여할 수 있습니다.</p>
        </div>
        <div class="faq-item">
          <h3>문의 답변은 얼마나 걸리나요?</h3>
          <p>보통 1~2일 내에 이메일로 답변드립니다.</p>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .cs-page {
    max-width: 720px;
    margin: 0 auto;
  }

  .cs-hero {
    text-align: center;
    padding: 2.5rem 0 1.5rem;
    background: var(--bg-hover);
    border-radius: 16px;
    margin-bottom: 2rem;
  }

  .cs-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 1rem;
    background: var(--accent-bg);
    color: var(--accent);
    border: 1px solid var(--accent);
    font-size: 0.78rem;
    font-weight: 600;
    border-radius: 100px;
    margin-bottom: 0.75rem;
    letter-spacing: 0.02em;
  }

  .cs-hero h1 {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--text-heading);
    margin-bottom: 0.4rem;
    letter-spacing: -0.03em;
  }

  .cs-desc {
    font-size: 0.9rem;
    color: var(--text-sub);
  }

  /* Form */
  .cs-form-wrapper {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.75rem;
    margin-bottom: 2rem;
  }

  .form-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 1.25rem;
  }

  .inquiry-form {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
  }

  @media (max-width: 480px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-sub);
  }

  input,
  textarea {
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 0.875rem;
    font-family: inherit;
    transition: border-color 0.15s;
    background: var(--bg-input);
    color: var(--text);
  }

  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--text-heading);
  }

  textarea {
    resize: vertical;
  }

  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 0.5rem;
    padding: 0.8rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.15s;
    font-family: inherit;
  }

  .submit-btn:hover { opacity: 0.85; }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .result-msg {
    text-align: center;
    font-size: 0.875rem;
    margin-top: 0.5rem;
  }

  .result-msg.success { color: #16a34a; }
  .result-msg.error { color: #dc2626; }

  /* FAQ */
  .cs-faq {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.75rem;
    margin-bottom: 1rem;
  }

  .faq-title {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text-heading);
    text-align: center;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .faq-item {
    background: var(--bg-hover);
    border-radius: 10px;
    padding: 1rem 1.25rem;
  }

  .faq-item h3 {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.3rem;
  }

  .faq-item p {
    font-size: 0.82rem;
    color: var(--text-sub);
    line-height: 1.6;
  }
</style>

<script>
  import { createInquiry } from '@/lib/api';

  function initCsPage() {
    const form = document.getElementById('inquiry-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const resultMsg = document.getElementById('result-msg') as HTMLParagraphElement | null;

    if (!form || !submitBtn || !resultMsg) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      resultMsg.hidden = true;

      const formData = new FormData(form);
      const email = formData.get('email') as string;
      const subject = formData.get('subject') as string;
      const content = formData.get('content') as string;
      const name = formData.get('name') as string;
      const phone = formData.get('phone') as string;

      const fullContent = `[이름: ${name}]${phone ? ` [연락처: ${phone}]` : ''}\n\n${content}`;

      try {
        await createInquiry({ category: 'feedback', email, subject, content: fullContent });
        resultMsg.textContent = '문의가 등록되었습니다. 감사합니다!';
        resultMsg.className = 'result-msg success';
        resultMsg.hidden = false;
        form.reset();
      } catch {
        resultMsg.textContent = '문의 등록에 실패했습니다. 잠시 후 다시 시도해 주세요.';
        resultMsg.className = 'result-msg error';
        resultMsg.hidden = false;
      } finally {
        submitBtn.disabled = false;
      }
    });
  }

  document.addEventListener('astro:page-load', initCsPage);
</script>
