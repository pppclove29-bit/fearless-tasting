---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="홈" description="둘만의 맛집 리스트를 만들고 공유하세요">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "한 방에 몇 명까지 참여할 수 있나요?",
        "acceptedAnswer": { "@type": "Answer", "text": "현재 한 방에 최대 4명까지 참여할 수 있습니다." }
      },
      {
        "@type": "Question",
        "name": "초대 코드는 어떻게 공유하나요?",
        "acceptedAnswer": { "@type": "Answer", "text": "방을 만들면 초대 코드가 자동으로 생성됩니다. 코드를 복사해서 카톡 등으로 상대방에게 보내주세요. 코드는 24시간 유효합니다." }
      },
      {
        "@type": "Question",
        "name": "공유 링크는 누구나 볼 수 있나요?",
        "acceptedAnswer": { "@type": "Answer", "text": "네, 공유 링크를 통해 비회원도 맛집 리스트를 열람할 수 있습니다. 단, 수정이나 리뷰 작성은 방 멤버만 가능합니다." }
      },
      {
        "@type": "Question",
        "name": "무모한 시식가는 무료인가요?",
        "acceptedAnswer": { "@type": "Answer", "text": "네, 무모한 시식가의 모든 기능은 무료로 이용할 수 있습니다. 카카오 계정으로 간편하게 가입하세요." }
      },
      {
        "@type": "Question",
        "name": "맛집 리뷰에 어떤 정보를 남길 수 있나요?",
        "acceptedAnswer": { "@type": "Answer", "text": "종합 별점(1~5), 세부 평점(맛, 가성비, 서비스, 청결, 접근성), 리뷰 본문, 재방문 의사, 또 먹고 싶은 메뉴, 다음에 시켜볼 메뉴 등을 기록할 수 있습니다." }
      }
    ]
  })} />

  <!-- 내 방 목록 (로그인 시) -->
  <div id="dashboard" hidden>
    <div class="dashboard-header">
      <div>
        <h1>내 방</h1>
        <p class="page-desc">방을 만들어 함께 맛집 리스트를 공유하세요.</p>
      </div>
    </div>

    <div class="rooms-actions">
      <form id="create-form" class="action-form">
        <div class="input-group">
          <input type="text" id="create-name" placeholder="방 이름을 입력하세요" required maxlength="100" />
          <button type="submit" class="btn-primary">만들기</button>
        </div>
      </form>
      <form id="join-form" class="action-form">
        <div class="input-group">
          <input type="text" id="join-code" placeholder="초대 코드 8자리" required maxlength="8" minlength="8" />
          <button type="submit" class="btn-outline">입장</button>
        </div>
      </form>
    </div>

    <div class="form-error" id="form-error" hidden></div>

    <div class="rooms-toolbar" id="rooms-toolbar" hidden>
      <span class="rooms-count" id="rooms-count"></span>
      <button type="button" class="sort-trigger" id="sort-trigger">
        <span id="sort-label">최근 참여순</span>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    <div id="rooms-list"></div>
    <p id="empty-msg" class="empty-state" hidden>
      <span class="empty-icon">🏠</span>
      <span class="empty-text">참여 중인 방이 없습니다</span>
      <span class="empty-sub">위에서 방을 만들거나 초대 코드로 입장하세요</span>
    </p>
  </div>

  <!-- 정렬 바텀시트 -->
  <div class="sheet-backdrop" id="sort-backdrop" hidden></div>
  <div class="sheet" id="sort-sheet" hidden>
    <div class="sheet-handle"></div>
    <div class="sheet-title">정렬</div>
    <div class="sheet-options" id="sort-options">
      <button type="button" class="sheet-option active" data-sort="recent">최근 참여순</button>
      <button type="button" class="sheet-option" data-sort="name">이름순</button>
      <button type="button" class="sheet-option" data-sort="members">멤버 많은순</button>
      <button type="button" class="sheet-option" data-sort="restaurants">식당 많은순</button>
    </div>
  </div>

  <!-- 랜딩 (비로그인 시 표시) -->
  <div id="landing" hidden>
    <section class="hero">
      <p class="hero-badge">맛집 공유 플랫폼</p>
      <h1 class="hero-title">둘만의<br/>맛집 리스트</h1>
      <p class="hero-sub">함께 다녀온 맛집을 기록하고,<br/>리뷰를 남기고, 링크 하나로 공유하세요.</p>
      <a href="/login" class="hero-cta login-only-cta">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="vertical-align: -3px; margin-right: 6px;">
          <path d="M9 1C4.58 1 1 3.8 1 7.2c0 2.2 1.47 4.13 3.68 5.22-.16.6-.59 2.17-.67 2.51-.1.42.15.41.32.3.13-.09 2.1-1.43 2.95-2.01.55.08 1.12.12 1.72.12 4.42 0 8-2.8 8-6.14S13.42 1 9 1z" fill="currentColor"/>
        </svg>
        카카오로 시작하기
      </a>
    </section>

    <section class="features">
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <h3>방 만들기</h3>
        <p>둘만의 맛집 방을 만들고 초대 코드로 상대방을 초대하세요.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </div>
        <h3>맛집 리뷰</h3>
        <p>다녀온 식당을 등록하고 별점과 함께 솔직한 리뷰를 남겨보세요.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
        </div>
        <h3>공유 링크</h3>
        <p>맛집 리스트를 공유 링크로 만들어 누구에게나 보여줄 수 있어요.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        </div>
        <h3>초대 코드</h3>
        <p>24시간 유효한 초대 코드로 원하는 사람만 방에 초대하세요.</p>
      </div>
    </section>

    <section class="recommend">
      <h2 class="section-title">이런 분들에게 추천해요</h2>
      <div class="recommend-list">
        <div class="recommend-item">
          <div class="recommend-icon-wrap">👫</div>
          <div>
            <h4>연인과 맛집을 기록하고 싶은 커플</h4>
            <p>함께 다녀온 맛집을 하나의 리스트로 관리하세요.</p>
          </div>
        </div>
        <div class="recommend-item">
          <div class="recommend-icon-wrap">👨‍👩‍👧‍👦</div>
          <div>
            <h4>가족끼리 맛집을 공유하고 싶은 분</h4>
            <p>부모님, 형제와 함께 우리 가족만의 맛집 지도를 만들어보세요.</p>
          </div>
        </div>
        <div class="recommend-item">
          <div class="recommend-icon-wrap">🍽️</div>
          <div>
            <h4>맛집 기록을 체계적으로 남기고 싶은 분</h4>
            <p>별점과 리뷰로 다녀온 식당을 깔끔하게 정리하세요.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="steps">
      <h2 class="section-title">이렇게 시작하세요</h2>
      <div class="steps-list">
        <div class="step">
          <span class="step-num">1</span>
          <div>
            <h4>카카오 로그인</h4>
            <p>카카오 계정으로 3초 만에 가입하세요.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div>
            <h4>방 만들기 또는 참여</h4>
            <p>새 방을 만들거나, 초대 코드로 기존 방에 참여하세요.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div>
            <h4>맛집 등록 & 리뷰</h4>
            <p>방문한 식당을 등록하고 별점과 리뷰를 남기세요.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">4</span>
          <div>
            <h4>공유하기</h4>
            <p>공유 링크를 만들어 누구나 볼 수 있게 하세요.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="faq">
      <h2 class="section-title">자주 묻는 질문</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>한 방에 몇 명까지 참여할 수 있나요?</summary>
          <p>현재 한 방에 최대 4명까지 참여할 수 있습니다.</p>
        </details>
        <details class="faq-item">
          <summary>초대 코드는 어떻게 공유하나요?</summary>
          <p>방을 만들면 초대 코드가 자동으로 생성됩니다. 코드를 복사해서 카톡 등으로 상대방에게 보내주세요. 코드는 24시간 유효합니다.</p>
        </details>
        <details class="faq-item">
          <summary>공유 링크는 누구나 볼 수 있나요?</summary>
          <p>네, 공유 링크를 통해 비회원도 맛집 리스트를 열람할 수 있습니다. 단, 수정이나 리뷰 작성은 방 멤버만 가능합니다.</p>
        </details>
        <details class="faq-item">
          <summary>무모한 시식가는 무료인가요?</summary>
          <p>네, 무모한 시식가의 모든 기능은 무료로 이용할 수 있습니다. 카카오 계정으로 간편하게 가입하세요.</p>
        </details>
        <details class="faq-item">
          <summary>맛집 리뷰에 어떤 정보를 남길 수 있나요?</summary>
          <p>종합 별점(1~5), 세부 평점(맛, 가성비, 서비스, 청결, 접근성), 리뷰 본문, 재방문 의사, 또 먹고 싶은 메뉴, 다음에 시켜볼 메뉴 등을 기록할 수 있습니다.</p>
        </details>
      </div>
    </section>

    <section class="platform-stats" id="platform-stats" hidden>
      <h2 class="section-title">지금까지의 기록</h2>
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number" id="stat-rooms">-</span>
          <span class="stat-label">개의 방</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" id="stat-users">-</span>
          <span class="stat-label">명의 시식가</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" id="stat-restaurants">-</span>
          <span class="stat-label">곳의 맛집</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" id="stat-reviews">-</span>
          <span class="stat-label">개의 리뷰</span>
        </div>
      </div>
    </section>

    <section class="bottom-cta">
      <p>지금 바로 시작해보세요.</p>
      <a href="/login" class="hero-cta login-only-cta">카카오로 시작하기</a>
      <a href="/cs" class="bottom-cta-link">문의하기</a>
    </section>
  </div>

  <!-- 로딩 -->
  <p id="loading-msg" class="status-msg">로딩 중...</p>
</BaseLayout>

<style>
  /* ─── 랜딩 ─── */
  .hero {
    text-align: center;
    padding: 5rem 1rem 3.5rem;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.35rem 0.9rem;
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-sub);
    margin-bottom: 1.25rem;
  }

  .hero-title {
    font-size: 2.8rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.2;
    margin-bottom: 1rem;
    color: var(--text-heading);
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--text-sub);
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2rem;
    background: #FEE500;
    color: #191919;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
  }

  .hero-cta:hover {
    background: #F5DC00;
  }

  .hero-cta:active {
    transform: scale(0.98);
  }

  .hero-cta[hidden] {
    display: none;
  }

  /* ─── 기능 소개 ─── */
  .features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    padding: 0 0 3.5rem;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.75rem 1.5rem;
  }

  .feature-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--text-heading);
    color: var(--bg);
    border-radius: 12px;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
    color: var(--text-heading);
  }

  .feature-card p {
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.55;
  }

  .section-title {
    text-align: center;
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: var(--text-heading);
  }

  /* ─── 추천 대상 ─── */
  .recommend {
    padding: 0 0 3.5rem;
  }

  .recommend-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 520px;
    margin: 0 auto;
  }

  .recommend-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem;
  }

  .recommend-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    min-width: 44px;
    background: var(--bg-hover);
    border-radius: 12px;
    font-size: 1.3rem;
  }

  .recommend-item h4 {
    font-size: 0.925rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: var(--text-heading);
  }

  .recommend-item p {
    font-size: 0.825rem;
    color: var(--text-sub);
    line-height: 1.5;
  }

  /* ─── 시작 스텝 ─── */
  .steps {
    padding: 0 0 3.5rem;
  }

  .steps-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem;
  }

  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    min-width: 32px;
    background: var(--text-heading);
    color: var(--bg);
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: 50%;
  }

  .step h4 {
    font-size: 0.925rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: var(--text-heading);
  }

  .step p {
    font-size: 0.825rem;
    color: var(--text-sub);
    line-height: 1.5;
  }

  /* ─── FAQ ─── */
  .faq {
    padding: 0 0 3.5rem;
  }

  .faq-list {
    max-width: 520px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .faq-item summary {
    padding: 1rem 1.25rem;
    font-size: 0.925rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-heading);
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--text-muted);
    transition: transform 0.2s;
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item p {
    padding: 0 1.25rem 1.1rem;
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.65;
  }

  /* ─── 플랫폼 통계 ─── */
  .platform-stats {
    padding: 0 0 3.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    max-width: 520px;
    margin: 0 auto;
  }

  .stat-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem 0.5rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--text-heading);
    margin-bottom: 0.2rem;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ─── 하단 CTA ─── */
  .bottom-cta {
