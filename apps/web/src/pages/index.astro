</style>

<style is:global>
  /* ─── 방 카드 ─── */
  .room-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 0.6rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.1s;
  }

  .room-card:hover {
    border-color: var(--border-mid);
  }

  .room-card:active {
    transform: scale(0.99);
  }

  .room-info {
    min-width: 0;
    flex: 1;
  }

  .room-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.2rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .room-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .room-right {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-left: 0.75rem;
    flex-shrink: 0;
  }

  .room-role {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 600;
    background: var(--bg-hover);
    color: var(--text-sub);
  }

  .room-role.owner { background: #fef3c7; color: #92400e; }
  .room-role.manager { background: #dbeafe; color: #1d4ed8; }

  .room-chevron {
    color: var(--text-muted);
    flex-shrink: 0;
  }

  /* ─── 바텀시트 ─── */
  .sheet-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 200;
    opacity: 0;
    transition: opacity 0.25s;
  }

  .sheet-backdrop.visible {
    opacity: 1;
  }

  .sheet {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: var(--bg-card);
    border-radius: 20px 20px 0 0;
    padding: 0.5rem 1.25rem 2rem;
    z-index: 201;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    max-height: 60vh;
    overflow-y: auto;
  }

  .sheet.visible {
    transform: translateY(0);
  }

  .sheet-handle {
    width: 36px;
    height: 4px;
    background: var(--border-mid);
    border-radius: 2px;
    margin: 0.5rem auto 1rem;
  }

  .sheet-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.75rem;
    padding: 0 0.25rem;
  }

  .sheet-options {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sheet-option {
    display: flex;
    align-items: center;
    width: 100%;
    padding: 0.85rem 0.75rem;
    background: none;
    border: none;
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-sub);
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    transition: background 0.15s;
  }

  .sheet-option:hover {
    background: var(--bg-hover);
  }

  .sheet-option.active {
    color: var(--text-heading);
    font-weight: 700;
    background: var(--bg-hover);
  }

  .sheet-option.active::before {
    content: '';
    display: inline-block;
    width: 6px;
    height: 6px;
    background: var(--text-heading);
    border-radius: 50%;
    margin-right: 0.6rem;
  }
</style>

<script>
  import { fetchCurrentUser, fetchMyRooms, createRoom, joinRoom, fetchPlatformStats } from '@/lib/api';
  import type { RoomListItem } from '@/lib/api';

  const landing = document.getElementById('landing')!;
  const dashboard = document.getElementById('dashboard')!;
  const loadingMsg = document.getElementById('loading-msg')!;
  const roomsList = document.getElementById('rooms-list')!;
  const emptyMsg = document.getElementById('empty-msg')!;
  const formError = document.getElementById('form-error')!;
  const createForm = document.getElementById('create-form') as HTMLFormElement;
  const createNameInput = document.getElementById('create-name') as HTMLInputElement;
  const joinForm = document.getElementById('join-form') as HTMLFormElement;
  const joinCodeInput = document.getElementById('join-code') as HTMLInputElement;

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  const roleLabel: Record<string, string> = {
    owner: '방장',
    manager: '매니저',
    member: '멤버',
  };

  const roomsToolbar = document.getElementById('rooms-toolbar')!;
  const roomsCount = document.getElementById('rooms-count')!;
  const sortTrigger = document.getElementById('sort-trigger')!;
  const sortLabel = document.getElementById('sort-label')!;
  const sortBackdrop = document.getElementById('sort-backdrop')!;
  const sortSheet = document.getElementById('sort-sheet')!;
  const sortOptions = document.getElementById('sort-options')!;

  let allRooms: RoomListItem[] = [];
  let currentSort = 'recent';

  const sortLabels: Record<string, string> = {
    recent: '최근 참여순',
    name: '이름순',
    members: '멤버 많은순',
    restaurants: '식당 많은순',
  };

  function sortRooms(rooms: RoomListItem[], sortBy: string): RoomListItem[] {
    const sorted = [...rooms];
    switch (sortBy) {
      case 'name': return sorted.sort((a, b) => a.name.localeCompare(b.name, 'ko'));
      case 'members': return sorted.sort((a, b) => b.memberCount - a.memberCount);
      case 'restaurants': return sorted.sort((a, b) => b.restaurantCount - a.restaurantCount);
      default: return sorted;
    }
  }

  function renderRooms(rooms: RoomListItem[]) {
    if (rooms.length === 0) {
      roomsList.innerHTML = '';
      roomsToolbar.hidden = true;
      emptyMsg.hidden = false;
      return;
    }

    emptyMsg.hidden = true;
    roomsToolbar.hidden = false;
    roomsCount.textContent = `${rooms.length}개의 방`;
    roomsList.innerHTML = rooms
      .map(
        (r) => `
        <a href="/room?id=${r.id}" class="room-card">
          <div class="room-info">
            <div class="room-name">${escapeHtml(r.name)}</div>
            <div class="room-meta">멤버 ${r.memberCount}명 · 식당 ${r.restaurantCount}개</div>
          </div>
          <div class="room-right">
            <span class="room-role ${r.myRole}">${roleLabel[r.myRole] || r.myRole}</span>
            <svg class="room-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
        </a>
      `,
      )
      .join('');
  }

  // 바텀시트 정렬
  function openSortSheet() {
    sortBackdrop.hidden = false;
    sortSheet.hidden = false;
    requestAnimationFrame(() => {
      sortBackdrop.classList.add('visible');
      sortSheet.classList.add('visible');
    });
  }

  function closeSortSheet() {
    sortBackdrop.classList.remove('visible');
    sortSheet.classList.remove('visible');
    setTimeout(() => {
      sortBackdrop.hidden = true;
      sortSheet.hidden = true;
    }, 300);
  }

  sortTrigger.addEventListener('click', openSortSheet);
  sortBackdrop.addEventListener('click', closeSortSheet);

  for (const btn of sortOptions.querySelectorAll<HTMLButtonElement>('.sheet-option')) {
    btn.addEventListener('click', () => {
      const value = btn.dataset.sort!;
      currentSort = value;
      sortLabel.textContent = sortLabels[value];

      for (const b of sortOptions.querySelectorAll('.sheet-option')) b.classList.remove('active');
      btn.classList.add('active');

      renderRooms(sortRooms(allRooms, currentSort));
      closeSortSheet();
    });
  }

  function showError(msg: string) {
    formError.textContent = msg;
    formError.hidden = false;
  }

  createForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.hidden = true;
    const name = createNameInput.value.trim();
    if (!name) return;

    try {
      await createRoom(name);
      createNameInput.value = '';
      allRooms = await fetchMyRooms();
      renderRooms(sortRooms(allRooms, currentSort));
    } catch (err) {
      showError(err instanceof Error ? err.message : '방 생성에 실패했습니다.');
    }
  });

  joinForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.hidden = true;
    const code = joinCodeInput.value.trim();
    if (!code) return;

    try {
      const room = await joinRoom(code);
      joinCodeInput.value = '';
      location.href = `/room?id=${room.id}`;
    } catch (err) {
      showError(err instanceof Error ? err.message : '입장에 실패했습니다.');
    }
  });

  // 플랫폼 통계 로드
  (async () => {
    try {
      const stats = await fetchPlatformStats();
      const fmt = (n: number) => n.toLocaleString('ko-KR');
      document.getElementById('stat-rooms')!.textContent = fmt(stats.roomCount);
      document.getElementById('stat-users')!.textContent = fmt(stats.userCount);
      document.getElementById('stat-restaurants')!.textContent = fmt(stats.restaurantCount);
      document.getElementById('stat-reviews')!.textContent = fmt(stats.reviewCount);
      document.getElementById('platform-stats')!.hidden = false;
    } catch { /* 통계 로드 실패 시 섹션 숨김 유지 */ }
  })();

  (async () => {
    const user = await fetchCurrentUser();
    loadingMsg.hidden = true;

    // 랜딩은 항상 표시
    landing.hidden = false;

    if (user) {
      // 로그인 시 대시보드 표시 + 로그인 CTA 숨김
      dashboard.hidden = false;
      for (const cta of document.querySelectorAll<HTMLElement>('.login-only-cta')) {
        cta.hidden = true;
      }
      allRooms = await fetchMyRooms();
      renderRooms(allRooms);
    }
  })();
</script>
