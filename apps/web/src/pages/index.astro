  /* ─── SEO 상세 ─── */
  .seo-detail {
    max-width: 640px;
    margin: 0 auto;
    padding: 2rem 0;
    border-top: 1px solid var(--border-light);
  }

  .seo-detail h2 {
    font-size: 1.15rem;
    font-weight: 700;
