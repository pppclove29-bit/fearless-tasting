    margin-bottom: 0.75rem;
  }

  .seo-detail h3 {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-heading);
    margin: 1.25rem 0 0.5rem;
  }

  .seo-detail p {
    font-size: 0.88rem;
    color: var(--text-sub);
    line-height: 1.7;
  }

  .seo-detail ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .seo-detail li {
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.5;
    padding-left: 1.1rem;
    position: relative;
  }

  .seo-detail li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--text-muted);
  }

  /* ─── 하단 CTA ─── */
  .bottom-cta {
    text-align: center;
    padding: 2rem 0 3rem;
  }

  .bottom-cta p {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-heading);
    margin-bottom: 1.25rem;
  }

  .bottom-cta-link {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .bottom-cta-link:hover {
    color: var(--text-heading);
  }

  @media (max-width: 600px) {
    .hero { padding: 2.5rem 1rem 2rem; }
    .hero-title { font-size: 2rem; }
    .hero-sub { font-size: 0.9rem; }
    .feature-card { padding: 1rem 1.25rem; }
  }

  /* ─── 대시보드 (방 목록) ─── */
  .dashboard-hero {
    background: var(--bg-hover);
    border-radius: 16px;
    padding: 2rem 1.5rem;
    margin-bottom: 1.25rem;
  }

  .dashboard-hero h1 {
    margin-bottom: 0.25rem;
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text-heading);
  }

  .page-desc {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .status-msg {
    text-align: center;
    padding: 2rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .rooms-actions {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .action-form {
    flex: 1;
    min-width: 0;
  }

  .input-group {
    display: flex;
    gap: 0.5rem;
  }

  .input-group input {
    flex: 1;
    min-width: 0;
    padding: 0.7rem 0.85rem;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 0.875rem;
    background: var(--bg-card);
    color: var(--text);
    font-family: inherit;
    transition: border-color 0.15s;
  }

  .input-group input:focus {
    outline: none;
    border-color: var(--text-heading);
  }

  .input-group input::placeholder {
    color: var(--text-muted);
  }

  .btn-primary {
    padding: 0.7rem 1.1rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 10px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
