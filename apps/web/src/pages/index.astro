---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="홈" description="둘만의 맛집 리스트를 만들고 공유하세요">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "한 방에 몇 명까지 참여할 수 있나요?",
        "acceptedAnswer": { "@type": "Answer", "text": "현재 한 방에 최대 4명까지 참여할 수 있습니다." }
      },
      {
        "@type": "Question",
        "name": "초대 코드는 어떻게 공유하나요?",
        "acceptedAnswer": { "@type": "Answer", "text": "방을 만들면 초대 코드가 자동으로 생성됩니다. 코드를 복사해서 카톡 등으로 상대방에게 보내주세요. 코드는 24시간 유효합니다." }
      },
      {
        "@type": "Question",
        "name": "공유 링크는 누구나 볼 수 있나요?",
        "acceptedAnswer": { "@type": "Answer", "text": "네, 공유 링크를 통해 비회원도 맛집 리스트를 열람할 수 있습니다. 단, 수정이나 리뷰 작성은 방 멤버만 가능합니다." }
      },
      {
        "@type": "Question",
        "name": "무모한 시식가는 무료인가요?",
        "acceptedAnswer": { "@type": "Answer", "text": "네, 무모한 시식가의 모든 기능은 무료로 이용할 수 있습니다. 카카오 계정으로 간편하게 가입하세요." }
      },
      {
        "@type": "Question",
        "name": "맛집 리뷰에 어떤 정보를 남길 수 있나요?",
        "acceptedAnswer": { "@type": "Answer", "text": "종합 별점(1~5), 세부 평점(맛, 가성비, 서비스, 청결, 접근성), 리뷰 본문, 재방문 의사, 또 먹고 싶은 메뉴, 다음에 시켜볼 메뉴 등을 기록할 수 있습니다." }
      }
    ]
  })} />

  <!-- 내 방 목록 (로그인 시) -->
  <div id="dashboard" hidden>
    <h1>내 방</h1>
    <p class="page-desc">방을 만들어 함께 맛집 리스트를 공유하세요.</p>

    <div class="rooms-actions">
      <form id="create-form" class="action-form">
        <input type="text" id="create-name" placeholder="방 이름" required maxlength="100" />
        <button type="submit" class="btn-primary">방 만들기</button>
      </form>
      <form id="join-form" class="action-form">
        <input type="text" id="join-code" placeholder="초대 코드 (8자)" required maxlength="8" minlength="8" />
        <button type="submit" class="btn-secondary">입장</button>
      </form>
    </div>

    <div class="form-error" id="form-error" hidden></div>

    <div class="rooms-sort-row" id="rooms-sort-row" hidden>
      <select id="rooms-sort">
        <option value="recent">최근 참여순</option>
        <option value="name">이름순</option>
        <option value="members">멤버 많은순</option>
        <option value="restaurants">식당 많은순</option>
      </select>
    </div>

    <div id="rooms-list"></div>
    <p id="empty-msg" class="status-msg" hidden>참여 중인 방이 없습니다. 방을 만들거나 초대 코드로 입장하세요.</p>
  </div>

  <!-- 랜딩 (항상 표시) -->
  <div id="landing" hidden>
    <section class="hero">
      <h1 class="hero-title">둘만의 맛집 리스트</h1>
      <p class="hero-sub">함께 다녀온 맛집을 기록하고, 리뷰를 남기고, 링크 하나로 공유하세요.</p>
      <a href="/login" class="hero-cta login-only-cta">카카오로 시작하기</a>
    </section>

    <section class="features">
      <div class="feature-card">
        <div class="feature-icon">🏠</div>
        <h3>방 만들기</h3>
        <p>둘만의 맛집 방을 만들고 초대 코드로 상대방을 초대하세요.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📝</div>
        <h3>맛집 리뷰</h3>
        <p>다녀온 식당을 등록하고 별점과 함께 솔직한 리뷰를 남겨보세요.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔗</div>
        <h3>공유 링크</h3>
        <p>맛집 리스트를 공유 링크로 만들어 누구에게나 보여줄 수 있어요.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔒</div>
        <h3>초대 코드</h3>
        <p>24시간 유효한 초대 코드로 원하는 사람만 방에 초대하세요.</p>
      </div>
    </section>

    <section class="recommend">
      <h2 class="section-title">이런 분들에게 추천해요</h2>
      <div class="recommend-list">
        <div class="recommend-item">
          <span class="recommend-icon">👫</span>
          <div>
            <h4>연인과 맛집을 기록하고 싶은 커플</h4>
            <p>함께 다녀온 맛집을 하나의 리스트로 관리하세요.</p>
          </div>
        </div>
        <div class="recommend-item">
          <span class="recommend-icon">👨‍👩‍👧‍👦</span>
          <div>
            <h4>가족끼리 맛집을 공유하고 싶은 분</h4>
            <p>부모님, 형제와 함께 우리 가족만의 맛집 지도를 만들어보세요.</p>
          </div>
        </div>
        <div class="recommend-item">
          <span class="recommend-icon">🍽️</span>
          <div>
            <h4>맛집 기록을 체계적으로 남기고 싶은 분</h4>
            <p>별점과 리뷰로 다녀온 식당을 깔끔하게 정리하세요.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="steps">
      <h2 class="section-title">이렇게 시작하세요</h2>
      <div class="steps-list">
        <div class="step">
          <span class="step-num">1</span>
          <div>
            <h4>카카오 로그인</h4>
            <p>카카오 계정으로 3초 만에 가입하세요.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div>
            <h4>방 만들기 또는 참여</h4>
            <p>새 방을 만들거나, 초대 코드로 기존 방에 참여하세요.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div>
            <h4>맛집 등록 & 리뷰</h4>
            <p>방문한 식당을 등록하고 별점과 리뷰를 남기세요.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">4</span>
          <div>
            <h4>공유하기</h4>
            <p>공유 링크를 만들어 누구나 볼 수 있게 하세요.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="faq">
      <h2 class="section-title">자주 묻는 질문</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>한 방에 몇 명까지 참여할 수 있나요?</summary>
          <p>현재 한 방에 최대 4명까지 참여할 수 있습니다.</p>
        </details>
        <details class="faq-item">
          <summary>초대 코드는 어떻게 공유하나요?</summary>
          <p>방을 만들면 초대 코드가 자동으로 생성됩니다. 코드를 복사해서 카톡 등으로 상대방에게 보내주세요. 코드는 24시간 유효합니다.</p>
        </details>
        <details class="faq-item">
          <summary>공유 링크는 누구나 볼 수 있나요?</summary>
          <p>네, 공유 링크를 통해 비회원도 맛집 리스트를 열람할 수 있습니다. 단, 수정이나 리뷰 작성은 방 멤버만 가능합니다.</p>
        </details>
        <details class="faq-item">
          <summary>무모한 시식가는 무료인가요?</summary>
          <p>네, 무모한 시식가의 모든 기능은 무료로 이용할 수 있습니다. 카카오 계정으로 간편하게 가입하세요.</p>
        </details>
        <details class="faq-item">
          <summary>맛집 리뷰에 어떤 정보를 남길 수 있나요?</summary>
          <p>종합 별점(1~5), 세부 평점(맛, 가성비, 서비스, 청결, 접근성), 리뷰 본문, 재방문 의사, 또 먹고 싶은 메뉴, 다음에 시켜볼 메뉴 등을 기록할 수 있습니다.</p>
        </details>
      </div>
    </section>

    <section class="platform-stats" id="platform-stats" hidden>
      <h2 class="section-title">지금까지의 기록</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-number" id="stat-rooms">-</span>
          <span class="stat-label">개의 방</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" id="stat-users">-</span>
          <span class="stat-label">명의 시식가</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" id="stat-restaurants">-</span>
          <span class="stat-label">곳의 맛집</span>
        </div>
        <div class="stat-card">
          <span class="stat-number" id="stat-reviews">-</span>
          <span class="stat-label">개의 리뷰</span>
        </div>
      </div>
    </section>

    <section class="bottom-cta">
      <p>지금 바로 시작해보세요.</p>
      <a href="/login" class="hero-cta login-only-cta">카카오로 시작하기</a>
      <a href="/cs" class="bottom-cta-link">문의하기</a>
    </section>
  </div>

  <!-- 로딩 -->
  <p id="loading-msg" class="status-msg">로딩 중...</p>
</BaseLayout>

<style>
  /* ─── 랜딩 ─── */
  .hero {
    text-align: center;
    padding: 4rem 1rem 3rem;
  }

  .hero-title {
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
    color: var(--text-heading);
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--text-sub);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .hero-cta {
    display: inline-block;
    padding: 0.85rem 2.5rem;
    background: #FEE500;
    color: #191919;
    font-size: 1rem;
    font-weight: 600;
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .hero-cta:hover {
    background: #F5DC00;
  }

  .hero-cta[hidden] {
    display: none;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    padding: 2rem 0 3rem;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.75rem 1.25rem;
    text-align: center;
  }

  .feature-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--text-heading);
  }

  .feature-card p {
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.5;
  }

  .section-title {
    text-align: center;
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--text-heading);
  }

  /* ─── 추천 대상 ─── */
  .recommend {
    padding: 0 0 3rem;
  }

  .recommend-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 520px;
    margin: 0 auto;
  }

  .recommend-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
  }

  .recommend-icon {
    font-size: 1.5rem;
    min-width: 32px;
    text-align: center;
  }

  .recommend-item h4 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
    color: var(--text-heading);
  }

  .recommend-item p {
    font-size: 0.85rem;
    color: var(--text-sub);
  }

  /* ─── 시작 스텝 ─── */
  .steps {
    padding: 0 0 3rem;
  }

  .steps-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem;
  }

  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    min-width: 32px;
    background: var(--text-heading);
    color: var(--bg);
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: 50%;
  }

  .step h4 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
    color: var(--text-heading);
  }

  .step p {
    font-size: 0.85rem;
    color: var(--text-sub);
  }

  /* ─── FAQ ─── */
  .faq {
    padding: 0 0 3rem;
  }

  .faq-list {
    max-width: 520px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .faq-item summary {
    padding: 1rem 1.25rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-heading);
  }

  .faq-item summary::after {
    content: '+';
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--text-muted);
    transition: transform 0.2s;
  }

  .faq-item[open] summary::after {
    content: '−';
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item p {
    padding: 0 1.25rem 1rem;
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.6;
  }

  /* ─── 플랫폼 통계 ─── */
  .platform-stats {
    padding: 0 0 3rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    max-width: 520px;
    margin: 0 auto;
  }

  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.25rem 0.5rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  @media (max-width: 480px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* ─── 하단 CTA ─── */
  .bottom-cta {
    text-align: center;
    padding: 2rem 0 3rem;
  }

  .bottom-cta p {
    font-size: 1rem;
    color: var(--text-sub);
    margin-bottom: 1rem;
  }

  .bottom-cta-link {
    display: block;
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    text-decoration: none;
  }

  .bottom-cta-link:hover {
    color: var(--text-heading);
  }

  @media (max-width: 600px) {
    .hero-title { font-size: 1.6rem; }
    .hero-sub { font-size: 0.9rem; }
    .features { grid-template-columns: 1fr; }
    .action-form { min-width: 100%; }
  }

  /* ─── 대시보드 (방 목록) ─── */
  h1 {
    margin-bottom: 0.25rem;
    font-size: 1.4rem;
    color: var(--text-heading);
  }

  .page-desc {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .status-msg {
    text-align: center;
    padding: 2rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .rooms-actions {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .action-form {
    display: flex;
    gap: 0.5rem;
    flex: 1;
    min-width: 240px;
  }

  .action-form input {
    flex: 1;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.875rem;
    background: var(--bg-input);
    color: var(--text);
    font-family: inherit;
  }

  .action-form input:focus {
    outline: none;
    border-color: var(--text-sub);
    box-shadow: 0 0 0 2px var(--shadow);
  }

  .action-form input::placeholder {
    color: var(--text-muted);
  }

  .btn-primary {
    padding: 0.6rem 1rem;
    background: var(--text-heading);
    color: var(--bg);
    border: none;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .btn-primary:hover { background: var(--text-sub); }

  .btn-secondary {
    padding: 0.6rem 1rem;
    background: var(--bg-card);
    color: var(--text-sub);
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.15s;
  }

  .btn-secondary:hover { background: var(--bg-hover); }

  .rooms-sort-row {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.75rem;
  }

  .rooms-sort-row select {
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.8rem;
    font-family: inherit;
    color: var(--text-sub);
    background: var(--bg-card);
    cursor: pointer;
  }

  .form-error {
    padding: 0.75rem;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 6px;
    color: #dc2626;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }

  [data-theme="dark"] .form-error {
    background: #451a1a;
    border-color: #7f1d1d;
    color: #fca5a5;
  }
</style>

<style is:global>
  .room-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    margin-bottom: 0.6rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .room-card:hover {
    border-color: var(--border-mid);
    box-shadow: 0 2px 8px var(--shadow);
  }

  .room-info { min-width: 0; }

  .room-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-heading);
    margin-bottom: 0.15rem;
  }

  .room-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .room-role {
    display: inline-block;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 600;
    background: var(--bg-hover);
    color: var(--text-sub);
    margin-left: 0.5rem;
  }

  .room-role.owner { background: #fef3c7; color: #92400e; }
  .room-role.manager { background: #dbeafe; color: #1d4ed8; }
</style>

<script>
  import { fetchCurrentUser, fetchMyRooms, createRoom, joinRoom, fetchPlatformStats } from '@/lib/api';
  import type { RoomListItem } from '@/lib/api';

  const landing = document.getElementById('landing')!;
  const dashboard = document.getElementById('dashboard')!;
  const loadingMsg = document.getElementById('loading-msg')!;
  const roomsList = document.getElementById('rooms-list')!;
  const emptyMsg = document.getElementById('empty-msg')!;
  const formError = document.getElementById('form-error')!;
  const createForm = document.getElementById('create-form') as HTMLFormElement;
  const createNameInput = document.getElementById('create-name') as HTMLInputElement;
  const joinForm = document.getElementById('join-form') as HTMLFormElement;
  const joinCodeInput = document.getElementById('join-code') as HTMLInputElement;

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  const roleLabel: Record<string, string> = {
    owner: '방장',
    manager: '매니저',
    member: '멤버',
  };

  const roomsSortRow = document.getElementById('rooms-sort-row')!;
  const roomsSortSelect = document.getElementById('rooms-sort') as HTMLSelectElement;
  let allRooms: RoomListItem[] = [];

  function sortRooms(rooms: RoomListItem[], sortBy: string): RoomListItem[] {
    const sorted = [...rooms];
    switch (sortBy) {
      case 'name': return sorted.sort((a, b) => a.name.localeCompare(b.name, 'ko'));
      case 'members': return sorted.sort((a, b) => b.memberCount - a.memberCount);
      case 'restaurants': return sorted.sort((a, b) => b.restaurantCount - a.restaurantCount);
      default: return sorted; // 'recent' — 서버에서 joinedAt desc로 정렬됨
    }
  }

  function renderRooms(rooms: RoomListItem[]) {
    if (rooms.length === 0) {
      roomsList.innerHTML = '';
      roomsSortRow.hidden = true;
      emptyMsg.hidden = false;
      return;
    }

    emptyMsg.hidden = true;
    roomsSortRow.hidden = rooms.length < 2;
    roomsList.innerHTML = rooms
      .map(
        (r) => `
        <a href="/room?id=${r.id}" class="room-card">
          <div class="room-info">
            <div class="room-name">${escapeHtml(r.name)}</div>
            <div class="room-meta">멤버 ${r.memberCount}명 · 식당 ${r.restaurantCount}개</div>
          </div>
          <span class="room-role ${r.myRole}">${roleLabel[r.myRole] || r.myRole}</span>
        </a>
      `,
      )
      .join('');
  }

  roomsSortSelect.addEventListener('change', () => {
    renderRooms(sortRooms(allRooms, roomsSortSelect.value));
  });

  function showError(msg: string) {
    formError.textContent = msg;
    formError.hidden = false;
  }

  createForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.hidden = true;
    const name = createNameInput.value.trim();
    if (!name) return;

    try {
      await createRoom(name);
      createNameInput.value = '';
      allRooms = await fetchMyRooms();
      renderRooms(sortRooms(allRooms, roomsSortSelect.value));
    } catch (err) {
      showError(err instanceof Error ? err.message : '방 생성에 실패했습니다.');
    }
  });

  joinForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.hidden = true;
    const code = joinCodeInput.value.trim();
    if (!code) return;

    try {
      const room = await joinRoom(code);
      joinCodeInput.value = '';
      location.href = `/room?id=${room.id}`;
    } catch (err) {
      showError(err instanceof Error ? err.message : '입장에 실패했습니다.');
    }
  });

  // 플랫폼 통계 로드 (비동기, 실패해도 무시)
  (async () => {
    try {
      const stats = await fetchPlatformStats();
      const fmt = (n: number) => n.toLocaleString('ko-KR');
      document.getElementById('stat-rooms')!.textContent = fmt(stats.roomCount);
      document.getElementById('stat-users')!.textContent = fmt(stats.userCount);
      document.getElementById('stat-restaurants')!.textContent = fmt(stats.restaurantCount);
      document.getElementById('stat-reviews')!.textContent = fmt(stats.reviewCount);
      document.getElementById('platform-stats')!.hidden = false;
    } catch { /* 통계 로드 실패 시 섹션 숨김 유지 */ }
  })();

  (async () => {
    const user = await fetchCurrentUser();
    loadingMsg.hidden = true;

    // 랜딩은 항상 표시
    landing.hidden = false;

    if (user) {
      // 로그인 시 대시보드 표시 + 로그인 CTA 숨김
      dashboard.hidden = false;
      for (const cta of document.querySelectorAll<HTMLElement>('.login-only-cta')) {
        cta.hidden = true;
      }
      allRooms = await fetchMyRooms();
      renderRooms(allRooms);
    }
  })();
</script>
