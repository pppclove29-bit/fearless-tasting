---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSlot from '@/components/AdSlot.astro';
---

<BaseLayout
  title="친구끼리 솔직한 맛집 리뷰 공유"
  description="친구, 연인, 가족끼리만 솔직한 맛집 후기를 공유하세요. 비공개 방에서 맛집 리스트 정리·방문 기록·평점 통계까지 무료."
  ogImageAlt="무모한 시식가 — 프라이빗 맛집 리뷰 공유 앱"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "홈", "item": (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '') }]
    })} />
  </Fragment>

  <!-- 공지사항 배너 -->
  <div id="notice-banner"></div>

  <!-- 내 방 목록 (로그인 시) -->
  <div id="dashboard" hidden>
    <div class="dashboard-hero">
      <h1>내 방</h1>
      <p class="page-desc">방을 만들어 함께 맛집 리스트를 공유하세요.</p>
    </div>

    <div class="rooms-actions">
      <form id="create-form" class="action-form">
        <div class="input-group">
          <input type="text" id="create-name" placeholder="방 이름을 입력하세요" required maxlength="100" />
          <button type="submit" class="btn-primary">만들기</button>
        </div>
        <div class="public-toggle-row">
          <label class="public-toggle-label">
            <input type="checkbox" id="create-public" />
            <span>공개 방으로 만들기</span>
          </label>
          <span class="public-help-trigger" id="public-help-btn">?</span>
        </div>
      </form>
    </div>

    <div class="form-error" id="form-error" hidden></div>

    <div class="rooms-toolbar" id="rooms-toolbar" hidden>
      <span class="rooms-count" id="rooms-count"></span>
    </div>

    <div id="rooms-list"></div>
    <p id="empty-msg" class="empty-state" hidden>
      <span class="empty-icon">🏠</span>
      <span class="empty-text">참여 중인 방이 없습니다</span>
      <span class="empty-sub">위에서 방을 만들거나 초대받은 방에 입장하세요</span>
    </p>
  </div>

  <!-- 랜딩 (기본 표시, 로그인 시 숨김) -->
  <div id="landing">
    <section class="hero">
      <p class="hero-badge">프라이빗 맛집 리뷰 공유 플랫폼</p>
      <h1 class="hero-title">우리만의<br/>맛집 리스트</h1>
      <p class="hero-sub">친구, 연인, 가족끼리 맛집을 기록하고 링크 하나로 공유하세요</p>
      <a href={`${import.meta.env.PUBLIC_API_URL || 'http://localhost:4000'}/auth/kakao`} class="hero-cta login-only-cta">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" style="vertical-align: -3px; margin-right: 6px;">
          <path d="M9 1C4.58 1 1 3.8 1 7.2c0 2.2 1.47 4.13 3.68 5.22-.16.6-.59 2.17-.67 2.51-.1.42.15.41.32.3.13-.09 2.1-1.43 2.95-2.01.55.08 1.12.12 1.72.12 4.42 0 8-2.8 8-6.14S13.42 1 9 1z" fill="currentColor"/>
        </svg>
        카카오로 시작하기
      </a>
    </section>

    <section class="features">
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <h3>프라이빗 맛집 방</h3>
        <p>비공개 맛집 방을 만들고 친구, 연인, 가족을 초대하세요.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        </div>
        <h3>솔직한 맛집 리뷰</h3>
        <p>다녀온 식당을 등록하고 별점 하나로 간편하게 솔직한 리뷰를 남겨보세요.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon-wrap">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h18v18H3z"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        </div>
        <h3>통계 & 분석</h3>
        <p>방문 통계, 카테고리 분포, 멤버 활동 분석으로 맛집 취향을 파악하세요.</p>
      </div>
    </section>

    <section class="recommend">
      <h2 class="section-title">이런 분들에게 추천해요</h2>
      <div class="recommend-list">
        <a href="/use/couples" class="recommend-item">
          <div class="recommend-icon-wrap">👫</div>
          <div>
            <h4>연인과 맛집을 기록하고 싶은 커플</h4>
            <p>함께 다녀온 맛집을 하나의 리스트로 관리해보세요.</p>
          </div>
        </a>
        <a href="/use/friends" class="recommend-item">
          <div class="recommend-icon-wrap">👨‍👩‍👧‍👦</div>
          <div>
            <h4>친구끼리 맛집을 공유하고 싶은 분</h4>
            <p>카톡에 묻히는 맛집, 한곳에 모아 함께 기록하세요.</p>
          </div>
        </a>
        <a href="/use/team" class="recommend-item">
          <div class="recommend-icon-wrap">🍽️</div>
          <div>
            <h4>회사 점심 맛집을 팀원들과 공유하고 싶은 분</h4>
            <p>팀 맛집 리스트를 만들어 점심 고민을 끝내보세요.</p>
          </div>
        </a>
      </div>
    </section>

    <section class="steps">
      <h2 class="section-title">이렇게 시작해보세요</h2>
      <div class="steps-list">
        <div class="step">
          <span class="step-num">1</span>
          <div>
            <h4>카카오 로그인</h4>
            <p>카카오 계정으로 3초 만에 가입해보세요.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <div>
            <h4>방 만들기 또는 참여</h4>
            <p>새 방을 만들거나, 기존 방에 참여해보세요.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <div>
            <h4>맛집 등록 & 리뷰</h4>
            <p>방문한 식당을 등록하고 별점과 리뷰를 남겨보세요.</p>
          </div>
        </div>
        <div class="step">
          <span class="step-num">4</span>
          <div>
            <h4>통계 확인</h4>
            <p>방문 통계와 멤버 분석으로 맛집 취향을 파악해보세요.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="faq">
      <h2 class="section-title">자주 묻는 질문</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>한 방에 몇 명까지 참여할 수 있나요?</summary>
          <p>현재 한 방에 최대 4명까지 참여할 수 있습니다.</p>
        </details>
        <details class="faq-item">
          <summary>친구를 어떻게 초대하나요?</summary>
          <p>방 상세 페이지에서 공유 버튼을 누르면 초대할 수 있습니다.</p>
        </details>
        <details class="faq-item">
          <summary>무모한 시식가는 무료인가요?</summary>
          <p>네, 무모한 시식가의 모든 기능은 무료로 이용할 수 있습니다. 카카오 계정으로 간편하게 가입하세요.</p>
        </details>
        <details class="faq-item">
          <summary>맛집 리뷰에 어떤 정보를 남길 수 있나요?</summary>
          <p>종합 별점(1~5점)만으로 간편하게 리뷰할 수 있습니다. 원하면 맛·가성비 세부 평점, 한줄평, 재방문 의사, 또 먹고 싶은 메뉴도 추가할 수 있습니다.</p>
        </details>
        <details class="faq-item">
          <summary>프라이빗 맛집 리뷰란 무엇인가요?</summary>
          <p>프라이빗 맛집 리뷰는 친구, 연인, 가족 등 가까운 사람들끼리만 비공개로 공유하는 맛집 리뷰입니다. 광고나 협찬 없이 신뢰할 수 있는 솔직한 후기를 기록할 수 있습니다.</p>
        </details>
        <details class="faq-item">
          <summary>커플 맛집 기록은 어떻게 하나요?</summary>
          <p>방을 만들고 연인을 초대하세요. 함께 다녀온 맛집을 등록하고 각자 리뷰를 남기면, 커플만의 맛집 리스트가 완성됩니다. 카카오맵 연동으로 식당을 쉽게 검색할 수 있습니다.</p>
        </details>
      </div>
    </section>

    <AdSlot slot="home-mid" position="middle" format="horizontal" />

    <section class="platform-stats" id="platform-stats" hidden>
      <h2 class="section-title">지금까지의 기록</h2>
      <div class="stats-grid">
        <div class="stat-item">
          <span class="stat-number" id="stat-rooms">-</span>
          <span class="stat-label">개의 방</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" id="stat-users">-</span>
          <span class="stat-label">명의 시식가</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" id="stat-restaurants">-</span>
          <span class="stat-label">곳의 맛집</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" id="stat-reviews">-</span>
          <span class="stat-label">개의 리뷰</span>
        </div>
      </div>
    </section>

    <section class="seo-detail">
      <h2>프라이빗 맛집 리뷰란?</h2>
      <p>
        맛집 리뷰 앱은 많지만, 광고나 협찬 리뷰가 섞여 신뢰하기 어렵습니다.
        무모한 시식가는 <strong>가까운 사람들끼리만 공유하는 프라이빗 맛집 리뷰 플랫폼</strong>입니다.
        커플 맛집 기록, 가족 맛집 공유, 친구끼리 맛집 리스트 관리에 최적화되어 있습니다.
      </p>
      <h3>이런 용도로 사용하세요</h3>
      <ul>
        <li><a href="/use/couples"><strong>커플 맛집 리스트 정리하는 방법</strong></a> — 연인과 함께 다녀온 맛집을 하나의 리스트로 관리</li>
        <li><a href="/use/friends"><strong>친구랑 맛집 공유 방법</strong></a> — 카톡에 묻히는 맛집 추천, 한곳에 모아 솔직한 리뷰 기록</li>
        <li><a href="/use/team"><strong>회사 점심 맛집 팀원들과 공유하기</strong></a> — 팀 맛집 리스트를 만들어 점심 고민 끝내기</li>
        <li><strong>맛집 기록 & 관리</strong> — 방문 기록, 별점, 세부 평점으로 체계적 관리</li>
        <li><strong>공개 방</strong> — 방을 공개로 설정하면 누구나 맛집 리스트를 열람 가능</li>
      </ul>
    </section>

    <section class="bottom-cta login-only-cta">
      <p>지금 바로 시작해보세요.</p>
      <a href={`${import.meta.env.PUBLIC_API_URL || 'http://localhost:4000'}/auth/kakao`} class="hero-cta">카카오로 시작하기</a>
      <a href="/cs" class="bottom-cta-link">문의하기</a>
    </section>
  </div>

  <!-- 로딩 (로그인 체크 중) -->
  <p id="loading-msg" class="status-msg" hidden></p>
</BaseLayout>

<style>
  /* ─── 공지 배너 ─── */
  #notice-banner:empty { display: none; }
</style>

<style is:global>
  .notice-list {
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 1rem;
    background: var(--bg-card);
  }

  .notice-list-header {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-sub);
    background: var(--bg-hover);
    border-bottom: 1px solid var(--border);
  }

  .notice-list-item {
    border-bottom: 1px solid var(--border-light, var(--border));
    cursor: pointer;
    transition: background 0.1s;
  }

  .notice-list-item:last-child { border-bottom: none; }
  .notice-list-item:hover { background: var(--bg-hover); }

  .notice-list-item-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.55rem 0.75rem;
    gap: 0.5rem;
  }

  .notice-list-item-title {
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--text);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .notice-list-item-date {
    font-size: 0.7rem;
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  .notice-list-item-content {
    padding: 0 0.75rem 0.6rem;
    font-size: 0.8rem;
    color: var(--text-sub);
    line-height: 1.5;
    white-space: pre-wrap;
  }

  .notice-list-item-content[hidden] { display: none; }
</style>

<style>
  /* ─── 랜딩 ─── */
  .hero {
    text-align: center;
    padding: 4rem 1.5rem 3rem;
    background: var(--bg-hover);
    border-radius: 16px;
    margin-bottom: 2rem;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.35rem 1rem;
    background: var(--text-heading);
    color: var(--bg);
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .hero-title {
    font-size: 2.8rem;
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1.15;
    margin-bottom: 1rem;
    color: var(--text-heading);
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--text-sub);
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.9rem 2rem;
    background: #FEE500;
    color: #191919;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 12px;
    text-decoration: none;
    transition: background 0.15s, transform 0.1s;
  }

  .hero-cta:hover {
    background: #F5DC00;
  }

  .hero-cta:active {
    transform: scale(0.98);
  }

  .hero-cta[hidden] {
    display: none;
  }

  /* ─── 기능 소개 ─── */
  .features {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0 0 3.5rem;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .feature-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    min-width: 44px;
    background: var(--text-heading);
    color: var(--bg);
    border-radius: 12px;
  }

  .feature-card h3 {
    font-size: 0.95rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: var(--text-heading);
  }

  .feature-card p {
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.55;
  }

  .section-title {
    text-align: center;
    font-size: 1.35rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
    color: var(--text-heading);
  }

  /* ─── 추천 대상 ─── */
  .recommend {
    padding: 0 0 3.5rem;
  }

  .recommend-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 520px;
    margin: 0 auto;
  }

  .recommend-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s;
  }

  .recommend-item:hover {
    border-color: var(--accent);
  }

  .recommend-icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    min-width: 44px;
    background: var(--bg-hover);
    border-radius: 12px;
    font-size: 1.3rem;
  }

  .recommend-item h4 {
    font-size: 0.925rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: var(--text-heading);
  }

  .recommend-item p {
    font-size: 0.825rem;
    color: var(--text-sub);
    line-height: 1.5;
  }

  /* ─── 시작 스텝 ─── */
  .steps {
    padding: 0 0 3.5rem;
  }

  .steps-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-width: 480px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.25rem;
  }

  .step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    min-width: 32px;
    background: var(--text-heading);
    color: var(--bg);
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: 50%;
  }

  .step h4 {
    font-size: 0.925rem;
    font-weight: 700;
    margin-bottom: 0.2rem;
    color: var(--text-heading);
  }

  .step p {
    font-size: 0.825rem;
    color: var(--text-sub);
    line-height: 1.5;
  }

  /* ─── FAQ ─── */
  .faq {
    padding: 0 0 3.5rem;
  }

  .faq-list {
    max-width: 520px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .faq-item {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .faq-item summary {
    padding: 1rem 1.25rem;
    font-size: 0.925rem;
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    display: flex;
