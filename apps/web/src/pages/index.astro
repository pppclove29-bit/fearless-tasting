</style>

<style is:global>
  /* ─── 방 카드 ─── */
  .room-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.1rem 1.25rem;
    margin-bottom: 0.6rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, transform 0.1s;
  }

  .room-card:hover {
    border-color: var(--border-mid);
  }

  .room-card:active {
    transform: scale(0.99);
  }

  .room-info {
    min-width: 0;
    flex: 1;
  }

  .room-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.2rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .room-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .room-right {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-left: 0.75rem;
    flex-shrink: 0;
  }

  .room-role {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 6px;
    font-size: 0.7rem;
    font-weight: 600;
    background: var(--bg-hover);
    color: var(--text-sub);
  }

  .room-role.owner { background: #fef3c7; color: #92400e; }
  .room-role.manager { background: #dbeafe; color: #1d4ed8; }

  .room-chevron {
    color: var(--text-muted);
    flex-shrink: 0;
  }

</style>

<script>
  import { fetchCurrentUser, getCachedUser, fetchMyRooms, createRoom, fetchPlatformStats, fetchNotices, showToast } from '@/lib/api';
  import type { RoomListItem } from '@/lib/api';
  import { formatDate } from '@repo/utils';

  async function initHomePage() {
    const landing = document.getElementById('landing');
    const dashboard = document.getElementById('dashboard');
    const roomsList = document.getElementById('rooms-list');
    if (!landing || !dashboard || !roomsList) return;

    // 공개 방 도움말 클릭
    document.getElementById('public-help-btn')?.addEventListener('click', () => {
      showToast('누구나 식당/리뷰를 볼 수 있는 방 (작성은 멤버만)');
    });

    // 캐시된 유저가 있으면 즉시 랜딩/로그인 버튼 숨김 (깜빡임 방지)
    const cached = getCachedUser();
    if (cached) {
      landing.hidden = true;
      dashboard.hidden = false;
      for (const cta of document.querySelectorAll<HTMLElement>('.login-only-cta')) {
        cta.hidden = true;
      }
    }

    const _loadingMsg = document.getElementById('loading-msg');
    const emptyMsg = document.getElementById('empty-msg');
    const formError = document.getElementById('form-error');
    const createForm = document.getElementById('create-form') as HTMLFormElement | null;
    const createNameInput = document.getElementById('create-name') as HTMLInputElement | null;
    const roomsToolbar = document.getElementById('rooms-toolbar');
    const roomsCount = document.getElementById('rooms-count');

    function escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    const roleLabel: Record<string, string> = {
      owner: '방장',
      manager: '매니저',
      member: '멤버',
    };

    let allRooms: RoomListItem[] = [];

    function applyAndRenderHome() {
      renderRooms(allRooms);
    }

    function renderRooms(rooms: RoomListItem[]) {
      if (rooms.length === 0) {
        roomsList.innerHTML = '';
        if (roomsToolbar) roomsToolbar.hidden = true;
        if (emptyMsg) emptyMsg.hidden = false;
        return;
      }

      if (emptyMsg) emptyMsg.hidden = true;
      if (roomsToolbar) roomsToolbar.hidden = false;
      if (roomsCount) roomsCount.textContent = `${rooms.length}개의 방`;
      roomsList.innerHTML = rooms
        .map(
          (r) => `
          <a href="/room?id=${r.id}" class="room-card">
            <div class="room-info">
              <div class="room-name">${escapeHtml(r.name)}</div>
              <div class="room-meta">멤버 ${r.memberCount}명 · 식당 ${r.restaurantCount}개</div>
            </div>
            <div class="room-right">
              <span class="room-role ${r.myRole}">${roleLabel[r.myRole] || r.myRole}</span>
              <svg class="room-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </a>
        `,
        )
        .join('');
    }

    function showError(msg: string) {
      if (formError) {
        formError.textContent = msg;
        formError.hidden = false;
      }
    }

    const createPublicCheckbox = document.getElementById('create-public') as HTMLInputElement | null;

    createForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (formError) formError.hidden = true;
      const name = createNameInput?.value.trim();
      if (!name) return;
      const isPublic = createPublicCheckbox?.checked ?? false;

      try {
        await createRoom(name, isPublic);
        if (createNameInput) createNameInput.value = '';
        if (createPublicCheckbox) createPublicCheckbox.checked = false;
        allRooms = await fetchMyRooms();
        applyAndRenderHome();
      } catch (err) {
        showError(err instanceof Error ? err.message : '방 생성에 실패했습니다.');
      }
    });

    // 유저/통계/공지 병렬 로드
    const [user, statsResult, noticesResult] = await Promise.all([
      fetchCurrentUser().catch(() => null),
      fetchPlatformStats().catch(() => null),
      fetchNotices().catch(() => null),
    ]);

    // 플랫폼 통계 렌더링
    if (statsResult) {
      const fmt = (n: number) => n.toLocaleString('ko-KR');
      const statRooms = document.getElementById('stat-rooms');
      const statUsers = document.getElementById('stat-users');
      const statRestaurants = document.getElementById('stat-restaurants');
      const statReviews = document.getElementById('stat-reviews');
      const platformStats = document.getElementById('platform-stats');
      if (statRooms) statRooms.textContent = fmt(statsResult.roomCount);
      if (statUsers) statUsers.textContent = fmt(statsResult.userCount);
      if (statRestaurants) statRestaurants.textContent = fmt(statsResult.restaurantCount);
      if (statReviews) statReviews.textContent = fmt(statsResult.reviewCount);
      if (platformStats) platformStats.hidden = false;
    }

    // 공지 리스트 렌더링
    if (noticesResult && noticesResult.length > 0) {
      const banner = document.getElementById('notice-banner');
      if (banner) {
        banner.innerHTML = `
          <div class="notice-list">
            <div class="notice-list-header">공지사항</div>
            ${noticesResult.map((n) => `
              <div class="notice-list-item">
                <div class="notice-list-item-header">
                  <span class="notice-list-item-title">${escapeHtml(n.title)}</span>
                  <span class="notice-list-item-date">${formatDate(n.createdAt)}</span>
                </div>
                <div class="notice-list-item-content" hidden>${escapeHtml(n.content)}</div>
              </div>
            `).join('')}
          </div>`;
        // 클릭 시 내용 펼치기/접기
        for (const item of banner.querySelectorAll<HTMLElement>('.notice-list-item')) {
          item.addEventListener('click', () => {
            const content = item.querySelector<HTMLElement>('.notice-list-item-content');
            if (content) content.hidden = !content.hidden;
          });
        }
      }
    }

    const loggedIn = user ?? cached;
    if (loggedIn) {
      landing.hidden = true;
      dashboard.hidden = false;
      for (const cta of document.querySelectorAll<HTMLElement>('.login-only-cta')) {
        cta.hidden = true;
      }
      try {
        allRooms = await fetchMyRooms();
      } catch {
        allRooms = [];
      }
      applyAndRenderHome();
    }
  }

  document.addEventListener('astro:page-load', initHomePage);
</script>
