---
import BaseLayout from '@/layouts/BaseLayout.astro';
const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';

const guides = [
  {
    href: '/guide/how-to-record',
    emoji: '📝',
    title: '맛집 기록 방법',
    desc: '방문·별점·세부 평점까지, 맛집리스트 정리 5단계',
  },
  {
    href: '/guide/restaurant-map-share',
    emoji: '🗺️',
    title: '맛집 공유지도 만드는 법',
    desc: '친구·연인과 함께 보고 함께 채우는 맛집 지도',
  },
  {
    href: '/guide/friends-restaurant-share',
    emoji: '👥',
    title: '친구끼리 맛집 공유하는 법',
    desc: '단톡방에 흩어진 맛집을 한 리스트로',
  },
  {
    href: '/guide/kakaomap-restaurant-list',
    emoji: '📍',
    title: '카카오맵 맛집 리스트 만들기',
    desc: '즐겨찾기에 없는 별점·리뷰·공유까지',
  },
  {
    href: '/guide/couple-restaurant-list',
    emoji: '💑',
    title: '커플 맛집 리스트 만들기',
    desc: '연인과 데이트 맛집을 함께 기록',
  },
  {
    href: '/guide/couple-app-comparison',
    emoji: '⚖️',
    title: '커플 맛집 앱 비교',
    desc: '어떤 방식이 우리에게 맞을까',
  },
  {
    href: '/guide/company-lunch-vote',
    emoji: '🗳️',
    title: '회식·점심 메뉴 투표',
    desc: '투표로 오늘 갈 곳 빠르게 정하기',
  },
];
---

<BaseLayout
  title="가이드 — 맛집 기록·공유 사용법 모음 | 무모한 시식가"
  description="맛집 기록 방법, 공유지도 만드는 법, 친구·커플과 맛집 공유, 카카오맵 리스트, 회식 투표까지. 무모한 시식가 사용법과 활용 가이드를 한곳에 모았습니다."
  ogImageAlt="무모한 시식가 가이드 모음"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "무모한 시식가 가이드",
      "description": "맛집 기록·공유 사용법과 활용 가이드 모음",
      "url": siteUrl + "/guide",
      "hasPart": guides.map((g) => ({
        "@type": "HowTo",
        "name": g.title,
        "url": siteUrl + g.href,
      })),
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "가이드", "item": siteUrl + "/guide" },
      ],
    })} />
  </Fragment>

  <div class="guide-page">
    <nav class="guide-breadcrumb">
      <a href="/">홈</a> &rsaquo; <span>가이드</span>
    </nav>

    <section class="guide-hero">
      <span class="guide-badge">가이드 · 사용법</span>
      <h1>맛집 기록·공유,<br/>어떻게 쓰는지 알려드려요</h1>
      <p class="guide-sub">
        처음이라면 <a href="/guide/how-to-record" class="guide-link">맛집 기록 방법</a>부터 보세요.
        아래에서 상황에 맞는 가이드를 골라 시작할 수 있습니다.
      </p>
    </section>

    <section class="guide-hub-grid">
      {guides.map((g) => (
        <a class="guide-hub-card" href={g.href}>
          <span class="guide-hub-emoji">{g.emoji}</span>
          <div>
            <div class="guide-hub-title">{g.title}</div>
            <div class="guide-hub-desc">{g.desc}</div>
          </div>
        </a>
      ))}
    </section>

    <section class="guide-section">
      <h2>바로 시작하기</h2>
      <p>
        가이드를 읽지 않아도 괜찮아요. 로그인하면 <a href="/use/templates" class="guide-link">템플릿</a>으로 방을 자동 세팅할 수 있고,
        다른 사람들의 <a href="/rooms/public" class="guide-link">공개 맛집 방</a>을 먼저 구경해볼 수도 있습니다.
      </p>
    </section>

    <section class="guide-cta">
      <h2>지금 바로 시작하기</h2>
      <p>카카오 로그인 3초면 첫 방을 만들 수 있어요.</p>
      <a href={`${apiUrl}/auth/kakao`} class="guide-cta-btn">무료로 시작하기</a>
    </section>
  </div>
</BaseLayout>

<style is:global>
  .guide-page { max-width: 720px; margin: 0 auto; padding: 0 1rem 3rem; }
  .guide-breadcrumb { font-size: 0.8rem; color: var(--text-muted); margin: 0.75rem 0 1rem; }
  .guide-breadcrumb a { color: inherit; text-decoration: none; }
  .guide-breadcrumb a:hover { color: var(--text-heading); }
  .guide-hero { text-align: center; padding: 2rem 0 1.5rem; }
  .guide-badge {
    display: inline-block; padding: 0.35rem 0.9rem; background: var(--text-heading);
    color: var(--bg); font-size: 0.75rem; font-weight: 700; border-radius: 100px; margin-bottom: 0.9rem;
  }
  .guide-hero h1 { font-size: 1.85rem; font-weight: 900; color: var(--text-heading); line-height: 1.3; letter-spacing: -0.03em; }
  .guide-sub { font-size: 0.95rem; color: var(--text-sub); line-height: 1.7; margin: 0.75rem 0 0; word-break: keep-all; }
  .guide-link { color: var(--text-heading); font-weight: 600; text-decoration: underline; }

  .guide-hub-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.6rem; margin-bottom: 1rem;
  }
  .guide-hub-card {
    display: flex; gap: 0.75rem; align-items: flex-start;
    background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px;
    padding: 1.1rem 1.2rem; text-decoration: none; color: inherit;
    transition: border-color 0.15s, transform 0.1s;
  }
  .guide-hub-card:hover { border-color: var(--border-mid); }
  .guide-hub-card:active { transform: scale(0.99); }
  .guide-hub-emoji { font-size: 1.4rem; line-height: 1; flex-shrink: 0; }
  .guide-hub-title { font-size: 0.95rem; font-weight: 700; color: var(--text-heading); margin-bottom: 0.2rem; }
  .guide-hub-desc { font-size: 0.82rem; color: var(--text-sub); line-height: 1.5; word-break: keep-all; }

  .guide-section { background: var(--bg-card); border: 1px solid var(--border); border-radius: 14px; padding: 1.5rem; margin-bottom: 1rem; }
  .guide-section h2 { font-size: 1.1rem; font-weight: 800; color: var(--text-heading); margin: 0 0 0.75rem; }
  .guide-section p { font-size: 0.92rem; color: var(--text-sub); line-height: 1.75; margin: 0; word-break: keep-all; }

  .guide-cta { text-align: center; padding: 2rem 1.5rem; background: var(--bg-card); border: 1px solid var(--text-heading); border-radius: 14px; margin-top: 1.5rem; }
  .guide-cta h2 { font-size: 1.15rem; font-weight: 800; color: var(--text-heading); margin: 0 0 0.35rem; }
  .guide-cta p { font-size: 0.88rem; color: var(--text-sub); margin: 0 0 1rem; }
  .guide-cta-btn { display: inline-block; padding: 0.8rem 2rem; background: #FEE500; color: #191919; font-weight: 700; font-size: 0.95rem; border-radius: 12px; text-decoration: none; }
  .guide-cta-btn:hover { background: #F5DC00; }
</style>
