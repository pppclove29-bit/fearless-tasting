---
import BaseLayout from '@/layouts/BaseLayout.astro';
const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';
---

<BaseLayout
  title="커플 맛집 리스트 만드는 법 | 데이트 맛집 기록 가이드"
  description="데이트 때마다 맛집 검색하는 거 이제 그만. 커플 둘이서 맛집 리스트를 함께 기록하고, 다녀온 곳을 지도에 저장하고, 서로의 평점을 비교하는 법을 정리했습니다."
  ogImageAlt="커플 맛집 리스트 만드는 법 — 데이트 맛집 기록 가이드"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "커플 맛집 리스트 만드는 법",
      "description": "커플이 함께 만드는 데이트 맛집 기록 플로우",
      "url": siteUrl + "/guide/couple-restaurant-list",
      "author": { "@type": "Organization", "name": "무모한 시식가" },
      "keywords": "커플 맛집 리스트, 데이트 맛집, 커플 맛집 공유, 데이트 맛집 기록, 둘이서 맛집 리스트",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "가이드", "item": siteUrl + "/guide/couple-restaurant-list" },
        { "@type": "ListItem", "position": 3, "name": "커플 맛집 리스트", "item": siteUrl + "/guide/couple-restaurant-list" },
      ]
    })} />
  </Fragment>

  <div class="guide-page">
    <nav class="guide-breadcrumb">
      <a href="/">홈</a> &rsaquo; <span>가이드</span> &rsaquo; <span>커플 맛집 리스트</span>
    </nav>

    <section class="guide-hero">
      <span class="guide-badge">커플 맛집 리스트 가이드</span>
      <h1>데이트 맛집,<br/>둘이서 같이 기록하세요</h1>
      <p class="guide-sub">
        데이트할 때마다 맛집 검색하고, 다녀온 건 또 까먹고. 커플 전용 맛집 방 하나만 있으면
        우리만의 맛집 지도가 자동으로 쌓입니다.
      </p>
    </section>

    <section class="guide-section">
      <h2>왜 커플끼리 맛집 기록이 필요할까</h2>
      <p>
        "저번에 갔던 그 집 이름 뭐였지?" — 커플이면 누구나 한 번쯤 겪는 대화입니다.
        각자 카카오맵 즐겨찾기·인스타 저장·블로그 스크랩에 분산돼 있으면 합칠 방법이 없어요.
      </p>
      <p>
        <strong>둘이서 공유하는 맛집 방</strong>을 만들면, 다녀온 순간 바로 기록되고,
        서로 별점이 어떻게 다른지 비교할 수 있고, 기념일에 "다시 가고 싶은 곳"을 바로 꺼내볼 수 있습니다.
      </p>
    </section>

    <section class="guide-section">
      <h2>커플 맛집 리스트 시작 4단계</h2>

      <div class="guide-step">
        <span class="guide-step-num">1</span>
        <div>
          <h3>"💑 데이트 맛집" 템플릿으로 방 만들기</h3>
          <p>
            <a href="/use/templates" class="guide-link">데이트 맛집 템플릿</a>을 선택하면
            위시리스트·지역·통계 탭이 기본으로 켜져서 바로 시작할 수 있습니다.
          </p>
        </div>
      </div>

      <div class="guide-step">
        <span class="guide-step-num">2</span>
        <div>
          <h3>상대에게 초대 링크 전송</h3>
          <p>
            카카오톡으로 링크 하나 보내면 끝. 상대가 링크 누르면 카카오 로그인 후 자동으로 방에 들어옵니다.
            각자 별도 회원가입 과정이 없어요.
          </p>
        </div>
      </div>

      <div class="guide-step">
        <span class="guide-step-num">3</span>
        <div>
          <h3>다녀오면 바로 등록</h3>
          <p>
            식사 후 카페에서 각자 별점·리뷰 남기는 시간 1분이면 충분합니다.
            "맛" "가성비" "분위기" 같은 세부 평점도 선택 사항이에요.
            "또 먹고 싶은 메뉴"를 메모해두면 재방문 시 바로 주문 가능.
          </p>
        </div>
      </div>

      <div class="guide-step">
        <span class="guide-step-num">4</span>
        <div>
          <h3>가고 싶은 곳은 위시리스트로</h3>
          <p>
            인스타에서 본 맛집, SNS에서 추천받은 곳을 위시리스트에 쌓아두세요.
            다음 데이트 장소 고를 때 "아직 안 가본 곳"부터 봅니다.
          </p>
        </div>
      </div>
    </section>

    <section class="guide-section">
      <h2>커플 맛집 방의 숨은 활용법</h2>

      <h3 style="font-size:0.95rem;font-weight:700;margin:0.75rem 0 0.4rem;color:var(--text-heading);">기념일 다시 방문</h3>
      <p>방문 기록이 쌓이면 통계 탭에서 "가장 별점 높은 식당" "가장 자주 간 곳"을 볼 수 있어요. 기념일에 어디 갈지 고민될 때 가장 확실한 추천 리스트가 됩니다.</p>

      <h3 style="font-size:0.95rem;font-weight:700;margin:0.75rem 0 0.4rem;color:var(--text-heading);">취향 비교</h3>
      <p>같은 식당에 서로 다른 별점을 남기면 "나는 이 집 좋았는데 상대는 별로였구나" 같은 취향 차이가 데이터로 보입니다. 재방문 판단이 쉬워지죠.</p>

      <h3 style="font-size:0.95rem;font-weight:700;margin:0.75rem 0 0.4rem;color:var(--text-heading);">여행·출장 기록</h3>
      <p>여행지에서 다녀온 맛집도 같은 방에 지역 태그로 쌓입니다. 몇 년 후에도 "부산 여행 때 그 돼지국밥집" 을 바로 찾을 수 있어요.</p>
    </section>

    <section class="guide-cta">
      <h2>우리 커플 맛집 방,<br/>지금 만들어보세요</h2>
      <p>카카오 로그인 3초면 시작. 상대에게 링크 하나 보내면 끝.</p>
      <a href={`${apiUrl}/auth/kakao`} class="guide-cta-btn">무료로 시작하기</a>
    </section>
  </div>
</BaseLayout>
