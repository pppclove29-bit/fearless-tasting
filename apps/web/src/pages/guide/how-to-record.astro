---
import BaseLayout from '@/layouts/BaseLayout.astro';
const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';
---

<BaseLayout
  title="맛집 기록 방법 완벽 가이드 | 맛집리스트 정리 5단계"
  description="다녀온 맛집, 그냥 넘기지 마세요. 방문 기록·별점·세부 평점·카테고리별 정리·공유까지 — 한 번 세팅하면 계속 쌓이는 나만의 맛집 리스트 만드는 5단계 방법."
  ogImageAlt="맛집 기록 방법 — 맛집리스트 정리 5단계 가이드"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "HowTo",
      "name": "맛집 기록 방법 — 맛집리스트 정리 5단계",
      "description": "다녀온 맛집을 체계적으로 기록하고 정리하는 가장 쉬운 방법",
      "url": siteUrl + "/guide/how-to-record",
      "step": [
        { "@type": "HowToStep", "name": "방 만들기", "text": "맛집 리스트를 담을 '방'을 만드세요. 템플릿으로 자동 세팅도 가능합니다." },
        { "@type": "HowToStep", "name": "식당 등록", "text": "카카오맵 검색 또는 직접 입력으로 다녀온 식당을 추가합니다." },
        { "@type": "HowToStep", "name": "방문 기록", "text": "언제, 누구와, 어떤 메뉴를 먹었는지 기록합니다." },
        { "@type": "HowToStep", "name": "별점·세부 평점", "text": "맛·가성비·서비스·청결·접근성 5개 축으로 리뷰를 남깁니다." },
        { "@type": "HowToStep", "name": "공유·활용", "text": "친구·연인에게 초대 링크로 공유하거나, 공개 방으로 전환해 누구나 볼 수 있게 합니다." }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "가이드", "item": siteUrl + "/guide/how-to-record" },
        { "@type": "ListItem", "position": 3, "name": "맛집 기록 방법", "item": siteUrl + "/guide/how-to-record" },
      ]
    })} />
  </Fragment>

  <div class="guide-page">
    <nav class="guide-breadcrumb">
      <a href="/">홈</a> &rsaquo; <span>가이드</span> &rsaquo; <span>맛집 기록 방법</span>
    </nav>

    <section class="guide-hero">
      <span class="guide-badge">맛집 기록 방법 완벽 가이드</span>
      <h1>다녀온 맛집,<br/>이제는 리스트로 남기세요</h1>
      <p class="guide-sub">
        "거기 이름이 뭐였지?" 매번 검색하던 맛집들, 한 번 세팅하면 계속 쌓입니다.
        무모한 시식가로 맛집리스트 정리하는 5단계를 정리했습니다.
      </p>
    </section>

    <section class="guide-section">
      <h2>맛집 기록, 왜 필요한가요?</h2>
      <p>
        네이버 블로그나 인스타 저장만 한 맛집은 시간이 지나면 이름조차 떠오르지 않습니다.
        카카오맵 "즐겨찾기"도 <strong>내가 실제로 맛있게 먹었는지</strong>는 알 수 없죠.
      </p>
      <p>
        맛집 기록의 핵심은 <strong>방문 경험을 데이터화</strong>하는 겁니다. 별점만 남겨도 6개월 뒤
        "4.5점 이상 한식집" 같은 조건으로 바로 꺼내볼 수 있습니다. 친구들과 함께 기록하면 취향이 겹치는
        맛집을 발견하기도 합니다.
      </p>
    </section>

    <section class="guide-section">
      <h2>5단계로 시작하는 맛집리스트 정리</h2>

      <div class="guide-step">
        <span class="guide-step-num">1</span>
        <div>
          <h3>방(room) 만들기</h3>
          <p>
            용도에 맞는 이름으로 방을 만듭니다. "우리 동네 맛집", "데이트 맛집", "회식 리스트" 같은 식으로요.
            <a href="/use/templates" class="guide-link">템플릿(회식/데이트/가족/친구 등 6종)</a>을 쓰면
            탭 구성과 기본 세팅이 자동으로 맞춰집니다.
          </p>
        </div>
      </div>

      <div class="guide-step">
        <span class="guide-step-num">2</span>
        <div>
          <h3>식당 등록 (카카오맵 or 직접 입력)</h3>
          <p>
            다녀온 식당을 검색으로 바로 추가하거나, 없으면 이름·주소·카테고리를 직접 입력합니다.
            "가고 싶은 식당"은 위시리스트로 따로 관리할 수 있어요.
          </p>
        </div>
      </div>

      <div class="guide-step">
        <span class="guide-step-num">3</span>
        <div>
          <h3>방문 기록 남기기</h3>
          <p>
            언제, 누구와 갔는지, 웨이팅은 있었는지, 배달/포장이었는지 같은 정보를 기록합니다.
            날짜를 정확히 기억 못 해도 "날짜 모름"으로 표시 가능합니다.
          </p>
        </div>
      </div>

      <div class="guide-step">
        <span class="guide-step-num">4</span>
        <div>
          <h3>별점·세부 평점·리뷰</h3>
          <p>
            전체 평점(0.5 단위 별점)과 함께 <strong>맛·가성비·서비스·청결·접근성</strong> 5개 세부 축으로 평가합니다.
            리뷰 본문은 선택이라, 별점만 남겨도 충분합니다. "또 먹고 싶은 메뉴"를 메모해두면
            다음에 갈 때 바로 뭘 시켜야 할지 알 수 있어요.
          </p>
        </div>
      </div>

      <div class="guide-step">
        <span class="guide-step-num">5</span>
        <div>
          <h3>공유하거나 공개 방으로 전환</h3>
          <p>
            친구·연인·가족에게 초대 링크를 보내 함께 기록할 수 있습니다. 내 방을 공개로 전환하면
            누구나 열람할 수 있는 "공개 맛집 방"이 됩니다 (멤버만 작성 가능).
          </p>
        </div>
      </div>
    </section>

    <section class="guide-section">
      <h2>자주 묻는 질문</h2>

      <details class="guide-faq">
        <summary>무료인가요?</summary>
        <p>네, 전 기능 무료입니다. 카카오/네이버 로그인 한 번이면 바로 시작할 수 있습니다.</p>
      </details>

      <details class="guide-faq">
        <summary>비공개로 우리끼리만 쓸 수 있나요?</summary>
        <p>기본이 비공개입니다. 초대 링크를 받은 사람만 방에 들어올 수 있습니다. 원할 때 공개 방으로 전환할 수 있고, 언제든 다시 비공개로 되돌릴 수 있습니다.</p>
      </details>

      <details class="guide-faq">
        <summary>리뷰 작성 없이 별점만 남겨도 되나요?</summary>
        <p>네, 별점만으로도 리뷰가 됩니다. 맛·가성비 같은 세부 평점도 선택 사항이에요.</p>
      </details>
    </section>

    <section class="guide-cta">
      <h2>지금 내 맛집리스트 시작하기</h2>
      <p>카카오 로그인 3초면 첫 방을 만들 수 있어요.</p>
      <a href={`${apiUrl}/auth/kakao`} class="guide-cta-btn">무료로 시작하기</a>
    </section>
  </div>
</BaseLayout>

<style is:global>
  .guide-page {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1rem 3rem;
  }

  .guide-breadcrumb {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0.75rem 0 1rem;
  }
  .guide-breadcrumb a { color: inherit; text-decoration: none; }
  .guide-breadcrumb a:hover { color: var(--text-heading); }

  .guide-hero {
    text-align: center;
    padding: 2rem 0 1.5rem;
  }

  .guide-badge {
    display: inline-block;
    padding: 0.35rem 0.9rem;
    background: var(--text-heading);
    color: var(--bg);
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 100px;
    margin-bottom: 0.9rem;
  }

  .guide-hero h1 {
    font-size: 1.85rem;
    font-weight: 900;
    color: var(--text-heading);
    line-height: 1.3;
    letter-spacing: -0.03em;
  }

  .guide-sub {
    font-size: 0.95rem;
    color: var(--text-sub);
    line-height: 1.7;
    margin: 0.75rem 0 0;
    word-break: keep-all;
  }

  .guide-section {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.5rem;
    margin-bottom: 1rem;
  }

  .guide-section h2 {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text-heading);
    margin: 0 0 0.75rem;
    letter-spacing: -0.01em;
  }

  .guide-section p {
    font-size: 0.92rem;
    color: var(--text-sub);
    line-height: 1.75;
    margin: 0 0 0.6rem;
    word-break: keep-all;
  }

  .guide-section p:last-child { margin-bottom: 0; }

  .guide-step {
    display: flex;
    gap: 0.85rem;
    align-items: flex-start;
    padding: 0.85rem;
    background: var(--bg-hover);
    border-radius: 10px;
    margin-top: 0.6rem;
  }

  .guide-step-num {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    background: var(--text-heading);
    color: var(--bg);
    font-size: 0.82rem;
    font-weight: 800;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .guide-step h3 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-heading);
    margin: 0 0 0.3rem;
  }

  .guide-step p {
    font-size: 0.85rem;
    line-height: 1.65;
    margin: 0;
  }

  .guide-link {
    color: var(--text-heading);
    font-weight: 600;
    text-decoration: underline;
  }

  .guide-faq {
    background: var(--bg-hover);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.7rem 0.9rem;
    margin-top: 0.5rem;
  }
  .guide-faq summary {
    cursor: pointer;
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-heading);
  }
  .guide-faq p {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
    color: var(--text-sub);
    line-height: 1.65;
  }

  .guide-cta {
    text-align: center;
    padding: 2rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--text-heading);
    border-radius: 14px;
    margin-top: 1.5rem;
  }
  .guide-cta h2 {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text-heading);
    margin: 0 0 0.35rem;
  }
  .guide-cta p {
    font-size: 0.88rem;
    color: var(--text-sub);
    margin: 0 0 1rem;
  }
  .guide-cta-btn {
    display: inline-block;
    padding: 0.8rem 2rem;
    background: #FEE500;
    color: #191919;
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 12px;
    text-decoration: none;
  }
  .guide-cta-btn:hover { background: #F5DC00; }
</style>
