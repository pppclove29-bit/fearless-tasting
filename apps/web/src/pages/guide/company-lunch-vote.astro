---
import BaseLayout from '@/layouts/BaseLayout.astro';
const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:4000';
---

<BaseLayout
  title="회사 점심 메뉴 투표 | 회식 장소 정하는 법 가이드"
  description="매번 '오늘 점심 뭐 먹지?'에 지친 팀을 위한 가이드. 회사 점심·회식 장소를 투표로 정하고, 다녀온 맛집은 팀 맛집 리스트로 쌓아가는 법을 정리했습니다."
  ogImageAlt="회사 점심 메뉴 투표 — 회식 장소 정하는 법 가이드"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "회사 점심 메뉴 투표 · 회식 장소 정하는 법",
      "description": "팀 맛집 방 + 투표 기능으로 점심·회식 장소를 정하는 플로우",
      "url": siteUrl + "/guide/company-lunch-vote",
      "author": { "@type": "Organization", "name": "무모한 시식가" },
      "keywords": "회사 점심 메뉴, 회식 장소, 점심 메뉴 투표, 팀 맛집 리스트, 회식 맛집",
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "홈", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "가이드", "item": siteUrl + "/guide/company-lunch-vote" },
        { "@type": "ListItem", "position": 3, "name": "회사 점심 메뉴 투표", "item": siteUrl + "/guide/company-lunch-vote" },
      ]
    })} />
  </Fragment>

  <div class="guide-page">
    <nav class="guide-breadcrumb">
      <a href="/">홈</a> &rsaquo; <span>가이드</span> &rsaquo; <span>회사 점심 메뉴 투표</span>
    </nav>

    <section class="guide-hero">
      <span class="guide-badge">회식·점심 장소 가이드</span>
      <h1>"오늘 뭐 먹지?"<br/>이제 투표로 5분 만에 결정</h1>
      <p class="guide-sub">
        매번 같은 사람이 점심 메뉴 정하고, 결국 어제 갔던 그 집에 다시 가는 팀이라면.
        투표 기능과 팀 맛집 방을 활용해 5분 안에 결정 나게 만드는 법을 정리했습니다.
      </p>
    </section>

    <section class="guide-section">
      <h2>팀에서 맛집 정할 때 흔한 문제</h2>
      <p>
        "점메추 부탁요" 같은 카톡이 매일 오후 11시 50분에 울립니다. 답 없는 대화를 30분 주고받다가
        결국 귀찮아서 어제 간 김밥집. 회식도 마찬가지예요. 막내가 리스트 검색하고, 단톡방에서
        10개쯤 던지고, 결정 안 나서 결국 한식집.
      </p>
      <p>
        문제는 <strong>선택지가 정리되어 있지 않다는 것</strong>과 <strong>의사결정 프로세스가 없다는 것</strong>입니다.
        팀 맛집 방 + 투표 기능이면 두 문제가 동시에 해결됩니다.
      </p>
    </section>

    <section class="guide-section">
      <h2>5분 점심 투표 만드는 법</h2>

      <div class="guide-step">
        <span class="guide-step-num">1</span>
        <div>
          <h3>"🍻 회식" 템플릿으로 방 만들기</h3>
          <p>
            <a href="/use/templates" class="guide-link">회식 맛집 템플릿</a>을 고르면 투표 탭이 자동 활성화되고,
            "🍜 오늘 뭐 먹지?" 투표까지 자동으로 생성됩니다 (한·중·일·양·분식·치킨).
          </p>
        </div>
      </div>

      <div class="guide-step">
        <span class="guide-step-num">2</span>
        <div>
          <h3>팀원 초대 링크 전송</h3>
          <p>
            슬랙·카톡·텔레그램 등에 초대 링크 한 번만 뿌리면 팀원 전체가 방에 들어옵니다.
            인원 제한은 최대 20명까지 가능해요.
          </p>
        </div>
      </div>

      <div class="guide-step">
        <span class="guide-step-num">3</span>
        <div>
          <h3>식당 기반 투표 만들기 (방 식당에서)</h3>
          <p>
            "🍽️ 방 식당에서 고르기" 템플릿을 선택하면 최근에 등록된 식당 6개로 투표가 바로 생성됩니다.
            이미 리뷰가 쌓여있어서 "어디 갈지"가 바로 결정 나죠.
          </p>
        </div>
      </div>

      <div class="guide-step">
        <span class="guide-step-num">4</span>
        <div>
          <h3>우승한 곳에 방문 기록 남기기</h3>
          <p>
            투표 마감 후 우승한 식당에 "방문 기록 남기기" 버튼이 나타납니다. 그대로 기록하면
            다음 투표 때 통계로 활용할 수 있어요 (재방문률·평균 별점 기반 추천).
          </p>
        </div>
      </div>
    </section>

    <section class="guide-section">
      <h2>회식 장소 결정에 쓰기 좋은 기능들</h2>

      <h3 style="font-size:0.95rem;font-weight:700;margin:0.75rem 0 0.4rem;color:var(--text-heading);">단체 웨이팅 있는 곳 표시</h3>
      <p>방문 기록에 웨이팅 시간을 체크할 수 있어서, 10명 이상 모이는 회식 때 "웨이팅 없는 곳"만 필터링 가능합니다.</p>

      <h3 style="font-size:0.95rem;font-weight:700;margin:0.75rem 0 0.4rem;color:var(--text-heading);">지역별·카테고리별 정리</h3>
      <p>지역 탭을 켜두면 시/구 단위로 식당이 자동 분류됩니다. "강남에서 4명 회식" 같은 조건 바로 찾기.</p>

      <h3 style="font-size:0.95rem;font-weight:700;margin:0.75rem 0 0.4rem;color:var(--text-heading);">비공개 방</h3>
      <p>팀 내부 정보만 남기고 싶으면 비공개로. 외부에 노출 안 됩니다. 필요하면 공개 방으로 전환도 가능.</p>
    </section>

    <section class="guide-cta">
      <h2>팀 맛집 방, 10분이면 세팅 끝</h2>
      <p>카카오 로그인 후 "회식" 템플릿 선택만 하면 됩니다.</p>
      <a href={`${apiUrl}/auth/kakao`} class="guide-cta-btn">무료로 시작하기</a>
    </section>
  </div>
</BaseLayout>
