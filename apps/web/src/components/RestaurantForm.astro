---
import { getProvinces, getCities, getNeighborhoods } from '@/data/areas';

const provinces = getProvinces();
---

<form id="restaurant-form" class="restaurant-form" novalidate>
  <div class="form-group">
    <label for="name">식당 이름 *</label>
    <input type="text" id="name" name="name" required placeholder="예: 맛있는 김치찌개" />
  </div>

  <div class="form-group">
    <label for="address">주소 *</label>
    <input type="text" id="address" name="address" required placeholder="예: 서울특별시 강남구 역삼동 123-45" />
  </div>

  <fieldset class="form-group area-group">
    <legend>지역 *</legend>
    <div class="area-selects">
      <div>
        <label for="province">시/도</label>
        <select id="province" name="province" required>
          <option value="">선택</option>
          {provinces.map((p) => <option value={p}>{p}</option>)}
        </select>
      </div>
      <div>
        <label for="city">시/군/구</label>
        <select id="city" name="city" required disabled>
          <option value="">시/도를 먼저 선택</option>
        </select>
      </div>
      <div>
        <label for="neighborhood">읍/면/동</label>
        <select id="neighborhood" name="neighborhood" required disabled>
          <option value="">시/군/구를 먼저 선택</option>
        </select>
      </div>
    </div>
  </fieldset>

  <div class="form-group">
    <label for="category">카테고리 *</label>
    <input type="text" id="category" name="category" required placeholder="예: 한식, 중식, 일식, 양식, 카페" />
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="latitude">위도 *</label>
      <input type="number" id="latitude" name="latitude" required step="any" placeholder="예: 37.5665" />
    </div>
    <div class="form-group">
      <label for="longitude">경도 *</label>
      <input type="number" id="longitude" name="longitude" required step="any" placeholder="예: 126.9780" />
    </div>
  </div>

  <div class="form-group">
    <label for="imageUrl">이미지 URL</label>
    <input type="url" id="imageUrl" name="imageUrl" placeholder="https://example.com/image.jpg" />
  </div>

  <hr class="form-divider" />

  <div class="form-group">
    <label for="rating">총점 *</label>
    <select id="rating" name="rating" required>
      <option value="">선택</option>
      <option value="5">5 - 최고</option>
      <option value="4">4 - 좋음</option>
      <option value="3">3 - 보통</option>
      <option value="2">2 - 별로</option>
      <option value="1">1 - 나쁨</option>
    </select>
  </div>

  <div class="form-group">
    <label for="content">한줄평 *</label>
    <input type="text" id="content" name="content" required maxlength="200" placeholder="이 식당에 대한 한줄평을 남겨주세요" />
  </div>

  <div class="form-error" id="form-error" hidden></div>
  <div class="form-success" id="form-success" hidden></div>

  <button type="submit" class="submit-btn" id="submit-btn">등록하기</button>
</form>

<style>
  .restaurant-form {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label,
  .area-group legend {
    font-size: 0.875rem;
    font-weight: 600;
    color: #333;
  }

  .area-group {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 1rem;
  }

  .area-group legend {
    padding: 0 0.5rem;
  }

  .area-selects {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .area-selects > div {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .area-selects label {
    font-size: 0.8rem;
    color: #666;
  }

  input, select {
    padding: 0.6rem 0.75rem;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    font-size: 0.9rem;
    transition: border-color 0.15s;
  }

  input:focus, select:focus {
    outline: none;
    border-color: #333;
    box-shadow: 0 0 0 2px rgba(0, 0, 0, 0.05);
  }

  select:disabled {
    background: #f5f5f5;
    color: #999;
    cursor: not-allowed;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-error {
    padding: 0.75rem;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: 6px;
    color: #dc2626;
    font-size: 0.875rem;
  }

  .form-success {
    padding: 0.75rem;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 6px;
    color: #16a34a;
    font-size: 0.875rem;
  }

  .submit-btn {
    padding: 0.75rem 1.5rem;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }

  .submit-btn:hover {
    background: #333;
  }

  .submit-btn:disabled {
    background: #999;
    cursor: not-allowed;
  }

  .form-divider {
    border: none;
    border-top: 1px solid #e0e0e0;
    margin: 0.5rem 0;
  }
</style>

<script>
  import { getCities, getNeighborhoods } from '@/data/areas';
  import { createRestaurant, findOrCreateUser, createReview } from '@/lib/api';

  const form = document.getElementById('restaurant-form') as HTMLFormElement;
  const provinceSelect = document.getElementById('province') as HTMLSelectElement;
  const citySelect = document.getElementById('city') as HTMLSelectElement;
  const neighborhoodSelect = document.getElementById('neighborhood') as HTMLSelectElement;
  const formError = document.getElementById('form-error')!;
  const formSuccess = document.getElementById('form-success')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  // 시/도 선택 → 시/군/구 옵션 업데이트
  provinceSelect.addEventListener('change', () => {
    const province = provinceSelect.value;
    citySelect.innerHTML = '<option value="">선택</option>';
    neighborhoodSelect.innerHTML = '<option value="">시/군/구를 먼저 선택</option>';
    neighborhoodSelect.disabled = true;

    if (!province) {
      citySelect.disabled = true;
      return;
    }

    const cities = getCities(province);
    for (const city of cities) {
      const opt = document.createElement('option');
      opt.value = city;
      opt.textContent = city;
      citySelect.appendChild(opt);
    }
    citySelect.disabled = false;
  });

  // 시/군/구 선택 → 읍/면/동 옵션 업데이트
  citySelect.addEventListener('change', () => {
    const province = provinceSelect.value;
    const city = citySelect.value;
    neighborhoodSelect.innerHTML = '<option value="">선택</option>';

    if (!city) {
      neighborhoodSelect.disabled = true;
      return;
    }

    const neighborhoods = getNeighborhoods(province, city);
    for (const n of neighborhoods) {
      const opt = document.createElement('option');
      opt.value = n;
      opt.textContent = n;
      neighborhoodSelect.appendChild(opt);
    }
    neighborhoodSelect.disabled = false;
  });

  // 폼 제출
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    formError.hidden = true;
    formSuccess.hidden = true;

    const formData = new FormData(form);
    const name = (formData.get('name') as string).trim();
    const address = (formData.get('address') as string).trim();
    const province = formData.get('province') as string;
    const city = formData.get('city') as string;
    const neighborhood = formData.get('neighborhood') as string;
    const category = (formData.get('category') as string).trim();
    const latitudeStr = formData.get('latitude') as string;
    const longitudeStr = formData.get('longitude') as string;
    const imageUrl = ((formData.get('imageUrl') as string) || '').trim() || undefined;
    const ratingStr = formData.get('rating') as string;
    const content = (formData.get('content') as string).trim();

    if (!name || !address || !province || !city || !neighborhood || !category || !latitudeStr || !longitudeStr || !ratingStr || !content) {
      formError.textContent = '필수 항목을 모두 입력해 주세요.';
      formError.hidden = false;
      return;
    }

    const latitude = parseFloat(latitudeStr);
    const longitude = parseFloat(longitudeStr);
    const rating = parseInt(ratingStr, 10);

    if (isNaN(latitude) || isNaN(longitude)) {
      formError.textContent = '위도/경도를 올바르게 입력해 주세요.';
      formError.hidden = false;
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = '등록 중...';

    try {
      // 1. 임시 익명 유저 생성 (추후 인증 시스템으로 대체)
      const user = await findOrCreateUser('익명');

      // 2. 식당 등록
      const restaurant = await createRestaurant({ name, address, province, city, neighborhood, latitude, longitude, category, imageUrl });

      // 3. 첫 리뷰 등록
      await createReview(restaurant.id, user.id, rating, content);

      formSuccess.textContent = '식당과 리뷰가 등록되었습니다! 잠시 후 해당 지역으로 이동합니다.';
      formSuccess.hidden = false;
      form.reset();
      citySelect.disabled = true;
      neighborhoodSelect.disabled = true;

      setTimeout(() => {
        const params = new URLSearchParams({ province, city, neighborhood });
        location.href = `/map?${params.toString()}`;
      }, 1500);
    } catch (err) {
      formError.textContent = err instanceof Error ? err.message : '등록에 실패했습니다.';
      formError.hidden = false;
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = '등록하기';
    }
  });
</script>
