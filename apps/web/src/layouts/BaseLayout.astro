---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '방 기반 맛집 리뷰 공유 플랫폼' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const fullTitle = `${title} | 무모한 시식가`;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="무모한 시식가" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="nav-brand">무모한 시식가</a>
        <div class="nav-links">
          <a href="/" class="nav-link">홈</a>
          <a href="/add" class="nav-link" id="add-link">등록</a>
          <a href="/rooms" class="nav-link">방</a>
          <a href="/cs" class="nav-link">문의</a>
          <a href="/about" class="nav-link">소개</a>
          <div class="nav-auth" id="auth-nav">
            <a href="/login" id="login-link" class="nav-link nav-login">로그인</a>
            <span id="user-info" hidden>
              <span id="user-email"></span>
              <button type="button" id="logout-btn">로그아웃</button>
            </span>
          </div>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; 2026 무모한 시식가 · <a href="/privacy">개인정보처리방침</a></p>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Noto Sans KR', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #f7f8fa;
    color: #1a1a1a;
    min-height: 100vh;
    line-height: 1.6;
  }

  header {
    background: #fff;
    border-bottom: 1px solid #e8e8e8;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 960px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
  }

  .nav-brand {
    font-size: 1.1rem;
    font-weight: 700;
    color: #111;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    white-space: nowrap;
  }

  .nav-link {
    padding: 0.45rem 0.85rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: #555;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .nav-link:hover {
    background: #f0f0f0;
    color: #111;
  }

  .nav-login {
    color: #fff;
    background: #111;
    margin-left: 0.5rem;
  }

  .nav-login:hover {
    background: #333;
    color: #fff;
  }

  .nav-auth {
    display: flex;
    align-items: center;
    margin-left: 0.5rem;
  }

  #user-info:not([hidden]) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
  }

  #user-email {
    color: #666;
    font-weight: 500;
  }

  #logout-btn {
    padding: 0.35rem 0.7rem;
    background: none;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    color: #555;
    transition: background 0.15s, border-color 0.15s;
  }

  #logout-btn:hover {
    background: #f0f0f0;
    border-color: #999;
  }

  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 3rem;
    min-height: calc(100vh - 130px);
  }

  @media (max-width: 600px) {
    .nav-brand {
      font-size: 0.95rem;
    }
    .nav-link {
      padding: 0.35rem 0.5rem;
      font-size: 0.75rem;
    }
    .nav-login {
      margin-left: 0.25rem;
    }
    nav {
      padding: 0.5rem 0.75rem;
    }
  }

  footer {
    border-top: 1px solid #e8e8e8;
    text-align: center;
    padding: 1.5rem;
    font-size: 0.8rem;
    color: #999;
    background: #fff;
  }

  footer a {
    color: #999;
    text-decoration: none;
  }

  footer a:hover {
    color: #555;
  }
</style>

<script>
  import { fetchCurrentUser, logout } from '@/lib/api';

  const loginLink = document.getElementById('login-link')!;
  const userInfo = document.getElementById('user-info')!;
  const userEmail = document.getElementById('user-email')!;
  const logoutBtn = document.getElementById('logout-btn')!;

  const user = await fetchCurrentUser();
  if (user) {
    loginLink.hidden = true;
    userInfo.hidden = false;
    userEmail.textContent = user.email;
  }

  logoutBtn.addEventListener('click', async () => {
    await logout();
    location.href = '/';
  });
</script>
