---
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
}

const {
  title,
  description = '친구, 연인, 가족과 함께 만드는 프라이빗 맛집 리뷰 플랫폼. 지금 무료로 시작하세요.',
  ogImage,
  ogImageAlt = '무모한 시식가 — 프라이빗 맛집 리뷰 공유 플랫폼',
  noindex = false,
} = Astro.props;
const siteOrigin = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const fullTitle = `${title} | 무모한 시식가`;
const resolvedOgImage = ogImage
  ? new URL(ogImage, siteOrigin).href
  : `${siteOrigin}/og-image.png`;
const kakaoLoginUrl = `${import.meta.env.PUBLIC_API_URL || 'http://localhost:4000'}/auth/kakao`;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="keywords" content="무모한시식가, 무모한 시식가, 프라이빗 맛집 리뷰, 맛집 공유 앱, 맛집 리스트 정리, 맛집 기록 앱, 솔직한 맛집 후기, 친구끼리 맛집 공유, 커플 맛집 기록, 가족 맛집 리스트, 맛집 추천, 맛집 리뷰 앱, 지인 추천 맛집, 맛집 지도 앱" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1'} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#111111" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="무모한 시식가" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="무모한 시식가" />

    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- JSON-LD: WebSite -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "무모한 시식가",
      "url": siteOrigin,
      "description": "친구, 연인, 가족끼리 프라이빗 맛집 리스트를 만들고 솔직한 리뷰를 공유하는 플랫폼",
      "inLanguage": "ko",
      "alternateName": ["무모한시식가", "Fearless Tasting"],
      "keywords": "맛집 공유, 맛집 리뷰, 프라이빗 맛집 리스트, 커플 맛집 기록, 음식 리뷰 공유",
      "publisher": {
        "@type": "Organization",
        "name": "무모한 시식가",
        "url": siteOrigin,
        "logo": { "@type": "ImageObject", "url": `${siteOrigin}/icons/icon-512.png` },
      },
    })} />
    <!-- JSON-LD: SoftwareApplication -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "무모한 시식가",
      "applicationCategory": "LifestyleApplication",
      "operatingSystem": "Web",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "KRW" },
      "description": "친구, 연인, 가족끼리 프라이빗 맛집 리스트를 만들고 솔직한 리뷰를 공유하는 무료 웹 앱",
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;600;700;800&display=swap" media="print" onload="this.media='all'" />
    {import.meta.env.PUBLIC_KAKAO_MAP_KEY && (
      <script defer type="text/javascript" src={`https://dapi.kakao.com/v2/maps/sdk.js?appkey=${import.meta.env.PUBLIC_KAKAO_MAP_KEY}&libraries=services&autoload=false`}></script>
    )}
    {import.meta.env.PUBLIC_KAKAO_MAP_KEY && (
      <script defer type="text/javascript" src="https://t1.kakaocdn.net/kakao_js_sdk/2.7.4/kakao.min.js" crossorigin="anonymous"></script>
    )}
    {import.meta.env.PUBLIC_KAKAO_MAP_KEY && (
      <meta name="kakao-app-key" content={import.meta.env.PUBLIC_KAKAO_MAP_KEY} />
    )}
    {import.meta.env.PUBLIC_AD_CLIENT && (
      <meta name="ad-client" content={import.meta.env.PUBLIC_AD_CLIENT} />
    )}
    <slot name="head" />
    <ViewTransitions />
    <title>{fullTitle}</title>
    <script is:inline>
      (function applyTheme() {
        const t = localStorage.getItem('theme') || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        else document.documentElement.removeAttribute('data-theme');
      })();
      document.addEventListener('astro:after-swap', function() {
        const t = localStorage.getItem('theme') || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
        else document.documentElement.removeAttribute('data-theme');
      });
    </script>
  </head>
  <body>
    <header>
      <nav aria-label="메인 내비게이션">
        <a href="/" class="nav-brand">무모한 시식가</a>
        <button type="button" class="hamburger" id="hamburger-btn" aria-label="메뉴 열기">
          <span></span><span></span><span></span>
        </button>
        <div class="nav-links" id="nav-links">
          <a href="/rooms" class="nav-link nav-auth-only" id="my-rooms-link" hidden>내 방</a>
          <a href="/about" class="nav-link">소개</a>
          <a href="/rankings" class="nav-link">랭킹</a>
          <a href="/discover" class="nav-link">맛집</a>
          <a href="/cs" class="nav-link">문의</a>
          <a href="/admin" class="nav-link nav-admin" id="admin-link" hidden>관리자</a>
          <div class="nav-auth" id="auth-nav">
            <a href={kakaoLoginUrl} id="login-link" class="nav-link nav-login">로그인</a>
            <span id="user-info" hidden>
              <button type="button" class="notif-bell" id="notif-bell" hidden title="알림" aria-label="알림">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                <span class="notif-badge" id="notif-badge" hidden></span>
              </button>
              <a href="/profile" class="user-profile-link">
                <img id="user-avatar" class="user-avatar" src="" alt="프로필 사진" hidden />
                <span id="user-nickname" class="user-nickname"></span>
              </a>
              <button type="button" id="logout-btn">로그아웃</button>
            </span>
          </div>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>

    <!-- PWA 설치 안내 배너 -->
    <div class="pwa-banner" id="pwa-banner" hidden>
      <div class="pwa-banner-content">
        <div class="pwa-banner-text">
          <strong>앱처럼 사용하기</strong>
          <span class="pwa-banner-desc" id="pwa-desc"></span>
        </div>
        <button type="button" class="pwa-banner-close" id="pwa-close" aria-label="닫기">&times;</button>
      </div>
    </div>

    <footer>
      <div class="footer-inner">
        <div class="footer-col footer-brand-col">
          <a href="/" class="footer-brand">무모한 시식가</a>
          <p class="footer-tagline">우리만의 맛집 리스트를 만들고 공유하는 플랫폼</p>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">메뉴</h4>
          <div class="footer-col-links">
            <a href="/about">소개</a>
            <a href="/rankings">랭킹</a>
            <a href="/discover">맛집</a>
            <a href="/cs">문의</a>
          </div>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">정보</h4>
          <div class="footer-col-links">
            <a href="/privacy">개인정보처리방침</a>
          </div>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">문의</h4>
          <div class="footer-col-links">
            <span>이메일: pppclove29@naver.com</span>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 무모한 시식가. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f7f8fa;
    --bg-card: #fff;
    --bg-hover: #f0f0f0;
    --bg-input: #fff;
    --text: #1a1a1a;
    --text-heading: #111;
    --text-sub: #555;
    --text-muted: #999;
    --text-tertiary: #777;
    --border: #e8e8e8;
    --border-light: #f0f0f0;
    --border-mid: #d0d0d0;
    --shadow: rgba(0,0,0,0.08);
    --accent: #0d9488;
    --accent-light: #ccfbf1;
    --accent-bg: rgba(13, 148, 136, 0.08);
    color-scheme: light;
  }

  [data-theme="dark"] {
    --bg: #121214;
    --bg-card: #1c1c1f;
    --bg-hover: #2a2a2e;
    --bg-input: #252528;
    --text: #e4e4e7;
    --text-heading: #f4f4f5;
    --text-sub: #a1a1aa;
    --text-muted: #71717a;
    --text-tertiary: #8b8b94;
    --border: #2e2e33;
    --border-light: #252528;
    --border-mid: #3f3f46;
    --shadow: rgba(0,0,0,0.3);
    --accent: #2dd4bf;
    --accent-light: #134e4a;
    --accent-bg: rgba(45, 212, 191, 0.1);
    color-scheme: dark;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Noto Sans KR', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    line-height: 1.6;
  }

  header {
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 960px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
  }

  .nav-brand {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-heading);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    white-space: nowrap;
  }

  .nav-link {
    padding: 0.45rem 0.85rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-sub);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .nav-link:hover {
    background: var(--bg-hover);
    color: var(--text-heading);
  }

  .nav-link.nav-active {
    color: var(--text-heading);
    font-weight: 600;
    background: var(--bg-hover);
  }

  .nav-login {
    color: #fff;
    background: #111;
    margin-left: 0.5rem;
  }

  .nav-login:hover {
    background: #333;
    color: #fff;
  }

  [data-theme="dark"] .nav-login {
    color: #111;
    background: #f4f4f5;
  }

  [data-theme="dark"] .nav-login:hover {
    background: #d4d4d8;
    color: #111;
  }

  .nav-admin {
    color: #dc2626;
    font-weight: 600;
  }

  .nav-auth {
    display: flex;
    align-items: center;
    margin-left: 0.5rem;
  }

  #user-info:not([hidden]) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
  }

  .user-profile-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .user-profile-link:hover { opacity: 0.8; }

  .user-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--border);
  }

  .user-nickname {
    color: var(--text-sub);
    font-weight: 500;
  }

  .user-profile-link:hover .user-nickname {
    color: var(--text-heading);
  }

  .notif-bell {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-sub);
    padding: 0.3rem;
    border-radius: 50%;
    transition: background 0.15s, color 0.15s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .notif-bell:hover {
    background: var(--bg-hover);
    color: var(--text-heading);
  }

  .notif-badge {
    position: absolute;
    top: -1px;
    right: -1px;
    min-width: 7px;
    height: 7px;
    background: #dc2626;
    border-radius: 50%;
  }

  .notif-dropdown {
    position: fixed;
    top: 52px;
    right: 1rem;
    width: min(360px, calc(100vw - 1.5rem));
    max-height: min(70vh, 450px);
    overflow-y: auto;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: 0 8px 24px var(--shadow);
    z-index: 200;
    padding: 0;
  }

  .notif-dropdown-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.85rem 1rem 0.6rem;
    border-bottom: 1px solid var(--border);
  }

  .notif-dropdown-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-heading);
  }

  .notif-mark-read {
    background: none;
    border: none;
    font-size: 0.75rem;
    color: var(--text-muted);
    cursor: pointer;
    font-family: inherit;
    padding: 0.25rem 0.5rem;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .notif-mark-read:hover { color: var(--text-heading); background: var(--bg-hover); }

  .notif-list {
    padding: 0.35rem;
  }

  .notif-item {
    display: flex;
    gap: 0.65rem;
    padding: 0.7rem 0.65rem;
    border-radius: 10px;
    transition: background 0.15s;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    align-items: flex-start;
  }

  .notif-item:hover { background: var(--bg-hover); }

  .notif-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .notif-icon--member { background: #dbeafe; color: #2563eb; }
  .notif-icon--restaurant { background: #dcfce7; color: #16a34a; }
  .notif-icon--visit { background: #f3e8ff; color: #9333ea; }
  .notif-icon--review { background: #fef3c7; color: #d97706; }

  [data-theme="dark"] .notif-icon--member { background: #1e3a5f; color: #60a5fa; }
  [data-theme="dark"] .notif-icon--restaurant { background: #14532d; color: #4ade80; }
  [data-theme="dark"] .notif-icon--visit { background: #3b0764; color: #c084fc; }
  [data-theme="dark"] .notif-icon--review { background: #451a03; color: #fbbf24; }

  .notif-item-body { flex: 1; min-width: 0; }

  .notif-item-label {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 0.15rem;
  }

  .notif-item-msg {
    font-size: 0.78rem;
    color: var(--text-sub);
    line-height: 1.4;
    word-break: break-word;
  }

  .notif-item-date {
    font-size: 0.68rem;
    color: var(--text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .notif-item.unread .notif-item-label { color: var(--text-heading); }
  .notif-item.unread .notif-item-msg { color: var(--text); }
  .notif-item.unread .notif-item-date { color: var(--text-sub); }

  .notif-footer {
    border-top: 1px solid var(--border);
    padding: 0.6rem 1rem;
    text-align: center;
  }

  .notif-footer-link {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s;
  }

  .notif-footer-link:hover { color: var(--text-heading); }

  .notif-empty {
    text-align: center;
    padding: 2rem 0.5rem;
    font-size: 0.85rem;
    color: var(--text-muted);
  }


  #logout-btn {
    padding: 0.35rem 0.7rem;
    background: none;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--text-sub);
    transition: background 0.15s, border-color 0.15s;
  }

  #logout-btn:hover {
    background: var(--bg-hover);
    border-color: var(--text-muted);
  }

  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 3rem;
    min-height: calc(100vh - 130px);
  }

  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    flex-direction: column;
    gap: 4px;
  }

  .hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-heading);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(4px, 4px);
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(4px, -4px);
  }

  @media (max-width: 600px) {
    .hamburger {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      padding: 0.5rem 1rem 1rem;
      gap: 0;
      box-shadow: 0 4px 12px var(--shadow);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-link {
      padding: 0.6rem 0.75rem;
      font-size: 0.9rem;
      border-radius: 8px;
    }

    .nav-auth {
      margin-left: 0;
      margin-top: 0.25rem;
      padding-top: 0.5rem;
      border-top: 1px solid var(--border-light);
    }

    .nav-login {
      margin-left: 0;
      text-align: center;
    }

    nav {
      padding: 0.5rem 0.75rem;
      position: relative;
    }
  }

  footer {
    border-top: 1px solid var(--border);
    padding: 2.5rem 1.5rem 0;
    font-size: 0.82rem;
    color: var(--text-muted);
    background: var(--bg-card);
  }

  .footer-inner {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 2rem;
    padding-bottom: 2rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer-col-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem 0.75rem;
  }

  .footer-brand-col {
    gap: 0.3rem;
  }

  .footer-brand {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-heading);
    text-decoration: none;
  }

  .footer-tagline {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .footer-col-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-sub);
    margin-bottom: 0.2rem;
  }

  footer a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.8rem;
  }

  footer a:hover {
    color: var(--text-sub);
  }

  .footer-bottom {
    max-width: 960px;
    margin: 0 auto;
    border-top: 1px solid var(--border);
    padding: 1.25rem 0;
    text-align: center;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }

    .footer-brand-col {
      grid-column: 1 / -1;
    }
  }

  /* PWA 설치 배너 */
  .pwa-banner {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 150;
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    box-shadow: 0 -4px 16px var(--shadow);
    padding: 0.85rem 1.25rem;
    animation: pwa-slide-up 0.3s ease-out;
  }

  @keyframes pwa-slide-up {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }

  .pwa-banner-content {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .pwa-banner-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .pwa-banner-text strong {
    font-size: 0.875rem;
    color: var(--text-heading);
  }

  .pwa-banner-desc {
    font-size: 0.78rem;
    color: var(--text-sub);
    line-height: 1.5;
  }

  .pwa-banner-close {
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-muted);
    font-size: 1.2rem;
    cursor: pointer;
    padding: 0.3rem 0.6rem;
    flex-shrink: 0;
    transition: background 0.15s, color 0.15s;
  }

  .pwa-banner-close:hover {
    background: var(--bg-hover);
    color: var(--text-heading);
  }

</style>

<script>
  import { fetchCurrentUser, getCachedUser, logout, resetUserCache, fetchMyNotifications, fetchUnreadNotificationCount, markNotificationsRead, apiFetch } from '@/lib/api';
  import type { AuthUser, Notification } from '@/lib/api';
  import { formatDate } from '@repo/utils';
  import { registerPushToken } from '@/lib/firebase';

  // View Transitions 전환 시 유저 캐시 리셋
  document.addEventListener('astro:before-swap', () => {
    resetUserCache();
  });

  function initPage() {
    // 현재 탭 활성 표시
    const currentPath = location.pathname.replace(/\/$/, '') || '/';
    for (const link of document.querySelectorAll<HTMLAnchorElement>('.nav-link')) {
      link.classList.remove('nav-active');
      const href = link.getAttribute('href')?.replace(/\/$/, '') || '/';
      if (href === currentPath || (href !== '/' && currentPath.startsWith(href))) {
        link.classList.add('nav-active');
      }
    }

    // 햄버거 메뉴 토글
    const hamburgerBtn = document.getElementById('hamburger-btn');
    const navLinks = document.getElementById('nav-links');

    if (hamburgerBtn && navLinks) {
      // 페이지 전환 시 메뉴 닫기
      hamburgerBtn.classList.remove('active');
      navLinks.classList.remove('open');

      // 기존 리스너 제거를 위해 replaceWith로 교체
      const newBtn = hamburgerBtn.cloneNode(true) as HTMLElement;
      hamburgerBtn.replaceWith(newBtn);
      newBtn.addEventListener('click', () => {
        newBtn.classList.toggle('active');
        navLinks.classList.toggle('open');
      });
    }

    const loginLink = document.getElementById('login-link') as HTMLElement | null;
    const userInfo = document.getElementById('user-info') as HTMLElement | null;
    const nicknameEl = document.getElementById('user-nickname') as HTMLElement | null;
    const avatarEl = document.getElementById('user-avatar') as HTMLImageElement | null;
    const logoutBtn = document.getElementById('logout-btn') as HTMLElement | null;

    function applyUserUI(user: AuthUser) {
      if (loginLink) loginLink.hidden = true;
      if (userInfo) userInfo.hidden = false;
      if (nicknameEl) nicknameEl.textContent = user.nickname;
      if (avatarEl) {
        if (user.profileImageUrl) {
          avatarEl.src = user.profileImageUrl;
          avatarEl.alt = user.nickname;
          avatarEl.hidden = false;
        } else {
          avatarEl.hidden = true;
        }
      }

      const myRoomsLink = document.getElementById('my-rooms-link');
      if (myRoomsLink) myRoomsLink.hidden = false;
      // footer-rooms-link removed in footer redesign

      if (user.role === 'admin') {
        const adminLink = document.getElementById('admin-link');
        if (adminLink) adminLink.hidden = false;
      }
    }

    function resetUserUI() {
      if (loginLink) loginLink.hidden = false;
      if (userInfo) userInfo.hidden = true;
      if (nicknameEl) nicknameEl.textContent = '';
    }

    // 캐시된 유저 또는 토큰 존재 시 즉시 로그인 UI (깜빡임 방지)
    const cachedUser = getCachedUser();
    if (cachedUser) applyUserUI(cachedUser);
    else if (localStorage.getItem('access_token')) {
      // 토큰은 있지만 캐시가 비었을 때 → 로그인 버튼 우선 숨김
      if (loginLink) loginLink.hidden = true;
    }

    // 백그라운드에서 실제 유저 검증
    fetchCurrentUser().then((user) => {
      if (user) {
        applyUserUI(user);

        // FCM 푸시 토큰 등록 (fire-and-forget)
        registerPushToken(apiFetch).catch(() => {});

        // 알림 벨 초기화
        const bellBtn = document.getElementById('notif-bell');
        const badge = document.getElementById('notif-badge');
        if (bellBtn && badge) {
          bellBtn.hidden = false;
          let dropdownOpen = false;

          const updateBadge = async () => {
            try {
              const count = await fetchUnreadNotificationCount();
              badge.hidden = !count || count <= 0;
            } catch {
              badge.hidden = true;
            }
          };
          updateBadge();

          // 기존 리스너 제거를 위해 교체
          const newBell = bellBtn.cloneNode(true) as HTMLElement;
          bellBtn.replaceWith(newBell);
          newBell.hidden = false;

          newBell.addEventListener('click', async (e) => {
            e.stopPropagation();
            const existing = document.querySelector('.notif-dropdown');
            if (existing) { existing.remove(); dropdownOpen = false; return; }

            dropdownOpen = true;
            const notifications: Notification[] = await fetchMyNotifications();

            const dropdown = document.createElement('div');
            dropdown.className = 'notif-dropdown';

            const typeConfig: Record<string, { icon: string; label: string; cls: string }> = {
              member_joined: { icon: '👤', label: '방 초대', cls: 'member' },
              restaurant_added: { icon: '🍽', label: '새로운 방문', cls: 'restaurant' },
              visit_added: { icon: '💬', label: '댓글', cls: 'visit' },
              review_added: { icon: '⭐', label: '알림', cls: 'review' },
            };
            const defaultType = { icon: '🔔', label: '알림', cls: 'review' };

            if (notifications.length === 0) {
              dropdown.innerHTML = `
                <div class="notif-dropdown-header">
                  <span class="notif-dropdown-title">알림</span>
                </div>
                <div class="notif-empty">알림이 없습니다.</div>`;
            } else {
              dropdown.innerHTML = `
                <div class="notif-dropdown-header">
                  <span class="notif-dropdown-title">알림</span>
                  <button type="button" class="notif-mark-read" id="notif-mark-all">모두 읽음</button>
                </div>
                <div class="notif-list">
                  ${notifications.slice(0, 20).map((n) => {
                    const t = typeConfig[n.type] || defaultType;
                    return `
                    <a href="/room?id=${n.roomId}" class="notif-item ${!n.isRead ? 'unread' : ''}">
                      <div class="notif-icon notif-icon--${t.cls}">${t.icon}</div>
                      <div class="notif-item-body">
                        <div class="notif-item-label">${t.label}</div>
                        <div class="notif-item-msg">${n.message}</div>
                      </div>
                      <span class="notif-item-date">${formatDate(n.createdAt)}</span>
                    </a>`;
                  }).join('')}
                </div>
                <div class="notif-footer">
                  <span class="notif-footer-link">모든 알림 보기</span>
                </div>`;
            }

            document.body.appendChild(dropdown);

            dropdown.querySelector('#notif-mark-all')?.addEventListener('click', async (ev) => {
              ev.preventDefault();
              ev.stopPropagation();
              await markNotificationsRead();
              badge.hidden = true;
              dropdown.querySelectorAll('.notif-item.unread').forEach((el) => el.classList.remove('unread'));
            });

            // 개별 알림 클릭 시에도 전체 읽음 처리
            for (const item of dropdown.querySelectorAll<HTMLElement>('.notif-item')) {
              item.addEventListener('click', () => {
                markNotificationsRead().catch(() => {});
                badge.hidden = true;
              });
            }

            const closeDropdown = (ev: MouseEvent) => {
              if (!dropdown.contains(ev.target as Node) && ev.target !== newBell) {
                dropdown.remove();
                dropdownOpen = false;
                document.removeEventListener('click', closeDropdown);
              }
            };
            setTimeout(() => document.addEventListener('click', closeDropdown), 0);
          });
        }
      } else if (cachedUser) {
        // 캐시는 있었지만 실제 인증 실패 (토큰 만료 등) → UI 원복
        resetUserUI();
      }
    });

    if (logoutBtn) {
      const newLogoutBtn = logoutBtn.cloneNode(true) as HTMLElement;
      logoutBtn.replaceWith(newLogoutBtn);
      newLogoutBtn.addEventListener('click', () => {
        logout();
        location.href = '/';
      });
    }

    // 알림 드롭다운 정리 (페이지 전환 시)
    document.querySelector('.notif-dropdown')?.remove();
  }

  // astro:page-load는 최초 로드에서도 발생
  document.addEventListener('astro:page-load', initPage);

  // PWA Service Worker 등록 (1회만)
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js').catch(() => {});
  }

  // 광고 초기화 (PUBLIC_AD_CLIENT 설정 시에만 동작)
  (() => {
    const adClient = document.querySelector('meta[name="ad-client"]')?.getAttribute('content');
    if (!adClient) return;
    import('@/lib/ads').then(({ initAds }) => initAds(adClient));
  })();

  // PWA 설치 안내 배너
  (() => {
    const DISMISS_KEY = 'pwa_banner_dismissed';
    const banner = document.getElementById('pwa-banner');
    const desc = document.getElementById('pwa-desc');
    const closeBtn = document.getElementById('pwa-close');
    if (!banner || !desc || !closeBtn) return;

    // 이미 설치된 상태 (standalone) 또는 이미 닫은 경우 표시 안 함
    const isStandalone = window.matchMedia('(display-mode: standalone)').matches
      || (navigator as Record<string, boolean>).standalone === true;
    if (isStandalone) return;
    if (localStorage.getItem(DISMISS_KEY)) return;

    // OS 판별
    const ua = navigator.userAgent;
    const isIOS = /iPhone|iPad|iPod/.test(ua);
    const isAndroid = /Android/.test(ua);

    if (isIOS) {
      desc.innerHTML = '하단 <strong>공유 버튼(□↑)</strong>을 누른 뒤 <strong>"홈 화면에 추가"</strong>를 선택하세요.';
    } else if (isAndroid) {
      desc.innerHTML = '브라우저 메뉴(<strong>⋮</strong>)에서 <strong>"홈 화면에 추가"</strong> 또는 <strong>"앱 설치"</strong>를 선택하세요.';
    } else {
      // 데스크톱은 표시하지 않음
      return;
    }

    banner.hidden = false;

    closeBtn.addEventListener('click', () => {
      banner.hidden = true;
      localStorage.setItem(DISMISS_KEY, '1');
    });
  })();
</script>
