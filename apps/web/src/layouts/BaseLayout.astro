---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | 무모한 시식가</title>
  </head>
  <body>
    <header>
      <nav>
        <div class="nav-left">
          <a href="/">홈</a>
          <a href="/map">지도</a>
          <a href="/add">등록</a>
          <a href="/my-list">내 리스트</a>
        </div>
        <div class="nav-right" id="auth-nav">
          <a href="/login" id="login-link">로그인</a>
          <span id="user-info" hidden>
            <span id="user-email"></span>
            <button type="button" id="logout-btn">로그아웃</button>
          </span>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; 2026 무모한 시식가</p>
    </footer>
  </body>
</html>

<style>
  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-left {
    display: flex;
    gap: 1rem;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  #user-info {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  #user-email {
    color: #555;
  }

  #logout-btn {
    padding: 0.3rem 0.6rem;
    background: none;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 0.8rem;
    cursor: pointer;
    color: #555;
  }

  #logout-btn:hover {
    background: #f5f5f5;
    border-color: #999;
  }
</style>

<script>
  import { fetchCurrentUser, logout } from '@/lib/api';

  const loginLink = document.getElementById('login-link')!;
  const userInfo = document.getElementById('user-info')!;
  const userEmail = document.getElementById('user-email')!;
  const logoutBtn = document.getElementById('logout-btn')!;

  const user = await fetchCurrentUser();
  if (user) {
    loginLink.hidden = true;
    userInfo.hidden = false;
    userEmail.textContent = user.email;
  }

  logoutBtn.addEventListener('click', async () => {
    await logout();
    location.href = '/';
  });
</script>
