---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '방 기반 맛집 리뷰 공유 플랫폼' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const fullTitle = `${title} | 무모한 시식가`;
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#111111" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="무모한 시식가" />
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content="무모한 시식가" />

    <meta property="og:image" content={new URL('/icons/icon-512.png', Astro.site ?? Astro.url.origin).href} />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/icons/icon-512.png', Astro.site ?? Astro.url.origin).href} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "무모한 시식가",
      "url": (Astro.site ?? Astro.url.origin).toString(),
      "description": "방 기반 맛집 리뷰 공유 플랫폼",
      "inLanguage": "ko",
    })} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;600;700&display=swap" rel="stylesheet" />
    {import.meta.env.PUBLIC_KAKAO_MAP_KEY && (
      <script type="text/javascript" src={`//dapi.kakao.com/v2/maps/sdk.js?appkey=${import.meta.env.PUBLIC_KAKAO_MAP_KEY}&libraries=services&autoload=false`}></script>
    )}
    {import.meta.env.PUBLIC_KAKAO_MAP_KEY && (
      <script type="text/javascript" src="https://t1.kakaocdn.net/kakao_js_sdk/2.7.4/kakao.min.js" crossorigin="anonymous"></script>
    )}
    {import.meta.env.PUBLIC_KAKAO_MAP_KEY && (
      <meta name="kakao-app-key" content={import.meta.env.PUBLIC_KAKAO_MAP_KEY} />
    )}
    <slot name="head" />
    <title>{fullTitle}</title>
    <script is:inline>
      (function() {
        const t = localStorage.getItem('theme') || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        if (t === 'dark') document.documentElement.setAttribute('data-theme', 'dark');
      })();
    </script>
  </head>
  <body>
    <header>
      <nav>
        <a href="/" class="nav-brand">무모한 시식가</a>
        <button type="button" class="hamburger" id="hamburger-btn" aria-label="메뉴 열기">
          <span></span><span></span><span></span>
        </button>
        <div class="nav-links" id="nav-links">
          <a href="/about" class="nav-link">소개</a>
          <a href="/rankings" class="nav-link">랭킹</a>
          <a href="/discover" class="nav-link">맛집</a>
          <a href="/cs" class="nav-link">문의</a>
          <a href="/admin" class="nav-link nav-admin" id="admin-link" hidden>관리자</a>
          <button type="button" class="theme-toggle" id="theme-toggle" aria-label="테마 전환">
            <span id="theme-icon"></span>
            <span id="theme-label"></span>
          </button>
          <div class="nav-auth" id="auth-nav">
            <a href="/login" id="login-link" class="nav-link nav-login">로그인</a>
            <span id="user-info" hidden>
              <a href="/profile" id="user-nickname" class="user-nickname"></a>
              <button type="button" id="logout-btn">로그아웃</button>
            </span>
          </div>
        </div>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p class="footer-desc">우리만의 맛집 리스트를 만들고 공유하는 플랫폼</p>
      <p class="footer-links">
        <a href="/about">소개</a> · <a href="/rankings">랭킹</a> · <a href="/discover">맛집</a> · <a href="/cs">문의</a> · <a href="/privacy">개인정보처리방침</a>
      </p>
      <p>&copy; 2026 무모한 시식가</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #f7f8fa;
    --bg-card: #fff;
    --bg-hover: #f0f0f0;
    --bg-input: #fff;
    --text: #1a1a1a;
    --text-heading: #111;
    --text-sub: #555;
    --text-muted: #999;
    --text-tertiary: #777;
    --border: #e8e8e8;
    --border-light: #f0f0f0;
    --border-mid: #d0d0d0;
    --shadow: rgba(0,0,0,0.08);
    color-scheme: light;
  }

  [data-theme="dark"] {
    --bg: #121214;
    --bg-card: #1c1c1f;
    --bg-hover: #2a2a2e;
    --bg-input: #252528;
    --text: #e4e4e7;
    --text-heading: #f4f4f5;
    --text-sub: #a1a1aa;
    --text-muted: #71717a;
    --text-tertiary: #8b8b94;
    --border: #2e2e33;
    --border-light: #252528;
    --border-mid: #3f3f46;
    --shadow: rgba(0,0,0,0.3);
    color-scheme: dark;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: 'Noto Sans KR', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    line-height: 1.6;
  }

  header {
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 960px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
  }

  .nav-brand {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-heading);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    white-space: nowrap;
  }

  .nav-link {
    padding: 0.45rem 0.85rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-sub);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .nav-link:hover {
    background: var(--bg-hover);
    color: var(--text-heading);
  }

  .nav-login {
    color: #fff;
    background: var(--text-heading);
    margin-left: 0.5rem;
  }

  .nav-login:hover {
    background: var(--text-sub);
    color: #fff;
  }

  .nav-admin {
    color: #dc2626;
    font-weight: 600;
  }

  .nav-auth {
    display: flex;
    align-items: center;
    margin-left: 0.5rem;
  }

  #user-info:not([hidden]) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
  }

  .user-nickname {
    color: var(--text-sub);
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px dashed transparent;
    transition: border-color 0.15s, color 0.15s;
  }

  .user-nickname:hover {
    border-bottom-color: var(--text-muted);
    color: var(--text-heading);
  }

  #logout-btn {
    padding: 0.35rem 0.7rem;
    background: none;
    border: 1px solid var(--border-mid);
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--text-sub);
    transition: background 0.15s, border-color 0.15s;
  }

  #logout-btn:hover {
    background: var(--bg-hover);
    border-color: var(--text-muted);
  }

  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 3rem;
    min-height: calc(100vh - 130px);
  }

  .hamburger {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem;
    flex-direction: column;
    gap: 4px;
  }

  .hamburger span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-heading);
    border-radius: 1px;
    transition: transform 0.2s, opacity 0.2s;
  }

  .hamburger.active span:nth-child(1) {
    transform: rotate(45deg) translate(4px, 4px);
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active span:nth-child(3) {
    transform: rotate(-45deg) translate(4px, -4px);
  }

  @media (max-width: 600px) {
    .hamburger {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg-card);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      padding: 0.5rem 1rem 1rem;
      gap: 0;
      box-shadow: 0 4px 12px var(--shadow);
    }

    .nav-links.open {
      display: flex;
    }

    .nav-link {
      padding: 0.6rem 0.75rem;
      font-size: 0.9rem;
      border-radius: 8px;
    }

    .nav-auth {
      margin-left: 0;
      margin-top: 0.25rem;
      padding-top: 0.5rem;
      border-top: 1px solid var(--border-light);
    }

    .nav-login {
      margin-left: 0;
      text-align: center;
    }

    nav {
      padding: 0.5rem 0.75rem;
      position: relative;
    }
  }

  footer {
    border-top: 1px solid var(--border);
    text-align: center;
    padding: 1.5rem;
    font-size: 0.8rem;
    color: var(--text-muted);
    background: var(--bg-card);
  }

  .footer-desc {
    color: var(--text-tertiary);
    margin-bottom: 0.4rem;
  }

  .footer-links {
    margin-bottom: 0.4rem;
  }

  footer a {
    color: var(--text-muted);
    text-decoration: none;
  }

  footer a:hover {
    color: var(--text-sub);
  }

  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text-sub);
    padding: 0.35rem 0.6rem;
    border-radius: 6px;
    font-size: 0.82rem;
    line-height: 1;
    transition: background 0.15s, color 0.15s;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }

  .theme-toggle:hover {
    background: var(--bg-hover);
    color: var(--text-heading);
  }
</style>

<script>
  import { fetchCurrentUser, logout } from '@/lib/api';

  // 햄버거 메뉴 토글
  const hamburgerBtn = document.getElementById('hamburger-btn')!;
  const navLinks = document.getElementById('nav-links')!;

  hamburgerBtn.addEventListener('click', () => {
    hamburgerBtn.classList.toggle('active');
    navLinks.classList.toggle('open');
  });

  const loginLink = document.getElementById('login-link')!;
  const userInfo = document.getElementById('user-info')!;
  const nicknameEl = document.getElementById('user-nickname')!;
  const logoutBtn = document.getElementById('logout-btn')!;

  const user = await fetchCurrentUser();
  if (user) {
    loginLink.hidden = true;
    userInfo.hidden = false;
    nicknameEl.textContent = user.nickname;

    if (user.role === 'admin') {
      const adminLink = document.getElementById('admin-link');
      if (adminLink) adminLink.hidden = false;
    }
  }

  logoutBtn.addEventListener('click', () => {
    logout();
    location.href = '/';
  });

  // 테마 토글
  const themeToggle = document.getElementById('theme-toggle')!;
  const themeIcon = document.getElementById('theme-icon')!;
  const themeLabel = document.getElementById('theme-label')!;
  function updateThemeIcon() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    themeIcon.textContent = isDark ? '\u2600\uFE0F' : '\uD83C\uDF19';
    themeLabel.textContent = isDark ? '라이트 모드' : '다크 모드';
  }
  updateThemeIcon();

  themeToggle.addEventListener('click', () => {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    if (isDark) {
      document.documentElement.removeAttribute('data-theme');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.setAttribute('data-theme', 'dark');
      localStorage.setItem('theme', 'dark');
    }
    updateThemeIcon();
  });

  // PWA Service Worker 등록
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js').catch(() => {});
  }
</script>
